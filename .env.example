# HoloScript Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to git - it's in .gitignore

# ====================================
# HOLOSCRIPT STUDIO
# ====================================

# Server Configuration
NODE_ENV=development
PORT=3000

# AI Integration (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# AI Integration (OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Three.js/WebGPU Rendering
ENABLE_WEBGPU=true
MAX_TEXTURE_SIZE=4096
ENABLE_SHADOWS=true
ENABLE_POST_PROCESSING=true

# Authentication (Auth0 or similar)
AUTH0_DOMAIN=your-domain.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.holoscript.net
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Session Management
SESSION_SECRET=random-secret-change-this-in-production
SESSION_COOKIE_SECURE=false  # Set to true in production (HTTPS)

# Analytics
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Feature Flags
ENABLE_AI_GENERATION=true
ENABLE_MULTIPLAYER=false
ENABLE_PLUGIN_MARKETPLACE=true

# ====================================
# MARKETPLACE WEB (Next.js)
# ====================================

# API Connection
NEXT_PUBLIC_API_URL=http://localhost:4000
# Production: https://marketplace-api.holoscript.net

# Authentication
NEXT_PUBLIC_AUTH_DOMAIN=your-domain.us.auth0.com
NEXT_PUBLIC_AUTH_CLIENT_ID=your-client-id

# Stripe Integration (for paid plugins)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Image Upload (Cloudinary or S3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ====================================
# MARKETPLACE API (Express/Node)
# ====================================

# Server Configuration
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/holoscript_marketplace
# Railway: Railway auto-provides this via ${{Postgres.DATABASE_URL}}

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production: https://marketplace.holoscript.net,https://www.holoscript.net

# Authentication (JWT)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d
AUTH0_DOMAIN=your-domain.us.auth0.com
AUTH0_AUDIENCE=https://api.holoscript.net

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379
# Railway: Railway auto-provides this via ${{Redis.REDIS_URL}}

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100

# Email (SendGrid)
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@holoscript.net

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# File Storage (S3 for plugin packages)
S3_BUCKET=holoscript-plugins
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Plugin Security
MAX_PLUGIN_SIZE_MB=50
ALLOWED_PLUGIN_EXTENSIONS=.hsplus,.holo,.zip
ENABLE_PLUGIN_SANDBOXING=true

# ====================================
# RENDER SERVICE
# ====================================

# Server Configuration
NODE_ENV=development
PORT=5000

# WebGPU Configuration
ENABLE_GPU_ACCELERATION=true
MAX_CONCURRENT_RENDERS=10
RENDER_TIMEOUT_MS=30000
ENABLE_HEADLESS_MODE=true

# Quality Settings
DEFAULT_RENDER_WIDTH=1920
DEFAULT_RENDER_HEIGHT=1080
MAX_RENDER_WIDTH=3840
MAX_RENDER_HEIGHT=2160
DEFAULT_FPS=30
MAX_FPS=60

# Storage (S3 for rendered outputs)
S3_BUCKET=holoscript-renders
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_OUTPUT_PREFIX=renders/

# Queue (Bull/BullMQ with Redis)
REDIS_URL=redis://localhost:6379
QUEUE_NAME=render-jobs
MAX_QUEUE_SIZE=1000

# Memory Management
MAX_MEMORY_MB=4096
ENABLE_GARBAGE_COLLECTION=true

# ====================================
# LLM SERVICE
# ====================================

# Server Configuration
NODE_ENV=development
PORT=6000

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# Model Configuration
DEFAULT_MODEL=claude-sonnet-4-5-20250929
FALLBACK_MODEL=gpt-4o
MAX_TOKENS=4096
TEMPERATURE=0.7

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_TOKENS_PER_REQUEST=4096
MAX_CONCURRENT_REQUESTS=10

# Caching (Redis)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600  # 1 hour
ENABLE_RESPONSE_CACHING=true

# Prompt Engineering
SYSTEM_PROMPT_PREFIX="You are HoloScript Assistant, an expert in VR scene generation."
ENABLE_PROMPT_OPTIMIZATION=true

# Safety & Moderation
ENABLE_CONTENT_MODERATION=true
OPENAI_MODERATION_MODEL=text-moderation-latest

# MCP Server Integration
MCP_ORCHESTRATOR_URL=http://localhost:5567
MCP_API_KEY=dev-key-12345

# ====================================
# MCP SERVER (packages/mcp-server)
# ====================================

# Hosted server (default — no setup required):
# https://mcp.holoscript.net

# Local development server
HOLOSCRIPT_MCP_URL=https://mcp.holoscript.net
# HOLOSCRIPT_MCP_URL=http://localhost:3000

# REST API endpoints (append to MCP URL)
# GET  /health      - Server health + tool count
# GET  /api/health  - Extended health with capabilities
# POST /api/render  - Render HoloScript preview
# POST /api/share   - Create X share link + QR code
# POST /mcp         - MCP protocol (65+ tools)

# AI provider for generate_scene / generate_object tools
# HOLOSCRIPT_MCP_AI_PROVIDER=anthropic
# HOLOSCRIPT_MCP_AI_DEBUG=0

# ====================================
# SHARED CONFIGURATION
# ====================================

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json or pretty
ENABLE_REQUEST_LOGGING=true

# Monitoring (Sentry)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Metrics (Prometheus/Grafana)
ENABLE_METRICS=true
METRICS_PORT=9090

# ====================================
# DEPLOYMENT-SPECIFIC
# ====================================

# Railway automatically provides:
# - $PORT (assigned port)
# - $RAILWAY_ENVIRONMENT (production, staging, etc.)
# - $RAILWAY_PUBLIC_DOMAIN (public URL)
# - $RAILWAY_PRIVATE_DOMAIN (internal network URL)
# - ${{SERVICE_NAME.RAILWAY_PRIVATE_DOMAIN}} (service discovery)

# GitHub Actions Secrets:
# - RAILWAY_TOKEN (Railway API token)
# - RAILWAY_PROJECT_ID (Railway project ID)
