# ============================================================
# HoloScript Platform — Environment Variables
# ============================================================
# Copy to .env and fill in your keys. NEVER commit .env to git.
#
# Architecture: .env is the single source of truth for all keys.
# Hooks, agents, and Studio API routes read from here.
# Browser NEVER sees keys — server-side proxy only.
# ============================================================

# ====================================
# LLM PROVIDERS (rotation for pipeline/daemon)
# ====================================
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
XAI_API_KEY=xai-...

# Rotation: agents cycle through providers for cost/availability
LLM_PROVIDER=rotation
LLM_PROVIDERS=anthropic,openai,xai

# Embeddings: OpenAI text-embedding-3-small (used by absorb + knowledge store)
EMBEDDING_PROVIDER=openai

# ====================================
# HOLOSCRIPT PLATFORM SERVICES
# ====================================

# MCP Orchestrator — tool discovery, knowledge store, server registry
MCP_ORCHESTRATOR_URL=https://mcp-orchestrator-production-45f9.up.railway.app
MCP_API_KEY=your-mcp-api-key

# HoloScript MCP Server — compilation, parsing, 156+ tools
HOLOSCRIPT_MCP_URL=https://mcp.holoscript.net

# Absorb Service — codebase intelligence, GraphRAG, self-improvement
ABSORB_SERVICE_URL=https://absorb.holoscript.net
ABSORB_API_KEY=your-absorb-api-key

# ====================================
# HOLOMESH AGENT IDENTITY
# ====================================

# Agent API key (obtain via POST /api/holomesh/register)
HOLOMESH_API_KEY=holomesh_sk_...
HOLOMESH_API_BASE_URL=https://mcp.holoscript.net/api/holomesh

# Team (obtain via POST /api/holomesh/team or join with invite code)
HOLOMESH_TEAM_ID=team_...
HOLOMESH_INVITE_CODE=

# Wallet (identity — NEVER overwrite, recover via challenge/sign)
HOLOMESH_WALLET_ADDRESS=0x...
HOLOMESH_WALLET_KEY=0x...

# ====================================
# MOLTBOOK SOCIAL
# ====================================
MOLTBOOK_API_KEY=moltbook_sk_...

# ====================================
# RAILWAY DEPLOYMENT
# ====================================
RAILWAY_TOKEN=your-railway-token

# ====================================
# GITHUB
# ====================================
GITHUB_TOKEN=github_pat_...
GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
ADMIN_GITHUB_USERNAMES=your-github-username

# ====================================
# STUDIO (Next.js)
# ====================================
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000
OAUTH_TOKEN_SECRET=generate-a-random-secret

# ====================================
# DATABASE (Railway auto-provides in production)
# ====================================
# DATABASE_URL=postgresql://user:password@localhost:5432/holoscript

# ====================================
# OPTIONAL — Package Registries
# ====================================
# NPM_TOKEN=npm_...
# PYPI_API_TOKEN=pypi-...

# ====================================
# OPTIONAL — Blockchain (Base L2)
# ====================================
# HOLOSCRIPT_WALLET_KEY=0x...
# HOLOSCRIPT_COLLECTION_ADDRESS=0x...

# ====================================
# OPTIONAL — Search
# ====================================
# BRAVE_API_KEY=BSA...

# ====================================
# OPTIONAL — Monitoring
# ====================================
# SENTRY_API_KEY=sntryu_...
# LOG_LEVEL=info
