# ============================================================
# HoloScript Platform — Environment Variables
# ============================================================
# Copy to .env and fill in your keys. NEVER commit .env to git.
#
# Architecture: .env is the single source of truth for all keys.
# Hooks, agents, and Studio API routes read from here.
# Browser NEVER sees keys — server-side proxy only.
#
# Quick start for agents:
#   npx holoscript-agent --name=my-bot --ide=vscode
# ============================================================

# ====================================
# LLM PROVIDERS (rotation for pipeline/daemon)
# ====================================
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
XAI_API_KEY=xai-...

# Rotation: agents cycle through providers for cost/availability
LLM_PROVIDER=rotation
LLM_PROVIDERS=anthropic,openai,xai

# Embeddings: OpenAI text-embedding-3-small (used by absorb + knowledge store)
EMBEDDING_PROVIDER=openai

# ====================================
# HOLOSCRIPT PLATFORM SERVICES
# ====================================

# HoloScript API key — used for MCP orchestrator, tool calls, knowledge sync
# Sent as: x-mcp-api-key header (protocol name unchanged for backward compat)
HOLOSCRIPT_API_KEY=your-holoscript-api-key

# Service URLs (defaults — override only if self-hosting)
# MCP_ORCHESTRATOR_URL=https://mcp-orchestrator-production-45f9.up.railway.app
# HOLOSCRIPT_MCP_URL=https://mcp.holoscript.net
# ABSORB_SERVICE_URL=https://absorb.holoscript.net

# Absorb Service — codebase intelligence, GraphRAG, self-improvement
ABSORB_API_KEY=your-absorb-api-key

# ====================================
# HOLOMESH AGENT IDENTITY
# ====================================

# Agent API key (obtain via POST /api/holomesh/register or npx holoscript-agent)
HOLOMESH_API_KEY=holomesh_sk_...

# Team (auto-joined via POST /api/holomesh/quickstart, or manually via /team/:id/join)
HOLOMESH_TEAM_ID=team_...

# Wallet (identity — NEVER overwrite, recover via /api/holomesh/key/challenge)
HOLOMESH_WALLET_ADDRESS=0x...
HOLOMESH_WALLET_KEY=0x...

# ====================================
# LOTUS GENESIS SEED (staged-blocker, I.007)
# ====================================
# Deterministic seed for examples/lotus-flower/garden.seedable.holo and the
# (forthcoming) PhyllotaxisTrait + BloomReactiveTrait. Pre-genesis = the
# documented placeholder 0x0000DEAD; post-genesis = first 16 bytes of
# events[0].hash from D:/GOLD/anchors/lotus-genesis.json.
#
# Pre-genesis (today — placeholder). Same seed → byte-for-byte same composition:
LOTUS_GENESIS_SEED=0x0000DEAD
#
# Post-genesis (when 16 papers land real benchmarks; founder-fired only —
# see project_lotus-genesis-trigger.md, I.007 in MEMORY.md):
# LOTUS_GENESIS_SEED=$(jq -r '.events[0].hash[0:34]' D:/GOLD/anchors/lotus-genesis.json)
#
# Trait code MUST read from this env var (env('LOTUS_GENESIS_SEED', '0x0000DEAD')),
# NEVER hardcode 0x0000DEAD inside trait source — the constant is staged-only.

# ====================================
# MOLTBOOK SOCIAL
# ====================================
MOLTBOOK_API_KEY=moltbook_sk_...

# ====================================
# RAILWAY DEPLOYMENT
# ====================================
# Account token (recommended for agents — broadest scope)
# Create at: https://railway.com/account/tokens → "No workspace"
# Header: Authorization: Bearer $RAILWAY_API_TOKEN
# API endpoint: https://backboard.railway.app/graphql/v2
RAILWAY_API_TOKEN=your-railway-account-token

# Project token (CI/CD pipelines — scoped to one project+environment)
# Header: Project-Access-Token: $RAILWAY_TOKEN
# `railway whoami` will fail with project tokens — expected
# RAILWAY_TOKEN=your-railway-project-token

# Project IDs (from GOLD vault w_gold_034 — do not guess)
RAILWAY_PROJECT_ID=your-project-id
RAILWAY_ENVIRONMENT_ID=your-environment-id
RAILWAY_ENVIRONMENT=production

# ====================================
# GITHUB
# ====================================
GITHUB_TOKEN=github_pat_...
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
ADMIN_GITHUB_USERNAMES=your-github-username

# ====================================
# STUDIO (Next.js)
# ====================================
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000
OAUTH_TOKEN_SECRET=generate-a-random-secret

# ====================================
# DATABASE (Railway auto-provides in production)
# ====================================
# DATABASE_URL=postgresql://user:password@localhost:5432/holoscript

# ====================================
# OPTIONAL — Package Registries
# ====================================
# NPM_TOKEN=npm_...
# PYPI_API_TOKEN=pypi-...

# ====================================
# OPTIONAL — Blockchain (Base L2)
# ====================================
# HOLOSCRIPT_WALLET_KEY=0x...
# HOLOSCRIPT_COLLECTION_ADDRESS=0x...

# ====================================
# OPTIONAL — Search
# ====================================
# BRAVE_API_KEY=BSA...

# ====================================
# OPTIONAL — Monitoring
# ====================================
# SENTRY_API_KEY=sntryu_...
# LOG_LEVEL=info
