{
  "name": "@holoscript/webgpu-compute-benchmark",
  "version": "1.0.0",
  "description": "WebGPU compute shader benchmark suite for HoloScript",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "ts-node webgpu-compute-benchmark.ts",
    "bench:fluid": "ts-node webgpu-compute-benchmark.ts --example fluid",
    "bench:particles": "ts-node webgpu-compute-benchmark.ts --example particles",
    "bench:cloth": "ts-node webgpu-compute-benchmark.ts --example cloth",
    "bench:physics": "ts-node webgpu-compute-benchmark.ts --example physics",
    "bench:nbody": "ts-node webgpu-compute-benchmark.ts --example nbody"
  },
  "keywords": [
    "webgpu",
    "compute-shaders",
    "wgsl",
    "benchmark",
    "gpu",
    "holoscript"
  ],
  "author": "HoloScript Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
