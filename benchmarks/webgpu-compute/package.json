{
  "name": "@holoscript/webgpu-compute-benchmark",
  "version": "1.0.0",
  "description": "WebGPU compute shader benchmark suite for HoloScript",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "ts-node gpu-wasm-benchmark.ts",
    "bench:webgpu": "ts-node gpu-wasm-benchmark.ts --engine webgpu",
    "bench:wasm": "ts-node gpu-wasm-benchmark.ts --engine wasm"
  },
  "keywords": [
    "webgpu",
    "compute-shaders",
    "wgsl",
    "benchmark",
    "gpu",
    "holoscript"
  ],
  "author": "HoloScript Team",
  "license": "MIT",
  "dependencies": {
    "@holoscript/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
