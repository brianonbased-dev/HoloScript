{
  "defaultBehavior": "report-unmanaged",
  "rootVersionFile": "package.json",
  "lanes": [
    {
      "name": "platform-v6",
      "description": "Primary platform/runtime packages on major 7 (lane id kept for scripts; 2026-04 platform-v7 release)",
      "enforce": "major",
      "targetMajor": 7,
      "sync": true,
      "packages": [
        "@holoscript/absorb-service",
        "@holoscript/absorb-service-host",
        "@holoscript/core",
        "@holoscript/cli",
        "@holoscript/agent-protocol",
        "@holoscript/auth",
        "@holoscript/config",
        "@holoscript/core-types",
        "@holoscript/engine",
        "@holoscript/framework",
        "@holoscript/holo-vm",
        "@holoscript/mcp-server",
        "@holoscript/r3f-renderer",
        "@holoscript/runtime",
        "@holoscript/sdk",
        "@holoscript/semantic-2d",
        "@holoscript/snn-webgpu",
        "@holoscript/studio",
        "@holoscript/uaal",
        "@holoscript/vm-bridge"
      ]
    },
    {
      "name": "tooling-v6",
      "description": "Tooling and developer-facing support packages on major 7 (aligned with platform lane)",
      "enforce": "major",
      "targetMajor": 7,
      "packages": [
        "@holoscript/benchmark",
        "@holoscript/linter",
        "@holoscript/lsp",
        "@holoscript/partner-sdk",
        "@holoscript/registry",
        "@holoscript/std",
        "@holoscript/visual",
        "@holoscript/wasm"
      ]
    },
    {
      "name": "tooling-v3",
      "description": "Tooling packages remaining on major 3",
      "enforce": "major",
      "targetMajor": 3,
      "packages": [
        "@holoscript/formatter",
        "@holoscript/fs"
      ]
    },
    {
      "name": "services-v1",
      "description": "Service, connector, and app-surface packages on major 1",
      "enforce": "major",
      "targetMajor": 1,
      "packages": [
        "@holoscript/ai-validator",
        "@holoscript/animation-presets",
        "@holoscript/agent-setup",
        "@holoscript/cdn",
        "@holoscript/collab-server",
        "@holoscript/comparative-benchmarks",
        "@holoscript/connector-appstore",
        "@holoscript/connector-core",
        "@holoscript/connector-github",
        "@holoscript/connector-railway",
        "@holoscript/connector-upstash",
        "@holoscript/adapter-postgres",
        "@holoscript/connector-vscode",
        "@holoscript/crdt",
        "@holoscript/crdt-spatial",
        "@holoscript/export-api",
        "@holoscript/llm-provider",
        "@holoscript/marketplace-api",
        "@holoscript/marketplace-web",
        "@holoscript/mvc-schema",
        "@holoscript/playground",
        "@holoscript/net-service",
        "@holoscript/security-sandbox",
        "@holoscript/spatial-index",
        "@holoscript/studio-api",
        "@holoscript/studio-bridge",
        "@holoscript/studio-plugin-sdk",
        "brittney-service"
      ]
    },
    {
      "name": "infra-v4",
      "description": "Platform-adjacent packages on major 4",
      "enforce": "major",
      "targetMajor": 4,
      "packages": [
        "@holoscript/render-service",
        "holoscript-vscode"
      ]
    },
    {
      "name": "experimental-v0",
      "description": "Experimental and early-stage packages that remain pre-1.0",
      "enforce": "major",
      "targetMajor": 0,
      "packages": [
        "@hololand/react-agent-sdk",
        "@holoscript/graphql-api",
        "@holoscript/preview-component",
        "@holoscript/ui",
        "@holoscript/video-tutorials"
      ]
    },
    {
      "name": "external-managed",
      "description": "Externally managed packages with explicit major guardrails",
      "enforce": "major",
      "targetMajor": 3,
      "packages": [
        "visualizer-client"
      ]
    },
    {
      "name": "language-bindings",
      "description": "Language integration packages with independent majors",
      "enforce": "major",
      "targetMajor": 2,
      "packages": [
        "tree-sitter-holoscript"
      ]
    }
  ]
}
