{
  "defaultBehavior": "report-unmanaged",
  "rootVersionFile": "package.json",
  "lanes": [
    {
      "name": "platform-v6",
      "description": "Core platform packages that should move together on major 6",
      "enforce": "major",
      "targetMajor": 6,
      "sync": true,
      "packages": [
        "@holoscript/core",
        "@holoscript/cli",
        "@holoscript/agent-protocol",
        "@holoscript/agent-sdk",
        "@holoscript/holo-vm",
        "@holoscript/snn-webgpu",
        "@holoscript/uaal",
        "@holoscript/vm-bridge"
      ]
    },
    {
      "name": "tooling-v3",
      "description": "Tooling/runtime ecosystem lane currently on major 3",
      "enforce": "major",
      "targetMajor": 3,
      "packages": [
        "@holoscript/benchmark",
        "@holoscript/formatter",
        "@holoscript/fs",
        "@holoscript/linter",
        "@holoscript/lsp",
        "@holoscript/mcp-server",
        "@holoscript/partner-sdk",
        "@holoscript/registry",
        "@holoscript/runtime",
        "@holoscript/sdk",
        "@holoscript/std",
        "@holoscript/test",
        "@holoscript/visual",
        "@holoscript/wasm"
      ]
    },
    {
      "name": "services-v1",
      "description": "Service packages currently on major 1",
      "enforce": "major",
      "targetMajor": 1,
      "packages": [
        "@holoscript/ai-validator",
        "@holoscript/animation-presets",
        "@holoscript/cdn",
        "@holoscript/collab-server",
        "@holoscript/comparative-benchmarks",
        "@holoscript/compiler",
        "@holoscript/crdt",
        "@holoscript/crdt-spatial",
        "@holoscript/engine",
        "@holoscript/export-api",
        "@holoscript/intelligence",
        "@holoscript/llm-provider",
        "@holoscript/marketplace-api",
        "@holoscript/marketplace-web",
        "@holoscript/mvc-schema",
        "@holoscript/neovim",
        "@holoscript/parser",
        "@holoscript/playground",
        "@holoscript/security-sandbox",
        "@holoscript/snn-poc",
        "@holoscript/spatial-index",
        "@holoscript/studio-bridge",
        "@holoscript/studio-plugin-sdk",
        "@holoscript/traits"
      ]
    },
    {
      "name": "infra-v4",
      "description": "Infra package lane currently on major 4",
      "enforce": "major",
      "targetMajor": 4,
      "packages": [
        "@holoscript/render-service"
      ]
    },
    {
      "name": "experimental-v0",
      "description": "Private/experimental packages that remain pre-1.0",
      "enforce": "major",
      "targetMajor": 0,
      "packages": [
        "@hololand/react-agent-sdk",
        "@holoscript/adapter-postgres",
        "@holoscript/auth",
        "@holoscript/component",
        "@holoscript/graphql-api",
        "@holoscript/preview-component",
        "@holoscript/r3f-renderer",
        "@holoscript/studio",
        "@holoscript/studio-desktop",
        "@holoscript/video-tutorials"
      ]
    },
    {
      "name": "external-managed",
      "description": "External/non-scope packages with explicit major guardrails",
      "enforce": "major",
      "targetMajor": 3,
      "packages": [
        "com.holoscript.core",
        "holoscript-vscode",
        "visualizer-client"
      ]
    },
    {
      "name": "language-bindings",
      "description": "Language integration packages with independent majors",
      "enforce": "major",
      "targetMajor": 2,
      "packages": [
        "tree-sitter-holoscript"
      ]
    },
    {
      "name": "external-v1",
      "description": "External service package lane currently on major 1",
      "enforce": "major",
      "targetMajor": 1,
      "packages": [
        "brittney-service"
      ]
    }
  ]
}
