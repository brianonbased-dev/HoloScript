{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/Josep/.ai-ecosystem/hooks/run-hook.mjs sessionstart/room-connect.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|WebFetch|WebSearch|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/Josep/.ai-ecosystem/hooks/run-hook.mjs pretooluse/skill-redirect.mjs",
            "timeout": 3,
            "async": false,
            "statusMessage": "Checking skill availability..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/Josep/.ai-ecosystem/hooks/run-hook.mjs pretooluse/caveat-reverify.mjs",
            "timeout": 3,
            "async": false,
            "statusMessage": "Checking caveat freshness..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/validate-edit.mjs \"$FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'SESSION_END: Saving metrics and consolidating session backlog'"
          }
        ]
      }
    ]
  }
}
