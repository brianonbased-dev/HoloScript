{
  "$schema": "https://unpkg.com/syncpack@14/dist/schema.json",
  "sortFirst": ["name", "version", "private", "description"],
  "versionGroups": [
    {
      "label": "Use workspace protocol for internal @holoscript packages",
      "dependencies": ["@holoscript/*"],
      "dependencyTypes": ["prod", "dev"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "TypeScript must be consistent across all packages",
      "dependencies": ["typescript"],
      "policy": "sameRange"
    },
    {
      "label": "Vitest must be consistent across all packages — pinned at ^4.1.0 (closes task_1777188537447_kbs6)",
      "dependencies": ["vitest", "@vitest/*"],
      "policy": "sameRange",
      "pinVersion": "^4.1.0"
    },
    {
      "label": "tsup must be consistent",
      "dependencies": ["tsup"],
      "policy": "sameRange"
    }
  ]
}
