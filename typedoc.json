{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "packages/core/src/index.ts",
    "packages/core/src/traits/TraitTypes.ts",
    "packages/core/src/traits/VRTraitSystem.ts",
    "packages/core/src/traits/GrabbableTrait.ts",
    "packages/core/src/traits/NetworkedTrait.ts",
    "packages/core/src/traits/LLMAgentTrait.ts",
    "packages/core/src/traits/AnimationTrait.ts",
    "packages/core/src/traits/RigidbodyTrait.ts",
    "packages/core/src/traits/MaterialTrait.ts",
    "packages/core/src/traits/ShaderTrait.ts",
    "packages/core/src/traits/SpatialAwarenessTrait.ts",
    "packages/core/src/traits/IKTrait.ts",
    "packages/security-sandbox/src/index.ts",
    "packages/ai-validator/src/index.ts",
    "packages/comparative-benchmarks/src/index.ts",
    "packages/cli/src/index.ts",
    "packages/mcp-server/src/index.ts",
    "packages/partner-sdk/src/index.ts",
    "packages/runtime/src/index.ts",
    "packages/formatter/src/index.ts",
    "packages/linter/src/index.ts",
    "packages/llm-provider/src/index.ts"
  ],
  "out": "docs/api",
  "exclude": [
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/dist/**",
    "**/__tests__/**",
    "**/__mocks__/**"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": false,
  "readme": "docs/api/README.md",
  "name": "HoloScript API Documentation",
  "navigationLinks": {
    "HoloScript Home": "https://github.com/brianonbased-dev/HoloScript",
    "Getting Started": "https://github.com/brianonbased-dev/HoloScript#readme",
    "Examples": "https://github.com/brianonbased-dev/HoloScript/tree/main/examples"
  },
  "includeVersion": true,
  "sort": ["source-order"],
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  },
  "categorizeByGroup": true,
  "defaultCategory": "Other",
  "categoryOrder": [
    "Core",
    "Traits",
    "Runtime",
    "Parser",
    "Security",
    "AI Validation",
    "Benchmarks",
    "CLI",
    "MCP Server",
    "*"
  ],
  "plugin": [],
  "lightHighlightTheme": "light-plus",
  "darkHighlightTheme": "dark-plus",
  "customCss": "docs/api/custom.css",
  "markdownItOptions": {
    "mangle": false
  },
  "githubPages": true,
  "gitRevision": "main",
  "gitRemote": "origin",
  "basePath": ".",
  "disableSources": false,
  "searchInComments": true,
  "searchInDocuments": true,
  "skipErrorChecking": true
}
