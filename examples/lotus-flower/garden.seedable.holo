  // ── POLLEN FIELD (GPU particle, gated on bloom_state == "full") ───────────
  // Backed by GPUParticleTrait (packages/core/src/traits/GPUParticleTrait.ts).
  // Single emitter at canopy origin pre-genesis. When BloomReactiveTrait + per-
  // petal particle activation land, this expands to 42 per-petal emitters that
  // ignite individually as petals reach `full`.

  object "PollenField" {
    @gpu_particle {
      count: 5000
      emission_rate: 20
      lifetime: 5.0
      lifetime_variance: 2.0
      initial_velocity: [0, 0.3, 0]
      velocity_variance: [0.4, 0.2, 0.4]
      spread_angle: 25
      forces: [
        { type: "gravity", strength: 0.05, direction: [0, -1, 0] },
        { type: "turbulence", strength: 0.15 }
      ]
      color_over_life: [
        { time: 0.0, color: [1.0, 1.0, 0.8, 0.0] },
        { time: 0.2, color: [1.0, 1.0, 0.8, 0.9] },
        { time: 1.0, color: [1.0, 1.0, 1.0, 0.0] }
      ]
      size_over_life: [
        { time: 0.0, size: 0.02 },
        { time: 1.0, size: 0.0 }
      ]
      collision: false
      sprite: "sprites/pollen_disc.png"
      blend_mode: "additive"
    }
    position: [0, 5.5, 0]
    // Staged: emits at low rate from canopy center.
    // TODO[trait-binding]: when BloomReactiveTrait + per-instance particle
    // gating land, replace this with `instanced_object` driven by phyllotaxis
    // anchor so each `full` petal spawns its own pollen drift.
  }

  // ── BRITTNEY (the gardener, identical to baseline) ────────────────────────

  object "Brittney" {
    type: "mesh"
    position: [4, 5, 0]
    // TODO[trait-binding]: replace with @lotus_gardener once trait lands.
    @animated {
      clip: "idle_gardener"
      speed: 1.0
      loop: true
    }
