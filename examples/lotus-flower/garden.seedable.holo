  // ── GENESIS LIGHT COLUMN (DORMANT until 16-paper trigger fires) ───────────
  // I.007 constraint: this asset SHIPS but is `enabled: false` until the
  // genesis hash anchors. Founder rules its activation, not /artist.

  object "GenesisLightColumn" {
    @gpu_particle {
      count: 8000
      emission_rate: 0
      lifetime: 6.0
      lifetime_variance: 2.0
      initial_velocity: [0, 1.5, 0]
      velocity_variance: [0.4, 0.5, 0.4]
      spread_angle: 5
      forces: [
        { type: "vortex", strength: 0.8, position: [0, 5, 0], direction: [0, 1, 0], radius: 1.5 }
      ]
      color_over_life: [
        { time: 0.0, color: [1.0, 1.0, 1.0, 0.0] },
        { time: 0.3, color: [1.0, 1.0, 1.0, 1.0] },
        { time: 1.0, color: [0.8, 0.55, 1.0, 0.0] }
      ]
      size_over_life: [
        { time: 0.0, size: 0.05 },
        { time: 1.0, size: 0.0 }
      ]
      collision: false
      sprite: "sprites/light_quanta.png"
      blend_mode: "additive"
    }
    position: [0, 7, 0]
    enabled: false
    // TODO[trait-binding]: replace with @lotus_genesis_trigger once trait lands.
    // Trigger contract (post-genesis):
    //   condition: "all 16 petals === full"
    //   wallet: "0x0C574397150Ad8d9f7FEF83fe86a2CBdf4A660E3"
    //   anchor_strategy: "ots+base"
    //   on_fire: { enabled: true; emission_rate: 100; duration_s: 60 }
    @glowing {
      color: "#ffffff"
      intensity: 0.05
      pulse: false
    }
  }
