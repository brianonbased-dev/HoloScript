// ============================================================================
// Structured Physics Block Test Composition
// ============================================================================
// Exercises all structured physics_block grammar constructs:
//   - physics_block (container with nested sub-blocks + flat properties)
//   - collider_block: box, sphere, capsule, mesh, convex, cylinder, heightfield
//   - rigidbody_block: mass, drag, angular_damping, use_gravity
//   - force_field_block: force_field, gravity_zone, wind_zone, buoyancy_zone,
//     magnetic_field, drag_zone
//   - articulation_block with joint sub-blocks:
//     joint, hinge, slider, ball_socket, fixed_joint, d6_joint,
//     spring_joint, prismatic
//   - Physics blocks inside objects, templates, and compositions
//   - Trigger colliders (is_trigger: true)
//   - Standalone collider/rigidbody directly in objects
// ============================================================================

// ── Standalone Force Field Blocks (top-level) ──────────────────────────────

gravity_zone "HeavyGravityPit" @persistent {
  strength: 20
  shape: "sphere"
  radius: 10
  falloff: "linear"
}

wind_zone "DesertWindCorridor" {
  direction: [1, 0.2, 0]
  strength: 15
  turbulence: 0.4
  pulse_frequency: 2.0
  radius: 25
}

buoyancy_zone "OceanSurface" @water {
  density: 1025
  surface_height: 0
  flow_direction: [0.1, 0, 0.05]
  damping: 0.8
}

magnetic_field "LabMagnet" {
  strength: 50
  polarity: "attract"
  axis: [0, 1, 0]
  range: 5
}

drag_zone "ViscousFluid" {
  linear_drag: 2.0
  angular_drag: 1.5
  shape: "box"
  size: [4, 4, 4]
}

// ── Standalone Articulation with Various Joint Types ────────────────────────

articulation "IndustrialRobotArm" @kinematic {
  solver_iterations: 16
  immovable_base: true

  hinge "Shoulder" {
    axis: [0, 1, 0]
    limits: [-90, 90]
    damping: 0.5
    stiffness: 100
    motor_force: 50
  }

  hinge "Elbow" {
    axis: [1, 0, 0]
    limits: [-120, 0]
    damping: 0.3
    stiffness: 80
  }

  slider "LinearActuator" {
    axis: [0, 0, 1]
    limits: [0, 0.5]
    damping: 1.0
    spring_force: 200
  }

  ball_socket "Wrist" {
    swing_limit: 45
    twist_limit: 90
    damping: 0.2
  }

  fixed_joint "GripperMount" {
    break_force: 500
    break_torque: 200
  }

  d6_joint "FlexibleCoupling" {
    x_motion: "locked"
    y_motion: "limited"
    z_motion: "free"
    swing1_limit: 30
    swing2_limit: 30
    twist_limit: 10
  }

  spring_joint "ShockAbsorber" {
    spring_force: 300
    damper_force: 50
    min_distance: 0.1
    max_distance: 0.5
    tolerance: 0.01
  }

  prismatic "Telescoper" {
    axis: [0, 1, 0]
    limits: [0, 2]
    motor_speed: 0.5
    motor_force: 100
  }
}

// ── Template with Physics Sub-Blocks ────────────────────────────────────────

template "PhysicsCrate" {
  @physics
  @grabbable
  @collidable

  geometry: "cube"
  mass: 5.0

  physics {
    collider box {
      size: [1, 1, 1]
      is_trigger: false
      offset: [0, 0, 0]
    }

    rigidbody {
      mass: 5
      drag: 0.1
      angular_damping: 0.05
      use_gravity: true
      freeze_rotation_x: false
      freeze_rotation_y: false
      freeze_rotation_z: false
    }

    friction: 0.6
    restitution: 0.2
  }
}

template "TriggerVolume" {
  geometry: "cube"
  visible: false

  collider box {
    size: [3, 3, 3]
    is_trigger: true
  }

  onTriggerEnter: {
    log("Entity entered trigger zone")
  }

  onTriggerExit: {
    log("Entity exited trigger zone")
  }
}

template "FloatingPlatform" {
  @physics

  geometry: "cube"

  physics {
    rigidbody {
      mass: 100
      use_gravity: false
      is_kinematic: true
    }

    collider box {
      size: [4, 0.3, 4]
      is_trigger: false
    }

    force_field "PlatformRepulsor" {
      strength: -10
      falloff: "inverse_square"
      shape: "sphere"
      radius: 3
    }
  }
}

// ── Composition with Physics Constructs ─────────────────────────────────────

composition "Physics Test Arena" {
  environment {
    skybox: "overcast"
    ambient_light: 0.5
    gravity: -9.81
    shadows: true
  }

  // Object with full physics block containing collider + rigidbody + flat props
  object "HeavyBoulder" @grabbable {
    geometry: "sphere"
    position: [0, 5, 0]
    scale: [1.5, 1.5, 1.5]
    color: #666666

    physics {
      collider sphere {
        radius: 0.75
        is_trigger: false
      }

      rigidbody {
        mass: 50
        drag: 0.2
        angular_damping: 0.1
        use_gravity: true
      }

      friction: 0.7
      restitution: 0.15
    }
  }

  // Object with collider directly (no wrapping physics block)
  object "InvisibleWall" {
    geometry: "cube"
    position: [0, 2, -10]
    scale: [20, 4, 0.1]
    visible: false

    collider box {
      size: [20, 4, 0.1]
      is_trigger: false
    }
  }

  // Object with rigidbody directly
  object "FallingBox" {
    geometry: "cube"
    position: [3, 8, 0]
    scale: [0.5, 0.5, 0.5]
    color: #cc3333

    rigidbody {
      mass: 10
      use_gravity: true
    }
  }

  // Object with capsule collider
  object "CharacterProxy" {
    geometry: "capsule"
    position: [0, 1, 5]

    collider capsule {
      radius: 0.3
      height: 1.8
      direction: "y"
    }

    rigidbody {
      mass: 75
      use_gravity: true
      freeze_rotation_x: true
      freeze_rotation_z: true
    }
  }

  // Object with mesh collider
  object "TerrainChunk" {
    geometry: "mesh"
    src: "models/terrain_chunk.glb"
    position: [0, 0, 0]

    collider mesh {
      convex: false
      cooking_options: "default"
    }
  }

  // Object with convex collider
  object "RockFormation" {
    src: "models/rock.glb"
    position: [-5, 0, 3]

    collider convex {
      vertex_limit: 64
      skin_width: 0.01
    }
  }

  // Object with cylinder collider
  object "Pillar" {
    geometry: "cylinder"
    position: [4, 1.5, -3]
    scale: [0.5, 3, 0.5]
    color: #aaaaaa

    collider cylinder {
      radius: 0.5
      height: 3
    }
  }

  // Object with heightfield collider
  object "LargeTerrain" {
    position: [0, 0, 0]

    collider heightfield {
      resolution: [256, 256]
      height_scale: 10
      source: "terrain/heightmap.raw"
    }
  }

  // Physics block with force field inside
  object "MagnetZone" {
    position: [0, 2, 0]

    physics {
      collider sphere {
        radius: 5
        is_trigger: true
      }

      force_field "Attractor" {
        strength: -15
        falloff: "inverse_square"
      }
    }
  }

  // Articulation block inside composition
  articulation "CraneArm" {
    solver_iterations: 12

    hinge "Base" {
      axis: [0, 1, 0]
      limits: [-180, 180]
      damping: 1.0
    }

    hinge "Boom" {
      axis: [1, 0, 0]
      limits: [0, 75]
      damping: 0.8
      motor_force: 200
    }

    slider "Cable" {
      axis: [0, -1, 0]
      limits: [0, 15]
      damping: 2.0
    }
  }

  // Object using template with physics
  object "Crate1" using "PhysicsCrate" {
    position: [2, 1, -2]
    color: #8b4513
  }

  object "Crate2" using "PhysicsCrate" {
    position: [2.5, 1, -2]
    color: #a0522d
  }

  // Ground
  object "Ground" @collidable {
    geometry: "plane"
    position: [0, 0, 0]
    scale: [50, 1, 50]
    color: #3a3a3a
  }
}
