// ============================================================================
// Spatial Audio Block Test Composition
// ============================================================================
// Exercises all audio_source_block grammar constructs:
//   - audio_source, audio_listener, reverb_zone,
//     audio_mixer, ambience, sound_emitter keywords
//   - Spatial audio traits (@spatial, @hrtf, @3d)
//   - Full property sets: clip, volume, pitch, spatial_blend,
//     min_distance, max_distance, rolloff_mode, loop, play_on_awake,
//     doppler_level, and more
//   - Audio blocks at top level AND inside compositions
// ============================================================================

// ── Top-Level: Spatial Audio Source with Full Properties ─────────────────────

audio_source "Waterfall" @spatial @hrtf {
  clip: "sounds/waterfall_loop.ogg"
  volume: 0.8
  pitch: 1.0
  spatial_blend: 1.0
  min_distance: 1
  max_distance: 50
  rolloff_mode: "logarithmic"
  loop: true
  play_on_awake: true
  doppler_level: 0.5
  spread: 60
  priority: 128
}

// ── Audio Listener (camera/player ear) ──────────────────────────────────────

audio_listener "PlayerEar" @hrtf {
  position: [0, 1.7, 0]
  hrtf_profile: "default"
  global_volume: 1.0
  speed_of_sound: 343
  distance_model: "inverse"
}

// ── Reverb Zone ─────────────────────────────────────────────────────────────

reverb_zone "CaveReverb" {
  preset: "cave"
  min_distance: 5
  max_distance: 30
  room: -1000
  room_hf: -500
  decay_time: 3.0
  reflections: -200
  reflections_delay: 0.02
  reverb_level: -100
  reverb_delay: 0.04
  diffusion: 100
  density: 100
}

reverb_zone "CathedralReverb" {
  preset: "cathedral"
  min_distance: 10
  max_distance: 100
  room: -800
  room_hf: -200
  decay_time: 5.5
  reflections: -400
  diffusion: 80
  density: 90
}

reverb_zone "SmallRoom" {
  preset: "room"
  min_distance: 1
  max_distance: 8
  room: -600
  room_hf: -300
  decay_time: 0.8
  reflections: -100
  diffusion: 70
  density: 100
}

// ── Audio Mixer ─────────────────────────────────────────────────────────────

audio_mixer "MasterMixer" {
  master_volume: 1.0
  music_volume: 0.7
  sfx_volume: 0.9
  ambient_volume: 0.6
  voice_volume: 1.0
  ducking_enabled: true
  ducking_threshold: 0.8
  ducking_ratio: 0.3
}

audio_mixer "CombatMixer" {
  master_volume: 1.0
  music_volume: 0.4
  sfx_volume: 1.0
  ambient_volume: 0.3
  voice_volume: 1.0
  low_pass_frequency: 22000
  high_pass_frequency: 20
}

// ── Ambience ────────────────────────────────────────────────────────────────

ambience "ForestAmbient" @spatial {
  clip: "sounds/forest_birds_wind.ogg"
  volume: 0.5
  loop: true
  play_on_awake: true
  spatial_blend: 0.3
  spread: 360
  min_distance: 0
  max_distance: 100
  rolloff_mode: "linear"
}

ambience "OceanWaves" @spatial {
  clip: "sounds/ocean_waves_loop.ogg"
  volume: 0.6
  loop: true
  play_on_awake: true
  spatial_blend: 0.7
  doppler_level: 0.1
  priority: 200
}

ambience "IndustrialHum" {
  clip: "sounds/factory_hum.ogg"
  volume: 0.35
  loop: true
  pitch: 0.95
  spatial_blend: 0.5
}

// ── Sound Emitter ───────────────────────────────────────────────────────────

sound_emitter "FootstepEmitter" @spatial {
  clip: "sounds/footstep_stone.ogg"
  volume: 0.6
  pitch: 1.0
  spatial_blend: 1.0
  min_distance: 0.5
  max_distance: 15
  rolloff_mode: "logarithmic"
  loop: false
  play_on_awake: false
  randomize_pitch: true
  pitch_range: [0.9, 1.1]
}

sound_emitter "GunfireEmitter" @spatial @spatialized {
  clip: "sounds/gunfire_rifle.ogg"
  volume: 1.0
  pitch: 1.0
  spatial_blend: 1.0
  min_distance: 2
  max_distance: 200
  rolloff_mode: "logarithmic"
  doppler_level: 1.0
  spread: 30
  priority: 10
  loop: false
}

sound_emitter "DoorCreak" @spatial {
  clip: "sounds/door_creak.ogg"
  volume: 0.7
  pitch: 0.9
  spatial_blend: 1.0
  min_distance: 1
  max_distance: 10
  loop: false
  play_on_awake: false
}

// ── Composition with Full Spatial Audio Setup ───────────────────────────────

composition "Spatial Audio Demo Scene" {
  environment {
    skybox: "twilight"
    ambient_light: 0.35
  }

  // Audio listener attached to player camera
  audio_listener "CameraListener" @hrtf {
    position: [0, 1.7, 5]
    global_volume: 1.0
    hrtf_profile: "default"
  }

  // Looping ambient audio source
  audio_source "RiverFlow" @spatial @hrtf {
    clip: "sounds/river_gentle.ogg"
    volume: 0.65
    pitch: 1.0
    spatial_blend: 1.0
    min_distance: 2
    max_distance: 40
    rolloff_mode: "logarithmic"
    loop: true
    play_on_awake: true
    doppler_level: 0.3
    spread: 90
  }

  // One-shot audio source
  audio_source "BellTower" @spatial {
    clip: "sounds/bell_toll.ogg"
    volume: 0.9
    pitch: 1.0
    spatial_blend: 1.0
    min_distance: 5
    max_distance: 150
    rolloff_mode: "logarithmic"
    loop: false
    play_on_awake: false
    doppler_level: 0.8
  }

  // Music source (non-spatial)
  audio_source "BackgroundMusic" {
    clip: "sounds/ambient_music.ogg"
    volume: 0.4
    pitch: 1.0
    spatial_blend: 0.0
    loop: true
    play_on_awake: true
    priority: 255
  }

  // Reverb zone inside a cave object
  reverb_zone "TunnelReverb" {
    preset: "hallway"
    min_distance: 2
    max_distance: 15
    room: -700
    room_hf: -300
    decay_time: 2.0
    reflections: -150
    diffusion: 85
    density: 95
  }

  // Audio mixer for scene mixing
  audio_mixer "SceneMixer" {
    master_volume: 1.0
    music_volume: 0.5
    sfx_volume: 0.8
    ambient_volume: 0.7
    voice_volume: 1.0
  }

  // Ambient soundscape
  ambience "WindThrough Trees" @spatial {
    clip: "sounds/wind_trees.ogg"
    volume: 0.4
    loop: true
    play_on_awake: true
    spatial_blend: 0.4
    spread: 270
  }

  // Sound emitter on an interactive object
  sound_emitter "ChestOpenSound" @spatial {
    clip: "sounds/chest_open.ogg"
    volume: 0.7
    spatial_blend: 1.0
    min_distance: 1
    max_distance: 12
    loop: false
    play_on_awake: false
  }

  // Scene objects
  object "River" {
    geometry: "plane"
    position: [-5, 0, 0]
    scale: [2, 1, 20]
    color: #3388cc
  }

  object "BellTowerStructure" {
    geometry: "cylinder"
    position: [10, 5, -8]
    scale: [1.5, 10, 1.5]
    color: #887766
  }

  object "TreasureChest" @clickable {
    geometry: "cube"
    position: [3, 0.3, 2]
    scale: [0.6, 0.4, 0.4]
    color: #8b6914

    onClick: {
      audio.play("ChestOpenSound")
    }
  }

  object "CaveTunnel" {
    src: "models/cave_tunnel.glb"
    position: [-8, 0, -5]
  }

  object "Ground" @collidable {
    geometry: "plane"
    position: [0, 0, 0]
    scale: [30, 1, 30]
    color: #445544
  }

  point_light "MoonLight" {
    position: [0, 20, 0]
    color: #ccddff
    intensity: 0.6
    range: 50
  }
}
