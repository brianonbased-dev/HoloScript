// ============================================================================
// Integrated Perception & Simulation Stack Test Composition
// ============================================================================
// This composition exercises ALL five block types together in a single
// realistic scene, verifying they compose correctly:
//   - material_block: PBR materials, glass, subsurface, texture maps
//   - physics_block: colliders, rigidbodies, force fields, articulations
//   - particle_block: fire, smoke, sparks with modules
//   - post_processing_block: bloom, DoF, color grading, SSAO, fog
//   - audio_source_block: spatial audio, reverb zones, ambience
//
// Scene: A blacksmith's forge workshop at twilight with an anvil,
// glowing metal, a roaring fire, ambient sounds, and atmospheric effects.
// ============================================================================

// ── Materials (top-level, referenced by objects) ────────────────────────────

pbr_material "ForgeAnvilSteel" @pbr {
  baseColor: #333344
  roughness: 0.25
  metallic: 1.0
  albedo_map {
    source: "textures/anvil_albedo.png"
    tiling: [1, 1]
    filtering: "anisotropic"
  }
  normal_map {
    source: "textures/anvil_normal.png"
    strength: 1.5
  }
  ao_map {
    source: "textures/anvil_ao.png"
    intensity: 0.9
  }
}

subsurface_material "GlowingIngot" @sss {
  baseColor: #ff4400
  roughness: 0.6
  metallic: 0.8
  subsurface_color: #ff2200
  subsurface_radius: [2.0, 0.5, 0.1]
  emissiveIntensity: 3.0
  emission_map: "textures/ingot_heat_emission.png"
}

glass_material "ForgeWindowGlass" @transparent {
  baseColor: #eeddcc
  opacity: 0.2
  IOR: 1.52
  transmission: 0.85
  roughness: 0.15
}

material "StoneBrick" @pbr {
  baseColor: #665544
  roughness: 0.9
  metallic: 0.0
  albedo_map {
    source: "textures/stone_albedo.png"
    tiling: [4, 4]
    filtering: "trilinear"
  }
  normal_map {
    source: "textures/stone_normal.png"
    strength: 1.2
  }
  height_map {
    source: "textures/stone_height.png"
    scale: 0.03
  }
}

toon_material "CartoonWood" @cel_shaded {
  baseColor: #aa7744
  outline_width: 0.015
  outline_color: #332211
  shade_steps: 4
  roughness: 0.7
}

// ── Physics: Standalone Force Fields ────────────────────────────────────────

wind_zone "ForgeChimneyDraft" {
  direction: [0, 1, 0]
  strength: 3
  turbulence: 0.4
  radius: 4
}

gravity_zone "HammerDropZone" @persistent {
  strength: 15
  shape: "box"
  radius: 2
}

// ── Physics: Articulated Mechanism ──────────────────────────────────────────

articulation "BellowsMechanism" {
  solver_iterations: 10

  hinge "BellowsHinge" {
    axis: [1, 0, 0]
    limits: [-30, 30]
    damping: 0.8
    stiffness: 60
    motor_force: 25
  }

  spring_joint "BellowsSpring" {
    spring_force: 150
    damper_force: 30
    min_distance: 0.05
    max_distance: 0.4
  }
}

// ── Particle Systems (top-level) ────────────────────────────────────────────

particles "ForgeFireEmbers" @looping {
  rate: 150
  max_particles: 800
  start_lifetime: [1, 3]
  start_speed: [1, 4]
  start_size: [0.01, 0.04]
  gravity_modifier: -0.3

  emission {
    rate_over_time: 150
    burst_count: 20
    burst_interval: 1.0
  }

  velocity {
    direction: [0, 1, 0]
    speed: 2
    spread: 40
  }

  color_over_life {
    gradient: ["#ffff00", "#ff8800", "#ff2200", "#00000000"]
    mode: "blend"
  }

  size_over_life {
    curve: [1.0, 0.8, 0.3, 0.0]
    mode: "bezier"
  }

  noise {
    strength: 0.6
    frequency: 3.0
    scroll_speed: 0.2
  }

  trails {
    enabled: true
    width: 0.01
    lifetime: 0.2
    color_over_trail: ["#ffcc00", "#00000000"]
    min_vertex_distance: 0.01
    world_space: true
  }

  renderer {
    material: "particles/ember_additive"
    render_mode: "billboard"
    sort_mode: "distance"
  }
}

emitter "ForgeSmoke" @looping {
  rate: 80
  max_particles: 400
  start_lifetime: [3, 6]
  start_speed: [0.3, 0.8]
  start_size: [0.2, 0.5]
  gravity_modifier: -0.05

  velocity {
    direction: [0, 1, 0.1]
    speed: 0.5
    spread: 20
  }

  color_over_life {
    gradient: ["#44444488", "#33333344", "#22222200"]
    mode: "blend"
  }

  size_over_life {
    curve: [0.5, 1.0, 1.5, 2.0]
    mode: "bezier"
  }

  noise {
    strength: 0.3
    frequency: 1.5
    scroll_speed: 0.08
  }

  shape {
    type: "cone"
    angle: 15
    radius: 0.4
    emit_from: "base"
  }

  renderer {
    material: "particles/smoke_soft"
    render_mode: "billboard"
    sort_mode: "distance"
  }
}

// ── Post-Processing (top-level) ─────────────────────────────────────────────

post_processing "ForgeAtmosphere" {
  bloom {
    intensity: 1.2
    threshold: 0.8
    scatter: 0.65
    tint: #ffddaa
  }

  ambient_occlusion {
    intensity: 1.8
    radius: 0.4
    quality: "high"
  }

  depth_of_field {
    aperture: 2.0
    focal_length: 35
    focus_distance: 4
  }

  color_grading {
    temperature: 4500
    contrast: 1.15
    saturation: 0.9
    lift: [0.02, 0.01, 0.0]
    gamma: [1.0, 0.98, 0.95]
  }

  tone_mapping {
    mode: "ACES"
    exposure: 0.8
  }

  vignette {
    intensity: 0.4
    smoothness: 0.4
  }

  volumetric_fog {
    density: 0.015
    height_falloff: 0.3
    color: #aa8866
    max_distance: 30
  }

  film_grain {
    intensity: 0.08
    response: 0.7
  }

  anti_aliasing {
    mode: "TAA"
    sharpness: 0.5
  }
}

// ── Audio Sources (top-level) ───────────────────────────────────────────────

audio_source "FireCrackling" @spatial @hrtf {
  clip: "sounds/fire_crackle_loop.ogg"
  volume: 0.75
  pitch: 1.0
  spatial_blend: 1.0
  min_distance: 1
  max_distance: 20
  rolloff_mode: "logarithmic"
  loop: true
  play_on_awake: true
  doppler_level: 0.2
  spread: 120
}

reverb_zone "WorkshopReverb" {
  preset: "room"
  min_distance: 2
  max_distance: 12
  room: -500
  room_hf: -200
  decay_time: 1.2
  reflections: -100
  diffusion: 80
  density: 90
}

// ── Main Composition: Blacksmith's Forge ────────────────────────────────────

composition "Blacksmith Forge Workshop" {
  environment {
    skybox: "twilight_warm"
    ambient_light: 0.25
    gravity: -9.81
    shadows: true
  }

  // ── Materials inside composition ──────────────────────────────────────
  material "FloorStone" @pbr {
    baseColor: #554433
    roughness: 0.95
    metallic: 0.0
    normal_map: "textures/cobblestone_normal.png"
    albedo_map {
      source: "textures/cobblestone_albedo.png"
      tiling: [6, 6]
      filtering: "trilinear"
    }
  }

  pbr_material "WoodenBeam" {
    albedo_map: "textures/oak_albedo.png"
    normal_map: "textures/oak_normal.png"
    roughness: 0.65
    metallic: 0.0
  }

  // ── Forge Fire particles inside composition ───────────────────────────
  particles "ForgeFlames" @looping {
    rate: 400
    max_particles: 1500
    start_lifetime: [0.3, 0.8]
    start_speed: [1, 3]
    start_size: [0.1, 0.3]

    emission {
      rate_over_time: 400
    }

    velocity {
      direction: [0, 1, 0]
      speed: 2
      spread: 20
    }

    color_over_life {
      gradient: ["#ffffff", "#ffdd00", "#ff6600", "#ff220088", "#00000000"]
      mode: "blend"
    }

    size_over_life {
      curve: [0.3, 1.0, 0.7, 0.0]
      mode: "bezier"
    }

    noise {
      strength: 0.5
      frequency: 4.0
      scroll_speed: 0.4
    }

    renderer {
      material: "particles/fire_additive"
      render_mode: "billboard"
    }
  }

  // ── Post-processing inside composition ────────────────────────────────
  post_processing "InteriorLighting" {
    bloom {
      intensity: 0.6
      threshold: 0.9
      scatter: 0.5
      tint: #ffccaa
    }

    ssao {
      intensity: 2.0
      radius: 0.3
      sample_count: 16
    }

    color_grading {
      temperature: 4000
      saturation: 0.85
      contrast: 1.2
    }

    vignette {
      intensity: 0.35
      smoothness: 0.5
    }
  }

  // ── Audio inside composition ──────────────────────────────────────────
  audio_source "AnvilStrike" @spatial {
    clip: "sounds/anvil_hammer.ogg"
    volume: 0.9
    pitch: 1.0
    spatial_blend: 1.0
    min_distance: 2
    max_distance: 30
    rolloff_mode: "logarithmic"
    loop: false
    play_on_awake: false
    doppler_level: 0.5
  }

  ambience "ForgeAmbient" @spatial {
    clip: "sounds/forge_ambient_loop.ogg"
    volume: 0.4
    loop: true
    play_on_awake: true
    spatial_blend: 0.3
    spread: 180
  }

  reverb_zone "ForgeInterior" {
    preset: "stone_room"
    min_distance: 3
    max_distance: 15
    room: -600
    room_hf: -300
    decay_time: 1.5
    reflections: -200
    diffusion: 75
    density: 85
  }

  audio_mixer "ForgeMixer" {
    master_volume: 1.0
    sfx_volume: 0.9
    ambient_volume: 0.5
    music_volume: 0.3
  }

  // ── Scene Objects with Physics ────────────────────────────────────────

  // Anvil with full physics
  object "Anvil" @collidable {
    src: "models/anvil.glb"
    position: [0, 0.5, 0]
    scale: [1, 1, 1]

    physics {
      collider convex {
        vertex_limit: 128
      }

      rigidbody {
        mass: 200
        use_gravity: true
        is_kinematic: true
      }

      friction: 0.8
      restitution: 0.1
    }
  }

  // Hot ingot on the anvil
  object "HotIngot" @grabbable {
    geometry: "cube"
    position: [0, 0.85, 0]
    scale: [0.3, 0.1, 0.1]
    color: #ff4400

    physics {
      collider box {
        size: [0.3, 0.1, 0.1]
        is_trigger: false
      }

      rigidbody {
        mass: 5
        use_gravity: true
        drag: 0.05
      }

      friction: 0.5
    }
  }

  // Blacksmith's hammer
  object "Hammer" @grabbable @throwable {
    src: "models/hammer.glb"
    position: [0.5, 0.8, 0.3]

    physics {
      collider capsule {
        radius: 0.05
        height: 0.4
      }

      rigidbody {
        mass: 3
        use_gravity: true
        angular_damping: 0.1
      }
    }

    onGrab: {
      haptic.feedback("medium")
    }
  }

  // Forge fire pit
  object "FirePit" @collidable {
    geometry: "cube"
    position: [-2, 0.4, 0]
    scale: [1.5, 0.8, 1]
    color: #443322

    collider box {
      size: [1.5, 0.8, 1]
      is_trigger: false
    }
  }

  // Bellows
  object "Bellows" @clickable {
    src: "models/bellows.glb"
    position: [-3, 0.5, 0]

    collider box {
      size: [0.5, 0.4, 0.3]
      is_trigger: false
    }

    onClick: {
      audio.play("bellows_push")
    }
  }

  // Water quench trough
  object "QuenchTrough" @collidable {
    geometry: "cube"
    position: [2, 0.3, 0]
    scale: [1.2, 0.6, 0.5]
    color: #554433

    collider box {
      size: [1.2, 0.6, 0.5]
      is_trigger: false
    }
  }

  // Window with glass material
  object "WorkshopWindow" {
    geometry: "plane"
    position: [0, 2, -4]
    scale: [2, 1.5, 1]
    rotation: [0, 0, 0]
  }

  // Stone walls
  object "WallNorth" @collidable {
    geometry: "cube"
    position: [0, 2, -4.1]
    scale: [10, 4, 0.2]
    color: #665544
  }

  object "WallEast" @collidable {
    geometry: "cube"
    position: [5, 2, 0]
    scale: [0.2, 4, 8]
    color: #665544
  }

  object "WallWest" @collidable {
    geometry: "cube"
    position: [-5, 2, 0]
    scale: [0.2, 4, 8]
    color: #665544
  }

  // Floor
  object "Floor" @collidable {
    geometry: "plane"
    position: [0, 0, 0]
    scale: [10, 1, 8]
    color: #554433
  }

  // Wooden support beams
  object "Beam1" {
    geometry: "cube"
    position: [-4, 3, -3]
    scale: [0.15, 0.15, 6]
    color: #8b6914
  }

  object "Beam2" {
    geometry: "cube"
    position: [4, 3, -3]
    scale: [0.15, 0.15, 6]
    color: #8b6914
  }

  // Lighting
  point_light "ForgeFire" {
    position: [-2, 1.5, 0]
    color: #ff8833
    intensity: 2.0
    range: 8
  }

  point_light "IncandescentBulb" {
    position: [0, 3.5, 0]
    color: #ffddaa
    intensity: 0.6
    range: 10
  }

  directional_light "MoonlightThroughWindow" {
    position: [0, 5, -5]
    color: #aabbff
    intensity: 0.15
  }
}
