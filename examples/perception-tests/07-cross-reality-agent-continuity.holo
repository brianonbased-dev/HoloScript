// ============================================================================
// Cross-Reality Agent Continuity — Full-Stack Demo
// ============================================================================
// Demonstrates an AI guide agent that persists seamlessly across:
//   VR headset → AR glasses → Phone → Desktop → Car → Wearable
//
// Features exercised:
//   - @platform() conditional compilation with category-level filtering
//   - MVC handoff payload (<10KB) with decision history + task state
//   - Embodiment transitions (Avatar3D → SpatialPersona → UI2D → VoiceHUD)
//   - CRDT-backed spatial anchors for shared world state
//   - Norm lifecycle (CRSEC) for agent behavior governance
//   - Offline recovery queue for airplane mode resilience
//   - Spatial memory zones with RBAC scoping
//
// Scene: A museum tour where an AI guide agent leads users through
// exhibits, adapting its form and interaction style per device.
// ============================================================================

composition "MuseumTourCrossReality" {

  // ── State ──────────────────────────────────────────────────────────────

  @state {
    currentExhibit: "lobby"
    tourProgress: 0.0
    userPreferences: {
      language: "en"
      accessibilityReducedMotion: false
      narrationSpeed: 1.0
    }
    agentMood: "welcoming"
    visitedExhibits: []
    bookmarkedArtworks: []
  }

  // ── Environment ────────────────────────────────────────────────────────

  @environment {
    skybox: "museum_atrium_hdri"
    ambientLight: 0.3
    tonemap: "aces"
    fog: none
  }

  // ── Spatial Memory Zones ───────────────────────────────────────────────
  // Each exhibit hall is a zone with RBAC-scoped spatial anchors.

  zone "LobbyZone" {
    bounds: box([-20, 0, -20], [20, 8, 20])
    anchor: geo(40.7484, -73.9857, 10.0)  // Met Museum, NYC
    access: public
  }

  zone "EgyptianWing" {
    bounds: box([-30, 0, 0], [0, 6, 40])
    anchor: geo(40.7489, -73.9862, 10.0)
    access: ticketed
  }

  zone "ModernArtGallery" {
    bounds: box([0, 0, 0], [25, 5, 30])
    anchor: geo(40.7481, -73.9853, 10.0)
    access: ticketed
  }

  zone "SculptureGarden" {
    bounds: box([-15, 0, 30], [15, 0, 60])
    anchor: geo(40.7478, -73.9850, 0.0)
    access: public
  }

  // ── AI Guide Agent ─────────────────────────────────────────────────────
  // The guide adapts its embodiment per platform.

  // VR: Full 3D avatar with spatial gestures
  @platform(vr)
  object "GuideAgent_VR" @agent_identity @avatar_embodiment @hand_tracking {
    model: "avatars/museum_guide_v2.glb"
    skeleton: humanoid
    position: [0, 0, -2]
    scale: 1.0

    @spatial_audio_3d {
      spatialize: true
      rolloff: logarithmic
      maxDistance: 15.0
    }

    @hand_gesture {
      gestures: [point, wave, beckon, present]
      handedness: right
    }

    personality {
      tone: "knowledgeable_friendly"
      gestureFrequency: 0.7
      eyeContactRatio: 0.6
    }
  }

  // AR: Spatial persona (floating, semi-transparent)
  @platform(ar)
  object "GuideAgent_AR" @agent_identity @spatial_anchor {
    model: "avatars/guide_spatial_persona.glb"
    opacity: 0.85
    position: [0, 0.5, -1.5]
    scale: 0.8
    billboardMode: "y-axis"

    @spatial_audio_3d {
      spatialize: true
      rolloff: linear
      maxDistance: 8.0
    }

    personality {
      tone: "concise_helpful"
      gestureFrequency: 0.3
    }
  }

  // Phone + Desktop: 2D UI card overlay
  @platform(mobile, desktop)
  object "GuideAgent_Screen" @agent_identity {
    layout: "bottom-sheet"
    avatarThumbnail: "avatars/guide_avatar_2d.png"
    chatBubbleStyle: "museum"
    maxVisibleMessages: 5

    personality {
      tone: "informative_casual"
      responseLength: "brief"
    }
  }

  // Automotive: Voice-only HUD (safety-critical)
  @platform(automotive)
  object "GuideAgent_Car" @agent_identity {
    layout: "voice-hud"
    displayMode: "minimal"
    interruptible: true

    @spatial_audio_3d {
      spatialize: false
      channel: "center"
    }

    personality {
      tone: "calm_brief"
      responseLength: "minimal"
      noVisualDistractions: true
    }
  }

  // Wearable: Haptic nudge + glanceable text
  @platform(wearable)
  object "GuideAgent_Watch" @agent_identity {
    layout: "glance"
    hapticOnNotify: true
    maxTextLength: 80

    personality {
      tone: "ultra_concise"
      responseLength: "one_liner"
    }
  }

  // ── Exhibit Objects ────────────────────────────────────────────────────
  // Universal objects visible on all platforms (no @platform constraint).

  object "TempleOfDendur" @interactive {
    model: "exhibits/temple_of_dendur.glb"
    position: [-15, 0, 20]
    scale: 1.0
    zone: "EgyptianWing"

    info {
      title: "Temple of Dendur"
      period: "circa 15 BC"
      origin: "Nubia, Egypt"
      description: "Roman-era Egyptian temple gifted to the US in 1965."
    }

    // VR-only: walkthrough with spatial annotations
    @platform(vr)
    interaction "Walkthrough" {
      type: spatial_tour
      waypoints: [[-15, 0, 18], [-14, 0, 22], [-16, 0, 25]]
      annotations: ["entrance", "inner_chamber", "sanctuary"]
    }

    // AR: overlay historical context
    @platform(ar)
    interaction "AROverlay" {
      type: info_overlay
      placement: "above_object"
      triggerDistance: 3.0
    }

    // Screen: swipeable image gallery
    @platform(mobile, desktop)
    interaction "Gallery" {
      type: image_carousel
      images: ["dendur_1.jpg", "dendur_2.jpg", "dendur_3.jpg"]
    }
  }

  object "StarryNight" @interactive {
    model: "exhibits/starry_night_frame.glb"
    position: [10, 1.5, 15]
    zone: "ModernArtGallery"

    info {
      title: "The Starry Night"
      artist: "Vincent van Gogh"
      year: 1889
      medium: "Oil on canvas"
    }

    @platform(vr, ar)
    interaction "ImmersiveDive" {
      type: portal
      destination: "starry_night_world"
      transitionDuration: 1500
    }
  }

  // ── Norms (Agent Behavior Governance) ──────────────────────────────────

  norm "QuietInGallery" @norm {
    lifecycle: constituted
    scope: zone:ModernArtGallery
    description: "Agent speaks softly in the gallery to maintain ambiance."

    representation {
      visual: "muted_icon"
      audio: { maxVolume: 0.3 }
    }

    sanction {
      violation: "loud_speech"
      consequence: "auto_lower_volume"
      severity: low
    }
  }

  norm "NoDistractionWhileDriving" @norm {
    lifecycle: constituted
    scope: global
    priority: critical

    condition {
      platform: automotive
    }

    representation {
      visual: none
      audio: { maxLength: 10 }
    }

    sanction {
      violation: "visual_notification"
      consequence: "suppress_and_queue"
      severity: critical
    }
  }

  norm "AccessibilityFirst" @norm {
    lifecycle: constituted
    scope: global

    condition {
      when: state.userPreferences.accessibilityReducedMotion == true
    }

    representation {
      transitions: instant
      animations: none
    }
  }

  // ── Spatial Group: Lobby Layout ────────────────────────────────────────

  spatial_group "LobbyArrangement" {
    layout: circular
    radius: 5.0
    center: [0, 0, 0]
    zone: "LobbyZone"

    object "WelcomeKiosk" @interactive {
      model: "props/kiosk_holographic.glb"
      position: [0, 0, 0]

      interaction "StartTour" {
        type: button
        label: "Begin Museum Tour"
        action: emit("tour:start")
      }
    }

    object "FloorMap" @interactive {
      model: "props/floor_map_holographic.glb"
      position: [3, 0.8, 0]

      interaction "SelectExhibit" {
        type: tap_region
        regions: ["egyptian", "modern_art", "sculpture"]
        action: emit("navigate:exhibit", selected)
      }
    }
  }

  // ── Logic ──────────────────────────────────────────────────────────────

  logic {
    on "tour:start" {
      state.tourProgress = 0.1
      state.currentExhibit = "EgyptianWing"
      agent.say("Welcome! Let's begin in the Egyptian Wing.")
      agent.navigate(zone: "EgyptianWing")
    }

    on "navigate:exhibit" (exhibit) {
      state.currentExhibit = exhibit
      agent.navigate(zone: exhibit)
      state.visitedExhibits.push(exhibit)
      state.tourProgress = state.visitedExhibits.length / 4.0
    }

    on "handoff:initiated" {
      agent.say("Switching devices. I'll meet you on the other side!")
    }

    on "handoff:received" {
      agent.say("I'm back! We were exploring " + state.currentExhibit + ".")
    }

    on "offline:detected" {
      agent.say("We're offline. I'll save our progress for when we reconnect.")
    }

    on "offline:recovered" (stats) {
      agent.say("Back online! Synced " + stats.applied + " updates.")
    }
  }
}
