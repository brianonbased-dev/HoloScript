// ============================================================================
// Material Block Test Composition
// ============================================================================
// Exercises all material_block grammar constructs:
//   - material, pbr_material, unlit_material, shader,
//     toon_material, glass_material, subsurface_material
//   - Inline texture_map assignments
//   - Structured texture_map_block sub-blocks
//   - shader_pass definitions
//   - shader_connection (output -> input wiring)
//   - Traits on material blocks
//   - Materials at top level AND inside compositions
// ============================================================================

// ── Top-Level PBR Material (inline properties + color values) ───────────────

material "BrushedSteel" @pbr {
  baseColor: #888888
  roughness: 0.3
  metallic: 1.0
  normal: 1.0
  emissive: #000000
  opacity: 1.0
  IOR: 1.45
}

// ── PBR Material with Inline Texture Maps ───────────────────────────────────

pbr_material "HardwoodFloor" {
  albedo_map: "textures/hardwood_albedo.png"
  normal_map: "textures/hardwood_normal.png"
  roughness_map: "textures/hardwood_roughness.png"
  ao_map: "textures/hardwood_ao.png"
  roughness: 0.55
  metallic: 0.0
}

// ── PBR Material with Structured Texture Map Sub-Blocks ─────────────────────

pbr_material "WeatheredBrick" @pbr {
  albedo_map {
    source: "textures/brick_albedo.png"
    tiling: [4, 4]
    filtering: "trilinear"
  }
  normal_map {
    source: "textures/brick_normal.png"
    strength: 1.2
    format: "opengl"
  }
  ao_map {
    source: "textures/brick_ao.png"
    intensity: 0.8
  }
  height_map {
    source: "textures/brick_height.png"
    scale: 0.05
    channel: "r"
  }
  roughness: 0.85
  metallic: 0.0
}

// ── Unlit Material ──────────────────────────────────────────────────────────

unlit_material "HologramOverlay" @transparent {
  baseColor: #00ffaa
  opacity: 0.6
  emission_map: "textures/hologram_emission.png"
  double_sided: true
}

// ── Toon / Cel-Shaded Material ──────────────────────────────────────────────

toon_material "CartoonCharacter" @cel_shaded {
  baseColor: #ff6633
  outline_width: 0.02
  outline_color: #000000
  shade_steps: 3
  specular_size: 0.2
  rim_light: 0.4
  rim_color: #ffffff
}

// ── Glass Material with Transmission ────────────────────────────────────────

glass_material "ArchitecturalGlass" @transparent {
  baseColor: #ffffff
  opacity: 0.15
  IOR: 1.52
  transmission: 0.95
  roughness: 0.02
  thickness: 0.01
  attenuation_color: #eeffee
}

// ── Subsurface Scattering Material ──────────────────────────────────────────

subsurface_material "HumanSkin" @sss {
  baseColor: #ddb8a0
  roughness: 0.4
  metallic: 0.0
  subsurface_color: #cc4422
  subsurface_radius: [1.0, 0.2, 0.1]
  subsurface_map: "textures/skin_subsurface.png"
  thickness_map: "textures/skin_thickness.png"
  normal_map {
    source: "textures/skin_normal.png"
    strength: 0.8
  }
}

// ── Shader with Pass and Connection ─────────────────────────────────────────

shader "CustomTerrain" {
  pass "ForwardBase" {
    vertex: "shaders/terrain.vert"
    fragment: "shaders/terrain.frag"
    blend: "opaque"
  }
  pass "ShadowCaster" {
    vertex: "shaders/terrain_shadow.vert"
    fragment: "shaders/terrain_shadow.frag"
  }
  roughness: 0.7
  tiling_scale: 4.0
  heightBlend -> material.baseColor
  normalOut -> material.normal
}

// ── Composition with Materials Inside ───────────────────────────────────────

composition "Material Showcase Gallery" {
  environment {
    skybox: "studio_hdr"
    ambient_light: 0.6
    shadows: true
  }

  // Material defined inside composition scope
  material "GalleryFloor" @pbr {
    baseColor: #cccccc
    roughness: 0.9
    metallic: 0.0
    normal_map: "textures/marble_normal.png"
    albedo_map {
      source: "textures/marble_albedo.png"
      tiling: [8, 8]
      filtering: "anisotropic"
    }
  }

  // PBR material with emissive map inside composition
  pbr_material "NeonSign" {
    baseColor: #111111
    roughness: 0.1
    metallic: 0.8
    emissive_map: "textures/neon_emissive.png"
    emission_map: "textures/neon_glow.png"
    emissiveIntensity: 2.5
  }

  // Glass material used for display case
  glass_material "DisplayCase" @transparent {
    baseColor: #ffffff
    opacity: 0.08
    IOR: 1.5
    transmission: 0.98
    roughness: 0.01
  }

  object "Floor" {
    geometry: "plane"
    position: [0, 0, 0]
    scale: [20, 1, 20]
  }

  object "MaterialSphere_Steel" {
    geometry: "sphere"
    position: [-3, 1, 0]
    scale: [0.8, 0.8, 0.8]
  }

  object "MaterialSphere_Wood" {
    geometry: "sphere"
    position: [0, 1, 0]
    scale: [0.8, 0.8, 0.8]
  }

  object "MaterialSphere_Glass" {
    geometry: "sphere"
    position: [3, 1, 0]
    scale: [0.8, 0.8, 0.8]
  }

  point_light "KeyLight" {
    position: [0, 5, 3]
    color: #ffffff
    intensity: 1.2
    range: 20
  }
}
