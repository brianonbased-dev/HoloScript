// ============================================================================
// Particle Block Test Composition
// ============================================================================
// Exercises all particle_block grammar constructs:
//   - particles, emitter, vfx, particle_system keywords
//   - All particle_module sub-blocks:
//     emission, lifetime, velocity, force, color_over_life,
//     size_over_life, noise, collision, sub_emitter, shape,
//     renderer, rotation_over_life, trails, texture_sheet,
//     inherit_velocity
//   - Flat properties alongside particle modules
//   - Traits on particle blocks
//   - Particles at top level AND inside compositions
// ============================================================================

// ── Top-Level: Looping Particle System with Multiple Modules ────────────────

particles "CampfireSmoke" @looping {
  rate: 500
  max_particles: 2000
  start_lifetime: [2, 4]
  start_speed: [0.5, 1.5]
  start_size: [0.1, 0.3]
  gravity_modifier: 0.1
  simulation_space: "world"

  emission {
    rate_over_time: 500
    burst_count: 10
    burst_interval: 0.5
  }

  lifetime {
    min: 2
    max: 4
    curve: "ease_out"
  }

  velocity {
    direction: [0, 1, 0]
    speed: 1.5
    spread: 25
    randomize: true
  }

  force {
    gravity: [0, -0.5, 0]
    wind: [0.3, 0, 0.1]
    turbulence: 0.2
  }

  color_over_life {
    gradient: ["#ff6600", "#888888", "#00000000"]
    mode: "blend"
  }

  size_over_life {
    curve: [1.0, 1.5, 0.0]
    mode: "bezier"
  }

  rotation_over_life {
    angular_velocity: [0, 0, 45]
    randomize: true
  }

  noise {
    strength: 0.3
    frequency: 2.0
    scroll_speed: 0.1
    octaves: 2
    quality: "medium"
  }

  shape {
    type: "cone"
    angle: 25
    radius: 0.3
    emit_from: "base"
  }

  renderer {
    material: "particles/smoke_additive"
    render_mode: "billboard"
    sort_mode: "distance"
    max_size: 2.0
    alignment: "view"
  }
}

// ── Emitter Variant with Trails ─────────────────────────────────────────────

emitter "WeldingSparks" @burst {
  rate: 200
  start_lifetime: [0.3, 0.8]
  start_speed: [3, 8]
  start_size: [0.01, 0.03]
  start_color: #ffcc00
  gravity_modifier: 1.0

  velocity {
    direction: [0, 1, 0]
    speed: 5
    spread: 60
  }

  collision {
    enabled: true
    bounce: 0.4
    lifetime_loss: 0.5
    dampen: 0.2
    type: "world"
  }

  trails {
    enabled: true
    width: 0.02
    lifetime: 0.3
    color_over_trail: ["#ffcc00", "#ff6600", "#00000000"]
    min_vertex_distance: 0.02
    world_space: true
  }

  color_over_life {
    gradient: ["#ffee00", "#ff6600", "#33000000"]
    mode: "blend"
  }

  size_over_life {
    curve: [1.0, 0.5, 0.0]
    mode: "linear"
  }
}

// ── VFX Keyword Variant with Sub-Emitter ────────────────────────────────────

vfx "Explosion" @oneshot {
  rate: 0
  max_particles: 500
  start_lifetime: [0.5, 2.0]
  start_speed: [5, 15]
  start_size: [0.2, 0.8]

  emission {
    burst_count: 200
    burst_interval: 0
  }

  velocity {
    direction: [0, 1, 0]
    speed: 10
    spread: 180
  }

  force {
    gravity: [0, -9.81, 0]
    drag: 0.5
  }

  collision {
    enabled: true
    bounce: 0.3
    lifetime_loss: 0.2
    type: "world"
  }

  sub_emitter {
    trigger: "collision"
    inherit_color: true
    inherit_size: 0.5
    emit_count: 5
    system: "SmokePuff"
  }

  noise {
    strength: 0.5
    frequency: 3.0
    scroll_speed: 0.2
  }

  texture_sheet {
    tiles_x: 8
    tiles_y: 8
    animation: "whole_sheet"
    frame_rate: 30
    start_frame: 0
    cycles: 1
  }

  renderer {
    material: "particles/explosion_atlas"
    render_mode: "stretched_billboard"
    length_scale: 0.5
    speed_scale: 0.1
  }
}

// ── particle_system Keyword Variant ─────────────────────────────────────────

particle_system "RainDrops" @looping {
  rate: 3000
  max_particles: 10000
  start_lifetime: [1.0, 2.0]
  start_speed: [8, 12]
  start_size: [0.005, 0.015]
  start_color: #aaccff
  gravity_modifier: 1.5

  emission {
    rate_over_time: 3000
  }

  shape {
    type: "box"
    scale: [50, 0, 50]
    emit_from: "volume"
  }

  velocity {
    direction: [0, -1, 0]
    speed: 10
    spread: 5
  }

  inherit_velocity {
    mode: "current"
    multiplier: 0.5
  }

  collision {
    enabled: true
    bounce: 0.1
    lifetime_loss: 1.0
    type: "world"
  }

  sub_emitter {
    trigger: "death"
    inherit_color: false
    emit_count: 3
    system: "RainSplash"
  }

  renderer {
    material: "particles/raindrop_streak"
    render_mode: "stretched_billboard"
    length_scale: 2.0
    speed_scale: 0.3
  }
}

// ── Composition with Multiple Particle Systems Inside ───────────────────────

composition "Particle Effects Gallery" {
  environment {
    skybox: "night_clear"
    ambient_light: 0.3
    gravity: -9.81
  }

  // Fireflies with emission + color + noise
  particles "Fireflies" @looping {
    rate: 50
    max_particles: 200
    start_lifetime: [3, 6]
    start_speed: [0.1, 0.3]
    start_size: [0.02, 0.05]

    emission {
      rate_over_time: 50
    }

    color_over_life {
      gradient: ["#00000000", "#aaff44", "#aaff44", "#00000000"]
      mode: "blend"
    }

    noise {
      strength: 0.5
      frequency: 1.0
      scroll_speed: 0.05
    }

    shape {
      type: "sphere"
      radius: 5
      emit_from: "volume"
    }

    renderer {
      material: "particles/glow_additive"
      render_mode: "billboard"
      max_size: 0.1
    }
  }

  // Waterfall mist with force and collision
  particles "WaterfallMist" @looping {
    rate: 800
    max_particles: 3000
    start_lifetime: [2, 5]
    start_size: [0.05, 0.2]
    gravity_modifier: -0.1

    emission {
      rate_over_time: 800
    }

    velocity {
      direction: [0, -1, 0.3]
      speed: 3
      spread: 20
    }

    force {
      gravity: [0, 0.5, 0]
      turbulence: 0.3
    }

    size_over_life {
      curve: [0.5, 1.0, 1.5, 2.0]
      mode: "bezier"
    }

    color_over_life {
      gradient: ["#ffffff88", "#ffffff44", "#ffffff00"]
      mode: "blend"
    }
  }

  // Torch fire emitter
  emitter "TorchFlame" @looping {
    rate: 300
    start_lifetime: [0.5, 1.2]
    start_speed: [1, 3]
    start_size: [0.1, 0.3]

    velocity {
      direction: [0, 1, 0]
      speed: 2
      spread: 15
    }

    color_over_life {
      gradient: ["#ffffff", "#ffaa00", "#ff3300", "#00000000"]
      mode: "blend"
    }

    size_over_life {
      curve: [0.5, 1.0, 0.8, 0.0]
      mode: "bezier"
    }

    noise {
      strength: 0.4
      frequency: 3.0
      scroll_speed: 0.3
    }
  }

  object "FirePit" {
    geometry: "cylinder"
    position: [0, 0, 0]
    scale: [1, 0.3, 1]
    color: #333333
  }

  object "WaterfallRock" {
    geometry: "cube"
    position: [8, 3, 0]
    scale: [3, 6, 2]
    color: #555555
  }
}
