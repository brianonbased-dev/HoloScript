// v5.6 Observable Agent Pipeline Example
//
// Extends the v5.5 IoT pipeline with observability:
//   - Distributed tracing across agent delegations
//   - Prometheus metrics for monitoring
//   - Structured logging with trace correlation
//   - OTLP export for Jaeger/Grafana Tempo
//
// Run: holoscript serve examples/agents/observable-agent-pipeline.holo

@world { name: "Observable IoT Pipeline", version: "5.6.0" }

// ============================================================
// Agent 1: Sensor Data Collector (with tracing)
// ============================================================

agent "SensorAgent" @agent @iot @observable {
  id: "sensor-agent-01"
  version: "1.0.0"
  trust_level: "local"
  status: "online"

  capability "collect" @analyze @iot {
    description: "Collect raw sensor telemetry with trace propagation"
    domain: "iot"
    tags: ["sensor", "telemetry", "traced"]
  }

  endpoint @local {
    protocol: "local"
    address: "local://sensor-agent-01"
    primary: true
  }

  skill "read_sensors" {
    inputs: { device_ids: "string[]", interval_ms: "number" }
    output: { readings: "SensorReading[]", timestamp: "string", traceId: "string" }
  }

  // Observability configuration
  observability {
    tracing: true
    metrics: true
    log_level: "info"
    otlp_endpoint: "http://localhost:4318/v1/traces"
  }
}

// ============================================================
// Agent 2: Analytics Engine (with metrics)
// ============================================================

agent "AnalyticsAgent" @agent @analytics @observable {
  id: "analytics-agent-01"
  version: "1.0.0"
  trust_level: "local"
  status: "online"

  capability "transform" @transform @iot {
    description: "Aggregate sensor data with latency tracking"
    domain: "iot"
    tags: ["analytics", "aggregation", "metered"]
  }

  endpoint @local {
    protocol: "local"
    address: "local://analytics-agent-01"
    primary: true
  }

  skill "aggregate_readings" {
    inputs: { readings: "SensorReading[]", window_ms: "number" }
    output: { summary: "AggregatedData", anomalies: "Anomaly[]" }
  }

  observability {
    tracing: true
    metrics: true
    log_level: "debug"
    histogram_buckets: [5, 10, 25, 50, 100, 250, 500]
  }
}

// ============================================================
// Agent 3: Dashboard Renderer (with health checks)
// ============================================================

agent "DashboardAgent" @agent @visualization @observable {
  id: "dashboard-agent-01"
  version: "1.0.0"
  trust_level: "local"
  status: "online"

  capability "render" @render @spatial {
    description: "Render dashboard with health status panel"
    domain: "spatial"
    tags: ["visualization", "3d", "health"]
  }

  endpoint @local {
    protocol: "local"
    address: "local://dashboard-agent-01"
    primary: true
  }

  skill "render_dashboard" {
    inputs: { data: "AggregatedData", metrics: "PrometheusText" }
    output: { scene: "HoloScene", widget_id: "string" }
  }

  observability {
    tracing: true
    metrics: true
    health_endpoint: "/health"
    metrics_endpoint: "/metrics"
  }
}

// ============================================================
// Workflow: Observable Sensor-to-Dashboard Pipeline
// ============================================================

workflow "ObservableSensorPipeline" {
  description: "IoT pipeline with end-to-end distributed tracing"

  step "collect" {
    skill: "read_sensors"
    inputs: {
      device_ids: ["temp-01", "humidity-01"]
      interval_ms: 5000
    }
  }

  step "analyze" {
    skill: "aggregate_readings"
    depends_on: ["collect"]
    inputs: {
      readings: { ref: "collect.readings" }
      window_ms: 60000
    }
  }

  step "visualize" {
    skill: "render_dashboard"
    depends_on: ["analyze"]
    inputs: {
      data: { ref: "analyze.summary" }
      metrics: { ref: "context.prometheus_text" }
    }
  }
}
