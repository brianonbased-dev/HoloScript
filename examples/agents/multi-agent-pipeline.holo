// v5.5 Multi-Agent Pipeline Example
//
// Three-agent IoT pipeline demonstrating agent orchestration:
//   SensorAgent -> AnalyticsAgent -> DashboardAgent
//
// Each agent declares its capabilities and endpoints.
// The OrchestratorAgent discovers them, delegates tasks,
// and chains them via a skill workflow.

@world { name: "IoT Agent Pipeline", version: "5.5.0" }

// ============================================================
// Agent 1: Sensor Data Collector
// Reads from IoT sensors and emits raw telemetry.
// ============================================================

agent "SensorAgent" @agent @iot @streaming {
  id: "sensor-agent-01"
  version: "1.0.0"
  trust_level: "local"
  status: "online"

  capability "collect" @analyze @iot {
    description: "Collect raw sensor telemetry"
    domain: "iot"
    tags: ["sensor", "telemetry", "realtime"]
  }

  capability "stream" @generate @iot {
    description: "Stream live sensor data"
    domain: "iot"
    tags: ["streaming", "websocket"]
  }

  endpoint @local {
    protocol: "local"
    address: "local://sensor-agent-01"
    primary: true
  }

  skill "read_sensors" {
    inputs: { device_ids: "string[]", interval_ms: "number" }
    output: { readings: "SensorReading[]", timestamp: "string" }
  }

  skill "calibrate" {
    inputs: { device_id: "string", reference_value: "number" }
    output: { status: "string", offset: "number" }
  }
}

// ============================================================
// Agent 2: Analytics Engine
// Processes raw telemetry into actionable insights.
// ============================================================

agent "AnalyticsAgent" @agent @analytics @ml {
  id: "analytics-agent-01"
  version: "1.0.0"
  trust_level: "local"
  status: "online"

  capability "transform" @transform @iot {
    description: "Aggregate and transform sensor data"
    domain: "iot"
    tags: ["analytics", "aggregation"]
  }

  capability "detect" @detect @iot {
    description: "Detect anomalies in telemetry streams"
    domain: "iot"
    tags: ["anomaly", "detection", "ml"]
  }

  endpoint @local {
    protocol: "local"
    address: "local://analytics-agent-01"
    primary: true
  }

  skill "aggregate_readings" {
    inputs: { readings: "SensorReading[]", window_ms: "number" }
    output: { summary: "AggregatedData", anomalies: "Anomaly[]" }
  }

  skill "predict_maintenance" {
    inputs: { history: "AggregatedData[]", device_id: "string" }
    output: { prediction: "MaintenanceWindow", confidence: "number" }
  }
}

// ============================================================
// Agent 3: Dashboard Renderer
// Visualizes processed data as spatial widgets.
// ============================================================

agent "DashboardAgent" @agent @visualization @spatial {
  id: "dashboard-agent-01"
  version: "1.0.0"
  trust_level: "local"
  status: "online"

  capability "render" @render @spatial {
    description: "Render data as spatial 3D dashboard widgets"
    domain: "spatial"
    tags: ["visualization", "3d", "dashboard"]
  }

  endpoint @local {
    protocol: "local"
    address: "local://dashboard-agent-01"
    primary: true
  }

  skill "render_chart" {
    inputs: { data: "AggregatedData", chart_type: "string" }
    output: { scene: "HoloScene", widget_id: "string" }
  }

  skill "render_alerts" {
    inputs: { anomalies: "Anomaly[]" }
    output: { scene: "HoloScene", alert_count: "number" }
  }
}

// ============================================================
// Workflow: Sensor-to-Dashboard Pipeline
// Chains the three agents into a single DAG.
// ============================================================

workflow "SensorToDashboard" {
  description: "End-to-end IoT pipeline: collect -> analyze -> visualize"

  step "collect" {
    skill: "read_sensors"
    inputs: {
      device_ids: ["temp-01", "humidity-01", "pressure-01"]
      interval_ms: 5000
    }
  }

  step "analyze" {
    skill: "aggregate_readings"
    depends_on: ["collect"]
    inputs: {
      readings: { ref: "collect.readings" }
      window_ms: 60000
    }
  }

  step "visualize" {
    skill: "render_chart"
    depends_on: ["analyze"]
    inputs: {
      data: { ref: "analyze.summary" }
      chart_type: "timeseries"
    }
  }

  step "alert" {
    skill: "render_alerts"
    depends_on: ["analyze"]
    inputs: {
      anomalies: { ref: "analyze.anomalies" }
    }
  }
}
