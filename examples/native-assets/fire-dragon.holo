// ═══════════════════════════════════════════════════════════════════════════
// INFERNO WYRM — Ultimate HoloScript Dragon (1300+ lines)
// ═══════════════════════════════════════════════════════════════════════════
// 200+ primitives · 15 animation sequences · 5-layer fire breath
// Full anatomical detail: individual teeth, multi-layered eyes,
// segmented horns, articulated wings, scale armor
// ═══════════════════════════════════════════════════════════════════════════

composition "Inferno Wyrm" {

  // ─── Environment ──────────────────────────────────────────────────────
  environment {
    skybox: "night"
    fog_density: 0.015
    ambient_color: "#0d0520"
    background: "#050210"
  }

  // ═════════════════════════════════════════════════════════════════════
  //  BODY CORE — Triple-sphere organic torso
  // ═════════════════════════════════════════════════════════════════════

  object "TorsoMain" @physics {
    geometry: "sphere"
    position: [0, 2.5, 0]
    scale: [1.8, 1.2, 2.4]
    color: "#1e0f3d"
    material: "skin_dark"

    keyframes "breathe" {
      0%:   { scale: [1.8, 1.2, 2.4] }
      50%:  { scale: [1.9, 1.28, 2.5] }
      100%: { scale: [1.8, 1.2, 2.4] }
      duration: 4000
      easing: "ease-in-out"
      loop: true
    }

    // Upper torso bulge
    object "TorsoUpper" {
      geometry: "sphere"
      position: [0, 0.3, 0.5]
      scale: [1.5, 1.0, 1.6]
      color: "#251548"
      material: "skin_dark"
    }

    // Lower torso
    object "TorsoLower" {
      geometry: "sphere"
      position: [0, -0.2, -0.3]
      scale: [1.4, 0.9, 1.5]
      color: "#1a0c35"
      material: "skin_dark"
    }

    // Chest plate — armored
    object "ChestPlate" {
      geometry: "cube"
      position: [0, -0.1, 0.9]
      scale: [0.9, 0.7, 0.3]
      color: "#2a1a50"
      material: "brushed_steel"
      metalness: 0.6
      roughness: 0.3
    }

    // Ribcage detail left
    object "RibLeft1" {
      geometry: "cylinder"
      position: [-0.7, 0, 0.3]
      rotation: [0, 0, 30]
      scale: [0.06, 0.5, 0.06]
      color: "#1a0c35"
      material: "bone"
    }
    object "RibLeft2" {
      geometry: "cylinder"
      position: [-0.65, 0, 0]
      rotation: [0, 0, 35]
      scale: [0.06, 0.45, 0.06]
      color: "#1a0c35"
      material: "bone"
    }
    object "RibRight1" {
      geometry: "cylinder"
      position: [0.7, 0, 0.3]
      rotation: [0, 0, -30]
      scale: [0.06, 0.5, 0.06]
      color: "#1a0c35"
      material: "bone"
    }
    object "RibRight2" {
      geometry: "cylinder"
      position: [0.65, 0, 0]
      rotation: [0, 0, -35]
      scale: [0.06, 0.45, 0.06]
      color: "#1a0c35"
      material: "bone"
    }

    // Belly scales (8 overlapping)
    object "BellyScale1" {
      geometry: "sphere"
      position: [0, -0.5, 0.8]
      scale: [0.5, 0.08, 0.3]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale2" {
      geometry: "sphere"
      position: [0, -0.5, 0.5]
      scale: [0.55, 0.08, 0.3]
      color: "#352260"
      material: "leather"
    }
    object "BellyScale3" {
      geometry: "sphere"
      position: [0, -0.5, 0.2]
      scale: [0.6, 0.08, 0.3]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale4" {
      geometry: "sphere"
      position: [0, -0.5, -0.1]
      scale: [0.55, 0.08, 0.3]
      color: "#352260"
      material: "leather"
    }
    object "BellyScale5" {
      geometry: "sphere"
      position: [0, -0.5, -0.4]
      scale: [0.5, 0.08, 0.3]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale6" {
      geometry: "sphere"
      position: [0, -0.5, -0.7]
      scale: [0.45, 0.08, 0.3]
      color: "#352260"
      material: "leather"
    }
    object "BellyScale7" {
      geometry: "sphere"
      position: [0, -0.45, -1.0]
      scale: [0.4, 0.08, 0.25]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale8" {
      geometry: "sphere"
      position: [0, -0.4, -1.3]
      scale: [0.35, 0.08, 0.2]
      color: "#352260"
      material: "leather"
    }

    // Shoulder plates
    object "LeftShoulderPlate" {
      geometry: "sphere"
      position: [-1.0, 0.5, 0.3]
      scale: [0.5, 0.3, 0.4]
      color: "#3c1f7eff"
      material: "brushed_steel"
      metalness: 0.5
    }
    object "RightShoulderPlate" {
      geometry: "sphere"
      position: [1.0, 0.5, 0.3]
      scale: [0.5, 0.3, 0.4]
      color: "#2a1a50"
      material: "brushed_steel"
      metalness: 0.5
    }
  }

  // ═════════════════════════════════════════════════════════════════════
  //  NECK — 6 vertebrae with spines and underbelly scales
  // ═════════════════════════════════════════════════════════════════════

  object "Neck1" {
    geometry: "cylinder"
    position: [0, 3.1, 1.6]
    rotation: [25, 0, 0]
    scale: [0.45, 0.4, 0.45]
    color: "#1e0f3d"
    material: "skin_dark"
    keyframes "neckWave" {
      0%:   { rotation: [25, -3, 0] }
      50%:  { rotation: [25, 3, 0] }
      100%: { rotation: [25, -3, 0] }
      duration: 5000
      easing: "ease-in-out"
      loop: true
    }
  }
  object "Neck1Spine" {
    geometry: "cone"
    position: [0, 3.4, 1.5]
    scale: [0.06, 0.2, 0.06]
    color: "#ff4400"
    emissive: "#ff2200"
    emissiveIntensity: 0.6
  }
  object "Neck1Scale" {
    geometry: "sphere"
    position: [0, 2.85, 1.7]
    scale: [0.3, 0.06, 0.15]
    color: "#3d2870"
    material: "leather"
  }

  object "Neck2" {
    geometry: "cylinder"
    position: [0, 3.5, 2.1]
    rotation: [20, 0, 0]
    scale: [0.42, 0.38, 0.42]
    color: "#1e0f3d"
    material: "skin_dark"
  }
  object "Neck2Spine" {
    geometry: "cone"
    position: [0, 3.8, 2.0]
    scale: [0.06, 0.22, 0.06]
    color: "#ff4400"
    emissive: "#ff2200"
    emissiveIntensity: 0.6
  }
  object "Neck2Scale" {
    geometry: "sphere"
    position: [0, 3.25, 2.2]
    scale: [0.28, 0.06, 0.14]
    color: "#352260"
    material: "leather"
  }

  object "Neck3" {
    geometry: "cylinder"
    position: [0, 3.8, 2.6]
    rotation: [15, 0, 0]
    scale: [0.4, 0.36, 0.4]
    color: "#1e0f3d"
    material: "skin_dark"
  }
  object "Neck3Spine" {
    geometry: "cone"
    position: [0, 4.1, 2.5]
    scale: [0.06, 0.24, 0.06]
    color: "#ff4400"
    emissive: "#ff2200"
    emissiveIntensity: 0.6
  }

  object "Neck4" {
    geometry: "cylinder"
    position: [0, 4.0, 3.0]
    rotation: [10, 0, 0]
    scale: [0.38, 0.34, 0.38]
    color: "#1e0f3d"
    material: "skin_dark"
  }
  object "Neck4Spine" {
    geometry: "cone"
    position: [0, 4.28, 2.95]
    scale: [0.055, 0.2, 0.055]
    color: "#ff4400"
    emissive: "#ff2200"
    emissiveIntensity: 0.6
  }

  object "Neck5" {
    geometry: "cylinder"
    position: [0, 4.15, 3.4]
    rotation: [5, 0, 0]
    scale: [0.36, 0.32, 0.36]
    color: "#1e0f3d"
    material: "skin_dark"
  }

  object "Neck6" {
    geometry: "cylinder"
    position: [0, 4.25, 3.75]
    rotation: [0, 0, 0]
    scale: [0.35, 0.3, 0.35]
    color: "#251548"
    material: "skin_dark"
  }

  // ═════════════════════════════════════════════════════════════════════
  //  HEAD — Skull, snout, jaw, eyes, teeth, horns, ear fins
  // ═════════════════════════════════════════════════════════════════════

  object "Skull" {
    geometry: "sphere"
