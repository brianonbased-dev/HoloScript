    scale: [0.7, 0.55, 0.8]
    color: "#251548"
    material: "skin_dark"

    keyframes "nod" {
      0%:   { rotation: [0, 0, 0] }
      25%:  { rotation: [-6, 4, 0] }
      50%:  { rotation: [0, 0, 0] }
