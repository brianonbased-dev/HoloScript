      rotation: [180, 0, 0]
      scale: [0.018, 0.08, 0.018]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperTooth4" {
      geometry: "cone"
      position: [0.02, -0.16, 0.83]
      rotation: [180, 0, 0]
      scale: [0.018, 0.08, 0.018]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperTooth5" {
      geometry: "cone"
      position: [0.1, -0.16, 0.8]
      rotation: [180, 0, -3]
      scale: [0.02, 0.1, 0.02]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperFang" {
      geometry: "cone"
      position: [0.18, -0.15, 0.75]
