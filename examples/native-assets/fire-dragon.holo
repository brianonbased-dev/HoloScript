  // ═══════════════════════════════════════════════════════════════════
  //  LEFT WING — Articulated bones + membrane planes
  // ═══════════════════════════════════════════════════════════════════

  object "LeftWingHumerus" {
    geometry: "cylinder"
    position: [-1.6, 3.2, 0.2]
