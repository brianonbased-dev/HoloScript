    }
    object "BrowRight" {
      geometry: "cube"
      position: [0.25, 0.2, 0.35]
      rotation: [0, 0, 15]
      scale: [0.2, 0.06, 0.15]
      color: "#1a0c35"
      material: "bone"
    }

    // ─── LEFT EYE (4 layers) ──────────────────────────────────
    object "LeftEyeSclera" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.35]
      scale: [0.12, 0.09, 0.06]
      color: "#1a0a00"
    }
    object "LeftEyeIris" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.38]
      scale: [0.08, 0.08, 0.04]
      color: "#ff6600"
      emissive: "#ff4400"
      emissiveIntensity: 1.5
    }
    object "LeftEyePupil" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.40]
      scale: [0.04, 0.06, 0.03]
      color: "#000000"
    }


    object "LeftEyeGlow" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.36]
      scale: [0.16, 0.13, 0.08]
      color: "#ff4400"
      emissive: "#ff2200"
      emissiveIntensity: 2.5
      opacity: 0.25
      transparent: true
      keyframes "eyeGlow" {
        0%:   { opacity: 0.2 }
        50%:  { opacity: 0.4 }
        100%: { opacity: 0.2 }
        duration: 3000
        easing: "ease-in-out"
        loop: true
      }
    }

    // ─── RIGHT EYE (4 layers) ─────────────────────────────────
    object "RightEyeSclera" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.35]
      scale: [0.12, 0.09, 0.06]
      color: "#1a0a00"
    }
    object "RightEyeIris" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.38]
      scale: [0.08, 0.08, 0.04]
      color: "#ff6600"
      emissive: "#ff4400"
      emissiveIntensity: 1.5
    }
    object "RightEyePupil" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.40]
      scale: [0.04, 0.06, 0.03]
      color: "#000000"
    }
    object "RightEyeGlow" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.36]
      scale: [0.16, 0.13, 0.08]
      color: "#ff4400"
      emissive: "#ff2200"
      emissiveIntensity: 2.5
      opacity: 0.25
      transparent: true
      keyframes "eyeGlow" {
        0%:   { opacity: 0.2 }
        50%:  { opacity: 0.4 }
        100%: { opacity: 0.2 }
        duration: 3000
        easing: "ease-in-out"
        loop: true
      }
    }

    // Nostrils
    object "LeftNostril" {
      geometry: "sphere"
      position: [-0.1, 0.02, 0.85]
      scale: [0.06, 0.04, 0.04]
      color: "#0a0520"
      emissive: "#ff2200"
      emissiveIntensity: 0.8
    }
    object "RightNostril" {
      geometry: "sphere"
      position: [0.1, 0.02, 0.85]
      scale: [0.06, 0.04, 0.04]
      color: "#0a0520"
      emissive: "#ff2200"
      emissiveIntensity: 0.8
    }

    // Ear fins
    object "LeftEarFin" {
      geometry: "cone"
