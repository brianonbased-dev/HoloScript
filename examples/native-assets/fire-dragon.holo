// ═══════════════════════════════════════════════════════════════════════════
// INFERNO WYRM — Ultimate HoloScript Dragon (1300+ lines)
// ═══════════════════════════════════════════════════════════════════════════
// 200+ primitives · 15 animation sequences · 5-layer fire breath
// Full anatomical detail: individual teeth, multi-layered eyes,
// segmented horns, articulated wings, scale armor
// ═══════════════════════════════════════════════════════════════════════════

composition "Inferno Wyrm" {

  // ─── Environment ──────────────────────────────────────────────────────
  environment {
    skybox: "night"
    fog_density: 0.015
    ambient_color: "#0d0520"
    background: "#050210"
  }

  // ═════════════════════════════════════════════════════════════════════
  //  BODY CORE — Triple-sphere organic torso
  // ═════════════════════════════════════════════════════════════════════

  object "TorsoHull" @physics {
    geometry: "hull"
    position: [0, 2.5, 0]
    blobs: [
      { center: [0, 0, 0], radius: [0.9, 0.6, 1.2] },
      { center: [0, 0.3, 0.5], radius: [0.75, 0.5, 0.8] },
      { center: [0, -0.2, -0.3], radius: [0.7, 0.45, 0.75] },
      { center: [0, 0.45, 0.1], radius: [0.35, 0.2, 0.9] },
      { center: [0, -0.35, 0.4], radius: [0.65, 0.18, 0.6] },
      { center: [-0.5, 0.0, 0.1], radius: [0.3, 0.4, 0.7] },
      { center: [0.5, 0.0, 0.1], radius: [0.3, 0.4, 0.7] }
    ]
    resolution: 48
    threshold: 1.0
    color: "#1e0f3d"
    material: "skin_dark"
    roughness: 0.7
    metalness: 0.05

    keyframes "breathe" {
      0%:   { scale: [1.0, 1.0, 1.0] }
      50%:  { scale: [1.05, 1.07, 1.04] }
      100%: { scale: [1.0, 1.0, 1.0] }
      duration: 4000
      easing: "ease-in-out"
      loop: true
    }

    // Chest plate — armored
    object "ChestPlate" {
      geometry: "cube"
      position: [0, -0.1, 0.9]
      scale: [0.9, 0.7, 0.3]
      color: "#2a1a50"
      material: "brushed_steel"
      metalness: 0.6
      roughness: 0.3
    }

    // Ribcage detail left
    object "RibLeft1" {
      geometry: "cylinder"
      position: [-0.7, 0, 0.3]
      rotation: [0, 0, 30]
      scale: [0.06, 0.5, 0.06]
      color: "#1a0c35"
      material: "bone"
    }
    object "RibLeft2" {
      geometry: "cylinder"
      position: [-0.65, 0, 0]
      rotation: [0, 0, 35]
      scale: [0.06, 0.45, 0.06]
      color: "#1a0c35"
      material: "bone"
    }
    object "RibRight1" {
      geometry: "cylinder"
      position: [0.7, 0, 0.3]
      rotation: [0, 0, -30]
      scale: [0.06, 0.5, 0.06]
      color: "#1a0c35"
      material: "bone"
    }
    object "RibRight2" {
      geometry: "cylinder"
      position: [0.65, 0, 0]
      rotation: [0, 0, -35]
      scale: [0.06, 0.45, 0.06]
      color: "#1a0c35"
      material: "bone"
    }

    // Belly scales (8 overlapping)
    object "BellyScale1" {
      geometry: "sphere"
      position: [0, -0.5, 0.8]
      scale: [0.5, 0.08, 0.3]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale2" {
      geometry: "sphere"
      position: [0, -0.5, 0.5]
      scale: [0.55, 0.08, 0.3]
      color: "#352260"
      material: "leather"
    }
    object "BellyScale3" {
      geometry: "sphere"
      position: [0, -0.5, 0.2]
      scale: [0.6, 0.08, 0.3]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale4" {
      geometry: "sphere"
      position: [0, -0.5, -0.1]
      scale: [0.55, 0.08, 0.3]
      color: "#352260"
      material: "leather"
    }
    object "BellyScale5" {
      geometry: "sphere"
      position: [0, -0.5, -0.4]
      scale: [0.5, 0.08, 0.3]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale6" {
      geometry: "sphere"
      position: [0, -0.5, -0.7]
      scale: [0.45, 0.08, 0.3]
      color: "#352260"
      material: "leather"
    }
    object "BellyScale7" {
      geometry: "sphere"
      position: [0, -0.45, -1.0]
      scale: [0.4, 0.08, 0.25]
      color: "#3d2870"
      material: "leather"
    }
    object "BellyScale8" {
      geometry: "sphere"
      position: [0, -0.4, -1.3]
      scale: [0.35, 0.08, 0.2]
      color: "#352260"
      material: "leather"
    }

    // Shoulder plates
    object "LeftShoulderPlate" {
      geometry: "sphere"
      position: [-1.0, 0.5, 0.3]
      scale: [0.5, 0.3, 0.4]
      color: "#3c1f7eff"
      material: "brushed_steel"
      metalness: 0.5
    }
    object "RightShoulderPlate" {
      geometry: "sphere"
      position: [1.0, 0.5, 0.3]
      scale: [0.5, 0.3, 0.4]
      color: "#2a1a50"
      material: "brushed_steel"
      metalness: 0.5
    }
  }

  // ═════════════════════════════════════════════════════════════════════
  //  NECK — 6 vertebrae with spines and underbelly scales
  // ═════════════════════════════════════════════════════════════════════

  object "NeckSpline" {
    geometry: "spline"
    position: [0, 0, 0]
    points: [[0, 3.1, 1.6], [0, 3.5, 2.1], [0, 3.8, 2.6], [0, 4.0, 3.0], [0, 4.15, 3.4], [0, 4.25, 3.75]]
    radii: [0.45, 0.42, 0.40, 0.38, 0.36, 0.35]
    color: "#1e0f3d"
    material: "skin_dark"
    keyframes "neckWave" {
      0%:   { rotation: [0, -3, 0] }
      50%:  { rotation: [0, 3, 0] }
      100%: { rotation: [0, -3, 0] }
      duration: 5000
      easing: "ease-in-out"
      loop: true
    }
  }
  // Neck spines (along the top of the spline)
  object "NeckSpine1" { geometry: "cone" position: [0, 3.4, 1.5] scale: [0.06, 0.2, 0.06] color: "#ff4400" emissive: "#ff2200" emissiveIntensity: 0.6 }
  object "NeckSpine2" { geometry: "cone" position: [0, 3.8, 2.0] scale: [0.06, 0.22, 0.06] color: "#ff4400" emissive: "#ff2200" emissiveIntensity: 0.6 }
  object "NeckSpine3" { geometry: "cone" position: [0, 4.1, 2.5] scale: [0.06, 0.24, 0.06] color: "#ff4400" emissive: "#ff2200" emissiveIntensity: 0.6 }
  object "NeckSpine4" { geometry: "cone" position: [0, 4.28, 2.95] scale: [0.055, 0.2, 0.055] color: "#ff4400" emissive: "#ff2200" emissiveIntensity: 0.6 }
  // Neck underbelly scales
  object "NeckScale1" { geometry: "sphere" position: [0, 2.85, 1.7] scale: [0.3, 0.06, 0.15] color: "#3d2870" material: "leather" }
  object "NeckScale2" { geometry: "sphere" position: [0, 3.25, 2.2] scale: [0.28, 0.06, 0.14] color: "#352260" material: "leather" }

  // ═════════════════════════════════════════════════════════════════════
  //  HEAD — Skull, snout, jaw, eyes, teeth, horns, ear fins
  // ═════════════════════════════════════════════════════════════════════

  object "SkullHull" {
    geometry: "hull"
    position: [0, 4.5, 4.2]
    blobs: [
      { center: [0, 0, 0], radius: [0.35, 0.275, 0.40] },
      { center: [0, -0.05, 0.55], radius: [0.225, 0.175, 0.30] },
      { center: [-0.25, 0.2, 0.35], radius: [0.10, 0.03, 0.075] },
      { center: [0.25, 0.2, 0.35], radius: [0.10, 0.03, 0.075] }
    ]
    resolution: 48
    threshold: 1.0
    color: "#251548"
    material: "skin_dark"

    keyframes "nod" {
      0%:   { rotation: [0, 0, 0] }
      25%:  { rotation: [-6, 4, 0] }
      50%:  { rotation: [0, 0, 0] }
      75%:  { rotation: [-4, -4, 0] }
      100%: { rotation: [0, 0, 0] }
      duration: 6000
      easing: "ease-in-out"
      loop: true
    }

    // ─── LEFT EYE (4 layers) ──────────────────────────────────
    object "LeftEyeSclera" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.35]
      scale: [0.12, 0.09, 0.06]
      color: "#1a0a00"
    }
    object "LeftEyeIris" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.38]
      scale: [0.08, 0.08, 0.04]
      color: "#ff6600"
      emissive: "#ff4400"
      emissiveIntensity: 1.5
    }
    object "LeftEyePupil" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.40]
      scale: [0.04, 0.06, 0.03]
      color: "#000000"
    }


    object "LeftEyeGlow" {
      geometry: "sphere"
      position: [-0.28, 0.12, 0.36]
      scale: [0.16, 0.13, 0.08]
      color: "#ff4400"
      emissive: "#ff2200"
      emissiveIntensity: 2.5
      opacity: 0.25
      transparent: true
      keyframes "eyeGlow" {
        0%:   { opacity: 0.2 }
        50%:  { opacity: 0.4 }
        100%: { opacity: 0.2 }
        duration: 3000
        easing: "ease-in-out"
        loop: true
      }
    }

    // ─── RIGHT EYE (4 layers) ─────────────────────────────────
    object "RightEyeSclera" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.35]
      scale: [0.12, 0.09, 0.06]
      color: "#1a0a00"
    }
    object "RightEyeIris" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.38]
      scale: [0.08, 0.08, 0.04]
      color: "#ff6600"
      emissive: "#ff4400"
      emissiveIntensity: 1.5
    }
    object "RightEyePupil" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.40]
      scale: [0.04, 0.06, 0.03]
      color: "#000000"
    }
    object "RightEyeGlow" {
      geometry: "sphere"
      position: [0.28, 0.12, 0.36]
      scale: [0.16, 0.13, 0.08]
      color: "#ff4400"
      emissive: "#ff2200"
      emissiveIntensity: 2.5
      opacity: 0.25
      transparent: true
      keyframes "eyeGlow" {
        0%:   { opacity: 0.2 }
        50%:  { opacity: 0.4 }
        100%: { opacity: 0.2 }
        duration: 3000
        easing: "ease-in-out"
        loop: true
      }
    }

    // Nostrils
    object "LeftNostril" {
      geometry: "sphere"
      position: [-0.1, 0.02, 0.85]
      scale: [0.06, 0.04, 0.04]
      color: "#0a0520"
      emissive: "#ff2200"
      emissiveIntensity: 0.8
    }
    object "RightNostril" {
      geometry: "sphere"
      position: [0.1, 0.02, 0.85]
      scale: [0.06, 0.04, 0.04]
      color: "#0a0520"
      emissive: "#ff2200"
      emissiveIntensity: 0.8
    }

    // Ear fins
    object "LeftEarFin" {
      geometry: "cone"
      position: [-0.4, 0.15, -0.1]
      rotation: [0, 0, -60]
      scale: [0.15, 0.35, 0.03]
      color: "#cc2200"
      material: "leather"
      opacity: 0.7
      transparent: true
    }
    object "RightEarFin" {
      geometry: "cone"
      position: [0.4, 0.15, -0.1]
      rotation: [0, 0, 60]
      scale: [0.15, 0.35, 0.03]
      color: "#cc2200"
      material: "leather"
      opacity: 0.7
      transparent: true
    }

    // ─── UPPER TEETH (6) ──────────────────────────────────────
    object "UpperTooth1" {
      geometry: "cone"
      position: [-0.18, -0.15, 0.75]
      rotation: [180, 0, 5]
      scale: [0.025, 0.12, 0.025]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperTooth2" {
      geometry: "cone"
      position: [-0.1, -0.16, 0.8]
      rotation: [180, 0, 3]
      scale: [0.02, 0.1, 0.02]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperTooth3" {
      geometry: "cone"
      position: [-0.02, -0.16, 0.83]
      rotation: [180, 0, 0]
      scale: [0.018, 0.08, 0.018]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperTooth4" {
      geometry: "cone"
      position: [0.02, -0.16, 0.83]
      rotation: [180, 0, 0]
      scale: [0.018, 0.08, 0.018]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperTooth5" {
      geometry: "cone"
      position: [0.1, -0.16, 0.8]
      rotation: [180, 0, -3]
      scale: [0.02, 0.1, 0.02]
      color: "#f5f0e0"
      material: "bone"
    }
    object "UpperFang" {
      geometry: "cone"
      position: [0.18, -0.15, 0.75]
      rotation: [180, 0, -5]
      scale: [0.025, 0.12, 0.025]
      color: "#f5f0e0"
      material: "bone"
    }

    // ─── HORNS — Smooth spline tubes ──────────────────────────
    object "LeftHorn" {
      geometry: "spline"
      position: [0, 0, 0]
      points: [[-0.3, 0.35, -0.15], [-0.42, 0.55, -0.22], [-0.55, 0.75, -0.3]]
      radii: [0.08, 0.05, 0.02]
      color: "#0d0520"
      material: "bone"
      roughness: 0.2
      metalness: 0.4
    }
    object "RightHorn" {
      geometry: "spline"
      position: [0, 0, 0]
      points: [[0.3, 0.35, -0.15], [0.42, 0.55, -0.22], [0.55, 0.75, -0.3]]
      radii: [0.08, 0.05, 0.02]
      color: "#0d0520"
      material: "bone"
      roughness: 0.2
      metalness: 0.4
    }

    // Crown horns (4 smaller)
    object "CrownHorn1" {
      geometry: "cone"
      position: [-0.15, 0.4, 0]
      rotation: [5, 0, -10]
      scale: [0.03, 0.12, 0.03]
      color: "#0d0520"
      material: "bone"
    }
    object "CrownHorn2" {
      geometry: "cone"
      position: [0.15, 0.4, 0]
      rotation: [5, 0, 10]
      scale: [0.03, 0.12, 0.03]
      color: "#0d0520"
      material: "bone"
    }
    object "CrownHorn3" {
      geometry: "cone"
      position: [-0.08, 0.42, -0.1]
      rotation: [10, 0, -5]
      scale: [0.025, 0.1, 0.025]
      color: "#0d0520"
      material: "bone"
    }
    object "CrownHorn4" {
      geometry: "cone"
      position: [0.08, 0.42, -0.1]
      rotation: [10, 0, 5]
      scale: [0.025, 0.1, 0.025]
      color: "#0d0520"
      material: "bone"
    }
  }

  // ─── JAW (separate for animation) ─────────────────────────────────
  object "Jaw" {
    geometry: "cube"
    position: [0, 4.2, 4.6]
    scale: [0.5, 0.18, 0.45]
    color: "#2a1a50"
    material: "skin_dark"

    keyframes "chomp" {
      0%:   { rotation: [0, 0, 0] }
      20%:  { rotation: [-20, 0, 0] }
      50%:  { rotation: [-20, 0, 0] }
      80%:  { rotation: [0, 0, 0] }
      100%: { rotation: [0, 0, 0] }
      duration: 3000
      easing: "ease-in-out"
      loop: true
    }

    // Lower teeth (6)
    object "LowerTooth1" {
      geometry: "cone"
      position: [-0.35, 0.12, 0.3]
      scale: [0.025, 0.1, 0.025]
      color: "#f5f0e0"
      material: "bone"
    }
    object "LowerTooth2" {
      geometry: "cone"
      position: [-0.2, 0.12, 0.38]
      scale: [0.02, 0.08, 0.02]
      color: "#f5f0e0"
      material: "bone"
    }
    object "LowerTooth3" {
      geometry: "cone"
      position: [-0.05, 0.12, 0.42]
      scale: [0.018, 0.07, 0.018]
      color: "#f5f0e0"
      material: "bone"
    }
    object "LowerTooth4" {
      geometry: "cone"
      position: [0.05, 0.12, 0.42]
      scale: [0.018, 0.07, 0.018]
      color: "#f5f0e0"
      material: "bone"
    }
    object "LowerTooth5" {
      geometry: "cone"
      position: [0.2, 0.12, 0.38]
      scale: [0.02, 0.08, 0.02]
      color: "#f5f0e0"
      material: "bone"
    }
    object "LowerFang" {
      geometry: "cone"
      position: [0.35, 0.12, 0.3]
      scale: [0.025, 0.1, 0.025]
      color: "#f5f0e0"
      material: "bone"
    }

    // Tongue
    object "Tongue" {
      geometry: "sphere"
      position: [0, 0.05, 0.2]
      scale: [0.2, 0.04, 0.3]
      color: "#8b2252"
      material: "skin_pale"
    }
  }

  // ═══════════════════════════════════════════════════════════════════
  //  LEFT WING — Articulated bones + membrane planes
  // ═══════════════════════════════════════════════════════════════════

  // Left wing main bone (shoulder to elbow to wrist — smooth spline)
  object "LeftWingBone" {
    geometry: "spline"
    position: [0, 0, 0]
    points: [[-1.2, 3.0, 0.2], [-1.6, 3.2, 0.2], [-2.2, 3.5, 0.2], [-2.6, 3.8, 0.2]]
    radii: [0.12, 0.10, 0.08, 0.07]
    color: "#1a0c35"
    material: "bone"
    keyframes "flapLeft" {
      0%:   { rotation: [0, 0, -5] }
      50%:  { rotation: [0, 0, 5] }
      100%: { rotation: [0, 0, -5] }
      duration: 2000
      easing: "ease-in-out"
      loop: true
    }
  }
  // Left wing fingers (4 spline "finger bones" radiating from wrist)
  object "LeftWingFinger1" {
    geometry: "spline"
    position: [0, 0, 0]
    points: [[-2.6, 3.8, 0.2], [-3.0, 4.1, 0.3], [-3.4, 4.3, 0.3], [-3.8, 4.5, 0.3]]
    radii: [0.06, 0.04, 0.03, 0.02]
    color: "#0d0520"
    material: "bone"
  }
  object "LeftWingFinger2" {
    geometry: "spline"
    position: [0, 0, 0]
    points: [[-2.6, 3.8, 0.2], [-3.0, 3.9, 0.1], [-3.3, 4.0, 0.1], [-3.6, 4.1, 0.0]]
    radii: [0.06, 0.04, 0.03, 0.02]
    color: "#0d0520"
    material: "bone"
  }
  object "LeftWingFinger3" {
    geometry: "spline"
    position: [0, 0, 0]
    points: [[-2.6, 3.8, 0.2], [-2.9, 3.7, -0.0], [-3.1, 3.7, -0.1], [-3.4, 3.6, -0.2]]
    radii: [0.06, 0.04, 0.03, 0.02]
    color: "#0d0520"
    material: "bone"
  }
  object "LeftWingFinger4" {
    geometry: "spline"
    position: [0, 0, 0]
    points: [[-2.6, 3.8, 0.2], [-2.7, 3.5, -0.1], [-2.8, 3.4, -0.3], [-2.9, 3.2, -0.4]]
    radii: [0.06, 0.04, 0.03, 0.02]
    color: "#0d0520"
    material: "bone"
  }
  // Left wing membrane — primary loft
  object "LeftWingMembrane" {
    geometry: "membrane"
    position: [0, 0, 0]
    anchors: [[-1.2, 2.8, -0.2], [-1.6, 3.2, 0.2], [-2.6, 3.8, 0.2], [-3.8, 4.5, 0.3], [-3.6, 4.1, 0.0], [-3.4, 3.6, -0.2], [-2.9, 3.2, -0.4]]
    subdivisions: 20
    bulge: 0.18
    color: "#4a1525"
    emissive: "#330a0a"
    emissiveIntensity: 0.5
    opacity: 0.8
    transparent: true
  }
  // Left wing sub-membranes (between each pair of finger bones)
  object "LeftSubMembrane12" {
    geometry: "membrane"
    position: [0, 0, 0]
    anchors: [[-2.6, 3.8, 0.2], [-3.2, 4.2, 0.3], [-3.8, 4.5, 0.3], [-3.6, 4.1, 0.0], [-3.15, 3.95, 0.1]]
    subdivisions: 12
    bulge: 0.12
    color: "#3d1020"
    emissive: "#220505"
    emissiveIntensity: 0.4
    opacity: 0.75
    transparent: true
  }
  object "LeftSubMembrane23" {
    geometry: "membrane"
    position: [0, 0, 0]
    anchors: [[-2.6, 3.8, 0.2], [-3.15, 3.95, 0.1], [-3.6, 4.1, 0.0], [-3.4, 3.6, -0.2], [-3.0, 3.7, -0.05]]
    subdivisions: 12
    bulge: 0.10
    color: "#3d1020"
    emissive: "#220505"
    emissiveIntensity: 0.35
    opacity: 0.7
    transparent: true
  }
  object "LeftSubMembrane34" {
    geometry: "membrane"
    position: [0, 0, 0]
    anchors: [[-2.6, 3.8, 0.2], [-3.0, 3.7, -0.05], [-3.4, 3.6, -0.2], [-2.9, 3.2, -0.4], [-2.75, 3.5, -0.1]]
    subdivisions: 12
