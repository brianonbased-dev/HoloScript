      easing: "ease-in-out"
      loop: true
    }

    // Snout
    object "Snout" {
      geometry: "sphere"
      position: [0, -0.05, 0.55]
      scale: [0.45, 0.35, 0.6]
      color: "#2a1a50"
      material: "skin_dark"
