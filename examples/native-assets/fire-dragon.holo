  // ═══════════════════════════════════════════════════════════════════
  //  FIRE BREATH — 9-layer volumetric flame with tendrils
  // ═══════════════════════════════════════════════════════════════════

  // Layer 1: White-hot core — wider, brighter
  object "FireCore" {
    geometry: "cone"
    position: [0, 4.35, 5.5]
    rotation: [90, 0, 0]
    scale: [0.25, 2.2, 0.25]
    color: "#ffffff"
    emissive: "#ffffdd"
    emissiveIntensity: 8.0
    opacity: 0.95
    transparent: true

    keyframes "firePulse" {
      0%:   { scale: [0.25, 2.2, 0.25] }
      25%:  { scale: [0.30, 2.5, 0.30] }
      50%:  { scale: [0.20, 1.9, 0.20] }
      75%:  { scale: [0.28, 2.3, 0.28] }
      100%: { scale: [0.25, 2.2, 0.25] }
      duration: 400
      easing: "linear"
      loop: true
    }
  }

  // Layer 2: Inner orange — wider spread
  object "FireInner" {
    geometry: "cone"
    position: [0, 4.35, 5.8]
