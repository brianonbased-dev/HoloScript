    }
    object "RightEarFin" {
      geometry: "cone"
      position: [0.4, 0.15, -0.1]
      rotation: [0, 0, 60]
      scale: [0.15, 0.35, 0.03]
      color: "#cc2200"
      material: "leather"
      opacity: 0.7
      transparent: true
    }

    // ─── UPPER TEETH (6) ──────────────────────────────────────
    object "UpperTooth1" {
