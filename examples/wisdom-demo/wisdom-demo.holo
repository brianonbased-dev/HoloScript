composition "Wisdom & Gotcha Demo" {

  // ─────────────────────────────────────────────────────────────────────────
  //  @wisdom — Captures battle-tested patterns as self-documenting atoms
  //  @gotcha — Captures known failure modes, severity, and mitigations
  //
  //  This composition is the reference for both meta-traits.
  //  See proposals/WISDOM_AND_GOTCHA_TRAITS_v1.md for the full RFC.
  // ─────────────────────────────────────────────────────────────────────────

  environment {
    skybox: "gradient"
    ambient_light: 0.4
    shadows: true
    gravity: 9.81
  }

  light "KeyLight" {
    type: "directional"
    color: "#ffffff"
    intensity: 0.9
    position: [3, 8, 5]
    cast_shadows: true
  }

  post_processing {
    bloom: { enabled: true, intensity: 0.15, threshold: 0.8 }
    tone_mapping: { type: "aces", exposure: 1.0 }
  }

  // ── 1. DECLARATIVE / IMPERATIVE SEPARATION WISDOM ────────────────────────

  template "InteractiveObject" {
    @grabbable
    @collidable
    @state { quality: 0 }

    @wisdom {
      description: "Declare WHAT objects are (.holo) separately from HOW they behave (.hsplus). Trust the compiler for cross-platform portability."
      source: "community"
      applies_to: ["category:all"]
    }
  }

  // ── 2. TREASURY — GOTCHA: rate-limit critical on-chain calls ─────────────

  object "SharedTreasury" using "InteractiveObject" {
    @credit { balance: 10000 }
    @escrow
    @dao_proposal
    @rate_limit { per_minute: 5 }

    position: [0, 1, 0]
    geometry: "cube"
    material: { baseColor: "#ffd700", roughness: 0.3, metallic: 0.9 }

    @wisdom {
      description: "Escrow + credit + DAO prevents double-spend and griefing in shared treasuries"
      source: "https://github.com/brianonbased-dev/Holoscript/commit/e48fb50"
      applies_to: [@credit, @escrow, @dao_proposal]
    }

    @gotcha {
      warning: "Without rate limiting, treasury can be drained in under 60 seconds via rapid onClick"
      severity: "critical"
      mitigation: "@rate_limit { per_minute: 5 }"
      triggers_on: [onClick]
    }
  }

  // ── 3. MULTIPLAYER BALL — GOTCHA: CRDT required for shared state ─────────

  object "SharedBall" {
    @grabbable
    @networked
    @crdt
    geometry: "sphere"
    position: [2, 1.5, 0]
    color: "#00ffcc"

    @networked position
    @networked rotation

    @wisdom {
      description: "Always pair @networked with @crdt on any object with mutable shared state"
      source: "community"
      applies_to: [@networked, @state]
    }

    @gotcha {
      warning: "Concurrent edits without CRDT state corrupt shared worlds under contention"
      severity: "critical"
      mitigation: "@crdt on any shared object"
      triggers_on: [state_write]
    }

    onGrab: {
      network.claim(this)
      network.sync(this.position, this.rotation)
      haptic.feedback("medium")
    }
  }

  // ── 4. HOT-RELOAD PAD — GOTCHA: debounce required ────────────────────────

  object "ReloadPad" {
    @pointable
    geometry: "cylinder"
    scale: [0.6, 0.05, 0.6]
    position: [-2, 0, 2]
    color: "#3399ff"

    @gotcha {
      warning: "Hot-reload without debounce causes thrashing and corrupts scene state on rapid saves"
      severity: "warning"
      mitigation: "debounce_ms: 300, on_reload: 'soft'"
      triggers_on: [hot_reload]
    }

    onPoint: {
      scene.reload({ debounce_ms: 300, on_reload: "soft" })
    }
  }

  // ── 5. AI AGENT NPC — GOTCHA: wrap MCP calls in circuit breaker ──────────

  object "GuardianAgent" {
    @npc
    @llm_agent
    @protocol
    @knowledge
    @circuit_breaker { max_failures: 3, reset_ms: 5000 }
    geometry: "capsule"
    position: [0, 1, -3]
    color: "#ff6600"

    @wisdom {
      description: "Always pair @llm_agent with both @protocol and @knowledge to prevent orphan AI behaviors"
      source: "community"
      applies_to: [@llm_agent, @protocol, @knowledge]
    }

    @gotcha {
      warning: "MCP/AI tool calls can fail silently — unguarded failures cause agents to freeze or hallucinate actions"
      severity: "warning"
      mitigation: "@circuit_breaker with retry and fallback on every MCP call"
      triggers_on: [mcp_call]
    }
  }

  // ── 6. PLUGIN ZONE — GOTCHA: untrusted plugins must be sandboxed ─────────

  object "PluginPortal" {
    @collidable
    @security_sandbox
    geometry: "torus"
    position: [3, 1.5, -2]
    color: "#cc00ff"

    @gotcha {
      warning: "Untrusted plugins without sandbox risk arbitrary code execution in the scene runtime"
      severity: "critical"
      mitigation: "@security_sandbox on all external plugin entry points"
      triggers_on: [plugin_load]
    }

    onTriggerEnter: {
      audio.play("portal-hum.mp3")
    }
  }

  // ── 7. TEST HARNESS MARKER — THE_BIGGEST_GOTCHA ──────────────────────────

  object "TestMarker" {
    @script_test
    geometry: "plane"
    position: [0, 0, 3]
    scale: [1, 0.01, 1]
    color: "#ffff00"

    @gotcha {
      warning: "THE_BIGGEST_GOTCHA: External test harnesses decouple validation from the runtime. Use @script_test blocks to keep tests in-scene."
      severity: "critical"
      mitigation: "@script_test inline blocks"
      triggers_on: [test_run]
    }
  }

  // ── LOGIC ─────────────────────────────────────────────────────────────────

  logic {
    on_scene_load() {
      // Wisdom and gotcha annotations are available to MCP/Studio/LSP at load time
      console.log("Wisdom & Gotcha demo loaded — all atoms are visible.")
    }
  }

}
