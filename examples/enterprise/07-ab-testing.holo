/**
 * A/B Testing — HoloScript v5.0 Enterprise Example
 *
 * Demonstrates multi-variate testing with ABTestTrait.
 * This example shows:
 *  - A/B test creation and management
 *  - User assignment to variants
 *  - Statistical significance calculation
 *  - Automatic winner selection
 *  - Conversion tracking
 *  - Gradual rollout
 *
 * Use Case: Feature Experimentation
 *   - Test new features before full launch
 *   - Optimize UI/UX with data
 *   - Measure conversion impact
 *   - Make data-driven decisions
 *
 * Run this example:
 *   holoc examples/enterprise/07-ab-testing.holo --target r3f
 *
 * @version 5.0.0
 */

scene ExperimentationPlatform {
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // A/B TEST CONFIGURATION
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity ABTestManager {
    traits: [ab_test];

    ab_test: {
      // Statistical configuration
      minSampleSize: 1000,           // Minimum users per variant
      confidenceLevel: 0.95,         // 95% confidence for significance
      minimumDetectableEffect: 0.05, // 5% MDE

      // Auto-winner selection
      autoSelectWinner: true,
      autoSelectThreshold: 0.99,     // 99% confidence for auto-selection

      // Assignment strategy
      assignmentStrategy: "consistent_hash", // Same user always gets same variant

      // Tracking
      trackingEnabled: true,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Experiment Lifecycle
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(ABTestManager, "experiment_created") {
    log("🧪 Experiment created");
    log(`  ID: ${event.experimentId}`);
    log(`  Name: ${event.name}`);
    log(`  Variants: ${event.variants.join(", ")}`);
    log(`  Traffic allocation: ${JSON.stringify(event.allocation)}`);
    log(`  Start date: ${event.startDate}`);
    log(`  End date: ${event.endDate || "open-ended"}`);
  }

  on(ABTestManager, "experiment_started") {
    log(`▶️  Experiment started: ${event.experimentId}`);
    log(`  Active variants: ${event.activeVariants.join(", ")}`);
  }

  on(ABTestManager, "experiment_paused") {
    log(`⏸️  Experiment paused: ${event.experimentId}`);
    log(`  Reason: ${event.reason}`);
  }

  on(ABTestManager, "experiment_resumed") {
    log(`▶️  Experiment resumed: ${event.experimentId}`);
  }

  on(ABTestManager, "experiment_completed") {
    log(`✅ Experiment completed: ${event.experimentId}`);
    log(`  Duration: ${event.durationDays} days`);
    log(`  Total participants: ${event.totalParticipants}`);
    log(`  Winner: ${event.winner || "inconclusive"}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — User Assignment
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(ABTestManager, "user_assigned") {
    log(`👤 User assigned to variant`);
    log(`  User: ${event.userId}`);
    log(`  Experiment: ${event.experimentId}`);
    log(`  Variant: ${event.variant}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Conversion Tracking
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(ABTestManager, "conversion_tracked") {
    log(`🎯 Conversion tracked`);
    log(`  Experiment: ${event.experimentId}`);
    log(`  Variant: ${event.variant}`);
    log(`  User: ${event.userId}`);
    log(`  Metric: ${event.metric}`);
    log(`  Value: ${event.value}`);
  }

  on(ABTestManager, "metric_updated") {
    log(`📊 Experiment metrics updated`);
    log(`  Experiment: ${event.experimentId}`);
    log(`  Variant: ${event.variant}`);
    log(`  Conversion rate: ${(event.conversionRate * 100).toFixed(2)}%`);
    log(`  Sample size: ${event.sampleSize}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Statistical Significance
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(ABTestManager, "significance_calculated") {
    log(`📈 Statistical significance calculated`);
    log(`  Experiment: ${event.experimentId}`);
    log(`  p-value: ${event.pValue.toFixed(4)}`);
    log(`  Significant: ${event.isSignificant ? "YES" : "NO"}`);
    log(`  Confidence: ${(event.confidence * 100).toFixed(1)}%`);
    log(`  Effect size: ${(event.effectSize * 100).toFixed(2)}%`);
  }

  on(ABTestManager, "winner_declared") {
    log(`🏆 WINNER DECLARED!`);
    log(`  Experiment: ${event.experimentId}`);
    log(`  Winner: ${event.winner}`);
    log(`  Control conversion: ${(event.controlConversion * 100).toFixed(2)}%`);
    log(`  Winner conversion: ${(event.winnerConversion * 100).toFixed(2)}%`);
    log(`  Improvement: +${(event.improvement * 100).toFixed(2)}%`);
    log(`  Confidence: ${(event.confidence * 100).toFixed(1)}%`);
    log(`  Recommendation: Roll out ${event.winner} to 100% of users`);
  }

  on(ABTestManager, "inconclusive_result") {
    log(`⚠️  Experiment inconclusive`);
    log(`  Experiment: ${event.experimentId}`);
    log(`  Reason: ${event.reason}`);
    log(`  Recommendation: ${event.recommendation}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DEMO CONTROLS
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity DemoControls {
    traits: [interactive];
  }

  // Demo 1: Create A/B test (button color experiment)
  on(DemoControls, "click") {
    if (event.target === "create_button_color_test") {
      emit(ABTestManager, "create_experiment", {
        name: "CTA Button Color Test",
        description: "Test blue vs green call-to-action button",
        hypothesis: "Green button will increase click-through rate by 10%",
        variants: [
          { id: "control", name: "Blue Button", allocation: 0.5 },
          { id: "variant_green", name: "Green Button", allocation: 0.5 },
        ],
        metric: "button_click_rate",
        startDate: new Date().toISOString(),
        endDate: null,  // Run until statistically significant
      });
      log("🧪 Creating button color experiment...");
    }
  }

  // Demo 2: Create multi-variate test (layout optimization)
  on(DemoControls, "click") {
    if (event.target === "create_layout_test") {
      emit(ABTestManager, "create_experiment", {
        name: "Dashboard Layout Optimization",
        description: "Test 3 different dashboard layouts",
        hypothesis: "Vertical layout will increase engagement time",
        variants: [
          { id: "control", name: "Grid Layout", allocation: 0.34 },
          { id: "variant_vertical", name: "Vertical Layout", allocation: 0.33 },
          { id: "variant_sidebar", name: "Sidebar Layout", allocation: 0.33 },
        ],
        metric: "engagement_time",
        startDate: new Date().toISOString(),
      });
      log("🧪 Creating layout experiment...");
    }
  }

  // Demo 3: Assign user to experiment
  on(DemoControls, "click") {
    if (event.target === "assign_user_button") {
      emit(ABTestManager, "assign_user", {
        experimentId: "exp_button_color_001",
        userId: "user_alice",
      });
      log("👤 Assigning user to experiment...");
    }
  }

  // Demo 4: Track conversion (button click)
  on(DemoControls, "click") {
    if (event.target === "track_click_button") {
      emit(ABTestManager, "track_conversion", {
        experimentId: "exp_button_color_001",
        userId: "user_alice",
        variant: "variant_green",
        metric: "button_click_rate",
        value: 1,  // Binary conversion (0 or 1)
      });
      log("🎯 Tracking button click conversion...");
    }
  }

  // Demo 5: Track metric value (engagement time)
  on(DemoControls, "click") {
    if (event.target === "track_engagement_button") {
      emit(ABTestManager, "track_conversion", {
        experimentId: "exp_layout_001",
        userId: "user_bob",
        variant: "variant_vertical",
        metric: "engagement_time",
        value: 342,  // 342 seconds of engagement
      });
      log("⏱️  Tracking engagement time...");
    }
  }

  // Demo 6: Get experiment results
  on(DemoControls, "click") {
    if (event.target === "get_results_button") {
      emit(ABTestManager, "get_results", {
        experimentId: "exp_button_color_001",
      });
      log("📊 Getting experiment results...");
    }
  }

  on(ABTestManager, "experiment_results") {
    log("📊 EXPERIMENT RESULTS");
    log("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    log(`  Experiment: ${event.experimentName}`);
    log(`  Status: ${event.status}`);
    log("");
    for (const variant of event.variants) {
      log(`  ${variant.name}:`);
      log(`    Participants: ${variant.participants}`);
      log(`    Conversions: ${variant.conversions}`);
      log(`    Conversion rate: ${(variant.conversionRate * 100).toFixed(2)}%`);
      log(`    Confidence interval: [${(variant.ciLower * 100).toFixed(2)}%, ${(variant.ciUpper * 100).toFixed(2)}%]`);
      log("");
    }
    if (event.significance) {
      log(`  Statistical Significance:`);
      log(`    p-value: ${event.significance.pValue.toFixed(4)}`);
      log(`    Significant: ${event.significance.isSignificant ? "YES ✓" : "NO ✗"}`);
      log(`    Confidence: ${(event.significance.confidence * 100).toFixed(1)}%`);
    }
    if (event.winner) {
      log(`  🏆 WINNER: ${event.winner}`);
    }
    log("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
  }

  // Demo 7: Stop experiment
  on(DemoControls, "click") {
    if (event.target === "stop_experiment_button") {
      emit(ABTestManager, "stop_experiment", {
        experimentId: "exp_button_color_001",
        reason: "Statistically significant winner found",
      });
      log("🛑 Stopping experiment...");
    }
  }

  // Demo 8: Gradual rollout (winner to 100%)
  on(DemoControls, "click") {
    if (event.target === "rollout_winner_button") {
      emit(ABTestManager, "rollout_winner", {
        experimentId: "exp_button_color_001",
        winner: "variant_green",
        schedule: [
          { percentage: 25, date: "2026-03-08T00:00:00Z" },
          { percentage: 50, date: "2026-03-09T00:00:00Z" },
          { percentage: 75, date: "2026-03-10T00:00:00Z" },
          { percentage: 100, date: "2026-03-11T00:00:00Z" },
        ],
      });
      log("🚀 Rolling out winner gradually...");
    }
  }

  on(ABTestManager, "rollout_progressed") {
    log(`📈 Rollout progressed`);
    log(`  Experiment: ${event.experimentId}`);
    log(`  Winner: ${event.winner}`);
    log(`  Traffic percentage: ${event.percentage}%`);
    log(`  Next step: ${event.nextPercentage}% on ${event.nextDate}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // VISUALIZATION
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity ABTestDashboard {
    geometry: plane;
    position: [0, 2.5, -4];
    scale: [6, 3.5, 1];
    traits: [text_display];

    text_display: {
      content: "A/B TESTING PLATFORM\n\n🧪 Experiment Types:\n  • A/B tests (2 variants)\n  • Multi-variate tests (3+ variants)\n  • Feature flags\n  • Gradual rollouts\n\n📊 Statistical Methods:\n  • Z-test (proportions)\n  • t-test (continuous metrics)\n  • 95% confidence level\n  • 5% minimum detectable effect\n  • Auto-winner selection (99% threshold)\n\n🎯 Conversion Metrics:\n  • Click-through rate (CTR)\n  • Conversion rate\n  • Engagement time\n  • Revenue per user\n  • Custom metrics\n\n⚙️  Features:\n  • Consistent user assignment (hash-based)\n  • Traffic allocation control\n  • Real-time metric tracking\n  • Confidence intervals\n  • Sample size calculation\n  • Gradual rollout schedules\n\n✅ Use Cases:\n  • UI/UX optimization\n  • Feature validation\n  • Performance testing\n  • Content experimentation",
      fontSize: 0.09,
      color: "#f59e0b",
    };
  }
}
