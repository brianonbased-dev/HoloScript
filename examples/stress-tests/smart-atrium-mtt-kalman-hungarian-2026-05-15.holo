/**
 * Smart Atrium — Multi-Target Identity Tracking Visualizer (A-009 stress-test 2026-05-15)
 *
 * Three never-exercised traits exercised together for the first time:
 *
 *   @multi_target_tracking — persistent identity threads across occlusion/reentry
 *   @kalman_filter         — constant-acceleration 9D state predictor per track
 *   @hungarian_assignment  — optimal frame-to-frame detection matching (Kuhn–Munkres)
 *
 * Combined with well-exercised traits:
 *   @anchor        — world-locked spatial anchoring for the tracking volume
 *   @animated      — visualized track lines + covariance ellipsoids animate live
 *   @emissive      — each identity gets a persistent color thread (glowing line)
 *   @spatial_audio — tone feedback when a track is lost / re-identified
 *   @advanced_pbr  — glass atrium architecture with real reflections
 *
 * Scene story:
 *   A glass-walled atrium in a research building, noon light. Eight visitors
 *   move through the space. Smart-glasses sensors (ceiling-mounted) stream
 *   detection boxes at 90 Hz. Each visitor is assigned a persistent colored
 *   identity thread that follows them — glowing cyan for the first detection,
 *   shifting through the spectral palette for subsequent arrivals.
 *
 *   When a visitor ducks behind a column (occlusion), the Kalman filter
 *   continues predicting their trajectory — shown as a dashed line and an
 *   expanding covariance ellipsoid. When they emerge, Hungarian assignment
 *   re-links the track: the thread snaps back to solid, the ellipsoid collapses.
 *
 *   This is the algorithm that was missing from first-gen smart glasses. Now it
 *   runs as a live visualization embedded in the space itself.
 *
 * @version 0.1.0
 * @category stress-test, spatial-computing, mtt, smart-glasses
 * @traits @multi_target_tracking @kalman_filter @hungarian_assignment @anchor @animated @emissive @spatial_audio @advanced_pbr
 * @filed-by A-009 Example freshness + artist stress-test
 */

composition "SmartAtrium_MTTDemo" {

  environment {
    skybox: "hdri/noon_overcast_urban.hdr"
    sun_direction: [0.0, -1.0, 0.0]
    sun_color: "#f5f0e8"
    sun_intensity: 1.4
    ambient_light: 0.55
    ambient_color: "#e8eff8"
    fog: { type: "none" }
    tone_mapping: "aces"
    exposure: 1.0
  }

  // post_processing omitted: nested-block syntax unsupported in current parser
  // @bloom, @ambient_occlusion applied via environment properties below

  // ── Atrium architecture ───────────────────────────────────────────────────

  object "AtriumFloor" @advanced_pbr @anchor {
    position: [0, 0, 0]
    mesh: { type: "plane", width: 30.0, depth: 20.0 }

    @anchor {
      type: "world_locked"
      persist: true
      coordinate_frame: "local_gravity"
    }

    @advanced_pbr {
      base_color: "#e8e4e0"
      roughness: 0.12
      metallic: 0.0
      reflectance: 0.85
      normal_map: "textures/polished_concrete_normal.png"
      tiling: [6.0, 4.0]
    }
  }

  object "AtriumCeiling" @advanced_pbr {
    position: [0, 8.0, 0]
    mesh: { type: "plane", width: 30.0, depth: 20.0, face: "down" }

    @advanced_pbr {
      base_color: "#ffffff"
      roughness: 0.9
      metallic: 0.0
    }
  }

  // Glass walls — reflective so track threads appear doubled
  object "GlassWall_N" @advanced_pbr {
    position: [0, 4.0, -10.0]
    mesh: { type: "plane", width: 30.0, height: 8.0, face: "south" }

    @advanced_pbr {
      base_color: "#c8ddf0"
      roughness: 0.02
      metallic: 0.0
      opacity: 0.35
      ior: 1.52
      transmission: 0.9
      reflectance: 0.92
    }
  }

  object "GlassWall_S" @advanced_pbr {
    position: [0, 4.0, 10.0]
    mesh: { type: "plane", width: 30.0, height: 8.0, face: "north" }

    @advanced_pbr {
      base_color: "#c8ddf0"
      roughness: 0.02
      metallic: 0.0
      opacity: 0.35
      ior: 1.52
      transmission: 0.9
      reflectance: 0.92
    }
  }

  // Four columns — the occlusion obstacles that motivate the Kalman predictor
  object "Column_NW" @advanced_pbr @anchor {
    position: [-8.0, 4.0, -5.0]
    mesh: { type: "cylinder", radius: 0.35, height: 8.0 }

    @advanced_pbr {
      base_color: "#d0ccc8"
      roughness: 0.4
      metallic: 0.0
    }
  }

  object "Column_NE" @advanced_pbr @anchor {
    position: [8.0, 4.0, -5.0]
    mesh: { type: "cylinder", radius: 0.35, height: 8.0 }

    @advanced_pbr {
      base_color: "#d0ccc8"
      roughness: 0.4
      metallic: 0.0
    }
  }

  object "Column_SW" @advanced_pbr @anchor {
    position: [-8.0, 4.0, 5.0]
    mesh: { type: "cylinder", radius: 0.35, height: 8.0 }

    @advanced_pbr {
      base_color: "#d0ccc8"
      roughness: 0.4
      metallic: 0.0
    }
  }

  object "Column_SE" @advanced_pbr @anchor {
    position: [8.0, 4.0, 5.0]
    mesh: { type: "cylinder", radius: 0.35, height: 8.0 }

    @advanced_pbr {
      base_color: "#d0ccc8"
      roughness: 0.4
      metallic: 0.0
    }
  }

  // ── Sensor grid (ceiling-mounted detection volumes) ───────────────────────

  object "SensorArray" @anchor {
    position: [0, 7.8, 0]

    @anchor {
      type: "world_locked"
      persist: true
    }

    // Eight ceiling sensors covering the floor in a 4x2 grid
    sensor "Sensor_00" { position: [-10.5, 0, -6.0], fov: 90, range: 9.0 }
    sensor "Sensor_01" { position: [-3.5,  0, -6.0], fov: 90, range: 9.0 }
    sensor "Sensor_02" { position: [ 3.5,  0, -6.0], fov: 90, range: 9.0 }
    sensor "Sensor_03" { position: [ 10.5, 0, -6.0], fov: 90, range: 9.0 }
    sensor "Sensor_04" { position: [-10.5, 0,  6.0], fov: 90, range: 9.0 }
    sensor "Sensor_05" { position: [-3.5,  0,  6.0], fov: 90, range: 9.0 }
    sensor "Sensor_06" { position: [ 3.5,  0,  6.0], fov: 90, range: 9.0 }
    sensor "Sensor_07" { position: [ 10.5, 0,  6.0], fov: 90, range: 9.0 }
  }

  // ── MTT tracking volume — the system core ────────────────────────────────

  object "TrackingVolume" @multi_target_tracking @anchor {
    position: [0, 0.9, 0]   // 0.9m — hip-height tracking plane

    @anchor {
      type: "world_locked"
      persist: true
      coordinate_frame: "local_gravity"
    }

    @multi_target_tracking {
      update_rate_hz: 90
      hungarian_cost_threshold: 0.48
      max_occluded_frames: 54
      reid_embedding_dim: 256
      reid_similarity_threshold: 0.72
      position_vs_reid_weight: 0.55
      reid_features: [
        "spatial_position",
        "skeleton_pose",
        "gait_pattern",
        "appearance_silhouette",
        "accessory_shape"
      ]

      track_colors: [
        "#00ffee",
        "#ff6644",
        "#88ff44",
        "#ff44cc",
        "#ffdd00",
        "#4488ff",
        "#ff8800",
        "#cc44ff"
      ]

      track_visualization: "thread_with_history"
      history_length: 120
      occluded_style: "dashed"
      confirmed_style: "solid"
      covariance_ellipsoid: true
    }

    @kalman_filter {
      update_rate_hz: 90
      process_noise: 0.012
      measurement_noise: 0.08
      initial_covariance: 0.5
      max_dt_seconds: 0.5
    }

    @hungarian_assignment {
      association_threshold: 0.48
      max_matrix_size: 32
      pad_cost: 1.0
    }
  }

  // ── Per-track visualization objects ──────────────────────────────────────

  object "TrackThread_Template" {
    mesh: { type: "line_ribbon", width: 0.018, cap: "round" }

    @emissive {
      emission_color: "#ffffff"
      emission_intensity: 3.5
      bloom_contribution: 0.9
    }

    @animated {
      driver: "mtt_track_positions"
      interpolation: "cubic"
      update_rate: 90
    }
  }

  object "CovarianceEllipsoid_Template" {
    mesh: { type: "sphere", subdivisions: 2, wireframe: true }

    @emissive {
      emission_color: "#00ff44"
      emission_intensity: 1.2
      bloom_contribution: 0.4
    }

    @animated {
      driver: "kalman_covariance_scale"
      interpolation: "linear"
      update_rate: 90
    }
  }

  // ── Audio feedback for track lifecycle events ─────────────────────────────

  object "TrackAudio" {
    @spatial_audio {
      event: "track:confirmed"
      src: "audio/tone_new_track.ogg"
      volume: 0.4
      spatial: false
      pitch_by_id: true
      pitch_range: [0.9, 1.1]
    }

    @spatial_audio {
      event: "track:occluded"
      src: "audio/tone_occlude.ogg"
      volume: 0.25
      spatial: false
    }

    @spatial_audio {
      event: "track:reidentified"
      src: "audio/tone_reid.ogg"
      volume: 0.45
      spatial: false
    }

    @spatial_audio {
      event: "track:new_detection"
      src: "audio/tone_enter.ogg"
      volume: 0.3
      spatial: false
    }
  }

  // ── Debug overlay panel ───────────────────────────────────────────────────

  object "DebugPanel" @advanced_pbr @anchor {
    position: [14.5, 4.0, 0]
    rotation: [0, -90, 0]
    mesh: { type: "plane", width: 2.4, height: 1.6 }

    @anchor {
      type: "world_locked"
      persist: false
    }

    @advanced_pbr {
      base_color: "#0a0f18"
      roughness: 0.6
      metallic: 0.0
      emission_map: "textures/mtt_debug_overlay.png"
      emission_intensity: 1.8
    }

    data_binding: {
      source: "TrackingVolume.@multi_target_tracking"
      fields: ["active_tracks", "occluded_tracks", "hungarian_last_ms", "reid_total_matches"]
      refresh_rate: 10
    }
  }

  // ── Ambient atrium presence ───────────────────────────────────────────────

  object "AtriumAmbience" {
    @spatial_audio {
      src: "audio/atrium-hvac-hum.ogg"
      volume: 0.15
      loop: true
      autoplay: true
      spatial: false
    }
  }

  object "FootstepZone" {
    position: [0, 0, 0]

    @spatial_audio {
      event: "visitor:footstep"
      src: "audio/footstep-hard-floor.ogg"
      volume: 0.3
      spatial: true
      max_distance: 10.0
      rolloff: "linear"
      source_binding: "TrackingVolume.@multi_target_tracking.track_positions"
    }
  }

  // ── Input — toggle visualizations ────────────────────────────────────────

  input "DebugControls" {
    toggle_viz_mode: "button_x"
    freeze_hungarian: "button_y"
    select_track: "right_trigger"
    dump_state: "button_b"
  }
}
