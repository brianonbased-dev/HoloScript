// ============================================================================
// Stress-Test: Drone Cohort — Temporal Safety + PID Flight + CSP Coordination
// A009 Phase 3 — 2026-05-16
//
// Trait combo (NEVER previously exercised together):
//   @temporal_guard  (0 prior examples) — aborts control actions on stale telemetry
//   @pid_controller  (0 prior examples) — altitude/pitch/roll/yaw stabilization
//   @csp_channel     (0 prior examples) — formally verified concurrent message-passing
//   @gpu_particle    (several examples) — thruster exhaust trails
//   @networked       (several examples) — cross-client position sync
//
// Three drones ascend from charging pads on a rooftop at dusk.
// Each has a PID flight controller for stabilization.
// A temporal guard trips if the sensor loop stalls > 80 ms, putting the drone
// into a safe hover until fresh telemetry arrives.
// CSP channels handle corridor negotiation so no two drones enter the same
// 2-meter exclusion sphere simultaneously, provably deadlock-free.
// ============================================================================

composition "DroneFleetCohort" {

  environment {
    skybox: "dusk_urban"
    background_color: "#1a0e28"
    background_gradient: ["#1a0e28", "#ff7722"]
    ambient_light: 0.25
    shadows: true
    fog: { density: 0.004, color: "#cc8833" }
  }

  object "DuskSun" {
    type: "directional_light"
    direction: [-0.6, -0.3, 0.7]
    color: "#ff9955"
    intensity: 0.8
    cast_shadows: true
  }

  object "SkyAmbient" {
    type: "point_light"
    position: [0, 12, 0]
    color: "#334466"
    intensity: 0.4
    range: 40
  }

  template "Drone" {
    @pid_controller(
      axes: ["altitude", "pitch", "roll", "yaw"],
      gains: {
        altitude: { kp: 2.5, ki: 0.1,  kd: 0.8 },
        pitch:    { kp: 3.2, ki: 0.05, kd: 1.1 },
        roll:     { kp: 3.2, ki: 0.05, kd: 1.1 },
        yaw:      { kp: 1.8, ki: 0.02, kd: 0.5 }
      },
      output_clamp: [-1.0, 1.0],
      update_rate_hz: 50
    )
    @temporal_guard(
      max_staleness_ms: 80,
      action_on_stale: "hover_safe",
      telemetry_source: "pid_sensor_feed",
      recovery_mode: "resume_on_fresh"
    )
    @csp_channel(
      channel_id: "drone_corridor_bus",
      message_types: ["corridor_claim", "corridor_release", "conflict_query"],
      buffer_size: 4,
      deadlock_timeout_ms: 200
    )
    @networked(sync_rate: 20, interpolation: true)
    @collidable
    @gpu_particle(
      emitter: "exhaust_nozzle",
      rate: 60,
      lifetime: 0.8,
      size_start: 0.08,
      size_end: 0.0,
      color_start: "#ffaa44",
      color_end: "#33334400",
      velocity: [0, -1.5, 0],
      spread: 0.3
    )

    geometry: "cube"
    scale: [0.6, 0.15, 0.6]
    material: { baseColor: "#222233", roughness: 0.25, metallic: 0.8 }
    emissive: "#003366"
    emissiveIntensity: 0.4

    state {
      formation_slot: 0
      corridor_id: null
      stale_trips: 0
      altitude_target: 6.0
      mode: "ascending"
    }

    on mount() {
      print("Drone online. Slot: " + this.state.formation_slot)
      emit("csp_channel_send", {
        type: "corridor_claim",
        slot: this.state.formation_slot,
        drone_id: this.id
      })
    }

    on temporal_guard_tripped(event) {
      this.state.stale_trips += 1
      this.state.mode = "safe_hover"
      print("Temporal guard tripped on " + this.id + ". Safe hover. Trips: " + this.state.stale_trips)
      emit("csp_channel_send", {
        type: "conflict_query",
        reason: "temporal_guard",
        drone_id: this.id
      })
    }

    on temporal_guard_recovered() {
      this.state.mode = "formation"
      print("Temporal guard cleared on " + this.id + " — resuming formation.")
    }

    on csp_channel_receive(msg) {
      if (msg.type == "corridor_claim" && msg.drone_id != this.id) {
        if (msg.slot == this.state.formation_slot) {
          emit("csp_channel_send", {
            type: "conflict_query",
            reason: "slot_collision",
            drone_id: this.id,
            conflicting_drone: msg.drone_id
          })
        }
      }
      if (msg.type == "corridor_release") {
        print(this.id + " registered corridor release from " + msg.drone_id)
      }
    }

    on pid_output(output) {
      if (this.state.mode != "safe_hover") {
        apply_thrust(this.id, output.altitude)
        apply_attitude(this.id, output.pitch, output.roll, output.yaw)
      }
    }
  }

  object "RooftopSurface" {
    @collidable

    geometry: "plane"
    position: [0, 0, 0]
    scale: [14, 1, 14]
    material: { baseColor: "#2a2830", roughness: 0.88, metallic: 0.08 }
  }

  object "ChargingPad_A" {
    @glowing

    geometry: "cylinder"
    position: [-3, 0.02, 0]
    scale: [1.0, 0.04, 1.0]
    material: { baseColor: "#003366", roughness: 0.2, metallic: 0.7 }
    emissive: "#0055ff"
    emissiveIntensity: 0.6
  }

  object "ChargingPad_B" {
    @glowing

    geometry: "cylinder"
    position: [0, 0.02, 0]
    scale: [1.0, 0.04, 1.0]
    material: { baseColor: "#003366", roughness: 0.2, metallic: 0.7 }
    emissive: "#0055ff"
    emissiveIntensity: 0.6
  }

  object "ChargingPad_C" {
    @glowing

    geometry: "cylinder"
    position: [3, 0.02, 0]
    scale: [1.0, 0.04, 1.0]
    material: { baseColor: "#003366", roughness: 0.2, metallic: 0.7 }
    emissive: "#0055ff"
    emissiveIntensity: 0.6
  }

  object "Railing_N" {
    @collidable

    geometry: "cube"
    position: [0, 0.5, -7]
    scale: [14, 1, 0.15]
    material: { baseColor: "#333344", roughness: 0.6, metallic: 0.5 }
  }

  object "HVAC_Unit" {
    @collidable

    geometry: "cube"
    position: [4, 0.75, 4]
    scale: [2, 1.5, 1.5]
    material: { baseColor: "#3a3a40", roughness: 0.7, metallic: 0.6 }
  }

  object "AntennaMast" {
    geometry: "cylinder"
    position: [-5, 3, -5]
    scale: [0.1, 6, 0.1]
    material: { baseColor: "#555566", roughness: 0.4, metallic: 0.8 }
  }

  object "Alpha" using "Drone" {
    position: [-3, 1, 0]
    properties: { formation_slot: 0 }
  }

  object "Beta" using "Drone" {
    position: [0, 1, 0]
    properties: { formation_slot: 1 }
  }

  object "Gamma" using "Drone" {
    position: [3, 1, 0]
    properties: { formation_slot: 2 }
  }

  post_processing {
    bloom: { intensity: 0.45, threshold: 0.5, radius: 0.4 }
    tone_mapping: "aces"
    lens_flare: { enabled: true, intensity: 0.3 }
    ssao: { intensity: 0.4, radius: 0.35 }
  }
}
