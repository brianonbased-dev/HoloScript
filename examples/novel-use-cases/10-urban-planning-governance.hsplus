/**
 * Urban Planning & Governance Simulator — .hsplus Behavior
 *
 * WHY .hsplus: Governance requires reactive voting + norm enforcement
 * state machines. ReferendumEngine module handles proposal lifecycle.
 *
 * @version 5.0.0
 * @format .hsplus (behavior)
 */
composition "UrbanPlanningGovernance" {
  environment { skybox: "city_sunset"; ambient_light: 0.6; physics: true }

  module ReferendumEngine {
    state { proposals: []; active: null; total_completed: 0 }
    action submit(title, category, steward_id) {
      const p = { id: generate_id(), title: title, category: category, proposer: steward_id, votes_for: 0, votes_against: 0, voters: [], status: "open", deadline: current_time() + 900000 };
      this.state.proposals.push(p); this.state.active = p.id;
      emit("referendum:submitted", p); return p.id;
    }
    action vote(proposal_id, voter_id, approve) {
      const p = this.state.proposals.find(x => x.id === proposal_id);
      if (!p || p.status !== "open" || p.voters.includes(voter_id)) return false;
      p.voters.push(voter_id);
      if (approve) p.votes_for += 1; else p.votes_against += 1;
      emit("referendum:vote_cast", { proposal_id: proposal_id, voter: voter_id, approve: approve });
      if (p.voters.length >= 4) this.tally(proposal_id);
      return true;
    }
    action tally(proposal_id) {
      const p = this.state.proposals.find(x => x.id === proposal_id);
      if (!p) return;
      p.status = p.votes_for > p.votes_against ? "approved" : "rejected";
      this.state.total_completed += 1;
      emit("referendum:tally", { id: proposal_id, approved: p.status === "approved", votes_for: p.votes_for, votes_against: p.votes_against });
    }
    exports { submit, vote, tally, state }
  }

  template "UrbanSteward" {
    @llm_agent
    @perception(range: 30)
    @tenant { tenantId: "city_001"; role: "steward"; rbac: true }

    @state_machine {
      initial: "analyzing"
      states: {
        analyzing: { on_issue_found: -> "proposing" }
        proposing: { on_proposal_submitted: -> "monitoring" action(on_proposed) }
        monitoring: { on_tally_complete: -> "analyzing" action(on_tally) }
      }
      actions: {
        on_proposed: () => { state.proposals_made += 1; }
        on_tally: () => { state.tallies_witnessed += 1; }
      }
    }

    state { agent_id: null; district: null; proposals_made: 0; tallies_witnessed: 0 }

    @on_event("referendum:tally"): (data) => {
      if (this.current_state === "monitoring") emit("on_tally_complete");
    }

    action submit_proposal(title, category) {
      ReferendumEngine.submit(title, category, state.agent_id);
      emit("on_proposal_submitted");
    }
  }

  template "CitizenVoter" {
    @llm_agent
    @perception(range: 15)

    @norm_compliant {
      norms: ["one_vote_per_citizen", "transparent_tally"]
      enforcement: "hard"; scope: "zone"; canPropose: false; canEnforce: false
    }

    state { voter_id: null; votes_cast: 0 }

    @on_event("referendum:submitted"): (data) => {
      // Auto-deliberate and vote
      const approve = Math.random() > 0.4;
      ReferendumEngine.vote(data.id, state.voter_id, approve);
      state.votes_cast += 1;
    }
  }

  object "CityGrid" { @collidable; geometry: "plane"; position: [0, -0.5, 0]; scale: [40, 1, 40]; color: "#2c3e50" }
  object "Steward_A" using "UrbanSteward" { position: [-5, 1, 3]; geometry: "humanoid"; color: "#3498db"; state { agent_id: "steward_zoning"; district: "downtown" } }
  object "Citizen_01" using "CitizenVoter" { position: [-3, 0.5, -2]; geometry: "capsule"; color: "#ecf0f1"; state { voter_id: "c01" } }
  object "Citizen_02" using "CitizenVoter" { position: [0, 0.5, -4]; geometry: "capsule"; color: "#ecf0f1"; state { voter_id: "c02" } }
  object "Citizen_03" using "CitizenVoter" { position: [3, 0.5, -2]; geometry: "capsule"; color: "#ecf0f1"; state { voter_id: "c03" } }
  object "Citizen_04" using "CitizenVoter" { position: [-1, 0.5, -6]; geometry: "capsule"; color: "#ecf0f1"; state { voter_id: "c04" } }

  panel "UrbanDashboard" {
    position: "top-right"
    text "Proposals" { bind: "Proposals: " + ReferendumEngine.state.proposals.length; style: "info" }
    text "Completed" { bind: "Completed: " + ReferendumEngine.state.total_completed; color: "#3498db" }
  }
}
