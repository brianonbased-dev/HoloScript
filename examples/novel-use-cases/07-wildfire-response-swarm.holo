/**
 * Wildfire Response Coordination Swarm
 *
 * FireGuardian agents patrol fire models + live IoT sensors, migrate
 * from IC headset → drones → ground robots. Escrow bounties for
 * containment actions. FeedbackLoop self-tunes fidelity on wind/FPS.
 * Post-quantum audit for multi-agency compliance.
 *
 * v5 Traits: agent_portal, economy, cultural_profile, feedback_loop,
 *            post_quantum_audit, digital_twin, ROS2Bridge
 *
 * Studio prompt: "Build a live wildfire command center where AI
 *   guardians migrate between headset, drones, and robots and pay
 *   each other for successful containment steps."
 *
 * Targets: XPRIZE Wildfire $11M, AWE "Best Use of AI", AWE Enterprise
 * @version 5.0.0
 */
composition "WildfireResponseSwarm" {

  metadata {
    name: "Wildfire Response Coordination Swarm"
    category: "wildfire"
    platforms: ["visionos", "webxr", "r3f", "urdf", "sdf", "dtdl", "unity"]
  }

  environment {
    skybox: "smoke_orange_haze"
    ambient_light: 0.35
    physics: true
    post_quantum_crypto: true
    wind: { direction: [1, 0, 0.5], speed: 15 }
  }

  state {
    fires_detected: 0
    containment_actions: 0
    area_contained_ha: 0
    active_guardians: 0
    drones_deployed: 0
    bounties_paid: 0
  }

  entity PortalHub {
    traits: [agent_portal];
    agent_portal: {
      scene_id: "wildfire_cmd_001",
      scene_name: "Wildfire Command Center",
      agent_id: "incident_commander",
      capabilities: ["fire_detection", "containment_coordination", "drone_dispatch"],
      relay_url: "wss://portal.holoscript.dev/wildfire",
      auto_reconnect: true,
      max_hop_count: 5,
      default_ttl: 60000,
      max_outbox_size: 500,
    };
  }

  entity EconomyEngine {
    traits: [economy];
    economy: {
      initial_balance: 200,
      default_spend_limit: 300,
      spend_limit_period: 3600000,
      max_transaction_history: 1000,
      default_bounty_deadline: 300000,
      max_bounties_per_agent: 20,
      escrow_enabled: true,
      task_completion_reward: 50,
    };
  }

  entity FeedbackEngine {
    traits: [feedback_loop];
    feedback_loop: {
      metrics: {
        fire_spread_accuracy: { target: 0.9,  min: 0, max: 1.0 },
        wind_model_fidelity:  { target: 0.85, min: 0, max: 1.0 },
        drone_coverage:       { target: 0.95, min: 0, max: 1.0 },
        response_time_sec:    { target: 120,  min: 0, max: 3600 },
        fps:                  { target: 60,   min: 0, max: 144 },
      },
      history_window: 60,
      min_samples_for_trend: 5,
      alert_threshold: 10,
      critical_threshold: 30,
      auto_signal: true,
    };
  }

  // ━━━ AGENT TEMPLATES ━━━

  template "FireGuardian" {
    @llm_agent
    @perception(range: 50)
    @post_quantum_audit { algorithm: "ML-KEM-768"; log_all: true }
    @cultural_profile {
      cooperation_index: 0.9
      cultural_family: "hierarchical"
      prompt_dialect: "directive"
      norm_set: ["chain_of_command", "safety_first", "cross_jurisdiction"]
    }

    geometry: "capsule"
    color: "#ff4400"
    scale: [0.5, 1.0, 0.5]

    state { sector: null; fires_spotted: 0; containment_verified: 0; mode: "patrol" }

    on mount() {
      print("FireGuardian " + this.id + " deployed — sector: " + state.sector)
    }

    action report_fire(location, intensity, area) {
      state.fires_spotted += 1
      emit("fire_detected", {
        guardianId: this.id, location: location,
        intensity: intensity, area_ha: area, timestamp: Date.now()
      })
      emit("economy:post_bounty", {
        posterId: this.id, reward: 50,
        description: "Contain fire at sector " + state.sector + " (" + area + " ha)",
        requiredCapabilities: ["fire_containment"],
        deadline: Date.now() + 300000, maxClaimants: 5,
      })
    }

    action verify_containment(actionId, areaContained) {
      state.containment_verified += 1
      emit("containment_verified", {
        guardianId: this.id, actionId: actionId,
        area_ha: areaContained, timestamp: Date.now()
      })
    }

    action migrate_to_drone(droneSceneId) {
      emit(PortalHub, "portal:migrate_out", {
        agentId: this.id, name: "FireGuardian",
        capabilities: ["fire_detection", "containment_coordination"],
        memory: { sector: state.sector, fires: state.fires_spotted },
        state: { mode: "drone_ops" },
        targetScene: droneSceneId,
      })
    }
  }

  template "FireSensor" {
    @digital_twin(
      physical_id: "iot_fire_sensor_01",
      sync_properties: [
        { physical_key: "temperature", virtual_property: "temp",  direction: "in" },
        { physical_key: "smoke_ppm",   virtual_property: "smoke", direction: "in" },
        { physical_key: "wind_speed",  virtual_property: "wind",  direction: "in" }
      ],
      update_mode: "push"
    )
    geometry: "cylinder"; scale: [0.2, 0.8, 0.2]; color: "#ff6600"
    state { temp: 0; smoke: 0; wind: 0 }

    on on_twin_sync(data) {
      if (data.state.temperature > 200 || data.state.smoke_ppm > 500) {
        pulsate(this.id, { color: "#ff0000", duration: 300 })
        emit("fire_anomaly", { sensorId: this.id, temp: data.state.temperature })
      }
    }
  }

  // ━━━ INSTANCES ━━━

  object "Terrain"         { geometry: "plane"; scale: [60, 1, 60]; color: "#3d2b1f"; position: [0, -0.5, 0] }
  object "FireZone"        { geometry: "cylinder"; position: [15, 0, -10]; scale: [12, 0.1, 12]; color: "#ff2200"; opacity: 0.3; emissive: "#ff0000"; emissive_intensity: 0.5 }
  object "Guardian_Red"    using "FireGuardian" { position: [-10, 1, 5]; color: "#ff4400" }
  object "Guardian_Orange" using "FireGuardian" { position: [0, 1, 10]; color: "#ff8800" }
  object "Guardian_Yellow" using "FireGuardian" { position: [10, 1, 5]; color: "#ffcc00" }
  object "Sensor_North"    using "FireSensor" { position: [0, 0.4, 20] }
  object "Sensor_East"     using "FireSensor" { position: [20, 0.4, 0] }
  object "Sensor_South"    using "FireSensor" { position: [0, 0.4, -20] }

  system "ROS2Bridge" {
    nodeName: "/wildfire_swarm"
    publishRate: 60
    topics: { droneCmd: "/drone/cmd_vel", sensorData: "/fire/sensors", groundRobotCmd: "/ground_robot/cmd" }
  }

  // ━━━ GLOBAL EVENTS ━━━

  on_fire_detected(data) {
    state.fires_detected += 1
    emit("system_log", { level: "error", message: "🔥 Fire at " + JSON.stringify(data.location) + " — " + data.area_ha + " ha" })
  }

  on_containment_verified(data) {
    state.containment_actions += 1
    state.area_contained_ha += data.area_ha
    state.bounties_paid += 1
  }

  on(FeedbackEngine, "feedback:optimization_signal") {
    if (event.suggestedAction === "reduce_fire_particle_count") {
      print("⚙️  Auto-tuning: reducing fire particles to maintain 60fps")
    }
  }

  panel "WildfireDashboard" {
    position: "top-right"
    text "Title" { content: "WILDFIRE COMMAND"; style: "heading" }
    text "F1"    { bind: "'Fires detected: ' + state.fires_detected"; color: "#ff4400" }
    text "F2"    { bind: "'Containment: ' + state.containment_actions"; color: "#00ff88" }
    text "F3"    { bind: "'Area contained: ' + state.area_contained_ha + ' ha'"; style: "info" }
    text "F4"    { bind: "'Bounties paid: ' + state.bounties_paid"; style: "info" }
    text "PQ"    { content: "Post-Quantum: ML-KEM-768 ✅"; color: "#7b2ff7" }
  }
}
