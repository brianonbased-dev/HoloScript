/**
 * Optimistic Sci-Fi World Co-Creation Metaverse
 *
 * Persistent arena where CitizenAgent swarm (cultural traits for diverse
 * voices) self-governs via bounties, migrates between creator headsets
 * and public Hololand, uses FeedbackLoop to evolve plot branches based
 * on viewer ratings, and exports to Unreal film pipeline. Cultural memory
 * preserves world lore across sessions.
 *
 * v5 Traits: agent_portal, economy, cultural_profile, cultural_memory,
 *            feedback_loop
 *
 * Studio prompt: "Build a persistent sci-fi world where AI citizens from
 *   different cultural factions co-author a story, remember past events,
 *   and evolve plot based on viewer votes. Export trailers to Unreal."
 *
 * Targets: Future Vision XPRIZE $3.5M, AWE "Best Art or Film", AWE AI
 * @version 5.0.0
 */
composition "SciFiCoCreation" {

  metadata {
    name: "Optimistic Sci-Fi World Co-Creation Metaverse"
    category: "co_creation"
    platforms: ["webxr", "visionos", "unreal", "r3f", "unity"]
  }

  environment {
    skybox: "nebula_city"
    ambient_light: 0.5
    physics: true
    bloom: true
  }

  state {
    lore_entries: 0
    plot_branches: 0
    viewer_votes: 0
    factions_active: 3
    sops_formed: 0
    trailers_exported: 0
  }

  entity PortalHub {
    traits: [agent_portal];
    agent_portal: {
      scene_id: "cocreation_001",
      scene_name: "Nebula City Co-Creation",
      agent_id: "world_narrator",
      capabilities: ["story_authoring", "lore_keeping", "faction_governance"],
      relay_url: "wss://portal.holoscript.dev/cocreation",
      auto_reconnect: true,
      max_hop_count: 4,
      default_ttl: 120000,
      max_outbox_size: 300,
    };
  }

  entity EconomyEngine {
    traits: [economy];
    economy: {
      initial_balance: 150,
      default_spend_limit: 60,
      spend_limit_period: 3600000,
      max_transaction_history: 400,
      default_bounty_deadline: 900000,
      max_bounties_per_agent: 5,
      escrow_enabled: true,
      task_completion_reward: 15,
    };
  }

  entity FeedbackEngine {
    traits: [feedback_loop];
    feedback_loop: {
      metrics: {
        viewer_rating:    { target: 4.5, min: 0, max: 5.0 },
        lore_coherence:   { target: 0.9, min: 0, max: 1.0 },
        faction_balance:  { target: 0.33, min: 0, max: 1.0 },
        audience_growth:  { target: 100,  min: 0, max: 10000 },
      },
      history_window: 60,
      min_samples_for_trend: 5,
      alert_threshold: 15,
      critical_threshold: 35,
      auto_signal: true,
    };
  }

  // ━━━ FACTION TEMPLATES ━━━

  template "SolarisCouncilCitizen" {
    @llm_agent
    @perception(range: 25)
    @cultural_profile {
      cooperation_index: 0.85
      cultural_family: "cooperative"
      prompt_dialect: "consensus"
      norm_set: ["story_continuity", "constructive_vote", "lore_respect"]
    }
    @cultural_memory {
      capacity: 300; episodicDecayRate: 0.003; traceLifetime: 800
      consolidation: true; consolidationThreshold: 5
    }

    geometry: "humanoid"; color: "#ffd700"; scale: [0.8, 1.6, 0.8]
    state { faction: "Solaris Council"; stories_authored: 0; sops_formed: 0 }

    on mount() {
      print(this.id + " (Solaris Council) ready to co-create")
    }

    action propose_lore(entry) {
      state.stories_authored += 1
      emit("economy:post_bounty", {
        posterId: this.id, reward: 15,
        description: "Lore contribution: " + entry,
        requiredCapabilities: ["story_authoring"],
        deadline: Date.now() + 600000, maxClaimants: 3,
      })
      emit("lore_proposed", { faction: state.faction, entry: entry })
    }

    on_memory_consolidation(data) {
      state.sops_formed += 1
      emit("sop_formed", {
        agent_id: this.id, sop_type: data.pattern_type,
        confidence: data.confidence, episodes: data.episode_count
      })
    }
  }

  template "DeepSpaceGuildCitizen" {
    @llm_agent
    @perception(range: 25)
    @cultural_profile {
      cooperation_index: 0.5
      cultural_family: "mercantile"
      prompt_dialect: "structured"
      norm_set: ["fair_trade", "story_continuity", "exploration_rights"]
    }
    @cultural_memory {
      capacity: 300; episodicDecayRate: 0.003; traceLifetime: 800
      consolidation: true; consolidationThreshold: 5
    }

    geometry: "humanoid"; color: "#0088ff"; scale: [0.8, 1.6, 0.8]
    state { faction: "Deep Space Guild"; trade_routes_authored: 0; sops_formed: 0 }

    action propose_trade_route(route) {
      state.trade_routes_authored += 1
      emit("lore_proposed", { faction: state.faction, entry: "Trade route: " + route })
    }

    on_memory_consolidation(data) {
      state.sops_formed += 1
      emit("sop_formed", { agent_id: this.id, sop_type: data.pattern_type,
        confidence: data.confidence, episodes: data.episode_count })
    }
  }

  template "TerraformUnionCitizen" {
    @llm_agent
    @perception(range: 25)
    @cultural_profile {
      cooperation_index: 0.7
      cultural_family: "exploratory"
      prompt_dialect: "socratic"
      norm_set: ["ecological_balance", "story_continuity", "constructive_vote"]
    }
    @cultural_memory {
      capacity: 300; episodicDecayRate: 0.003; traceLifetime: 800
      consolidation: true; consolidationThreshold: 5
    }

    geometry: "humanoid"; color: "#00cc66"; scale: [0.8, 1.6, 0.8]
    state { faction: "Terraform Union"; worlds_seeded: 0; sops_formed: 0 }

    action seed_world(worldName) {
      state.worlds_seeded += 1
      emit("lore_proposed", { faction: state.faction, entry: "World seeded: " + worldName })
    }

    on_memory_consolidation(data) {
      state.sops_formed += 1
      emit("sop_formed", { agent_id: this.id, sop_type: data.pattern_type,
        confidence: data.confidence, episodes: data.episode_count })
    }
  }

  // ━━━ INSTANCES ━━━

  object "CityPlatform" { geometry: "cylinder"; position: [0, 0, 0]; scale: [30, 0.3, 30]; color: "#0d0d1a" }
  object "NebulaSphere" { geometry: "sphere"; position: [0, 20, 0]; scale: [8, 8, 8]; color: "#220044"; emissive: "#4400aa"; emissive_intensity: 0.4 }

  object "Solaris_A" using "SolarisCouncilCitizen" { position: [-6, 1, 4] }
  object "Solaris_B" using "SolarisCouncilCitizen" { position: [-4, 1, 6] }
  object "Guild_A"   using "DeepSpaceGuildCitizen" { position: [6, 1, 4] }
  object "Guild_B"   using "DeepSpaceGuildCitizen" { position: [4, 1, 6] }
  object "Terra_A"   using "TerraformUnionCitizen" { position: [0, 1, -6] }
  object "Terra_B"   using "TerraformUnionCitizen" { position: [2, 1, -8] }

  // ━━━ GLOBAL EVENTS ━━━

  on_lore_proposed(data) {
    state.lore_entries += 1
    emit("system_log", { level: "info", message: "📜 [" + data.faction + "] " + data.entry })
  }

  on_sop_formed(data) {
    state.sops_formed += 1
  }

  on(EconomyEngine, "economy:bounty_completed") {
    state.plot_branches += 1
  }

  on(FeedbackEngine, "feedback:optimization_signal") {
    if (event.suggestedAction === "boost_underrepresented_faction") {
      print("⚖️  Auto-tuning: boosting underrepresented faction voice for balance")
    }
  }

  panel "CoCreationDashboard" {
    position: "top-right"
    text "Title" { content: "CO-CREATION METAVERSE"; style: "heading" }
    text "L1"    { bind: "'Lore entries: ' + state.lore_entries"; style: "info" }
    text "L2"    { bind: "'Plot branches: ' + state.plot_branches"; color: "#ffd700" }
    text "L3"    { bind: "'SOPs formed: ' + state.sops_formed"; style: "info" }
    text "L4"    { bind: "'Factions active: ' + state.factions_active"; style: "info" }
  }
}
