/**
 * Disaster Robotics Swarm Training — .hsplus Behavior
 *
 * WHY .hsplus: Swarm coordination needs reactive skill-trading
 * events, @state_machine for rescue mission phases, and module-
 * encapsulated curriculum evolution with sim-to-real gap tracking.
 *
 * @version 5.0.0
 * @format .hsplus (behavior)
 */
composition "DisasterRoboticsSwarm" {
  environment { skybox: "collapsed_building"; ambient_light: 0.3; physics: true; physics_engine: "ode"; gravity: [0, -9.81, 0] }

  module SwarmCurriculum {
    state { scenarios: []; current: 0; total_episodes: 0; curricula_evolved: 0 }
    action add_scenario(name, difficulty, obstacles) {
      this.state.scenarios.push({ name: name, difficulty: difficulty, obstacles: obstacles, pass_count: 0, attempts: 0 });
    }
    action record(scenario_idx, success, metrics) {
      const s = this.state.scenarios[scenario_idx];
      if (!s) return;
      s.attempts += 1; if (success) s.pass_count += 1;
      this.state.total_episodes += 1;
      emit("feedback:update_metric", { name: "rescue_success_rate", value: s.pass_count / s.attempts });
      if (s.pass_count / s.attempts > 0.85 && s.attempts >= 10) {
        emit("curriculum:mastered", { scenario: scenario_idx });
      }
    }
    action evolve() {
      this.state.curricula_evolved += 1;
      emit("curriculum:evolved", { generation: this.state.curricula_evolved });
    }
    exports { add_scenario, record, evolve, state }
  }

  module SkillMarket {
    state { trades: []; total_trades: 0 }
    action list_skill(seller_id, skill_name, price) {
      const listing = { id: generate_id(), seller: seller_id, skill: skill_name, price: price, status: "listed", at: current_time() };
      this.state.trades.push(listing);
      emit("market:listed", listing);
      return listing.id;
    }
    action buy_skill(listing_id, buyer_id) {
      const listing = this.state.trades.find(t => t.id === listing_id);
      if (!listing || listing.status !== "listed") return false;
      listing.status = "sold"; listing.buyer = buyer_id;
      this.state.total_trades += 1;
      emit("economy:transfer", { from: buyer_id, to: listing.seller, amount: listing.price, reason: "Skill: " + listing.skill, item: listing.skill });
      emit("market:sold", { listing_id: listing_id, buyer: buyer_id, skill: listing.skill });
      return true;
    }
    exports { list_skill, buy_skill, state }
  }

  template "RescueTrainer" {
    @llm_agent
    @perception(range: 40)

    @state_machine {
      initial: "training"
      states: {
        training: { on_episode_done: -> "evaluating" action(log_episode) }
        evaluating: {
          on_mastered: -> "selling_skills"
          on_not_mastered: -> "training"
          on_transfer_ready: -> "transferring" guard(state.credits >= 20)
        }
        selling_skills: { on_skill_sold: -> "training" action(on_skill_traded) }
        transferring: {
          on_transfer_complete: -> "validating"
          on_transfer_failed: -> "training" action(on_transfer_error)
        }
        validating: {
          on_validated: -> "training" action(on_validation_success)
          on_validation_failed: -> "training"
        }
      }
      actions: {
        log_episode: () => { state.episodes += 1; }
        on_skill_traded: () => { state.skills_traded += 1; }
        on_transfer_error: () => { emit("trainer:error", { agent_id: state.agent_id, phase: "transfer" }); }
        on_validation_success: () => {
          state.successful_transfers += 1;
          emit("economy:earn", { agentId: state.agent_id, amount: 30, reason: "Validated sim-to-real transfer" });
        }
      }
    }

    state { agent_id: null; credits: 150; episodes: 0; skills_traded: 0; successful_transfers: 0 }

    @on_event("curriculum:mastered"): (data) => {
      if (this.current_state === "evaluating") emit("on_mastered");
    }

    @on_event("market:sold"): (data) => {
      if (data.buyer === state.agent_id || data.listing?.seller === state.agent_id) {
        if (this.current_state === "selling_skills") emit("on_skill_sold");
      }
    }

    @on_event("feedback:optimization_signal"): (signal) => {
      if (signal.suggestedAction === "increase_rubble_complexity") {
        SwarmCurriculum.evolve();
      }
    }

    action run_rescue(scenario_idx) {
      const success = Math.random() > 0.35;
      SwarmCurriculum.record(scenario_idx, success, { detection_rate: 0.85 + Math.random() * 0.1 });
      emit("on_episode_done");
    }
  }

  object "RubbleField" { @collidable; geometry: "plane"; position: [0, -0.5, 0]; scale: [40, 1, 40]; color: "#4a3728" }
  object "Trainer_Search" using "RescueTrainer" { position: [-8, 1, 8]; geometry: "capsule"; color: "#ff3300"; state { agent_id: "search_001" } }
  object "Trainer_Extract" using "RescueTrainer" { position: [8, 1, 8]; geometry: "capsule"; color: "#ff6600"; state { agent_id: "extract_001" } }

  panel "DisasterDashboard" {
    position: "top-right"
    text "Episodes" { bind: "Episodes: " + SwarmCurriculum.state.total_episodes; style: "info" }
    text "Trades" { bind: "Skill trades: " + SkillMarket.state.total_trades; style: "info" }
    text "Evolved" { bind: "Curricula evolved: " + SwarmCurriculum.state.curricula_evolved; color: "#ffd700" }
  }
}
