/**
 * Autonomous Water-Scarcity Digital Twin Swarm
 *
 * A swarm of WaterGuardian agents patrol OpenUSD water-system models,
 * migrate to physical drone ROS 2 fleets or government visionOS dashboards,
 * award escrow bounties for verified conservation actions, and self-optimize
 * via linear regression on drought metrics. Post-quantum audit logs ensure
 * international compliance across jurisdictions.
 *
 * v5 Traits: agent_portal, economy, cultural_profile, feedback_loop,
 *            post_quantum_audit, digital_twin, ROS2Bridge
 * Compile targets: visionos, webxr, r3f, urdf, sdf, dtdl, unity
 *
 * Studio prompt:
 *   "Build a global water management command center where AI guardian
 *    agents patrol river basins, migrate between drones and government
 *    dashboards, and pay bounties for verified water conservation."
 *
 * Prize targets:
 *   - XPRIZE Water Scarcity
 *   - AWE XR Prize Climate (Optimize & Educate)
 *   - AWE Auggie Societal Impact
 *
 * @version 5.0.0
 */
composition "WaterScarcitySwarm" {

  metadata {
    name: "Autonomous Water-Scarcity Digital Twin Swarm"
    category: "climate_water"
    platforms: ["visionos", "webxr", "r3f", "urdf", "sdf", "dtdl", "unity"]
  }

  environment {
    skybox: "arid_sunset"
    ambient_light: 0.65
    physics: true
    post_quantum_crypto: true
  }

  state {
    basins_monitored: 0
    conservation_actions: 0
    water_saved_liters: 0
    drought_index: 0.0
    active_guardians: 0
    bounties_awarded: 0
    compliance_audits: 0
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // PORTAL — government scenes + drone fleets
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity PortalHub {
    traits: [agent_portal];
    agent_portal: {
      scene_id: "water_command_001",
      scene_name: "Global Water Command",
      agent_id: "water_coordinator",
      capabilities: ["drought_analysis", "conservation_verification", "drone_dispatch"],
      relay_url: "wss://portal.holoscript.dev/water",
      auto_reconnect: true,
      max_hop_count: 6,
      default_ttl: 180000,
      max_outbox_size: 400,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ECONOMY — conservation bounties
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity EconomyEngine {
    traits: [economy];
    economy: {
      initial_balance: 100,
      default_spend_limit: 200,
      spend_limit_period: 3600000,
      max_transaction_history: 500,
      default_bounty_deadline: 1200000,
      max_bounties_per_agent: 15,
      escrow_enabled: true,
      task_completion_reward: 30,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // FEEDBACK — drought metric self-optimization
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity FeedbackEngine {
    traits: [feedback_loop];
    feedback_loop: {
      metrics: {
        drought_index:          { target: 0.2, min: 0, max: 1.0 },
        water_flow_rate:        { target: 500, min: 0, max: 5000 },
        sensor_coverage:        { target: 0.95, min: 0, max: 1.0 },
        conservation_efficiency:{ target: 0.8, min: 0, max: 1.0 },
        drone_battery:          { target: 80, min: 0, max: 100 },
      },
      history_window: 120,
      min_samples_for_trend: 10,
      alert_threshold: 20,
      critical_threshold: 50,
      max_feedback_entries: 1000,
      auto_signal: true,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // AGENT TEMPLATES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  template "WaterGuardian" {
    @llm_agent
    @perception(range: 40)
    @post_quantum_audit { algorithm: "ML-KEM-768"; log_all: true }
    @cultural_profile {
      cooperation_index: 0.85
      cultural_family: "cooperative"
      prompt_dialect: "structured"
      norm_set: ["conservation_first", "data_integrity", "cross_jurisdiction"]
    }

    geometry: "capsule"
    color: "#0088ff"
    scale: [0.5, 1.0, 0.5]

    state {
      patrol_zone: null
      anomalies_found: 0
      bounties_posted: 0
      conservation_verified: 0
    }

    on mount() {
      print("WaterGuardian " + this.id + " patrolling basin " + state.patrol_zone)
    }

    action scan_basin(basinId) {
      state.patrol_zone = basinId
      emit("feedback:update_metric", { name: "sensor_coverage", value: 0.92 })
      print("Scanning basin " + basinId + " for drought anomalies…")
    }

    action post_conservation_bounty(description, reward) {
      emit("economy:post_bounty", {
        posterId: this.id, reward: reward,
        description: description,
        requiredCapabilities: ["water_conservation"],
        deadline: Date.now() + 1200000,
        maxClaimants: 5,
      })
      state.bounties_posted += 1
    }

    action verify_conservation(actionId, litersSaved) {
      state.conservation_verified += 1
      emit("conservation_verified", {
        guardianId: this.id, actionId: actionId,
        litersSaved: litersSaved, timestamp: Date.now(),
      })
    }

    action migrate_to_drone(droneSceneId) {
      emit(PortalHub, "portal:migrate_out", {
        agentId: this.id,
        name: "WaterGuardian",
        capabilities: ["drought_analysis", "conservation_verification"],
        memory: { anomalies: state.anomalies_found },
        state: { patrol_zone: state.patrol_zone },
        targetScene: droneSceneId,
      })
    }
  }

  template "WaterSensor" {
    @digital_twin(
      physical_id: "iot_water_sensor_01",
      sync_properties: [
        { physical_key: "flow_rate",  virtual_property: "flow",     direction: "in" },
        { physical_key: "turbidity",  virtual_property: "clarity",  direction: "in" },
        { physical_key: "ph_level",   virtual_property: "ph",       direction: "in" }
      ],
      update_mode: "push"
    )
    geometry: "cylinder"
    scale: [0.3, 1.0, 0.3]
    color: "#00aaff"

    state { flow: 0; clarity: 0; ph: 7.0 }

    on on_twin_sync(data) {
      emit("feedback:update_metric", { name: "water_flow_rate", value: data.state.flow_rate })
      if (data.state.ph_level < 6.0 || data.state.ph_level > 9.0) {
        pulsate(this.id, { color: "#ff0000", duration: 1000 })
        emit("water_anomaly", { sensorId: this.id, type: "ph_out_of_range", value: data.state.ph_level })
      }
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // INSTANCES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  object "Terrain" {
    geometry: "plane"; scale: [50, 1, 50]; color: "#5a3d2b"; position: [0, -0.5, 0]
  }
  object "RiverBed" {
    geometry: "plane"; scale: [8, 1, 50]; color: "#003366"; position: [0, -0.4, 0]; opacity: 0.6
  }

  object "Guardian_Alpha"  using "WaterGuardian" { position: [-8, 1, 5]; color: "#0088ff" }
  object "Guardian_Beta"   using "WaterGuardian" { position: [8, 1, -5]; color: "#00ccaa" }
  object "Guardian_Gamma"  using "WaterGuardian" { position: [0, 1, 15]; color: "#44aaff" }

  object "Sensor_Upstream"  using "WaterSensor" { position: [0, 0.5, 20] }
  object "Sensor_Midstream" using "WaterSensor" { position: [0, 0.5, 0] }
  object "Sensor_Downstream" using "WaterSensor" { position: [0, 0.5, -20] }

  system "ROS2Bridge" {
    nodeName: "/water_swarm"
    publishRate: 30
    topics: { droneCmd: "/drone/cmd_vel", sensorData: "/water/sensors" }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // GLOBAL EVENTS
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on_conservation_verified(data) {
    state.conservation_actions += 1
    state.water_saved_liters += data.litersSaved
    state.bounties_awarded += 1
    emit("system_log", { level: "info",
      message: "💧 Conservation verified: " + data.litersSaved + "L saved by " + data.guardianId
    })
  }

  on_water_anomaly(data) {
    emit("system_log", { level: "warn",
      message: "⚠️  Anomaly at " + data.sensorId + ": " + data.type + " = " + data.value
    })
  }

  on(FeedbackEngine, "feedback:optimization_signal") {
    if (event.suggestedAction === "increase_sensor_density") {
      print("📡 Auto-dispatching additional drone sensors to low-coverage basin")
    }
    if (event.suggestedAction === "recall_low_battery_drones") {
      print("🔋 Auto-recalling drones below 20% battery")
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DASHBOARD
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  panel "WaterDashboard" {
    position: "top-right"
    text "Title"  { content: "WATER SCARCITY COMMAND"; style: "heading" }
    text "W1"     { bind: "'Conservation actions: ' + state.conservation_actions"; style: "info" }
    text "W2"     { bind: "'Water saved: ' + state.water_saved_liters + ' L'"; color: "#00aaff" }
    text "W3"     { bind: "'Active guardians: ' + state.active_guardians"; style: "info" }
    text "W4"     { bind: "'Compliance audits: ' + state.compliance_audits"; style: "info" }
    text "PQ"     { content: "Post-Quantum Audit: ML-KEM-768 ✅"; color: "#7b2ff7" }
  }
}
