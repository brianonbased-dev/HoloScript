/**
 * Physical-AI Robot Training Metaverse
 *
 * A persistent training arena where TrainerSwarm agents run behavior trees
 * in simulation, migrate live to real ROS 2 / Gazebo robots for validation,
 * pay each other compute credits for successful sim-to-real transfers, and
 * use FeedbackLoop to evolve training curricula. Ships to Quest (human
 * oversight) + physical factory from one file.
 *
 * v5 Traits: agent_portal, economy, feedback_loop, ROS2Bridge, digital_twin
 * Compile targets: urdf, sdf, unity, unreal, webxr, visionos, r3f
 *
 * Studio prompt:
 *   "Build a robot training arena where AI trainer agents run behavior
 *    trees in VR, transfer skills to real ROS 2 robots, and pay each
 *    other credits for successful transfers. Let me observe on Quest."
 *
 * Prize targets:
 *   - CVPR Physical AI / 4D Digital Twins
 *   - AWE Auggie "Best Enterprise"
 *   - Augmented Enterprise Summit
 *
 * @version 5.0.0
 */
composition "RobotTrainingMetaverse" {

  metadata {
    name: "Physical-AI Robot Training Metaverse"
    category: "physical_ai"
    platforms: ["urdf", "sdf", "unity", "unreal", "webxr", "visionos", "r3f"]
  }

  environment {
    skybox: "industrial_hangar"
    ambient_light: 0.5
    physics: true
    physics_engine: "ode"
    gravity: [0, -9.81, 0]
  }

  state {
    training_episodes: 0
    successful_transfers: 0
    transfer_success_rate: 0.0
    credits_exchanged: 0
    curricula_evolved: 0
    active_trainers: 0
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // PORTAL — sim ↔ physical factory ↔ quest oversight
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity PortalHub {
    traits: [agent_portal];
    agent_portal: {
      scene_id: "training_arena_001",
      scene_name: "Robot Training Arena",
      agent_id: "arena_master",
      capabilities: ["behavior_tree_sim", "sim2real_transfer", "curriculum_evolution"],
      relay_url: "wss://portal.holoscript.dev/robotics",
      auto_reconnect: true,
      max_hop_count: 4,
      default_ttl: 120000,
      max_outbox_size: 300,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ECONOMY — credits for successful transfers
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity EconomyEngine {
    traits: [economy];
    economy: {
      initial_balance: 100,
      default_spend_limit: 150,
      spend_limit_period: 3600000,
      max_transaction_history: 500,
      default_bounty_deadline: 600000,
      max_bounties_per_agent: 10,
      escrow_enabled: true,
      task_completion_reward: 20,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // FEEDBACK — curriculum evolution metrics
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity FeedbackEngine {
    traits: [feedback_loop];
    feedback_loop: {
      metrics: {
        sim_success_rate:    { target: 0.9,  min: 0, max: 1.0 },
        real_success_rate:   { target: 0.7,  min: 0, max: 1.0 },
        sim2real_gap:        { target: 0.1,  min: 0, max: 1.0 },
        training_throughput: { target: 50,   min: 0, max: 500 },
        collision_rate:      { target: 0.01, min: 0, max: 1.0 },
      },
      history_window: 200,
      min_samples_for_trend: 15,
      alert_threshold: 15,
      critical_threshold: 40,
      max_feedback_entries: 2000,
      auto_signal: true,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ROBOT TEMPLATES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  template "RobotLink" {
    @physics
    @collidable
    color: "#95a5a6"
    material: "aluminum_alloy"
  }

  template "RevoluteJoint" {
    @rotatable
    geometry: "cylinder"
    scale: [0.05, 0.04, 0.05]
    color: "#e74c3c"
    behavior "RevoluteJoint" {
      axis: [0, 0, 1]
      lowerLimit: -3.14159
      upperLimit: 3.14159
      maxVelocity: 2.094
      maxTorque: 150.0
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // AGENT TEMPLATES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  template "TrainerAgent" {
    @llm_agent
    @perception(range: 30)

    geometry: "capsule"
    color: "#ff6600"
    scale: [0.5, 1.0, 0.5]

    state {
      curriculum: "pick_and_place"
      episode_count: 0
      sim_successes: 0
      real_successes: 0
      credits: 100
    }

    on mount() {
      print("TrainerAgent " + this.id + " online — curriculum: " + state.curriculum)
    }

    action run_episode(taskConfig) {
      state.episode_count += 1
      // Simulate behavior tree execution
      emit("feedback:update_metric", { name: "training_throughput", value: state.episode_count })
      print("Running episode #" + state.episode_count + " for " + state.curriculum)
    }

    action report_sim_result(success) {
      if (success) { state.sim_successes += 1 }
      let rate = state.sim_successes / Math.max(1, state.episode_count)
      emit("feedback:update_metric", { name: "sim_success_rate", value: rate })
    }

    action transfer_to_real(robotSceneId) {
      // Spend credits on real hardware time
      emit("economy:spend", {
        agentId: this.id, amount: 15,
        reason: "Sim-to-real transfer: " + state.curriculum, target: "__hardware__"
      })
      emit(PortalHub, "portal:migrate_out", {
        agentId: this.id,
        name: "TrainerAgent",
        capabilities: ["behavior_tree_sim", "sim2real_transfer"],
        memory: {
          curriculum: state.curriculum,
          simSuccessRate: state.sim_successes / Math.max(1, state.episode_count)
        },
        state: { episode_count: state.episode_count, credits: state.credits },
        targetScene: robotSceneId,
      })
    }

    action sell_curriculum(buyerAgentId, price) {
      emit("economy:transfer", {
        from: buyerAgentId, to: this.id,
        amount: price, reason: "Curriculum purchase: " + state.curriculum,
        item: state.curriculum
      })
    }
  }

  template "PhysicalRobotTwin" {
    @digital_twin(
      physical_id: "ros2_arm_factory_01",
      sync_properties: [
        { physical_key: "joint_angles", virtual_property: "joints",     direction: "bidirectional" },
        { physical_key: "end_effector", virtual_property: "gripper_pos", direction: "in" },
        { physical_key: "force_torque", virtual_property: "force",      direction: "in" }
      ],
      update_mode: "push"
    )
    geometry: "cube"
    scale: [0.8, 2.0, 0.8]
    color: "#2c3e50"

    state { joints: [0, 0, 0, 0, 0, 0]; gripper_pos: [0, 0, 0]; force: [0, 0, 0] }

    on on_twin_sync(data) {
      if (data.state.force_torque && Math.abs(data.state.force_torque[2]) > 50) {
        pulsate(this.id, { color: "#ff0000", duration: 500 })
        emit("collision_detected", { robotId: this.id, force: data.state.force_torque })
      }
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // INSTANCES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  object "ArenaFloor" {
    geometry: "plane"; scale: [30, 1, 30]; color: "#1a1a1a"; position: [0, -0.5, 0]
  }
  object "SafetyFence" {
    geometry: "torus"; position: [0, 0.5, 0]; scale: [14, 0.8, 14]
    color: "#ffcc00"; opacity: 0.3
  }

  object "Trainer_Alpha" using "TrainerAgent" { position: [-5, 1, 3]; color: "#ff6600" }
  object "Trainer_Beta"  using "TrainerAgent" { position: [5, 1, 3]; color: "#ff9900" }
  object "Trainer_Gamma" using "TrainerAgent" { position: [0, 1, -5]; color: "#ffcc00" }

  object "RobotTwin_01" using "PhysicalRobotTwin" { position: [0, 1, 0] }

  object "TargetObject" {
    @grabbable
    @physics
    geometry: "cube"; position: [3, 0.5, 0]; scale: 0.1; color: "#e74c3c"
  }

  system "ROS2Bridge" {
    nodeName: "/training_arena"
    publishRate: 125
    topics: {
      jointStates: "/robot/joint_states",
      jointCmd: "/robot/joint_cmd",
      gripperCmd: "/robot/gripper_cmd"
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // GLOBAL EVENTS
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on_collision_detected(data) {
    emit("feedback:update_metric", { name: "collision_rate", value: 0.1 })
    emit("system_log", { level: "warn",
      message: "⚠️  Collision at " + data.robotId + " — force: " + JSON.stringify(data.force)
    })
  }

  on(EconomyEngine, "economy:transaction") {
    state.credits_exchanged += event.amount
  }

  on(FeedbackEngine, "feedback:optimization_signal") {
    if (event.suggestedAction === "increase_domain_randomization") {
      print("🎲 Auto-tuning: increasing domain randomization to close sim-to-real gap")
      state.curricula_evolved += 1
    }
    if (event.suggestedAction === "simplify_task") {
      print("📉 Auto-tuning: simplifying task — success rate too low")
      state.curricula_evolved += 1
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DASHBOARD
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  panel "TrainingDashboard" {
    position: "top-right"
    text "Title"  { content: "ROBOT TRAINING METAVERSE"; style: "heading" }
    text "T1"     { bind: "'Training episodes: ' + state.training_episodes"; style: "info" }
    text "T2"     { bind: "'Sim→Real transfers: ' + state.successful_transfers"; color: "#00ff88" }
    text "T3"     { bind: "'Credits exchanged: ' + state.credits_exchanged"; style: "info" }
    text "T4"     { bind: "'Curricula evolved: ' + state.curricula_evolved"; style: "info" }
    text "T5"     { bind: "'Active trainers: ' + state.active_trainers"; style: "info" }
  }
}
