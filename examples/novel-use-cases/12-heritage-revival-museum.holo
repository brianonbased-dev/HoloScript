/**
 * Cultural Heritage Revival & Living Museum Agents
 *
 * HeritageKeeper agents (loaded with cultural_trait libraries) guard
 * OpenUSD artifact twins, migrate from Quest visitor headsets → visionOS
 * elder storytelling sessions → ROS 2 robotic restoration arms.
 * EconomyPrimitives funds virtual restoration bounties. Cultural memory
 * preserves oral histories. Stigmergic traces mark artifact provenance.
 *
 * v5 Traits: agent_portal, economy, cultural_profile, cultural_memory,
 *            cultural_trace
 *
 * Studio prompt: "Build a living museum where AI keepers guard digital
 *   artifact twins, tell stories in culturally authentic dialects,
 *   and let visitors fund restoration bounties."
 *
 * Targets: AWE "Best Art or Film", AWE Societal Impact, heritage grants
 * @version 5.0.0
 */
composition "HeritageRevivalMuseum" {

  metadata {
    name: "Cultural Heritage Revival & Living Museum Agents"
    category: "cultural_heritage"
    platforms: ["webxr", "visionos", "quest", "r3f", "unity", "urdf"]
  }

  environment {
    skybox: "gradient"
    ambient_light: 0.4
    shadows: true
    physics: true
  }

  light "GallerySpot" {
    type: "directional"
    color: "#fff5e0"
    intensity: 0.8
    position: [3, 8, 5]
    cast_shadows: true
  }

  light "ArtifactGlow" {
    type: "point"
    color: "#ffcc88"
    intensity: 0.5
    position: [0, 2, 0]
    range: 10
  }

  post_processing {
    bloom: { enabled: true, intensity: 0.15, threshold: 0.8 }
    tone_mapping: { type: "aces", exposure: 1.0 }
  }

  state {
    artifacts_catalogued: 0
    stories_told: 0
    restoration_bounties: 0
    visitor_count: 0
    sops_formed: 0
    active_traces: 0
  }

  entity PortalHub {
    traits: [agent_portal];
    agent_portal: {
      scene_id: "museum_001",
      scene_name: "Living Heritage Museum",
      agent_id: "museum_curator",
      capabilities: ["storytelling", "artifact_restoration", "provenance_tracking"],
      relay_url: "wss://portal.holoscript.dev/heritage",
      auto_reconnect: true, max_hop_count: 4,
      default_ttl: 180000, max_outbox_size: 200,
    };
  }

  entity EconomyEngine {
    traits: [economy];
    economy: {
      initial_balance: 50,
      default_spend_limit: 40,
      spend_limit_period: 3600000,
      max_transaction_history: 300,
      default_bounty_deadline: 2592000000,
      max_bounties_per_agent: 10,
      escrow_enabled: true,
      task_completion_reward: 15,
    };
  }

  // ━━━ CULTURAL ZONES ━━━

  object "IndigenousWing" {
    position: [-15, 0, 0]; geometry: "cylinder"; scale: [12, 0.1, 12]
    color: "#8b4513"; opacity: 0.2
  }
  object "AncientWing" {
    position: [15, 0, 0]; geometry: "cylinder"; scale: [12, 0.1, 12]
    color: "#c9a84c"; opacity: 0.2
  }
  object "RestorationLab" {
    position: [0, 0, -20]; geometry: "cylinder"; scale: [10, 0.1, 10]
    color: "#95a5a6"; opacity: 0.2
  }

  // ━━━ STIGMERGIC TRACES (provenance markers) ━━━

  object "ProvenanceMarker_01" {
    @cultural_trace {
      traceType: "artifact"; intensity: 0.9; decayRate: 0
      label: "artifact provenance"; perceptionRadius: 8
    }
    position: [-12, 0.3, 3]; geometry: "cylinder"; scale: [0.2, 0.3, 0.2]
    color: "#8b4513"; emissive: "#8b4513"; emissive_intensity: 0.3
  }
  object "StorytellingMarker" {
    @cultural_trace {
      traceType: "signal"; intensity: 0.7; decayRate: 0.001
      label: "oral history site"; perceptionRadius: 12
    }
    position: [-15, 0.3, -5]; geometry: "sphere"; scale: [0.3, 0.3, 0.3]
    color: "#ffd700"; emissive: "#ffd700"; emissive_intensity: 0.5
  }

  // ━━━ AGENT TEMPLATES ━━━

  template "HeritageKeeper" {
    @llm_agent
    @perception(range: 20)
    @cultural_profile {
      cooperation_index: 0.9
      cultural_family: "cooperative"
      prompt_dialect: "socratic"
      norm_set: ["cultural_accuracy", "respectful_presentation", "provenance_integrity"]
    }
    @cultural_memory {
      capacity: 500; episodicDecayRate: 0.001; traceLifetime: 2000
      consolidation: true; consolidationThreshold: 3
    }

    geometry: "humanoid"; color: "#c9a84c"; scale: [0.8, 1.6, 0.8]

    state {
      assigned_wing: null
      stories_told: 0
      artifacts_guarded: 0
      sops_formed: 0
    }

    on mount() {
      print("HeritageKeeper " + this.id + " — guardian of " + state.assigned_wing)
    }

    action tell_story(artifactId, story) {
      state.stories_told += 1
      emit("story_told", {
        keeperId: this.id, artifactId: artifactId,
        story_excerpt: story.substring(0, 100),
        cultural_context: state.assigned_wing
      })
    }

    action post_restoration_bounty(artifactId, description, reward) {
      emit("economy:post_bounty", {
        posterId: this.id, reward: reward,
        description: "Restore " + artifactId + ": " + description,
        requiredCapabilities: ["artifact_restoration"],
        deadline: Date.now() + 2592000000, maxClaimants: 3,
      })
    }

    action migrate_to_elder_session(sceneId) {
      emit(PortalHub, "portal:migrate_out", {
        agentId: this.id, name: "HeritageKeeper",
        capabilities: ["storytelling", "provenance_tracking"],
        memory: {
          stories: state.stories_told,
          artifacts: state.artifacts_guarded,
          wing: state.assigned_wing
        },
        state: { sops: state.sops_formed },
        targetScene: sceneId,
      })
    }

    on_memory_consolidation(data) {
      state.sops_formed += 1
      emit("sop_formed", {
        agent_id: this.id, sop_type: data.pattern_type,
        confidence: data.confidence, episodes: data.episode_count
      })
    }

    on_trace_detected(trace) {
      if (trace.traceType === "artifact" && trace.label === "artifact provenance") {
        print("📜 Provenance trace detected — verifying authenticity")
      }
    }
  }

  // ━━━ INSTANCES ━━━

  object "MuseumFloor" { geometry: "plane"; scale: [50, 1, 50]; color: "#2c2c2c"; position: [0, -0.5, 0] }

  object "Keeper_Indigenous" using "HeritageKeeper" {
    position: [-13, 1, 2]; color: "#8b4513"
    state: { assigned_wing: "Indigenous Heritage" }
  }
  object "Keeper_Ancient" using "HeritageKeeper" {
    position: [13, 1, 2]; color: "#c9a84c"
    state: { assigned_wing: "Ancient Civilizations" }
  }

  // Artifact display stands
  object "Artifact_Mask" {
    geometry: "sphere"; position: [-12, 1.5, 0]; scale: [0.5, 0.7, 0.3]
    color: "#cd853f"; emissive: "#8b4513"; emissive_intensity: 0.1
  }
  object "Artifact_Vase" {
    geometry: "cylinder"; position: [12, 1.2, 0]; scale: [0.4, 0.8, 0.4]
    color: "#daa520"; emissive: "#c9a84c"; emissive_intensity: 0.1
  }

  // ━━━ GLOBAL EVENTS ━━━

  on_story_told(data) {
    state.stories_told += 1
    emit("system_log", { level: "info",
      message: "📖 " + data.keeperId + " told story about " + data.artifactId })
  }

  on_sop_formed(data) { state.sops_formed += 1 }
  on_trace_deposited(t) { state.active_traces += 1 }
  on_trace_evaporated(t) { state.active_traces -= 1 }

  on(EconomyEngine, "economy:bounty_posted") {
    state.restoration_bounties += 1
  }

  panel "HeritageDashboard" {
    position: "top-right"
    text "Title" { content: "LIVING MUSEUM"; style: "heading" }
    text "H1"    { bind: "'Stories told: ' + state.stories_told"; style: "info" }
    text "H2"    { bind: "'Restoration bounties: ' + state.restoration_bounties"; color: "#c9a84c" }
    text "H3"    { bind: "'SOPs (lore consolidated): ' + state.sops_formed"; style: "info" }
    text "H4"    { bind: "'Active provenance traces: ' + state.active_traces"; style: "info" }
  }
}
