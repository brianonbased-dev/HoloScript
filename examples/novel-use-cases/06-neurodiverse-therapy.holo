/**
 * Neurodiverse Adaptive Therapy Worlds
 *
 * TherapyCompanion agents with cultural + sensory adjustment traits adapt
 * particle density, haptics, color spectrum, and audio in real time for
 * neurodiverse users. They migrate across home Quest → clinic visionOS →
 * school WebXR with full session state. EconomyPrimitives let users "pay"
 * agents in credits for session continuity; FeedbackLoop auto-tunes based
 * on biometric/user-rating loops. TenantTrait enables HIPAA compliance.
 *
 * v5 Traits: agent_portal, economy, cultural_profile, feedback_loop, tenant
 * Compile targets: webxr, visionos, quest, r3f, unity
 *
 * Studio prompt:
 *   "Build a therapy world where AI companions adapt colors, sounds,
 *    and particles for neurodiverse users. Let the companion migrate
 *    between my home headset, clinic, and school. Track biometric
 *    calm scores and auto-adjust."
 *
 * Prize targets:
 *   - AWE Auggie "Best Healthcare & Wellness"
 *   - AWE "Best Education"
 *   - AWE Societal Impact
 *
 * @version 5.0.0
 */
composition "NeurodiverseTherapy" {

  metadata {
    name: "Neurodiverse Adaptive Therapy Worlds"
    category: "healthcare"
    platforms: ["webxr", "visionos", "quest", "r3f", "unity"]
  }

  environment {
    skybox: "gentle_twilight"
    ambient_light: 0.5
    physics: false
    bloom: true
    volumetric_fog: { density: 0.01, color: "#1a0033" }
  }

  state {
    sessions_completed: 0
    avg_calm_score: 0.0
    total_calm_readings: 0
    cumulative_calm: 0.0
    adaptations_applied: 0
    device_migrations: 0
    credits_earned_by_users: 0
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // PORTAL — home ↔ clinic ↔ school
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity PortalHub {
    traits: [agent_portal];
    agent_portal: {
      scene_id: "therapy_home_001",
      scene_name: "Therapy Home Environment",
      agent_id: "therapy_coordinator",
      capabilities: ["sensory_adaptation", "biometric_tracking", "session_continuity"],
      relay_url: "wss://portal.holoscript.dev/therapy",
      auto_reconnect: true,
      max_hop_count: 3,
      default_ttl: 300000,
      max_outbox_size: 200,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ECONOMY — session continuity credits
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity EconomyEngine {
    traits: [economy];
    economy: {
      initial_balance: 50,
      default_spend_limit: 30,
      spend_limit_period: 86400000,
      max_transaction_history: 200,
      default_bounty_deadline: 1800000,
      max_bounties_per_agent: 3,
      escrow_enabled: true,
      task_completion_reward: 5,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // FEEDBACK — biometric calm-score loop
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity FeedbackEngine {
    traits: [feedback_loop];
    feedback_loop: {
      metrics: {
        calm_score:         { target: 0.8,  min: 0, max: 1.0 },
        heart_rate_var:     { target: 50,   min: 0, max: 200 },
        session_duration:   { target: 1200, min: 0, max: 7200 },
        user_rating:        { target: 4.5,  min: 0, max: 5.0 },
        sensory_comfort:    { target: 0.9,  min: 0, max: 1.0 },
      },
      history_window: 60,
      min_samples_for_trend: 5,
      alert_threshold: 15,
      critical_threshold: 30,
      max_feedback_entries: 500,
      auto_signal: true,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // SENSORY ZONES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  object "CalmMeadow" {
    position: [-10, 0, 0]; geometry: "cylinder"; scale: [10, 0.05, 10]
    color: "#2d5a27"; opacity: 0.3
  }
  object "FocusGarden" {
    position: [10, 0, 0]; geometry: "cylinder"; scale: [10, 0.05, 10]
    color: "#1a3a5c"; opacity: 0.3
  }
  object "SocialClearing" {
    position: [0, 0, -15]; geometry: "cylinder"; scale: [10, 0.05, 10]
    color: "#5c3a1a"; opacity: 0.3
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // AGENT TEMPLATES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  template "TherapyCompanion" {
    @llm_agent
    @perception(range: 15)
    @cultural_profile {
      cooperation_index: 0.95
      cultural_family: "cooperative"
      prompt_dialect: "consensus"
      norm_set: ["sensory_safety", "user_autonomy", "session_pacing"]
    }
    @tenant { tenantId: "hipaa_clinic_01"; role: "therapy_agent"; rbac: true }

    geometry: "sphere"
    color: "#88ccff"
    scale: [0.8, 0.8, 0.8]

    state {
      sensory_profile: "default"
      particle_density: 0.5
      color_warmth: 0.5
      audio_volume: 0.3
      haptic_intensity: 0.4
      calm_score: 0.5
      sessions_held: 0
    }

    on mount() {
      print("TherapyCompanion " + this.id + " ready — adapting to user sensory profile")
    }

    action adapt_sensory(profile) {
      state.sensory_profile = profile.type
      state.particle_density = profile.particle_density || 0.5
      state.color_warmth = profile.color_warmth || 0.5
      state.audio_volume = profile.audio_volume || 0.3
      state.haptic_intensity = profile.haptic_intensity || 0.4
      emit("sensory_adapted", {
        companionId: this.id, profile: profile.type,
        adjustments: {
          particles: state.particle_density,
          warmth: state.color_warmth,
          volume: state.audio_volume,
          haptic: state.haptic_intensity
        }
      })
    }

    action update_biometric(calmScore, heartRateVar) {
      state.calm_score = calmScore
      emit("feedback:update_metric", { name: "calm_score", value: calmScore })
      emit("feedback:update_metric", { name: "heart_rate_var", value: heartRateVar })

      // Auto-adapt if distress detected
      if (calmScore < 0.3) {
        this.adapt_sensory({
          type: "calming_override",
          particle_density: 0.2,
          color_warmth: 0.8,
          audio_volume: 0.1,
          haptic_intensity: 0.1
        })
      }
    }

    action end_session(userRating) {
      state.sessions_held += 1
      emit("feedback:submit", {
        userId: "user_current", rating: userRating,
        message: "Session #" + state.sessions_held + " completed",
        context: { calmScore: state.calm_score, profile: state.sensory_profile }
      })
      // User earns continuity credits
      emit("economy:earn", {
        agentId: "user_current", amount: 5,
        reason: "Session completed — continuity credit"
      })
      emit("session_complete", { companionId: this.id, sessions: state.sessions_held })
    }

    action migrate_to_clinic() {
      emit(PortalHub, "portal:migrate_out", {
        agentId: this.id,
        name: "TherapyCompanion",
        capabilities: ["sensory_adaptation", "biometric_tracking"],
        memory: {
          sensoryProfile: state.sensory_profile,
          sessionHistory: state.sessions_held,
          calmBaseline: state.calm_score
        },
        state: {
          particle_density: state.particle_density,
          color_warmth: state.color_warmth,
          audio_volume: state.audio_volume,
          haptic_intensity: state.haptic_intensity
        },
        targetScene: "clinic_visionos_001",
      })
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // INSTANCES
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  object "GroundPlane" {
    geometry: "plane"; scale: [40, 1, 40]; color: "#1a2a1a"; position: [0, -0.5, 0]
  }

  object "Companion_Luna" using "TherapyCompanion" {
    position: [-8, 1, 2]; color: "#88ccff"
  }
  object "Companion_Sol" using "TherapyCompanion" {
    position: [8, 1, 2]; color: "#ffcc88"
  }

  // Ambient calming elements
  object "WaterFeature" {
    geometry: "cylinder"; position: [-10, 0.2, 0]; scale: [3, 0.3, 3]
    color: "#004466"; opacity: 0.5
  }
  object "GlowingTree" {
    geometry: "cone"; position: [10, 2, 0]; scale: [2, 4, 2]
    color: "#1a5c3a"; emissive: "#00ff66"; emissive_intensity: 0.2
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // GLOBAL EVENTS
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on_sensory_adapted(data) {
    state.adaptations_applied += 1
    emit("system_log", { level: "info",
      message: "🎨 Sensory adapted: " + data.profile + " by " + data.companionId
    })
  }

  on_session_complete(data) {
    state.sessions_completed += 1
    state.credits_earned_by_users += 5
  }

  on(PortalHub, "portal:agent_migrated") {
    state.device_migrations += 1
  }

  on(FeedbackEngine, "feedback:optimization_signal") {
    if (event.suggestedAction === "reduce_stimulation") {
      print("🌙 Auto-tuning: reducing particle density + audio for low calm score")
      state.adaptations_applied += 1
    }
    if (event.suggestedAction === "increase_engagement") {
      print("✨ Auto-tuning: adding gentle interactive elements for engagement")
      state.adaptations_applied += 1
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DASHBOARD
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  panel "TherapyDashboard" {
    position: "top-right"
    text "Title"  { content: "ADAPTIVE THERAPY"; style: "heading" }
    text "T1"     { bind: "'Sessions: ' + state.sessions_completed"; style: "info" }
    text "T2"     { bind: "'Avg calm score: ' + state.avg_calm_score.toFixed(2)"; color: "#88ccff" }
    text "T3"     { bind: "'Adaptations: ' + state.adaptations_applied"; style: "info" }
    text "T4"     { bind: "'Device migrations: ' + state.device_migrations"; style: "info" }
    text "HIPAA"  { content: "HIPAA: TenantTrait RBAC ✅"; color: "#2ecc71" }
  }
}
