/**
 * Decentralized Urban Planning & Governance Simulator
 *
 * UrbanSteward agents migrate across public WebXR town halls → municipal
 * visionOS dashboards → ROS 2 traffic-light hardware. EconomyPrimitives
 * runs in-scene referendums with escrow. FeedbackLoop optimizes sim
 * fidelity based on crowd feedback. TenantTrait handles multi-city RBAC.
 * Norm enforcement ensures democratic process integrity.
 *
 * v5 Traits: agent_portal, economy, norm_compliant, feedback_loop, tenant
 *
 * Studio prompt: "Build a smart city simulator where AI stewards run
 *   referendums with bounties, citizens vote on zoning and traffic,
 *   and the sim auto-optimizes based on crowd feedback."
 *
 * Targets: AWE Enterprise, Smart City tracks
 * @version 5.0.0
 */
composition "UrbanPlanningGovernance" {

  metadata {
    name: "Decentralized Urban Planning & Governance Simulator"
    category: "smart_city"
    platforms: ["webxr", "visionos", "r3f", "unity", "dtdl"]
  }

  environment {
    skybox: "city_sunset"
    ambient_light: 0.6
    physics: true
  }

  state {
    proposals_submitted: 0
    votes_cast: 0
    referendums_completed: 0
    policy_changes: 0
    citizen_satisfaction: 0.0
    norm_violations: 0
  }

  entity PortalHub {
    traits: [agent_portal];
    agent_portal: {
      scene_id: "urban_sim_001",
      scene_name: "Urban Planning Town Hall",
      agent_id: "urban_coordinator",
      capabilities: ["zoning_analysis", "traffic_optimization", "referendum_hosting"],
      relay_url: "wss://portal.holoscript.dev/urban",
      auto_reconnect: true,
      max_hop_count: 4,
      default_ttl: 120000,
      max_outbox_size: 300,
    };
  }

  entity EconomyEngine {
    traits: [economy];
    economy: {
      initial_balance: 100,
      default_spend_limit: 80,
      spend_limit_period: 3600000,
      max_transaction_history: 500,
      default_bounty_deadline: 1800000,
      max_bounties_per_agent: 10,
      escrow_enabled: true,
      task_completion_reward: 10,
    };
  }

  entity FeedbackEngine {
    traits: [feedback_loop];
    feedback_loop: {
      metrics: {
        citizen_satisfaction: { target: 0.8,  min: 0, max: 1.0 },
        traffic_flow:        { target: 0.85, min: 0, max: 1.0 },
        green_space_ratio:   { target: 0.3,  min: 0, max: 1.0 },
        housing_density:     { target: 0.6,  min: 0, max: 1.0 },
        voter_turnout:       { target: 0.7,  min: 0, max: 1.0 },
      },
      history_window: 60,
      min_samples_for_trend: 5,
      alert_threshold: 15,
      critical_threshold: 30,
      auto_signal: true,
    };
  }

  // ━━━ GOVERNANCE ZONES ━━━

  object "TownHallZone" {
    position: [0, 0, 0]; geometry: "cylinder"; scale: [15, 0.1, 15]
    color: "#3498db"; opacity: 0.2
  }
  object "TownHallGuardian" {
    position: [0, 1.5, -12]; geometry: "capsule"; color: "#2980b9"
    @norm_compliant {
      norms: ["one_vote_per_citizen", "transparent_tally", "no_bribery"]
      enforcement: "hard"; scope: "zone"; canPropose: false; canEnforce: true
    }
    on_vote_attempt(data) {
      if (data.already_voted) {
        emit("norm_violation", {
          norm_id: "one_vote_per_citizen", enforcement: "hard",
          agent_id: data.voter_id, zone: "TownHall",
          message: "BLOCKED: duplicate vote"
        })
        return false
      }
    }
  }

  // ━━━ AGENT TEMPLATES ━━━

  template "UrbanSteward" {
    @llm_agent
    @perception(range: 30)
    @tenant { tenantId: "city_001"; role: "steward"; rbac: true }

    geometry: "humanoid"; color: "#3498db"; scale: [0.8, 1.6, 0.8]

    state {
      proposals_made: 0
      referendums_hosted: 0
      district: null
    }

    on mount() {
      print("UrbanSteward " + this.id + " managing district " + state.district)
    }

    action submit_proposal(title, description, category) {
      state.proposals_made += 1
      emit("economy:post_bounty", {
        posterId: this.id, reward: 20,
        description: title + ": " + description,
        requiredCapabilities: ["urban_analysis"],
        deadline: Date.now() + 1800000, maxClaimants: 10,
      })
      emit("proposal_submitted", {
        stewardId: this.id, title: title,
        category: category, timestamp: Date.now()
      })
    }

    action host_referendum(proposalId) {
      state.referendums_hosted += 1
      emit("referendum_started", {
        stewardId: this.id, proposalId: proposalId,
        deadline: Date.now() + 900000
      })
    }

    action migrate_to_dashboard(citySceneId) {
      emit(PortalHub, "portal:migrate_out", {
        agentId: this.id, name: "UrbanSteward",
        capabilities: ["zoning_analysis", "traffic_optimization"],
        memory: { proposals: state.proposals_made, district: state.district },
        state: { referendums: state.referendums_hosted },
        targetScene: citySceneId,
      })
    }
  }

  template "CitizenVoter" {
    @llm_agent
    @perception(range: 15)

    geometry: "capsule"; color: "#ecf0f1"; scale: [0.4, 0.8, 0.4]
    state { votes_cast: 0; satisfaction: 0.5 }

    action vote(proposalId, approve) {
      state.votes_cast += 1
      emit("vote_cast", { voterId: this.id, proposalId: proposalId, approve: approve })
      emit("feedback:submit", {
        userId: this.id, rating: approve ? 4 : 2,
        message: (approve ? "Approve" : "Reject") + " proposal " + proposalId
      })
    }
  }

  // ━━━ INSTANCES ━━━

  object "CityGrid" { geometry: "plane"; scale: [40, 1, 40]; color: "#2c3e50"; position: [0, -0.5, 0] }

  object "Steward_Zoning"  using "UrbanSteward" { position: [-5, 1, 3]; color: "#3498db" }
  object "Steward_Traffic" using "UrbanSteward" { position: [5, 1, 3]; color: "#2ecc71" }

  object "Citizen_01" using "CitizenVoter" { position: [-3, 0.5, -2] }
  object "Citizen_02" using "CitizenVoter" { position: [0, 0.5, -4] }
  object "Citizen_03" using "CitizenVoter" { position: [3, 0.5, -2] }
  object "Citizen_04" using "CitizenVoter" { position: [-1, 0.5, -6] }

  // City models
  object "Building_A" { geometry: "cube"; position: [-8, 3, -8]; scale: [3, 6, 3]; color: "#34495e" }
  object "Building_B" { geometry: "cube"; position: [8, 2, -8]; scale: [4, 4, 4]; color: "#2c3e50" }
  object "Park"       { geometry: "cylinder"; position: [0, 0.1, 8]; scale: [6, 0.1, 6]; color: "#27ae60"; opacity: 0.4 }

  // ━━━ GLOBAL EVENTS ━━━

  on_proposal_submitted(data) {
    state.proposals_submitted += 1
  }

  on_vote_cast(data) {
    state.votes_cast += 1
    emit("feedback:update_metric", { name: "voter_turnout", value: state.votes_cast / 10 })
  }

  on_norm_violation(data) {
    state.norm_violations += 1
    emit("system_log", { level: "error", message: "[" + data.enforcement + "] " + data.norm_id + " by " + data.agent_id })
  }

  on(FeedbackEngine, "feedback:optimization_signal") {
    if (event.suggestedAction === "increase_green_space") {
      print("🌳 Auto-suggesting: increase green space ratio in next proposal cycle")
    }
  }

  panel "UrbanDashboard" {
    position: "top-right"
    text "Title" { content: "URBAN GOVERNANCE"; style: "heading" }
    text "U1"    { bind: "'Proposals: ' + state.proposals_submitted"; style: "info" }
    text "U2"    { bind: "'Votes cast: ' + state.votes_cast"; style: "info" }
    text "U3"    { bind: "'Referendums: ' + state.referendums_completed"; color: "#3498db" }
    text "U4"    { bind: "'Policy changes: ' + state.policy_changes"; color: "#00ff88" }
    text "U5"    { bind: "'Norm violations: ' + state.norm_violations"; color: "#e74c3c" }
  }
}
