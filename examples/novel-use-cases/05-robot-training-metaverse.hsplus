/**
 * Physical-AI Robot Training Metaverse — .hsplus Behavior
 *
 * WHY .hsplus: Sim-to-real transfer requires a state machine
 * (train → evaluate → decide_transfer → sim2real → validate) with
 * guard conditions and module-encapsulated curriculum logic.
 *
 * @version 5.0.0
 * @format .hsplus (behavior)
 */
composition "RobotTrainingMetaverse" {
  environment {
    skybox: "training_arena"
    ambient_light: 0.5
    physics: true
    physics_engine: "ode"
    gravity: [0, -9.81, 0]
  }

  module CurriculumEngine {
    state {
      levels: []
      current_level: 0
      total_episodes: 0
      success_threshold: 0.85
    }

    action add_level(name, difficulty, scenarios) {
      this.state.levels.push({
        name: name, difficulty: difficulty,
        scenarios: scenarios, pass_count: 0, attempts: 0
      });
    }

    action record_result(level_index, success) {
      const level = this.state.levels[level_index];
      if (!level) return;
      level.attempts += 1;
      if (success) level.pass_count += 1;
      this.state.total_episodes += 1;

      const rate = level.pass_count / level.attempts;
      emit("feedback:update_metric", { name: "success_rate", value: rate });

      if (rate >= this.state.success_threshold && level.attempts >= 10) {
        emit("curriculum:level_mastered", { level: level_index, rate: rate });
      }
    }

    action advance() {
      if (this.state.current_level < this.state.levels.length - 1) {
        this.state.current_level += 1;
        emit("curriculum:advanced", { new_level: this.state.current_level });
      }
    }

    exports { add_level, record_result, advance, state }
  }

  module Sim2RealBridge {
    state {
      transfers_attempted: 0
      transfers_successful: 0
      sim_real_gap: 1.0
      connected_robots: []
    }

    action register_robot(robot_id, capabilities) {
      this.state.connected_robots.push({
        id: robot_id, capabilities: capabilities,
        status: "idle", last_transfer: null
      });
      emit("bridge:robot_registered", { robot_id: robot_id });
    }

    action transfer(agent_id, robot_id, policy) {
      this.state.transfers_attempted += 1;
      const robot = this.state.connected_robots.find(r => r.id === robot_id);
      if (!robot) {
        emit("bridge:transfer_failed", { reason: "robot_not_found" });
        return;
      }

      robot.status = "transferring";
      emit("economy:spend", {
        agentId: agent_id, amount: 20,
        reason: "Sim-to-real transfer to " + robot_id,
        target: robot_id
      });
      emit("bridge:transfer_started", {
        agent_id: agent_id, robot_id: robot_id
      });
    }

    action confirm_transfer(robot_id, gap_metric) {
      const robot = this.state.connected_robots.find(r => r.id === robot_id);
      if (robot) {
        robot.status = "active";
        robot.last_transfer = current_time();
      }
      this.state.transfers_successful += 1;
      this.state.sim_real_gap = gap_metric;
      emit("feedback:update_metric", { name: "sim2real_gap", value: gap_metric });
      emit("bridge:transfer_complete", { robot_id: robot_id, gap: gap_metric });
    }

    exports { register_robot, transfer, confirm_transfer, state }
  }

  template "TrainerAgent" {
    @llm_agent
    @perception(range: 30)

    @state_machine {
      initial: "training"

      states: {
        training: {
          on_episode_complete: -> "evaluating" action(log_episode)
        }
        evaluating: {
          on_mastered: -> "deciding_transfer"
          on_not_mastered: -> "training"
        }
        deciding_transfer: {
          on_transfer_approved: -> "transferring" guard(state.credits >= 20)
          on_transfer_denied: -> "training"
        }
        transferring: {
          on_transfer_complete: -> "validating"
          on_transfer_failed: -> "training" action(on_transfer_error)
        }
        validating: {
          on_validation_passed: -> "training" action(on_validated)
          on_validation_failed: -> "training" action(on_validation_error)
        }
      }

      actions: {
        log_episode: () => {
          state.episodes_run += 1;
        }
        on_validated: () => {
          state.successful_transfers += 1;
          emit("economy:earn", {
            agentId: state.agent_id, amount: 30,
            reason: "Successful sim-to-real transfer"
          });
        }
        on_transfer_error: () => {
          emit("trainer:error", { agent_id: state.agent_id, phase: "transfer" });
        }
        on_validation_error: () => {
          emit("trainer:error", { agent_id: state.agent_id, phase: "validation" });
        }
      }
    }

    state {
      agent_id: null
      credits: 150
      episodes_run: 0
      successful_transfers: 0
    }

    @on_event("curriculum:level_mastered"): (data) => {
      if (this.current_state === "evaluating") {
        emit("on_mastered");
      }
    }

    @on_event("bridge:transfer_complete"): (data) => {
      if (this.current_state === "transferring") {
        emit("on_transfer_complete");
      }
    }

    action run_episode(scenario) {
      const success = Math.random() > 0.3;
      CurriculumEngine.record_result(CurriculumEngine.state.current_level, success);
      emit("on_episode_complete");
    }
  }

  // Instances
  object "ArenaFloor" { @collidable; geometry: "plane"; position: [0, 0, 0]; scale: [30, 1, 30]; color: "#1a1a1a" }
  object "Trainer_A" using "TrainerAgent" { position: [-5, 1, 0]; geometry: "capsule"; color: "#ff6600"; state { agent_id: "trainer_alpha" } }
  object "Trainer_B" using "TrainerAgent" { position: [5, 1, 0]; geometry: "capsule"; color: "#0066ff"; state { agent_id: "trainer_beta" } }

  panel "TrainingStatus" {
    position: "top-right"
    text "Episodes" { bind: "Episodes: " + CurriculumEngine.state.total_episodes; style: "info" }
    text "Level" { bind: "Level: " + CurriculumEngine.state.current_level; color: "#ffd700" }
    text "Transfers" { bind: "Transfers: " + Sim2RealBridge.state.transfers_successful; color: "#00ff88" }
    text "Gap" { bind: "Sim-Real gap: " + Sim2RealBridge.state.sim_real_gap; style: "info" }
  }
}
