/**
 * Cultural Heritage Revival Museum — .hsplus Behavior
 *
 * WHY .hsplus: Heritage storytelling requires @cultural_memory
 * consolidation callbacks, reactive trace detection, and module-
 * encapsulated provenance and restoration bounty management.
 *
 * @version 5.0.0
 * @format .hsplus (behavior)
 */
composition "HeritageRevivalMuseum" {
  environment { skybox: "warm_gallery"; ambient_light: 0.55; physics: true }

  module ProvenanceRegistry {
    state { artifacts: {}; total_verified: 0 }
    action register(artifact_id, origin, era, condition) {
      this.state.artifacts[artifact_id] = { origin: origin, era: era, condition: condition, verified: false, chain: [], registered_at: current_time() };
      emit("provenance:registered", { artifact_id: artifact_id });
    }
    action verify(artifact_id, verifier_id) {
      const a = this.state.artifacts[artifact_id];
      if (!a) return;
      a.verified = true;
      a.chain.push({ verifier: verifier_id, at: current_time() });
      this.state.total_verified += 1;
      emit("provenance:verified", { artifact_id: artifact_id, verifier: verifier_id });
    }
    exports { register, verify, state }
  }

  module RestorationManager {
    state { bounties: []; completed: 0 }
    action post_bounty(artifact_id, description, reward, keeper_id) {
      const b = { id: generate_id(), artifact_id: artifact_id, description: description, reward: reward, poster: keeper_id, status: "open", posted_at: current_time() };
      this.state.bounties.push(b);
      emit("economy:post_bounty", { posterId: keeper_id, reward: reward, description: "Restore: " + description, requiredCapabilities: ["artifact_restoration"], deadline: Date.now() + 2592000000, maxClaimants: 3 });
      emit("restoration:posted", b);
    }
    action complete(bounty_id) {
      const b = this.state.bounties.find(x => x.id === bounty_id);
      if (b) { b.status = "completed"; this.state.completed += 1; }
      emit("restoration:completed", { bounty_id: bounty_id });
    }
    exports { post_bounty, complete, state }
  }

  template "HeritageKeeper" {
    @llm_agent
    @perception(range: 20)
    @cultural_profile { cooperation_index: 0.9; cultural_family: "cooperative"; prompt_dialect: "socratic"; norm_set: ["cultural_accuracy", "provenance_integrity"] }
    @cultural_memory { capacity: 500; episodicDecayRate: 0.001; traceLifetime: 2000; consolidation: true; consolidationThreshold: 3 }

    @state_machine {
      initial: "guarding"
      states: {
        guarding: { on_visitor_approaches: -> "storytelling"; on_restoration_needed: -> "restoring" }
        storytelling: { on_story_complete: -> "guarding" action(log_story) }
        restoring: { on_bounty_posted: -> "guarding" action(log_restoration) }
      }
      actions: {
        log_story: () => { state.stories_told += 1; emit("economy:earn", { agentId: state.keeper_id, amount: 5, reason: "Story told" }); }
        log_restoration: () => { state.restorations_initiated += 1; }
      }
    }

    state { keeper_id: null; wing: null; stories_told: 0; restorations_initiated: 0; sops_formed: 0 }

    on_memory_consolidation(data) {
      state.sops_formed += 1;
      emit("sop_formed", { agent_id: state.keeper_id, type: data.pattern_type });
    }

    @on_event("cultural_trace:detected"): (trace) => {
      if (trace.traceType === "artifact") {
        ProvenanceRegistry.verify(trace.label, state.keeper_id);
      }
    }

    action tell_story(artifact_id, story_text) {
      emit("keeper:story_told", { keeper: state.keeper_id, artifact: artifact_id, excerpt: story_text.substring(0, 80) });
      emit("on_story_complete");
    }
  }

  object "MuseumFloor" { @collidable; geometry: "plane"; position: [0, -0.5, 0]; scale: [50, 1, 50]; color: "#2c2c2c" }
  object "Keeper_A" using "HeritageKeeper" { position: [-13, 1, 2]; geometry: "humanoid"; color: "#8b4513"; state { keeper_id: "keeper_indigenous"; wing: "Indigenous Heritage" } }
  object "Keeper_B" using "HeritageKeeper" { position: [13, 1, 2]; geometry: "humanoid"; color: "#c9a84c"; state { keeper_id: "keeper_ancient"; wing: "Ancient Civilizations" } }

  panel "HeritageDashboard" {
    position: "top-right"
    text "Verified" { bind: "Verified: " + ProvenanceRegistry.state.total_verified; style: "info" }
    text "Restored" { bind: "Restored: " + RestorationManager.state.completed; color: "#c9a84c" }
  }
}
