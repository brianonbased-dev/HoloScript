/**
 * Agent Portal Federation — .hsplus Behavior Example
 *
 * Demonstrates inter-scene agent communication via the AgentPortalTrait.
 * WHY .hsplus: Portal connections are inherently stateful (disconnected,
 * connecting, connected, migrating) with event-driven transitions that
 * require reactive state machines. Neither .holo (static scene) nor
 * .hs (sequential script) can express connection lifecycle guards,
 * automatic reconnection loops, or message routing reactively.
 *
 * Features:
 * - Connection lifecycle state machine with reconnection guards
 * - MessageRouter module for inbound dispatch and outbound queuing
 * - FederationDirectory module for scene/agent discovery
 * - Two simulated portal agents demonstrating cross-scene messaging
 * - Heartbeat monitoring with offline detection
 *
 * @version 5.0.0
 * @format .hsplus (behavior)
 */

composition "AgentPortalFederation" {
  environment {
    skybox: "nebula"
    ambient_light: 0.4
    physics: false
  }

  // ========================================================================
  // MESSAGE ROUTER MODULE
  // ========================================================================
  // Encapsulates all message routing logic: inbound dispatch by topic,
  // outbound queuing with retry, and dead-letter handling.

  module MessageRouter {
    state {
      inbound_queue: []
      outbound_queue: []
      dead_letters: []
      routes: {}
      messages_routed: 0
      max_outbox_size: 256
      retry_limit: 3
    }

    // Register a handler for a specific message topic
    action register_route(topic, handler) {
      this.state.routes[topic] = handler;
      emit("router:route_registered", { topic: topic });
    }

    // Dispatch an inbound message to the appropriate handler
    action dispatch(message) {
      const handler = this.state.routes[message.topic];

      if (handler) {
        handler(message);
        this.state.messages_routed += 1;
        emit("router:dispatched", {
          topic: message.topic,
          from: message.sender_id,
          count: this.state.messages_routed
        });
      } else {
        // No handler registered -- dead letter
        this.state.dead_letters.push({
          message: message,
          reason: "no_route",
          timestamp: current_time()
        });
        emit("router:dead_letter", { topic: message.topic });
      }
    }

    // Queue an outbound message for delivery
    action enqueue_outbound(target_scene, topic, payload) {
      if (this.state.outbound_queue.length >= this.state.max_outbox_size) {
        // Drop oldest message to prevent unbounded growth
        const dropped = this.state.outbound_queue.shift();
        emit("router:outbox_overflow", { dropped_topic: dropped.topic });
      }

      const message = {
        id: generate_id(),
        target_scene: target_scene,
        topic: topic,
        payload: payload,
        attempts: 0,
        created_at: current_time()
      };

      this.state.outbound_queue.push(message);
      emit("router:enqueued", { id: message.id, topic: topic });
      return message.id;
    }

    // Flush outbound queue -- called when portal is connected
    action flush_outbound() {
      const pending = this.state.outbound_queue.splice(0);
      for (const msg of pending) {
        msg.attempts += 1;
        emit("portal:send", {
          target_scene: msg.target_scene,
          topic: msg.topic,
          payload: msg.payload,
          message_id: msg.id
        });
      }
      emit("router:flushed", { count: pending.length });
    }

    // Handle delivery failure -- re-enqueue or dead-letter
    action handle_send_failure(message_id, error) {
      const idx = this.state.outbound_queue.findIndex(m => m.id === message_id);
      if (idx === -1) return;

      const msg = this.state.outbound_queue[idx];
      if (msg.attempts >= this.state.retry_limit) {
        this.state.outbound_queue.splice(idx, 1);
        this.state.dead_letters.push({
          message: msg,
          reason: "max_retries",
          error: error,
          timestamp: current_time()
        });
        emit("router:delivery_failed", { id: message_id, topic: msg.topic });
      }
    }

    exports {
      register_route
      dispatch
      enqueue_outbound
      flush_outbound
      handle_send_failure
      state
    }
  }

  // ========================================================================
  // FEDERATION DIRECTORY MODULE
  // ========================================================================
  // Tracks discovered remote scenes, their capabilities, and connected
  // agents. Provides query-by-capability for targeted messaging.

  module FederationDirectory {
    state {
      scenes: {}
      agents: {}
      last_query_time: 0
      discovery_count: 0
    }

    // Register a newly discovered scene
    action register_scene(scene_id, scene_name, capabilities) {
      this.state.scenes[scene_id] = {
        id: scene_id,
        name: scene_name,
        capabilities: capabilities || [],
        discovered_at: current_time(),
        last_seen: current_time(),
        status: "online"
      };
      this.state.discovery_count += 1;
      emit("directory:scene_added", { scene_id: scene_id, name: scene_name });
    }

    // Remove a scene that has gone offline
    action remove_scene(scene_id) {
      if (this.state.scenes[scene_id]) {
        this.state.scenes[scene_id].status = "offline";
        emit("directory:scene_removed", { scene_id: scene_id });
      }
    }

    // Register an agent in the directory
    action register_agent(agent_id, scene_id, capabilities) {
      this.state.agents[agent_id] = {
        id: agent_id,
        scene_id: scene_id,
        capabilities: capabilities || [],
        registered_at: current_time(),
        last_seen: current_time()
      };
      emit("directory:agent_registered", {
        agent_id: agent_id,
        scene_id: scene_id
      });
    }

    // Update agent location after migration
    action update_agent_location(agent_id, new_scene_id) {
      if (this.state.agents[agent_id]) {
        const old_scene = this.state.agents[agent_id].scene_id;
        this.state.agents[agent_id].scene_id = new_scene_id;
        this.state.agents[agent_id].last_seen = current_time();
        emit("directory:agent_moved", {
          agent_id: agent_id,
          from: old_scene,
          to: new_scene_id
        });
      }
    }

    // Query agents by capability
    action find_agents_by_capability(capability) {
      this.state.last_query_time = current_time();
      const results = [];
      for (const [id, agent] of Object.entries(this.state.agents)) {
        if (agent.capabilities.includes(capability)) {
          results.push(agent);
        }
      }
      emit("directory:query_result", {
        capability: capability,
        count: results.length
      });
      return results;
    }

    // Query scenes by capability
    action find_scenes_by_capability(capability) {
      const results = [];
      for (const [id, scene] of Object.entries(this.state.scenes)) {
        if (scene.status === "online" && scene.capabilities.includes(capability)) {
          results.push(scene);
        }
      }
      return results;
    }

    exports {
      register_scene
      remove_scene
      register_agent
      update_agent_location
      find_agents_by_capability
      find_scenes_by_capability
      state
    }
  }

  // ========================================================================
  // PORTAL AGENT TEMPLATE
  // ========================================================================
  // Defines the connection lifecycle state machine. Every portal agent
  // follows this pattern: disconnected -> connecting -> connected -> migrating.
  // Guards prevent invalid transitions (e.g., cannot migrate while disconnected).

  template "PortalAgent" {
    @agent_portal {
      auto_reconnect: true
      reconnect_delay: 2000
      max_reconnect_attempts: 5
      heartbeat_interval: 5000
      offline_threshold: 15000
      max_hop_count: 4
      default_ttl: 30000
      max_outbox_size: 256
    }

    @state_machine {
      initial: "disconnected"

      states: {
        disconnected: {
          on_connect: -> "connecting"
          on_migrate_request: -> "disconnected"  // reject, log warning
        }

        connecting: {
          on_ws_connected: -> "connected" action(on_connection_established)
          on_ws_failed: -> "disconnected" action(on_connection_failed)
          on_timeout: -> "disconnected" action(on_connection_timeout)
        }

        connected: {
          on_disconnect: -> "disconnected" action(on_graceful_disconnect)
          on_ws_disconnected: -> "reconnecting" action(on_unexpected_disconnect)
          on_migrate_request: -> "migrating" guard(state.migration_target != null)
          on_heartbeat_timeout: -> "reconnecting" action(on_heartbeat_lost)
        }

        reconnecting: {
          on_ws_connected: -> "connected" action(on_reconnection_success)
          on_max_retries: -> "disconnected" action(on_reconnect_exhausted)
          on_cancel: -> "disconnected"
        }

        migrating: {
          on_migration_complete: -> "connected" action(on_migration_arrived)
          on_migration_failed: -> "connected" action(on_migration_rollback)
          on_timeout: -> "connected" action(on_migration_timeout)
        }
      }

      actions: {
        on_connection_established: () => {
          state.reconnect_attempts = 0;
          state.connected_at = current_time();
          state.last_heartbeat = current_time();
          MessageRouter.flush_outbound();
          emit("portal:connected", {
            scene_id: state.scene_id,
            agent_id: state.agent_id
          });
        }

        on_connection_failed: () => {
          state.last_error = "Connection refused";
          emit("portal:connection_failed", {
            agent_id: state.agent_id,
            error: state.last_error
          });
        }

        on_connection_timeout: () => {
          state.last_error = "Connection timed out";
          emit("portal:connection_timeout", { agent_id: state.agent_id });
        }

        on_graceful_disconnect: () => {
          state.connected_at = null;
          emit("portal:disconnected", {
            agent_id: state.agent_id,
            reason: "graceful"
          });
        }

        on_unexpected_disconnect: () => {
          state.reconnect_attempts += 1;
          emit("portal:disconnected", {
            agent_id: state.agent_id,
            reason: "unexpected",
            attempt: state.reconnect_attempts
          });
        }

        on_heartbeat_lost: () => {
          state.reconnect_attempts += 1;
          emit("portal:disconnected", {
            agent_id: state.agent_id,
            reason: "heartbeat_timeout"
          });
        }

        on_reconnection_success: () => {
          state.reconnect_attempts = 0;
          state.last_heartbeat = current_time();
          MessageRouter.flush_outbound();
          emit("portal:reconnected", { agent_id: state.agent_id });
        }

        on_reconnect_exhausted: () => {
          state.last_error = "Max reconnection attempts reached";
          emit("portal:reconnect_failed", {
            agent_id: state.agent_id,
            attempts: state.reconnect_attempts
          });
        }

        on_migration_arrived: () => {
          const old_scene = state.scene_id;
          state.scene_id = state.migration_target;
          state.migration_target = null;
          FederationDirectory.update_agent_location(
            state.agent_id, state.scene_id
          );
          emit("portal:agent_migrated", {
            agent_id: state.agent_id,
            from: old_scene,
            to: state.scene_id
          });
        }

        on_migration_rollback: () => {
          state.migration_target = null;
          state.last_error = "Migration failed, rolled back";
          emit("portal:migration_failed", { agent_id: state.agent_id });
        }

        on_migration_timeout: () => {
          state.migration_target = null;
          state.last_error = "Migration timed out";
          emit("portal:migration_timeout", { agent_id: state.agent_id });
        }
      }
    }

    state {
      agent_id: null
      scene_id: null
      relay_url: null
      connected_at: null
      last_heartbeat: null
      reconnect_attempts: 0
      migration_target: null
      last_error: null
      messages_sent: 0
      messages_received: 0
      capabilities: []
    }

    // ------------------------------------------------------------------
    // Heartbeat monitoring -- detect stale connections
    // ------------------------------------------------------------------
    @on_update: (delta) => {
      if (this.current_state !== "connected") return;

      const elapsed = current_time() - state.last_heartbeat;
      if (elapsed > 15000) {
        emit("on_heartbeat_timeout");
      }
    }

    // ------------------------------------------------------------------
    // Event handlers for portal messages
    // ------------------------------------------------------------------

    @on_event("portal:ws_connected"): (data) => {
      emit("on_ws_connected");
    }

    @on_event("portal:ws_disconnected"): (data) => {
      emit("on_ws_disconnected");
    }

    @on_event("portal:message_in"): (message) => {
      state.messages_received += 1;
      state.last_heartbeat = current_time();

      // Dispatch through the message router
      MessageRouter.dispatch(message);
    }

    @on_event("portal:scene_discovered"): (scene_data) => {
      FederationDirectory.register_scene(
        scene_data.scene_id,
        scene_data.scene_name,
        scene_data.capabilities
      );
    }

    @on_event("portal:scene_lost"): (scene_data) => {
      FederationDirectory.remove_scene(scene_data.scene_id);
    }

    @on_event("portal:agent_migrated"): (migration_data) => {
      FederationDirectory.update_agent_location(
        migration_data.agent_id,
        migration_data.to_scene
      );
    }

    // ------------------------------------------------------------------
    // Public actions
    // ------------------------------------------------------------------

    action send_message(target_scene, topic, payload) {
      if (this.current_state === "connected") {
        state.messages_sent += 1;
        emit("portal:send", {
          target_scene: target_scene,
          topic: topic,
          payload: payload
        });
      } else {
        // Queue for later delivery
        MessageRouter.enqueue_outbound(target_scene, topic, payload);
      }
    }

    action request_migration(target_scene_id) {
      if (this.current_state !== "connected") {
        emit("portal:migration_rejected", {
          reason: "Not connected",
          current_state: this.current_state
        });
        return;
      }
      state.migration_target = target_scene_id;
      emit("on_migrate_request");
    }
  }

  // ========================================================================
  // SCENE OBJECTS -- Two Simulated Portal Agents
  // ========================================================================

  // Agent Alpha: a research agent that queries for collaborators
  object "AgentAlpha" using "PortalAgent" {
    position: [-3, 1, 0]

    @glowing
    geometry: "sphere"
    color: "#00aaff"
    emissive: "#00aaff"
    emissiveIntensity: 0.6

    state {
      agent_id: "alpha-001"
      scene_id: "research-lab"
      relay_url: "wss://portal.holoscript.dev/relay"
      capabilities: ["research", "data_analysis", "summarization"]
    }

    @on_event("portal:connected"): (data) => {
      // On connection, register self in directory and look for peers
      FederationDirectory.register_agent(
        state.agent_id,
        state.scene_id,
        state.capabilities
      );

      // Register message routes
      MessageRouter.register_route("collaboration_request", (msg) => {
        emit("alpha:collaboration_received", msg.payload);
      });

      MessageRouter.register_route("data_response", (msg) => {
        emit("alpha:data_received", msg.payload);
      });

      // Query for agents with "visualization" capability
      const viz_agents = FederationDirectory.find_agents_by_capability("visualization");
      if (viz_agents.length > 0) {
        this.send_message(
          viz_agents[0].scene_id,
          "collaboration_request",
          {
            from: state.agent_id,
            task: "visualize_research_data",
            priority: "normal"
          }
        );
      }
    }
  }

  // Agent Beta: a visualization agent that renders data
  object "AgentBeta" using "PortalAgent" {
    position: [3, 1, 0]

    @glowing
    geometry: "sphere"
    color: "#ff6600"
    emissive: "#ff6600"
    emissiveIntensity: 0.6

    state {
      agent_id: "beta-002"
      scene_id: "viz-studio"
      relay_url: "wss://portal.holoscript.dev/relay"
      capabilities: ["visualization", "rendering", "export"]
    }

    @on_event("portal:connected"): (data) => {
      FederationDirectory.register_agent(
        state.agent_id,
        state.scene_id,
        state.capabilities
      );

      // Register message routes
      MessageRouter.register_route("collaboration_request", (msg) => {
        // Accept collaboration and respond
        this.send_message(
          msg.payload.from_scene || "research-lab",
          "collaboration_accepted",
          {
            from: state.agent_id,
            task: msg.payload.task,
            estimated_time: 5000
          }
        );
      });

      MessageRouter.register_route("render_request", (msg) => {
        emit("beta:render_started", msg.payload);
      });
    }

    @on_event("portal:agent_migrated"): (data) => {
      // When an agent migrates into our scene, greet it
      if (data.to === state.scene_id && data.agent_id !== state.agent_id) {
        this.send_message(
          state.scene_id,
          "welcome",
          {
            from: state.agent_id,
            message: "Welcome to " + state.scene_id
          }
        );
      }
    }
  }

  // ------------------------------------------------------------------
  // Visual connection indicators
  // ------------------------------------------------------------------
  object "ConnectionBeam" {
    @glowing
    geometry: "cube"
    position: [0, 1, 0]
    scale: [5.5, 0.02, 0.02]
    color: "#333333"
    emissive: "#333333"
    emissiveIntensity: 0.2

    @on_event("portal:connected"): (data) => {
      this.color = "#00ff88";
      this.emissive = "#00ff88";
      this.emissiveIntensity = 0.8;
    }

    @on_event("portal:disconnected"): (data) => {
      this.color = "#ff3333";
      this.emissive = "#ff3333";
      this.emissiveIntensity = 0.4;
    }

    @on_event("portal:agent_migrated"): (data) => {
      this.color = "#ffaa00";
      this.emissive = "#ffaa00";
      this.emissiveIntensity = 1.2;
      setTimeout(() => {
        this.emissiveIntensity = 0.8;
      }, 500);
    }
  }

  // Platform objects
  object "Floor" {
    @collidable
    geometry: "cube"
    position: [0, 0, 0]
    scale: [12, 0.1, 8]
    color: "#0d0d1a"
  }

  object "PlatformAlpha" {
    @glowing
    geometry: "cylinder"
    position: [-3, 0.15, 0]
    scale: [1.5, 0.1, 1.5]
    color: "#001a33"
    emissive: "#00aaff"
    emissiveIntensity: 0.2
  }

  object "PlatformBeta" {
    @glowing
    geometry: "cylinder"
    position: [3, 0.15, 0]
    scale: [1.5, 0.1, 1.5]
    color: "#331a00"
    emissive: "#ff6600"
    emissiveIntensity: 0.2
  }

  // ========================================================================
  // HUD -- Reactive portal status panels
  // ========================================================================

  panel "PortalStatus" {
    position: "top-left"

    text "AlphaStatus" {
      bind: "Alpha [" + AgentAlpha.current_state + "] - msgs: " + AgentAlpha.state.messages_sent + "/" + AgentAlpha.state.messages_received
      style: "info"
    }
    text "BetaStatus" {
      bind: "Beta  [" + AgentBeta.current_state + "] - msgs: " + AgentBeta.state.messages_sent + "/" + AgentBeta.state.messages_received
      style: "info"
    }
    text "RouterStats" {
      bind: "Routed: " + MessageRouter.state.messages_routed + " | Dead: " + MessageRouter.state.dead_letters.length
      style: "info"
    }
  }

  panel "FederationInfo" {
    position: "top-right"

    text "ScenesFound" {
      bind: "Scenes: " + FederationDirectory.state.discovery_count
      style: "info"
    }
    text "AgentsTracked" {
      bind: "Agents: " + Object.keys(FederationDirectory.state.agents).length
      style: "info"
    }
  }
}
