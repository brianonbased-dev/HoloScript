/**
 * Economy Primitives — HoloScript v5.0 Example
 *
 * Demonstrates in-scene economic system with EconomyPrimitivesTrait.
 * This example shows:
 *  - Compute credit accounts with spend limits
 *  - Agent bounties with automatic escrow
 *  - Microtransactions between agents
 *  - Recurring subscriptions with auto-charge
 *  - Transaction history and balance queries
 *
 * Core Mechanics:
 *   1. Agents earn credits by completing tasks
 *   2. Agents spend credits on inference/rendering/compute
 *   3. Bounties create competitive task markets with escrow protection
 *   4. Subscriptions enable recurring credit allocations
 *
 * Run this example:
 *   holoc examples/autonomous-ecosystems/02-economy-primitives.holo --target r3f
 *
 * @version 5.0.0
 */

scene ComputeEconomy {
  // ─── Environment ──────────────────────────────────────────────────────────
  environment {
    skybox: { type: "gradient", top: "#050510", bottom: "#16213e" }
    ambient_light: 0.2
    shadows: true
  }

  light "OverheadNeon" {
    type: "directional"
    color: "#aabbff"
    intensity: 0.6
    position: [0, 10, 5]
    cast_shadows: true
  }

  light "CreditGlow" {
    type: "point"
    color: "#ffcc00"
    intensity: 0.8
    position: [0, 2, 0]
    range: 12
  }

  post_processing {
    bloom: { enabled: true, intensity: 0.4, threshold: 0.6 }
    tone_mapping: { type: "aces", exposure: 0.85 }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ECONOMY CONFIGURATION
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity EconomyEngine {
    traits: [economy];

    economy: {
      // Initial balance for new agent accounts
      initial_balance: 100,

      // Spend limit enforcement (0 = unlimited)
      default_spend_limit: 50,       // Max 50 credits per hour
      spend_limit_period: 3600000,   // 1 hour in milliseconds

      // Transaction history management
      max_transaction_history: 200,

      // Bounty configuration
      default_bounty_deadline: 300000,  // 5 minutes
      max_bounties_per_agent: 10,
      escrow_enabled: true,

      // Task completion rewards
      task_completion_reward: 10,
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Account Management
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(EconomyEngine, "economy:ready") {
    log("💰 Economy system initialized");
    log(`  Timestamp: ${event.timestamp}`);

    // Create initial agent accounts
    emit(EconomyEngine, "economy:earn", {
      agentId: "agent_researcher",
      amount: 100,
      reason: "Initial allocation",
    });

    emit(EconomyEngine, "economy:earn", {
      agentId: "agent_builder",
      amount: 100,
      reason: "Initial allocation",
    });

    emit(EconomyEngine, "economy:earn", {
      agentId: "agent_analyst",
      amount: 100,
      reason: "Initial allocation",
    });
  }

  on(EconomyEngine, "economy:account_created") {
    log(`✅ Account created: ${event.agentId}`);
    log(`  Initial balance: ${event.initialBalance} credits`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Credit Operations
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(EconomyEngine, "economy:credit_earned") {
    log(`💵 Credits earned: ${event.agentId}`);
    log(`  Amount: +${event.amount}`);
    log(`  Reason: ${event.reason}`);
    log(`  New balance: ${event.newBalance}`);
  }

  on(EconomyEngine, "economy:credit_spent") {
    log(`💸 Credits spent: ${event.agentId}`);
    log(`  Amount: -${event.amount}`);
    log(`  Reason: ${event.reason}`);
    log(`  New balance: ${event.newBalance}`);
  }

  on(EconomyEngine, "economy:insufficient_funds") {
    log(`⚠️  Insufficient funds: ${event.agentId}`);
    log(`  Attempted: ${event.amount}`);
    log(`  Available: ${event.balance}`);
    log(`  Deficit: ${event.amount - event.balance}`);
  }

  on(EconomyEngine, "economy:spend_limit_exceeded") {
    log(`🚫 Spend limit exceeded: ${event.agentId}`);
    log(`  Attempted: ${event.amount}`);
    log(`  Limit: ${event.limit}`);
    log(`  Already spent this period: ${event.spentThisPeriod}`);
  }

  on(EconomyEngine, "economy:transaction") {
    log(`🔄 Transaction completed`);
    log(`  ID: ${event.txId}`);
    log(`  From: ${event.from} → To: ${event.to}`);
    log(`  Amount: ${event.amount} credits`);
    if (event.item) {
      log(`  Item: ${event.item}`);
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Bounty System
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(EconomyEngine, "economy:bounty_posted") {
    log(`📋 Bounty posted!`);
    log(`  ID: ${event.bountyId}`);
    log(`  Reward: ${event.reward} credits`);
    log(`  Description: ${event.description}`);
    log(`  Required Capabilities: ${event.requiredCapabilities.join(", ")}`);
  }

  on(EconomyEngine, "economy:bounty_claimed") {
    log(`🎯 Bounty claimed`);
    log(`  ID: ${event.bountyId}`);
    log(`  Claimant: ${event.claimantId}`);
  }

  on(EconomyEngine, "economy:bounty_completed") {
    log(`✅ Bounty completed!`);
    log(`  ID: ${event.bountyId}`);
    log(`  Winner: ${event.winnerId}`);
    log(`  Reward paid: ${event.reward} credits`);
  }

  on(EconomyEngine, "economy:bounty_expired") {
    log(`⏰ Bounty expired`);
    log(`  ID: ${event.bountyId}`);
    log(`  Escrow returned to poster`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DEMO SCENARIO: Task Delegation with Bounties
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity DemoControls {
    traits: [interactive];
  }

  // Scenario 1: Post a bounty for 3D model optimization
  on(DemoControls, "click") {
    if (event.target === "post_bounty_button") {
      emit(EconomyEngine, "economy:post_bounty", {
        posterId: "agent_researcher",
        reward: 30,
        description: "Optimize 3D model to reduce poly count by 50% while preserving visual quality",
        requiredCapabilities: ["3d_modeling", "mesh_optimization"],
        deadline: Date.now() + 300000,  // 5 minutes from now
        maxClaimants: 1,
      });
      log("📢 Posted bounty for 3D model optimization");
    }
  }

  // Scenario 2: Claim a bounty
  on(DemoControls, "click") {
    if (event.target === "claim_bounty_button") {
      // Query bounties first
      emit(EconomyEngine, "economy:get_bounties", { status: "open" });
    }
  }

  on(EconomyEngine, "economy:bounties_list") {
    if (event.bounties.length > 0) {
      const bounty = event.bounties[0];
      emit(EconomyEngine, "economy:claim_bounty", {
        bountyId: bounty.id,
        claimantId: "agent_builder",
      });
      log(`🎯 Agent Builder claimed bounty: ${bounty.id}`);
    } else {
      log("⚠️  No open bounties available");
    }
  }

  // Scenario 3: Complete a claimed bounty
  on(DemoControls, "click") {
    if (event.target === "complete_bounty_button") {
      emit(EconomyEngine, "economy:get_bounties", { status: "claimed" });
    }
  }

  on(EconomyEngine, "economy:bounties_list") {
    if (event.bounties.length > 0 && event.bounties[0].status === "claimed") {
      const bounty = event.bounties[0];
      emit(EconomyEngine, "economy:complete_bounty", {
        bountyId: bounty.id,
        result: {
          originalPolyCount: 150000,
          optimizedPolyCount: 75000,
          reductionPercent: 50,
          visualQualityScore: 0.95,
          processingTime: 4200,
        },
      });
      log(`✅ Bounty ${bounty.id} completed by agent_builder`);
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DEMO SCENARIO: Compute Credit Spending
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  // Scenario 4: Agent spends credits on inference
  on(DemoControls, "click") {
    if (event.target === "inference_button") {
      emit(EconomyEngine, "economy:spend", {
        agentId: "agent_analyst",
        amount: 15,
        reason: "LLM inference (GPT-4, 1000 tokens)",
        target: "__compute__",
      });
      log("🤖 Agent Analyst spent credits on LLM inference");
    }
  }

  // Scenario 5: Agent spends credits on rendering
  on(DemoControls, "click") {
    if (event.target === "render_button") {
      emit(EconomyEngine, "economy:spend", {
        agentId: "agent_builder",
        amount: 8,
        reason: "Gaussian Splatting render (1920x1080, 60fps)",
        target: "__gpu__",
      });
      log("🎨 Agent Builder spent credits on GPU rendering");
    }
  }

  // Scenario 6: Agent earns credits by completing a task
  on(DemoControls, "click") {
    if (event.target === "task_complete_button") {
      emit(EconomyEngine, "economy:earn", {
        agentId: "agent_researcher",
        amount: 10,
        reason: "Completed spatial reasoning task",
      });
      log("✅ Agent Researcher earned credits for task completion");
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DEMO SCENARIO: Microtransactions
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  // Scenario 7: Transfer credits between agents
  on(DemoControls, "click") {
    if (event.target === "transfer_button") {
      emit(EconomyEngine, "economy:transfer", {
        from: "agent_researcher",
        to: "agent_builder",
        amount: 20,
        reason: "Payment for custom asset creation",
        item: "CustomBuilding_v2.glb",
      });
      log("💸 Agent Researcher paid Agent Builder for custom asset");
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DEMO SCENARIO: Balance Queries
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  // Scenario 8: Check account balance
  on(DemoControls, "click") {
    if (event.target === "balance_button") {
      emit(EconomyEngine, "economy:get_balance", {
        agentId: "agent_researcher",
      });
      emit(EconomyEngine, "economy:get_balance", {
        agentId: "agent_builder",
      });
      emit(EconomyEngine, "economy:get_balance", {
        agentId: "agent_analyst",
      });
      log("📊 Querying account balances...");
    }
  }

  on(EconomyEngine, "economy:balance") {
    log(`💰 Account: ${event.agentId}`);
    log(`  Balance: ${event.balance} credits`);
    log(`  Total Earned: ${event.totalEarned}`);
    log(`  Total Spent: ${event.totalSpent}`);
    log(`  Lifetime Profit: ${event.totalEarned - event.totalSpent}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ADVANCED: Spend Limit Protection
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  // Scenario 9: Attempt to exceed spend limit
  on(DemoControls, "click") {
    if (event.target === "exceed_limit_button") {
      // Try to spend 60 credits (limit is 50 per hour)
      emit(EconomyEngine, "economy:spend", {
        agentId: "agent_analyst",
        amount: 60,
        reason: "Expensive operation",
      });
      log("🚫 Attempting to exceed spend limit...");
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // VISUALIZATION: Credit Flow
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity CreditFlowViz {
    geometry: plane;
    position: [0, 2, -3];
    scale: [4, 2, 1];
    traits: [text_display];

    text_display: {
      content: "COMPUTE ECONOMY\n\n💰 Credits flow through:\n  • Task completion rewards\n  • Bounty escrow system\n  • Microtransactions\n  • Subscriptions\n\n🔒 Protections:\n  • Spend limits per period\n  • Automatic escrow\n  • Transaction history\n  • Insufficient funds checks",
      fontSize: 0.15,
      color: "#00ff88",
    };
  }
}
