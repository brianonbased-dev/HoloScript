/**
 * Agent Portal Messaging — HoloScript v5.0 Example
 *
 * Demonstrates cross-scene agent communication via AgentPortalTrait.
 * This example shows:
 *  - Agent discovery across multiple connected scenes
 *  - Unicast and broadcast messaging with TTL/hop-count protection
 *  - Agent migration (serialize state + transfer to another scene)
 *  - Offline queueing with outbox pattern
 *  - Federated query routing
 *
 * Architecture:
 *   Scene A ─┐
 *            ├─ Portal Relay Server (ws://localhost:4200/portal)
 *   Scene B ─┘
 *
 * Run this example:
 *   holoc examples/autonomous-ecosystems/01-agent-portal-messaging.holo --target r3f
 *
 * @version 5.0.0
 */

scene CrossSceneMessaging {
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // SCENE CONFIGURATION
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity PortalHub {
    traits: [agent_portal];

    agent_portal: {
      // This scene's identity
      scene_id: "scene_alpha_001",
      scene_name: "Alpha Research Lab",
      agent_id: "researcher_agent",
      capabilities: ["data_analysis", "3d_visualization", "pathfinding"],

      // WebSocket relay server (connects multiple scenes)
      relay_url: "ws://localhost:4200/portal",
      auth_token: "secure_token_12345",

      // Connection resilience
      auto_reconnect: true,
      reconnect_delay: 3000,
      max_reconnect_attempts: 10,

      // Heartbeat configuration (30s interval, offline after 3 missed)
      heartbeat_interval: 30000,
      offline_threshold: 3,

      // Message routing protection
      max_hop_count: 5,           // Prevent infinite loops in federated network
      default_ttl: 60000,          // Messages expire after 60 seconds
      max_outbox_size: 200,        // Queue up to 200 messages when offline
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Portal Connection Lifecycle
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(PortalHub, "portal:init") {
    log("🚀 Agent Portal initialized");
    log(`  Scene ID: ${event.sceneId}`);
    log(`  Scene Name: ${event.sceneName}`);
    log(`  Agent ID: ${event.agentId}`);
    log(`  Relay URL: ${event.relayUrl}`);
    log(`  Capabilities: ${event.capabilities.join(", ")}`);
  }

  on(PortalHub, "portal:connected") {
    log("✅ Connected to portal relay");
    log(`  Scene: ${event.sceneId}`);

    // Send initial discovery broadcast
    emit(PortalHub, "portal:broadcast", {
      messageType: "agent_hello",
      data: {
        greeting: "Hello from Alpha Research Lab!",
        timestamp: Date.now(),
        capabilities: ["data_analysis", "3d_visualization", "pathfinding"],
      },
    });
  }

  on(PortalHub, "portal:disconnected") {
    log("⚠️  Disconnected from portal relay");
    log(`  Scene: ${event.sceneId}`);
    log(`  Reason: ${event.reason}`);
  }

  on(PortalHub, "portal:reconnecting") {
    log(`🔄 Reconnecting... (attempt ${event.attempt})`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Scene Discovery
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(PortalHub, "portal:scene_discovered") {
    log("🌍 New scene discovered!");
    log(`  Scene ID: ${event.sceneId}`);
    log(`  Name: ${event.name}`);
    log(`  Agents: ${event.agentCount}`);
    log(`  Capabilities: ${event.capabilities.join(", ")}`);

    // Send direct message to the new scene
    emit(PortalHub, "portal:send", {
      to: { sceneId: event.sceneId, agentId: "__any__" },
      messageType: "welcome",
      data: {
        message: `Welcome to the federation, ${event.name}!`,
        fromScene: "scene_alpha_001",
      },
    });
  }

  on(PortalHub, "portal:scene_lost") {
    log("❌ Scene went offline");
    log(`  Scene ID: ${event.sceneId}`);
    log(`  Reason: ${event.reason}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Messaging
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(PortalHub, "portal:message_in") {
    log("📨 Message received");
    log(`  From: ${event.from.sceneId}/${event.from.agentId}`);
    log(`  Type: ${event.type}`);
    log(`  Payload: ${JSON.stringify(event.payload)}`);

    // Reply to welcome messages
    if (event.type === "welcome") {
      emit(PortalHub, "portal:send", {
        to: event.from,
        messageType: "welcome_ack",
        data: { message: "Thanks for the warm welcome!" },
        correlationId: event.id,
      });
    }

    // Handle task delegation requests
    if (event.type === "task_request") {
      const hasCapability = event.payload.requiredCapability &&
        ["data_analysis", "3d_visualization", "pathfinding"].includes(event.payload.requiredCapability);

      if (hasCapability) {
        emit(PortalHub, "portal:send", {
          to: event.from,
          messageType: "task_accepted",
          data: {
            taskId: event.payload.taskId,
            estimatedTime: 5000,
            agentId: "researcher_agent",
          },
          correlationId: event.id,
        });
      }
    }
  }

  on(PortalHub, "portal:message_out") {
    log("📤 Message sent");
    log(`  To: ${event.to ? `${event.to.sceneId}/${event.to.agentId}` : "broadcast"}`);
    log(`  Type: ${event.type}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Agent Migration
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(PortalHub, "portal:agent_migrated") {
    log("🚀 Agent migrated out");
    log(`  Agent ID: ${event.agentId}`);
    log(`  From: ${event.fromScene}`);
    log(`  To: ${event.toScene}`);
  }

  on(PortalHub, "portal:agent_arrived") {
    log("🎉 Agent arrived from another scene!");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Name: ${event.name}`);
    log(`  Capabilities: ${event.capabilities.join(", ")}`);
    log(`  Source: ${event.sourceScene}`);

    // Restore agent state
    const memory = event.memory || {};
    const state = event.state || {};
    log(`  Restored memory: ${Object.keys(memory).length} entries`);
    log(`  Restored state: ${Object.keys(state).length} properties`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Federation Queries
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(PortalHub, "portal:federation_query") {
    log("🔍 Federation query result");
    log(`  Capability: ${event.capability || "all"}`);
    log(`  Found ${event.results.length} agents across ${event.totalScenes} scenes`);

    for (const agent of event.results) {
      log(`    - ${agent.sceneId}/${agent.agentId} (${agent.name})`);
      log(`      Capabilities: ${agent.capabilities.join(", ")}`);
      log(`      Status: ${agent.status}`);
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // INTERACTIVE DEMO TRIGGERS
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity DemoControls {
    traits: [interactive];
  }

  // Trigger 1: Send a broadcast message to all connected scenes
  on(DemoControls, "click") {
    if (event.target === "broadcast_button") {
      emit(PortalHub, "portal:broadcast", {
        messageType: "announcement",
        data: {
          message: "Hello to all connected scenes!",
          timestamp: Date.now(),
          priority: "normal",
        },
      });
      log("📢 Broadcast message sent to all scenes");
    }
  }

  // Trigger 2: Query federation for agents with specific capability
  on(DemoControls, "click") {
    if (event.target === "query_button") {
      emit(PortalHub, "portal:query_agents", {
        capability: "3d_visualization",
      });
      log("🔍 Querying federation for 3d_visualization agents...");
    }
  }

  // Trigger 3: Migrate this agent to another scene
  on(DemoControls, "click") {
    if (event.target === "migrate_button") {
      emit(PortalHub, "portal:migrate_out", {
        agentId: "researcher_agent",
        name: "Research Agent Alpha",
        capabilities: ["data_analysis", "3d_visualization", "pathfinding"],
        memory: {
          knowledgeBase: ["spatial_reasoning", "neural_networks"],
          completedTasks: 42,
        },
        state: {
          currentTask: null,
          energyLevel: 85,
        },
        targetScene: "scene_beta_002",
      });
      log("🚀 Migration initiated to scene_beta_002...");
    }
  }

  // Trigger 4: Get portal statistics
  on(DemoControls, "click") {
    if (event.target === "stats_button") {
      emit(PortalHub, "portal:get_stats", {});
    }
  }

  on(PortalHub, "portal:stats") {
    log("📊 Portal Statistics");
    log(`  Connected: ${event.connected}`);
    log(`  Known Scenes: ${event.sceneCount}`);
    log(`  Remote Agents: ${event.remoteAgentCount}`);
    log(`  Outbox Size: ${event.outboxSize}`);
    log(`  Total Sent: ${event.totalSent}`);
    log(`  Total Received: ${event.totalReceived}`);
    log(`  Total Migrations: ${event.totalMigrations}`);
    log(`  Reconnect Attempts: ${event.reconnectAttempts}`);
  }
}
