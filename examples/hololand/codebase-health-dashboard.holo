// =============================================================================
// HoloScript Codebase Health VR Dashboard
// =============================================================================
// Interactive spatial visualization of HoloScript project quality metrics,
// absorbed code graph topology, convergence trajectory, and community detection.
//
// Uses holo_absorb_repo with interactive: true for live code graph navigation.
// Overlays QualityScore dimensions (test_pass_rate, coverage, type_check,
// lint, circuit_breaker_health) as color-coded spatial annotations.
// =============================================================================

composition "HoloScript Codebase Health Dashboard" {
    @author("HoloScript_Core")
    @version("2.0.0")
    @networked
    @tags(["dashboard", "codebase-health", "quality", "graph", "analytics"])

    environment {
        skyColor: "#030308"
        horizonColor: "#0a0a1a"
        groundColor: "#020205"
        grid: true
        gridColor: "#0a1a2a"
        ambientLight: 0.3
        fog: { type: "exponential", color: "#030308", density: 0.008 }
    }

    post_processing {
        bloom { intensity: 0.45, threshold: 0.65 }
        tone_mapping { mode: "aces" }
        ambient_occlusion { intensity: 0.35, radius: 0.5 }
    }

    // =========================================================================
    // SECTION 0: GROUND PLANE & SPATIAL ANCHORS
    // =========================================================================

    object "Dashboard_Floor" {
        geometry: "plane"
        scale: [300, 1, 300]
        material: "obsidian_reflective"
        @physics(type: "static")
    }

    // Spawn point for VR users
    object "Spawn_Point" @glowing {
        position: [0, 0.05, 8]
        geometry: "cylinder"
        scale: [2, 0.05, 2]
        color: "#00ff88"
        emissive: "#00ff88"
        emissiveIntensity: 0.4
    }

    // Dashboard title hologram
    object "Dashboard_Title" {
        @hologram
        position: [0, 12, -25]
        geometry: "text"
        properties: {
            text: "HOLOSCRIPT CODEBASE HEALTH"
            fontSize: 72
            color: "#00ffff"
            fontWeight: "bold"
        }
    }

    object "Dashboard_Subtitle" {
        @hologram
        position: [0, 10.5, -25]
        geometry: "text"
        properties: {
            text: "Absorbed Graph Visualization | QualityScore Overlay | Convergence Tracking"
            fontSize: 24
            color: "#4488aa"
        }
    }

    // =========================================================================
    // SECTION 1: ABSORBED CODE GRAPH (Center Stage)
    // =========================================================================
    // Uses holo_absorb_repo to build a spatial force-directed graph of the
    // codebase. Each node is a module/file, edges are import/call references.
    // Node size = lines of code, node color = quality score.

    // --- Graph Control Console ---
    object "Graph_Console" {
        @interaction
        @pointable
        @collidable
        position: [0, 1, 0]
        geometry: "box"
        scale: [3, 1, 1.5]
        color: "#1a1a2a"
        material: "metal"

        object "Console_Screen" {
            @hologram
            position: [0, 0.8, -0.1]
            geometry: "box"
            scale: [2.8, 0.6, 0.05]
            color: "#001122"
            emissive: "#003355"
            emissiveIntensity: 0.3

            object "Console_Label" {
                geometry: "text"
                position: [0, 0, 0.05]
                properties: {
                    text: "ABSORBED GRAPH CONTROL"
                    fontSize: 18
                    color: "#00ccff"
                }
            }
        }

        onInteraction: {
            emit "graph:toggle_layout" { algorithm: "force_directed" }
        }
    }

    // --- Core Module Nodes (force-directed positions) ---
    // Each node represents a HoloScript core module directory.
    // Colors encode QualityScore: green (#00ff88) = excellent, yellow (#ffcc00) = fair,
    // red (#ff3333) = poor. Size proportional to lines of code.

    // -- compiler cluster --
    orb "node_compiler" @glowing @animated @pointable {
        position: [-8, 6, -15]
        scale: [1.2, 1.2, 1.2]
        geometry: "sphere"
        color: "#00cc66"
        emissive: "#00cc66"
        emissiveIntensity: 0.7
        animate: "pulse"
        animSpeed: 0.3
        @tooltip("compiler/ -- 24 files, 3,200 LOC\nQuality: 87% (good)")
        @data_binding(source: "quality.compiler", field: "color")
    }

    // -- parser cluster --
    orb "node_parser" @glowing @animated @pointable {
        position: [-12, 5, -12]
        scale: [1.0, 1.0, 1.0]
        geometry: "sphere"
        color: "#00cc66"
        emissive: "#00cc66"
        emissiveIntensity: 0.7
        animate: "pulse"
        animSpeed: 0.35
        @tooltip("parser/ -- 18 files, 2,800 LOC\nQuality: 85% (good)")
    }

    // -- ai cluster --
    orb "node_ai" @glowing @animated @pointable {
        position: [-4, 8, -18]
        scale: [1.4, 1.4, 1.4]
        geometry: "sphere"
        color: "#ffcc00"
        emissive: "#ffcc00"
        emissiveIntensity: 0.6
        animate: "pulse"
        animSpeed: 0.25
        @tooltip("ai/ -- 32 files, 5,100 LOC\nQuality: 72% (fair)")
    }

    // -- analysis cluster --
    orb "node_analysis" @glowing @animated @pointable {
        position: [4, 7, -16]
        scale: [0.8, 0.8, 0.8]
        geometry: "sphere"
        color: "#00ff88"
        emissive: "#00ff88"
        emissiveIntensity: 0.8
        animate: "pulse"
        animSpeed: 0.4
        @tooltip("analysis/ -- 10 files, 1,400 LOC\nQuality: 92% (excellent)")
    }

    // -- self-improvement cluster --
    orb "node_self_improvement" @glowing @animated @pointable {
        position: [8, 6, -14]
        scale: [0.9, 0.9, 0.9]
        geometry: "sphere"
        color: "#00ff88"
        emissive: "#00ff88"
        emissiveIntensity: 0.8
        animate: "pulse"
        animSpeed: 0.35
        @tooltip("self-improvement/ -- 8 files, 1,100 LOC\nQuality: 95% (excellent)")
    }

    // -- accessibility --
    orb "node_accessibility" @glowing @animated @pointable {
        position: [12, 5, -12]
        scale: [0.6, 0.6, 0.6]
        geometry: "sphere"
        color: "#00cc66"
        emissive: "#00cc66"
        emissiveIntensity: 0.7
        animate: "pulse"
        animSpeed: 0.5
        @tooltip("accessibility/ -- 5 files, 680 LOC\nQuality: 88% (good)")
    }

    // -- agents --
    orb "node_agents" @glowing @animated @pointable {
        position: [-6, 4, -10]
        scale: [0.7, 0.7, 0.7]
        geometry: "sphere"
        color: "#00cc66"
        emissive: "#00cc66"
        emissiveIntensity: 0.7
        animate: "pulse"
        animSpeed: 0.45
        @tooltip("agents/ -- 6 files, 900 LOC\nQuality: 83% (good)")
    }

    // -- animation --
    orb "node_animation" @glowing @animated @pointable {
        position: [6, 4, -10]
        scale: [0.85, 0.85, 0.85]
        geometry: "sphere"
        color: "#ffcc00"
        emissive: "#ffcc00"
        emissiveIntensity: 0.6
        animate: "pulse"
        animSpeed: 0.4
        @tooltip("animation/ -- 8 files, 1,200 LOC\nQuality: 74% (fair)")
    }

    // -- CircuitBreaker --
    orb "node_circuit_breaker" @glowing @animated @pointable {
        position: [10, 7, -17]
        scale: [0.7, 0.7, 0.7]
        geometry: "sphere"
        color: "#00ff88"
        emissive: "#00ff88"
        emissiveIntensity: 0.8
        animate: "pulse"
        animSpeed: 0.35
        @tooltip("CircuitBreaker -- 2 files, 400 LOC\nQuality: 96% (excellent)\nState: CLOSED (healthy)")
    }

    // -- lsp --
    orb "node_lsp" @glowing @animated @pointable {
        position: [-14, 7, -18]
        scale: [0.9, 0.9, 0.9]
        geometry: "sphere"
        color: "#00cc66"
        emissive: "#00cc66"
        emissiveIntensity: 0.7
        animate: "pulse"
        animSpeed: 0.3
        @tooltip("lsp/ -- 12 files, 1,800 LOC\nQuality: 81% (good)")
    }

    // -- vscode-extension --
    orb "node_vscode_ext" @glowing @animated @pointable {
        position: [-16, 5, -15]
        scale: [0.65, 0.65, 0.65]
        geometry: "sphere"
        color: "#ffcc00"
        emissive: "#ffcc00"
        emissiveIntensity: 0.6
        animate: "pulse"
        animSpeed: 0.5
        @tooltip("vscode-extension/ -- 8 files, 950 LOC\nQuality: 70% (fair)")
    }

    // -- tree-sitter-holoscript --
    orb "node_tree_sitter" @glowing @animated @pointable {
        position: [-14, 3, -8]
        scale: [0.75, 0.75, 0.75]
        geometry: "sphere"
        color: "#00cc66"
        emissive: "#00cc66"
        emissiveIntensity: 0.7
        animate: "pulse"
        animSpeed: 0.4
        @tooltip("tree-sitter-holoscript/ -- grammar.js + bindings\nQuality: 86% (good)")
    }

    // -- registry --
    orb "node_registry" @glowing @animated @pointable {
        position: [14, 4, -10]
        scale: [0.6, 0.6, 0.6]
        geometry: "sphere"
        color: "#00cc66"
        emissive: "#00cc66"
        emissiveIntensity: 0.7
        animate: "pulse"
        animSpeed: 0.45
        @tooltip("registry/ -- trait registry & resolution\nQuality: 84% (good)")
    }

    // -- physics --
    orb "node_physics" @glowing @animated @pointable {
        position: [2, 5, -20]
        scale: [0.8, 0.8, 0.8]
        geometry: "sphere"
        color: "#ffcc00"
        emissive: "#ffcc00"
        emissiveIntensity: 0.6
        animate: "pulse"
        animSpeed: 0.35
        @tooltip("physics/ -- 7 files, 1,050 LOC\nQuality: 73% (fair)")
    }

    // -- rendering --
    orb "node_rendering" @glowing @animated @pointable {
        position: [-2, 5, -22]
        scale: [0.9, 0.9, 0.9]
        geometry: "sphere"
        color: "#ffcc00"
        emissive: "#ffcc00"
        emissiveIntensity: 0.6
        animate: "pulse"
        animSpeed: 0.3
        @tooltip("rendering/ -- 11 files, 1,600 LOC\nQuality: 71% (fair)")
    }

    // --- Graph Edges (import/reference connections) ---
    // Rendered as glowing line segments between nodes

    object "edge_compiler_parser" @glowing {
        geometry: "line"
        vertices: [[-8, 6, -15], [-12, 5, -12]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_compiler_ai" @glowing {
        geometry: "line"
        vertices: [[-8, 6, -15], [-4, 8, -18]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_compiler_analysis" @glowing {
        geometry: "line"
        vertices: [[-8, 6, -15], [4, 7, -16]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_ai_analysis" @glowing {
        geometry: "line"
        vertices: [[-4, 8, -18], [4, 7, -16]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_self_improve_analysis" @glowing {
        geometry: "line"
        vertices: [[8, 6, -14], [4, 7, -16]]
        color: "#2a5a2a"
        lineWidth: 2
        emissive: "#2a5a2a"
        emissiveIntensity: 0.4
    }

    object "edge_self_improve_cb" @glowing {
        geometry: "line"
        vertices: [[8, 6, -14], [10, 7, -17]]
        color: "#2a5a2a"
        lineWidth: 2
        emissive: "#2a5a2a"
        emissiveIntensity: 0.4
    }

    object "edge_parser_tree_sitter" @glowing {
        geometry: "line"
        vertices: [[-12, 5, -12], [-14, 3, -8]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_lsp_parser" @glowing {
        geometry: "line"
        vertices: [[-14, 7, -18], [-12, 5, -12]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_lsp_tree_sitter" @glowing {
        geometry: "line"
        vertices: [[-14, 7, -18], [-14, 3, -8]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_vscode_lsp" @glowing {
        geometry: "line"
        vertices: [[-16, 5, -15], [-14, 7, -18]]
        color: "#1a4a6a"
        lineWidth: 2
        emissive: "#1a4a6a"
        emissiveIntensity: 0.3
    }

    object "edge_compiler_rendering" @glowing {
        geometry: "line"
        vertices: [[-8, 6, -15], [-2, 5, -22]]
        color: "#1a4a6a"
        lineWidth: 1.5
        emissive: "#1a4a6a"
        emissiveIntensity: 0.2
    }

    object "edge_compiler_physics" @glowing {
        geometry: "line"
        vertices: [[-8, 6, -15], [2, 5, -20]]
        color: "#1a4a6a"
        lineWidth: 1.5
        emissive: "#1a4a6a"
        emissiveIntensity: 0.2
    }

    object "edge_agents_registry" @glowing {
        geometry: "line"
        vertices: [[-6, 4, -10], [14, 4, -10]]
        color: "#1a4a6a"
        lineWidth: 1.5
        emissive: "#1a4a6a"
        emissiveIntensity: 0.2
    }

    object "edge_ai_accessibility" @glowing {
        geometry: "line"
        vertices: [[-4, 8, -18], [12, 5, -12]]
        color: "#1a4a6a"
        lineWidth: 1
        emissive: "#1a4a6a"
        emissiveIntensity: 0.15
    }

    // =========================================================================
    // SECTION 2: QUALITY SCORE OVERLAY PANELS (Left Wing)
    // =========================================================================
    // Five gauge-style panels showing each QualityScore dimension with
    // color-coded severity and weighted contribution.

    // --- Panel Group Header ---
    object "Quality_Header" {
        @hologram
        position: [-35, 10, -10]
        geometry: "text"
        properties: {
            text: "QUALITY SCORE DIMENSIONS"
            fontSize: 36
            color: "#00ccff"
        }
    }

    object "Quality_Composite_Label" {
        @hologram
        position: [-35, 8.5, -10]
        geometry: "text"
        properties: {
            text: "Composite Score: 84.2% (good)"
            fontSize: 28
            color: "#00cc66"
        }
    }

    // --- test_pass_rate gauge (weight: 0.30) ---
    object "Gauge_TestPassRate" {
        @hologram
        @interaction
        position: [-40, 5, -10]
        geometry: "box"
        scale: [6, 4, 0.15]
        material: "neon_green_alpha"

        object "Gauge_Title_TPR" {
            geometry: "text"
            position: [0, 1.5, 0.1]
            properties: { text: "TEST PASS RATE"; color: "#ffffff"; fontSize: 16 }
        }

        object "Gauge_Value_TPR" {
            geometry: "text"
            position: [0, 0.3, 0.1]
            properties: { text: "97.3%"; color: "#00ff88"; fontSize: 42 }
        }

        object "Gauge_Weight_TPR" {
            geometry: "text"
            position: [0, -1, 0.1]
            properties: { text: "Weight: 0.30 | Weighted: 0.2919"; color: "#8888aa"; fontSize: 12 }
        }

        object "Gauge_Bar_TPR" {
            geometry: "box"
            position: [-0.15, -1.5, 0.1]
            scale: [5.35, 0.2, 0.05]
            color: "#00ff88"
            emissive: "#00ff88"
            emissiveIntensity: 0.5
        }
    }

    // --- coverage gauge (weight: 0.25) ---
    object "Gauge_Coverage" {
        @hologram
        @interaction
        position: [-40, 5, -5]
        geometry: "box"
        scale: [6, 4, 0.15]
        material: "neon_green_alpha"

        object "Gauge_Title_Cov" {
            geometry: "text"
            position: [0, 1.5, 0.1]
            properties: { text: "CODE COVERAGE"; color: "#ffffff"; fontSize: 16 }
        }

        object "Gauge_Value_Cov" {
            geometry: "text"
            position: [0, 0.3, 0.1]
            properties: { text: "78.5%"; color: "#cccc00"; fontSize: 42 }
        }

        object "Gauge_Weight_Cov" {
            geometry: "text"
            position: [0, -1, 0.1]
            properties: { text: "Weight: 0.25 | Weighted: 0.1963"; color: "#8888aa"; fontSize: 12 }
        }

        object "Gauge_Bar_Cov" {
            geometry: "box"
            position: [-0.53, -1.5, 0.1]
            scale: [4.32, 0.2, 0.05]
            color: "#cccc00"
            emissive: "#cccc00"
            emissiveIntensity: 0.4
        }
    }

    // --- type_check_pass gauge (weight: 0.20) ---
    object "Gauge_TypeCheck" {
        @hologram
        @interaction
        position: [-40, 5, 0]
        geometry: "box"
        scale: [6, 4, 0.15]
        material: "neon_green_alpha"

        object "Gauge_Title_TC" {
            geometry: "text"
            position: [0, 1.5, 0.1]
            properties: { text: "TYPE CHECK"; color: "#ffffff"; fontSize: 16 }
        }

        object "Gauge_Value_TC" {
            geometry: "text"
            position: [0, 0.3, 0.1]
            properties: { text: "PASS"; color: "#00ff88"; fontSize: 42 }
        }

        object "Gauge_Weight_TC" {
            geometry: "text"
            position: [0, -1, 0.1]
            properties: { text: "Weight: 0.20 | Weighted: 0.2000"; color: "#8888aa"; fontSize: 12 }
        }

        object "Gauge_Bar_TC" {
            geometry: "box"
            position: [0, -1.5, 0.1]
            scale: [5.5, 0.2, 0.05]
            color: "#00ff88"
            emissive: "#00ff88"
            emissiveIntensity: 0.5
        }
    }

    // --- lint_score gauge (weight: 0.10) ---
    object "Gauge_Lint" {
        @hologram
        @interaction
        position: [-40, 5, 5]
        geometry: "box"
        scale: [6, 4, 0.15]
        material: "neon_yellow_alpha"

        object "Gauge_Title_Lint" {
            geometry: "text"
            position: [0, 1.5, 0.1]
            properties: { text: "LINT SCORE"; color: "#ffffff"; fontSize: 16 }
        }

        object "Gauge_Value_Lint" {
            geometry: "text"
            position: [0, 0.3, 0.1]
            properties: { text: "68.0%"; color: "#ffaa00"; fontSize: 42 }
        }

        object "Gauge_Weight_Lint" {
            geometry: "text"
            position: [0, -1, 0.1]
            properties: { text: "Weight: 0.10 | Weighted: 0.0680"; color: "#8888aa"; fontSize: 12 }
        }

        object "Gauge_Bar_Lint" {
            geometry: "box"
            position: [-0.88, -1.5, 0.1]
            scale: [3.74, 0.2, 0.05]
            color: "#ffaa00"
            emissive: "#ffaa00"
            emissiveIntensity: 0.4
        }
    }

    // --- circuit_breaker_health gauge (weight: 0.15) ---
    object "Gauge_CircuitBreaker" {
        @hologram
        @interaction
        position: [-40, 5, 10]
        geometry: "box"
        scale: [6, 4, 0.15]
        material: "neon_green_alpha"

        object "Gauge_Title_CB" {
            geometry: "text"
            position: [0, 1.5, 0.1]
            properties: { text: "CIRCUIT BREAKER HEALTH"; color: "#ffffff"; fontSize: 16 }
        }

        object "Gauge_Value_CB" {
            geometry: "text"
            position: [0, 0.3, 0.1]
            properties: { text: "92.0%"; color: "#00ff88"; fontSize: 42 }
        }

        object "Gauge_Weight_CB" {
            geometry: "text"
            position: [0, -1, 0.1]
            properties: { text: "Weight: 0.15 | Weighted: 0.1380"; color: "#8888aa"; fontSize: 12 }
        }

        object "Gauge_Bar_CB" {
            geometry: "box"
            position: [-0.22, -1.5, 0.1]
            scale: [5.06, 0.2, 0.05]
            color: "#00ff88"
            emissive: "#00ff88"
            emissiveIntensity: 0.5
        }
    }

    // --- Circuit Breaker State Indicators ---
    object "CB_State_Panel" {
        @hologram
        position: [-40, 1, 10]
        geometry: "box"
        scale: [6, 2.5, 0.1]
        color: "#0a0a1a"

        object "CB_State_Title" {
            geometry: "text"
            position: [0, 0.8, 0.1]
            properties: { text: "Circuit States"; color: "#aaaacc"; fontSize: 14 }
        }

        // CLOSED = green ring, OPEN = red ring, HALF_OPEN = yellow ring
        orb "cb_closed_indicator" @glowing {
            position: [-1.5, 0, 0.15]
            scale: [0.3, 0.3, 0.3]
            geometry: "sphere"
            color: "#00ff88"
            emissive: "#00ff88"
            emissiveIntensity: 0.8
        }
        object "cb_closed_label" {
            geometry: "text"
            position: [-1.5, -0.5, 0.1]
            properties: { text: "CLOSED: 8"; color: "#00ff88"; fontSize: 11 }
        }

        orb "cb_open_indicator" @glowing {
            position: [0, 0, 0.15]
            scale: [0.2, 0.2, 0.2]
            geometry: "sphere"
            color: "#333333"
            emissive: "#333333"
            emissiveIntensity: 0.3
        }
        object "cb_open_label" {
            geometry: "text"
            position: [0, -0.5, 0.1]
            properties: { text: "OPEN: 0"; color: "#888888"; fontSize: 11 }
        }

        orb "cb_halfopen_indicator" @glowing {
            position: [1.5, 0, 0.15]
            scale: [0.2, 0.2, 0.2]
            geometry: "sphere"
            color: "#333333"
            emissive: "#333333"
            emissiveIntensity: 0.3
        }
        object "cb_halfopen_label" {
            geometry: "text"
            position: [1.5, -0.5, 0.1]
            properties: { text: "HALF_OPEN: 0"; color: "#888888"; fontSize: 11 }
        }
    }

    // =========================================================================
    // SECTION 3: CONVERGENCE TRAJECTORY (Right Wing)
    // =========================================================================
    // 3D line chart showing quality score over self-improvement iterations.
    // X-axis = iteration number, Y-axis = score (0-1), Z = time.
    // Color shifts from red (early) to green (converged).

    object "Convergence_Header" {
        @hologram
        position: [35, 10, -10]
        geometry: "text"
        properties: {
            text: "CONVERGENCE TRAJECTORY"
            fontSize: 36
            color: "#00ccff"
        }
    }

    object "Convergence_Status" {
        @hologram
        position: [35, 8.5, -10]
        geometry: "text"
        properties: {
            text: "Status: CONVERGING | Slope: 0.0012 | Plateau: 3/8"
            fontSize: 20
            color: "#ffcc00"
        }
    }

    // --- 3D Line Chart Frame ---
    object "Chart_Frame_Base" {
        position: [35, 2, -10]
        geometry: "box"
        scale: [16, 0.05, 10]
        color: "#1a1a2a"
        material: "grid_dark"
