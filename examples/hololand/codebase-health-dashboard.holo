            scale: [0.2, 0.2, 0.2]
            geometry: "sphere"
            color: "#00ff88"
            emissive: "#00ff88"
            emissiveIntensity: 0.8
        }
        object "legend_excellent_text" {
            geometry: "text"
            position: [-1, 1, 0.1]
            properties: { text: "Excellent (>= 90%)"; color: "#00ff88"; fontSize: 12 }
        }

        orb "legend_good" @glowing {
            position: [-2.5, 0.3, 0.15]
            scale: [0.2, 0.2, 0.2]
            geometry: "sphere"
            color: "#00cc66"
            emissive: "#00cc66"
            emissiveIntensity: 0.7
        }
        object "legend_good_text" {
            geometry: "text"
            position: [-1, 0.3, 0.1]
            properties: { text: "Good (75-89%)"; color: "#00cc66"; fontSize: 12 }
        }

        orb "legend_fair" @glowing {
            position: [-2.5, -0.4, 0.15]
            scale: [0.2, 0.2, 0.2]
            geometry: "sphere"
            color: "#ffcc00"
            emissive: "#ffcc00"
            emissiveIntensity: 0.6
        }
        object "legend_fair_text" {
            geometry: "text"
            position: [-1, -0.4, 0.1]
            properties: { text: "Fair (55-74%)"; color: "#ffcc00"; fontSize: 12 }
        }

        orb "legend_poor" @glowing {
            position: [-2.5, -1.1, 0.15]
            scale: [0.2, 0.2, 0.2]
            geometry: "sphere"
            color: "#ff6633"
            emissive: "#ff6633"
            emissiveIntensity: 0.5
        }
        object "legend_poor_text" {
            geometry: "text"
            position: [-1, -1.1, 0.1]
            properties: { text: "Poor (35-54%)"; color: "#ff6633"; fontSize: 12 }
        }

        orb "legend_critical" @glowing {
            position: [-2.5, -1.8, 0.15]
            scale: [0.2, 0.2, 0.2]
            geometry: "sphere"
            color: "#ff3333"
            emissive: "#ff3333"
            emissiveIntensity: 0.5
        }
        object "legend_critical_text" {
            geometry: "text"
            position: [-1, -1.8, 0.1]
            properties: { text: "Critical (< 35%)"; color: "#ff3333"; fontSize: 12 }
        }
    }

    // =========================================================================
    // SECTION 7: INTERACTIVE CONTROLS & DATA BINDINGS
    // =========================================================================

    // Data source for live quality metrics from QualityScore pipeline
    data_source "QualityPipeline" {
        type: "holoscript_self_improve"
        endpoint: "self-improvement/QualityScore"
        poll_interval: 30000
        cache_ttl: 15000
    }

    // Data source for convergence trajectory
    data_source "ConvergenceHistory" {
        type: "holoscript_self_improve"
        endpoint: "self-improvement/ConvergenceDetector"
        poll_interval: 30000
    }

    // Data source for absorbed graph topology
    data_source "AbsorbedGraph" {
        type: "holoscript_codebase"
        endpoint: "codebase/CodebaseScanner"
        poll_interval: 60000
    }

    // Data source for circuit breaker states
    data_source "CircuitBreakerStates" {
        type: "holoscript_resilience"
        endpoint: "CircuitBreakerManager/getAllMetrics"
        poll_interval: 10000
    }

    // --- Binding: Quality dimensions to gauge panels ---
    binding "QualityToGauges" {
        source: "QualityPipeline"
        targets: [
            { field: "dimensions.testPassRate.raw", target: "Gauge_Value_TPR.text" },
            { field: "dimensions.coverage.raw", target: "Gauge_Value_Cov.text" },
            { field: "dimensions.typeCheckPass.raw", target: "Gauge_Value_TC.text" },
            { field: "dimensions.lintScore.raw", target: "Gauge_Value_Lint.text" },
            { field: "dimensions.circuitBreakerHealth.raw", target: "Gauge_Value_CB.text" }
        ]
        transform: "percent_format"
    }

    // --- Binding: Convergence history to trajectory points ---
    binding "ConvergenceToTrajectory" {
        source: "ConvergenceHistory"
        target: "conv_pt_*"
        field: "history"
        transform: "spatial_trajectory"
        color_map: {
            0.0: "#ff3333"
            0.35: "#ff6633"
            0.55: "#ffcc00"
            0.75: "#44cc44"
            0.90: "#00ff88"
        }
    }

    // --- Binding: Graph topology to node positions ---
    binding "GraphToNodes" {
        source: "AbsorbedGraph"
        target: "node_*"
        field: "nodes"
        layout: "force_directed"
        interactive: true
    }

    // --- Binding: Circuit breaker to state indicators ---
    binding "CBToIndicators" {
        source: "CircuitBreakerStates"
        targets: [
            { field: "byState.closed", target: "cb_closed_label.text" },
            { field: "byState.open", target: "cb_open_label.text" },
            { field: "byState.halfOpen", target: "cb_halfopen_label.text" }
        ]
    }

    // =========================================================================
    // SECTION 8: AMBIENT ENVIRONMENT
    // =========================================================================

    // Floating ambient particles for depth perception
    orb "ambient_particle_1" @glowing @animated {
        position: [-20, 8, -20]
        scale: [0.08, 0.08, 0.08]
        geometry: "sphere"
        color: "#00aaff"
        emissive: "#00aaff"
        emissiveIntensity: 0.3
        animate: "float"
        animSpeed: 0.15
    }

    orb "ambient_particle_2" @glowing @animated {
        position: [25, 10, -25]
        scale: [0.06, 0.06, 0.06]
        geometry: "sphere"
        color: "#aa44ff"
        emissive: "#aa44ff"
        emissiveIntensity: 0.3
        animate: "float"
        animSpeed: 0.1
    }

    orb "ambient_particle_3" @glowing @animated {
        position: [10, 12, -30]
        scale: [0.07, 0.07, 0.07]
        geometry: "sphere"
        color: "#00ffaa"
        emissive: "#00ffaa"
        emissiveIntensity: 0.3
        animate: "float"
        animSpeed: 0.12
    }

    orb "ambient_particle_4" @glowing @animated {
        position: [-30, 6, -15]
        scale: [0.05, 0.05, 0.05]
        geometry: "sphere"
        color: "#ff44aa"
        emissive: "#ff44aa"
        emissiveIntensity: 0.2
        animate: "float"
        animSpeed: 0.18
    }

    // =========================================================================
    // SECTION 9: LOGIC & EVENT HANDLERS
    // =========================================================================

    logic {
        // When a graph node is clicked, show detailed module info
        on_node_selected(data) {
            emit "ui_overlay" {
                title: data.moduleName
                content: "Files: " + data.fileCount + " | LOC: " + data.loc + " | Quality: " + data.quality + "%"
                position: data.worldPosition
            }
        }

        // When convergence is detected, flash the trajectory endpoint
        on_convergence_detected(data) {
            emit "hologram:flash" { target: "conv_pt_10"; color: "#00ff88"; duration: 3000 }
            emit "ui_notification" "Convergence detected: " + data.reason + " at score " + data.score
        }

        // When circuit breaker state changes, update indicators
        on_circuit_state_change(data) {
            emit "hologram:color_wipe" {
                target: "cb_" + data.newState.toLowerCase() + "_indicator"
                color: data.newState == "OPEN" ? "#ff3333" : data.newState == "HALF_OPEN" ? "#ffcc00" : "#00ff88"
            }
        }

        // Quality score update handler
        on_quality_updated(data) {
            emit "hologram:update_text" {
                target: "Quality_Composite_Label"
                text: "Composite Score: " + data.scorePercent + "% (" + data.status + ")"
            }
        }

        // Graph layout toggle
        on_layout_change(data) {
            emit "graph:relayout" { algorithm: data.algorithm; animate: true; duration: 2000 }
        }
    }
}
