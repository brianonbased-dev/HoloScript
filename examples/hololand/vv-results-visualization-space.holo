            text: "LEVEL 4: TET10 (p=2)"
            fontSize: 20
            color: "#00ffaa"
            fontWeight: "bold"
        }
    }

    object "Mesh_L4_Stats" {
        @hologram
        position: [17, 5.8, -85]
        geometry: "text"
        properties: {
            text: "384 TET10 | DOF: 2880 | h=0.5, p=2"
            fontSize: 14
            color: "#44aa88"
        }
    }

    object "Mesh_L4_Body" @pointable @glowing {
        position: [17, 3.5, -85]
        geometry: "box"
        scale: [3, 3, 3]
        color: "#00ffaa"
        material: "wireframe"
        emissive: "#00ffaa"
        emissiveIntensity: 0.3
        @tooltip("TET10 mesh: 384 elements, 10 nodes each\nMidedge nodes capture curved geometry\nSuperior stress accuracy at same h as Level 2")
    }

    orb "Mesh_L4_Quality" @glowing @animated {
        position: [17, 6, -82]
        geometry: "sphere"
        scale: [0.4, 0.4, 0.4]
        color: "#00ffaa"
        emissive: "#00ffaa"
        emissiveIntensity: 0.9
        animate: "pulse"
        animSpeed: 0.5
        @tooltip("Mesh Quality: 0.93 (EXCELLENT)\nMin Jacobian: 0.81\nCurved edges: 960 midedge nodes")
    }

    // --- Mesh Comparison Console ---
    object "Mesh_Control_Console" {
        @interaction
        @pointable
        @collidable
        position: [0, 1, -76]
        geometry: "box"
        scale: [4, 1, 1.5]
        color: "#1a1a2e"
        material: "metal"

        object "Mesh_Console_Screen" {
            @hologram
            position: [0, 0.8, -0.1]
            geometry: "box"
            scale: [3.6, 0.6, 0.05]
            color: "#001122"
            emissive: "#003344"
            emissiveIntensity: 0.3

            object "Mesh_Console_Label" {
                geometry: "text"
                position: [0, 0, 0.05]
                properties: {
                    text: "MESH CONTROLS | EXPLODE | SLICE | COMPARE"
                    fontSize: 14
                    color: "#ffaa00"
                }
            }
        }
    }

    // Explode View Toggle
    object "Mesh_Btn_Explode" @pointable @glowing {
        position: [-3, 1.2, -76]
        geometry: "box"
        scale: [1.8, 0.6, 0.6]
        color: "#ff6644"
        emissive: "#ff6644"
        emissiveIntensity: 0.4
        @tooltip("Toggle exploded view - separates elements for interior inspection")
        onInteraction: {
            emit "mesh:explode_toggle" { factor: 1.5 }
        }
    }

    // Slice Plane Toggle
    object "Mesh_Btn_Slice" @pointable @glowing {
        position: [0, 1.2, -76]
        geometry: "box"
        scale: [1.8, 0.6, 0.6]
        color: "#4488ff"
        emissive: "#4488ff"
