        properties: {
            text: "UNCERTAINTY SOURCES (Sensitivity Analysis)"
            fontSize: 20
            color: "#cc44ff"
            fontWeight: "bold"
        }
    }

    // Sensitivity bars (horizontal bars showing contribution)
    object "Unc_Bar_Material" @glowing {
        position: [55, 5, -59.5]
        geometry: "box"
        scale: [6, 0.4, 0.1]
        color: "#ff4444"
        emissive: "#ff4444"
        emissiveIntensity: 0.5
    }

    object "Unc_Bar_Material_Label" {
        @hologram
        position: [49, 5, -59.3]
        geometry: "text"
        properties: {
            text: "Material Props (42%)"
            fontSize: 12
            color: "#ff6666"
        }
    }

    object "Unc_Bar_BC" @glowing {
        position: [54, 4.2, -59.5]
        geometry: "box"
        scale: [4.5, 0.4, 0.1]
        color: "#ff8844"
        emissive: "#ff8844"
        emissiveIntensity: 0.5
    }

    object "Unc_Bar_BC_Label" {
        @hologram
        position: [49, 4.2, -59.3]
        geometry: "text"
        properties: {
            text: "Boundary Cond (31%)"
