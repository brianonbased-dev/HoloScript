        geometry: "box"
        scale: [1, 0.02, 40]
        color: "#ffaa00"
        emissive: "#ffaa00"
        emissiveIntensity: 0.15
    }

    // Path: Hub -> Uncertainty Lab
    object "Path_Hub_Unc_1" @glowing {
