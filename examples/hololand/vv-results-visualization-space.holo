        }
    }

    object "Unc_Bar_Mesh" @glowing {
        position: [53, 3.4, -59.5]
        geometry: "box"
        scale: [3, 0.4, 0.1]
        color: "#ffcc00"
        emissive: "#ffcc00"
        emissiveIntensity: 0.5
    }

    object "Unc_Bar_Mesh_Label" {
        @hologram
        position: [49, 3.4, -59.3]
        geometry: "text"
        properties: {
            text: "Mesh Discretiz (18%)"
            fontSize: 12
            color: "#ffdd44"
        }
    }

    object "Unc_Bar_Solver" @glowing {
        position: [52.3, 2.6, -59.5]
        geometry: "box"
        scale: [1.5, 0.4, 0.1]
        color: "#44ff44"
        emissive: "#44ff44"
        emissiveIntensity: 0.5
    }

    object "Unc_Bar_Solver_Label" {
        @hologram
        position: [49, 2.6, -59.3]
        geometry: "text"
        properties: {
            text: "Solver Toler (9%)"
            fontSize: 12
            color: "#66ff66"
        }
    }

    // --- Uncertainty Control Console ---
    object "Unc_Control_Console" {
        @interaction
        @pointable
        @collidable
        position: [60, 1, -25]
        geometry: "box"
        scale: [3, 1, 1.5]
        color: "#1a1a2e"
        material: "metal"

        object "Unc_Console_Screen" {
            @hologram
            position: [0, 0.8, -0.1]
            geometry: "box"
            scale: [2.8, 0.6, 0.05]
            color: "#001122"
            emissive: "#220033"
            emissiveIntensity: 0.3

            object "Unc_Console_Label" {
                geometry: "text"
                position: [0, 0, 0.05]
                properties: {
                    text: "UNCERTAINTY CONTROLS"
                    fontSize: 16
                    color: "#cc44ff"
                }
            }
        }
    }

    // Monte Carlo toggle
    object "Unc_Btn_MonteCarlo" @pointable @glowing {
        position: [56, 1.2, -25]
        geometry: "box"
        scale: [1.8, 0.6, 0.6]
        color: "#cc44ff"
        emissive: "#cc44ff"
        emissiveIntensity: 0.4
        @tooltip("Toggle Monte Carlo sample scatter (1000 dots inside clouds)")
        onInteraction: {
            emit "uncertainty:monte_carlo_toggle" { samples: 1000 }
        }
    }

    // Sigma level selector
    object "Unc_Btn_Sigma" @pointable @glowing {
        position: [59, 1.2, -25]
        geometry: "box"
        scale: [1.8, 0.6, 0.6]
        color: "#8844ff"
        emissive: "#8844ff"
        emissiveIntensity: 0.4
        @tooltip("Cycle sigma levels: 1s / 2s / 3s visibility")
        onInteraction: {
