        @tooltip("Toggle cross-section slice plane - drag to move cut position")
        onInteraction: {
            emit "mesh:slice_toggle" { plane: "xz", position: 0.5 }
        }
    }

    // Stress Overlay Toggle
    object "Mesh_Btn_Stress" @pointable @glowing {
        position: [3, 1.2, -76]
