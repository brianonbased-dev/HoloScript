        onInteraction: {
            emit "uncertainty:pdf_projection_toggle" { plane: "xz" }
        }
    }

    // =========================================================================
    // SECTION 4: GLOBAL STATUS BAR (floating above spawn)
    // =========================================================================

    object "Status_Bar_BG" @collidable {
        position: [0, 16, -35]
        geometry: "box"
        scale: [50, 2, 0.2]
        color: "#060610"
        material: "glass_dark"
    }

    // Overall V&V status
    object "Status_Overall" {
        @hologram
        position: [-18, 16, -34.5]
        geometry: "text"
        properties: {
            text: "V&V STATUS: PASSED"
            fontSize: 22
            color: "#00ff88"
            fontWeight: "bold"
        }
    }

    // Convergence status
    object "Status_Convergence" {
        @hologram
        position: [-5, 16, -34.5]
        geometry: "text"
        properties: {
            text: "Convergence: ACHIEVED (h & p)"
            fontSize: 16
            color: "#00ddaa"
        }
        @data_binding(source: "vv.convergence_status", field: "properties.text")
    }

    // Mesh independence status
    object "Status_MeshIndep" {
        @hologram
        position: [8, 16, -34.5]
        geometry: "text"
        properties: {
            text: "Mesh Independence: GCI < 2%"
            fontSize: 16
            color: "#00ddaa"
        }
        @data_binding(source: "vv.mesh_independence_status", field: "properties.text")
    }

    // Uncertainty budget
    object "Status_UQ" {
        @hologram
        position: [20, 16, -34.5]
        geometry: "text"
        properties: {
            text: "UQ Budget: 95% CI within spec"
            fontSize: 16
            color: "#00ddaa"
        }
        @data_binding(source: "vv.uq_status", field: "properties.text")
    }

    // =========================================================================
    // SECTION 5: WALKWAY CONNECTORS (glowing floor paths between zones)
    // =========================================================================

    // Path: Hub -> Convergence Gallery
    object "Path_Hub_Conv_1" @glowing {
        position: [-15, 0.02, -5]
        geometry: "box"
        scale: [1, 0.02, 20]
        color: "#00ff88"
        emissive: "#00ff88"
        emissiveIntensity: 0.15
    }

    object "Path_Hub_Conv_2" @glowing {
