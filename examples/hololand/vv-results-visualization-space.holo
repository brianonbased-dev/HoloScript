        scale: [1.8, 0.6, 0.6]
        color: "#ff44ff"
        emissive: "#ff44ff"
        emissiveIntensity: 0.4
        @tooltip("Toggle von Mises stress color overlay on all meshes")
        onInteraction: {
            emit "mesh:stress_overlay_toggle" { colormap: "jet" }
        }
    }

    // --- Richardson Extrapolation Reference Panel ---
    object "Mesh_Richardson_Panel" @collidable {
        position: [0, 4, -92]
        geometry: "box"
        scale: [20, 6, 0.2]
        color: "#0a0a1e"
        material: "glass_dark"
    }

    object "Mesh_Richardson_Title" {
        @hologram
        position: [0, 6.5, -91.5]
        geometry: "text"
        properties: {
            text: "RICHARDSON EXTRAPOLATION"
            fontSize: 22
            color: "#ffcc00"
            fontWeight: "bold"
        }
    }

    object "Mesh_Richardson_Formula" {
        @hologram
        position: [0, 5.5, -91.5]
        geometry: "text"
        properties: {
            text: "f_exact ~ f_h + C*h^p  |  GCI_fine = Fs * |e| / (r^p - 1)"
            fontSize: 16
            color: "#88aacc"
        }
    }

    object "Mesh_Richardson_Values" {
        @hologram
        position: [0, 4.2, -91.5]
        geometry: "text"
        properties: {
            text: "Extrapolated: 142.7 MPa | GCI_fine: 1.2% | Safety Factor: 1.25"
            fontSize: 16
            color: "#00ff88"
        }
    }

    object "Mesh_Richardson_Status" {
        @hologram
        position: [0, 3.2, -91.5]
        geometry: "text"
        properties: {
            text: "Asymptotic range: YES (ratio = 1.01) | Mesh-independent solution achieved"
            fontSize: 14
            color: "#44ddaa"
        }
    }

    // =========================================================================
    // ZONE 3: UNCERTAINTY CLOUD LAB (right wing, +60x, -30z)
    // =========================================================================
    // Volumetric probability clouds around simulation results. Each cloud
    // represents the uncertainty envelope: denser = more probable, transparent
    // = tail probability. Users walk INTO the cloud to inspect local
    // confidence intervals.

    // --- Zone 3 Boundary Arch ---
    object "Unc_Arch_Left" @collidable {
        position: [54, 5, -20]
        geometry: "box"
        scale: [1, 10, 1]
        color: "#cc44ff"
        material: "metal"
    }

    object "Unc_Arch_Right" @collidable {
        position: [66, 5, -20]
        geometry: "box"
        scale: [1, 10, 1]
        color: "#cc44ff"
        material: "metal"
    }

    object "Unc_Arch_Top" @glowing {
        position: [60, 10.5, -20]
        geometry: "box"
        scale: [13, 1, 1]
        color: "#cc44ff"
        emissive: "#cc44ff"
        emissiveIntensity: 0.4
    }

    object "Unc_Zone_Title" {
        @hologram
        position: [60, 12, -20]
        geometry: "text"
        properties: {
            text: "UNCERTAINTY CLOUD LAB"
            fontSize: 36
            color: "#cc44ff"
            fontWeight: "bold"
        }
    }

    object "Unc_Zone_Desc" {
        @hologram
        position: [60, 10.8, -19.5]
        geometry: "text"
        properties: {
            text: "Walk into probability clouds | See confidence intervals in 3D"
            fontSize: 16
            color: "#aa66cc"
        }
    }

    // --- Uncertainty Cloud 1: Structural Displacement Field ---
    object "Unc_Cloud1_Pedestal" @collidable {
        position: [55, 0.3, -35]
        geometry: "cylinder"
        scale: [6, 0.6, 6]
        color: "#1a1a2e"
        material: "metal"
    }

    object "Unc_Cloud1_Title" {
        @hologram
        position: [55, 10, -35]
        geometry: "text"
        properties: {
            text: "DISPLACEMENT UNCERTAINTY"
            fontSize: 20
            color: "#44aaff"
            fontWeight: "bold"
        }
    }

    // Core result (mean value) - solid bright sphere
    orb "Unc_Cloud1_Mean" @glowing @pointable {
        position: [55, 5, -35]
        geometry: "sphere"
        scale: [1.2, 1.2, 1.2]
        color: "#00ddff"
        emissive: "#00ddff"
        emissiveIntensity: 0.9
        @tooltip("Mean displacement: 2.34mm\nThis is the deterministic solution")
        @data_binding(source: "uncertainty.displacement.mean", field: "scale")
    }

    // 1-sigma cloud (68% confidence) - semi-transparent
    orb "Unc_Cloud1_1sigma" @glowing @animated {
        position: [55, 5, -35]
        geometry: "sphere"
        scale: [2.2, 2.2, 2.2]
        color: "#4488ff"
        emissive: "#4488ff"
        emissiveIntensity: 0.15
        opacity: 0.25
        animate: "breathe"
        animSpeed: 0.15
        @tooltip("1-sigma envelope (68% CI)\nRange: 2.12mm - 2.56mm\n+/- 0.22mm from mean")
        @data_binding(source: "uncertainty.displacement.sigma1", field: "scale")
    }

    // 2-sigma cloud (95% confidence) - more transparent
    orb "Unc_Cloud1_2sigma" @glowing @animated {
        position: [55, 5, -35]
        geometry: "sphere"
        scale: [3.5, 3.5, 3.5]
        color: "#6644cc"
        emissive: "#6644cc"
        emissiveIntensity: 0.08
        opacity: 0.12
        animate: "breathe"
        animSpeed: 0.1
        @tooltip("2-sigma envelope (95% CI)\nRange: 1.90mm - 2.78mm\n+/- 0.44mm from mean")
        @data_binding(source: "uncertainty.displacement.sigma2", field: "scale")
    }

    // 3-sigma cloud (99.7% confidence) - barely visible
    orb "Unc_Cloud1_3sigma" @glowing @animated {
        position: [55, 5, -35]
        geometry: "sphere"
        scale: [5.0, 5.0, 5.0]
        color: "#8822aa"
        emissive: "#8822aa"
        emissiveIntensity: 0.04
        opacity: 0.06
        animate: "breathe"
        animSpeed: 0.08
        @tooltip("3-sigma envelope (99.7% CI)\nRange: 1.68mm - 3.00mm\nExtreme tail: material property scatter")
        @data_binding(source: "uncertainty.displacement.sigma3", field: "scale")
    }

    // Sigma legend
    object "Unc_Cloud1_Legend_1s" {
        @hologram
        position: [55, 1.5, -30]
        geometry: "text"
        properties: {
            text: "Bright core = mean | Inner cloud = 68% | Mid = 95% | Outer = 99.7%"
            fontSize: 12
            color: "#8888aa"
        }
    }

    // --- Uncertainty Cloud 2: Thermal Field ---
    object "Unc_Cloud2_Pedestal" @collidable {
        position: [65, 0.3, -35]
        geometry: "cylinder"
        scale: [6, 0.6, 6]
        color: "#1a1a2e"
        material: "metal"
    }

    object "Unc_Cloud2_Title" {
        @hologram
        position: [65, 10, -35]
        geometry: "text"
        properties: {
            text: "THERMAL UNCERTAINTY"
            fontSize: 20
            color: "#ff8844"
            fontWeight: "bold"
        }
    }

    // Mean thermal result
    orb "Unc_Cloud2_Mean" @glowing @pointable {
        position: [65, 5, -35]
        geometry: "sphere"
        scale: [1.0, 1.0, 1.0]
        color: "#ff6622"
        emissive: "#ff6622"
        emissiveIntensity: 0.9
        @tooltip("Mean temperature: 347.2K\nHot spot at geometric concentration")
    }

    // 1-sigma thermal cloud
    orb "Unc_Cloud2_1sigma" @glowing @animated {
        position: [65, 5, -35]
        geometry: "sphere"
        scale: [2.0, 1.8, 2.0]
        color: "#ff8844"
        emissive: "#ff8844"
        emissiveIntensity: 0.15
        opacity: 0.22
        animate: "breathe"
        animSpeed: 0.12
        @tooltip("1-sigma thermal (68% CI)\nRange: 339K - 355K\nConvection coefficient uncertainty")
    }

    // 2-sigma thermal cloud (asymmetric - hotter tail is wider)
    orb "Unc_Cloud2_2sigma" @glowing @animated {
        position: [65, 5.3, -35]
        geometry: "sphere"
        scale: [3.2, 3.8, 3.2]
        color: "#cc4422"
        emissive: "#cc4422"
        emissiveIntensity: 0.08
        opacity: 0.10
        animate: "breathe"
        animSpeed: 0.09
        @tooltip("2-sigma thermal (95% CI)\nRange: 331K - 368K\nAsymmetric: hot tail extends further\nSource: convection + material conductivity")
    }

    // --- Uncertainty Cloud 3: Combined Multi-Physics ---
    object "Unc_Cloud3_Pedestal" @collidable {
        position: [60, 0.3, -50]
        geometry: "cylinder"
        scale: [8, 0.6, 8]
        color: "#1a1a2e"
        material: "metal"
    }

    object "Unc_Cloud3_Title" {
        @hologram
        position: [60, 12, -50]
        geometry: "text"
        properties: {
            text: "COUPLED THERMO-STRUCTURAL UNCERTAINTY"
            fontSize: 20
            color: "#ff44ff"
            fontWeight: "bold"
        }
    }

    object "Unc_Cloud3_Subtitle" {
        @hologram
        position: [60, 11, -50]
        geometry: "text"
        properties: {
            text: "Propagated uncertainty through coupled solver chain"
            fontSize: 14
            color: "#aa66aa"
        }
    }

    // Core coupled result
    orb "Unc_Cloud3_Mean" @glowing @pointable {
        position: [60, 6, -50]
        geometry: "sphere"
        scale: [1.5, 1.5, 1.5]
        color: "#ff44ff"
        emissive: "#ff44ff"
        emissiveIntensity: 0.9
        @tooltip("Coupled result: thermal stress = 89.4 MPa\nDisplacement = 0.47mm (thermal expansion)\nIteration count: 12 (converged)")
    }

    // Coupled 1-sigma (larger than individual due to propagation)
    orb "Unc_Cloud3_1sigma" @glowing @animated {
        position: [60, 6, -50]
        geometry: "sphere"
        scale: [3.0, 2.8, 3.0]
        color: "#cc44cc"
        emissive: "#cc44cc"
        emissiveIntensity: 0.12
        opacity: 0.20
        animate: "breathe"
        animSpeed: 0.12
        @tooltip("Coupled 1-sigma (68% CI)\nStress: 78-101 MPa | Disp: 0.39-0.55mm\nUncertainty AMPLIFIED by coupling")
    }

    // Coupled 2-sigma (much larger - coupling amplifies uncertainty)
    orb "Unc_Cloud3_2sigma" @glowing @animated {
        position: [60, 6, -50]
        geometry: "sphere"
        scale: [5.0, 4.5, 5.0]
        color: "#8822aa"
        emissive: "#8822aa"
        emissiveIntensity: 0.06
        opacity: 0.08
        animate: "breathe"
        animSpeed: 0.08
        @tooltip("Coupled 2-sigma (95% CI)\nStress: 67-118 MPa | Disp: 0.31-0.63mm\nCoupling propagation factor: 1.8x\nDominant source: thermal BC uncertainty")
    }

    // --- Uncertainty Sources Panel ---
    object "Unc_Sources_Panel" @collidable {
        position: [60, 4, -60]
        geometry: "box"
        scale: [18, 5, 0.2]
        color: "#0a0a1e"
        material: "glass_dark"
    }

    object "Unc_Sources_Title" {
        @hologram
        position: [60, 6, -59.5]
