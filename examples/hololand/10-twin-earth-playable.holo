// Twin Earth — First Playable Proof (HoloLand)
// Location-based AR game layer with privacy governance and graceful degradation.
// Canary: task_1778616474061_3yjb

@world {
  backgroundColor: "#87CEEB"
  ambient: 0.6
  fog: { type: "linear", color: "#e0f7fa", near: 80, far: 300 }
  shadows: true
}

// ═══════════════════════════════════════════════════════════════════
// EarthLayer — Digital twin strata
// ═══════════════════════════════════════════════════════════════════

object "terrain_shell" @earth_layer @earth_terrain @game_geo_anchor @game_geo_persistent {
  position: [0, -0.5, 0]
  scale: [200, 1, 200]
  color: "#5d8a3e"
  geometry: "plane"
  material: "grass"
  lat: 40.7128
  lon: -74.0060
  alt: 10
}

object "city_hall" @earth_layer @earth_building @game_place @place_social {
  position: [12, 15, -8]
  scale: [8, 30, 8]
  color: "#8b4513"
  geometry: "cube"
  material: "brick"
  place_capacity: 500
  place_schedule: "09:00-17:00"
}

object "broadway_road" @earth_layer @earth_road {
  position: [0, 0.1, 20]
  scale: [120, 0.2, 6]
  color: "#333333"
  geometry: "cube"
  material: "asphalt"
}

object "central_pond" @earth_layer @earth_water {
  position: [-25, 0.2, 10]
  scale: [15, 0.5, 10]
  color: "#1e90ff"
  geometry: "cylinder"
  material: "water"
}

object "tree_canopy" @earth_layer @earth_vegetation {
  position: [-15, 4, -15]
  scale: [3, 8, 3]
  color: "#228b22"
  geometry: "sphere"
  material: "foliage"
}

// ═══════════════════════════════════════════════════════════════════
// Place — Named venue with ingress/egress
// ═══════════════════════════════════════════════════════════════════

object "museum_entrance" @game_place @place_ingress @location_quest @location_quest_checkin {
  position: [12, 1, -12]
  scale: [2, 2.5, 0.5]
  color: "#ffd700"
  geometry: "cube"
  emissive: "#ffd700"
  emissiveIntensity: 0.4
}

object "museum_exit" @game_place @place_egress {
  position: [16, 1, -4]
  scale: [2, 2.5, 0.5]
  color: "#cd5c5c"
  geometry: "cube"
}

zone "museum_quarter" @place_zone @game_geo_radius {
  position: [12, 0, -8]
  scale: [20, 1, 20]
  color: "#ffffff"
  opacity: 0.1
  geometry: "cube"
  game_geo_radius: 25
}

// ═══════════════════════════════════════════════════════════════════
// PrivacyRule — Consent and governance attached to the museum zone
// ═══════════════════════════════════════════════════════════════════

object "privacy_governance" @privacy_rule @privacy_collection_scope @privacy_consent_receipt {
  position: [12, 3, -8]
  scale: [0.5, 0.5, 0.5]
  color: "#00ff00"
  geometry: "octahedron"
  material: "glass"
  privacy_collection_scope: ["location_coarse", "visit_duration"]
  privacy_retention_policy: "30_days"
  privacy_anonymization: true
  privacy_opt_out: true
}

// ═══════════════════════════════════════════════════════════════════
// LocationQuest — Real-world quest primitives
// ═══════════════════════════════════════════════════════════════════

orb "quest_marker_streak" @location_quest @location_quest_streak @location_quest_proximity {
  position: [30, 2, 20]
  scale: [0.6, 0.6, 0.6]
  color: "#ff4500"
  geometry: "sphere"
  emissive: "#ff4500"
  emissiveIntensity: 1.2
  animate: "pulse"
  animSpeed: 1.2
  location_quest_radius: 15
}

orb "quest_marker_route" @location_quest @location_quest_route @location_quest_timegate {
  position: [-30, 2, 20]
  scale: [0.6, 0.6, 0.6]
  color: "#9400d3"
  geometry: "sphere"
  emissive: "#9400d3"
  emissiveIntensity: 1.2
  animate: "pulse"
  animSpeed: 0.9
  location_quest_timegate: "weekend_only"
}

// ═══════════════════════════════════════════════════════════════════
// Degradation — Graceful fallback annotations
// ═══════════════════════════════════════════════════════════════════

object "degradation_anchor_mobile" @mobile_degradation @degradation_map_view {
  position: [0, 5, 0]
  scale: [1, 0.2, 1]
  color: "#ffa500"
  geometry: "cube"
}

object "degradation_anchor_browser" @browser_degradation @degradation_static_render @degradation_text_description {
  position: [5, 5, 0]
  scale: [1, 0.2, 1]
  color: "#4169e1"
  geometry: "cube"
}

// ═══════════════════════════════════════════════════════════════════
// Robot / AI Actors — Twin Earth substrate participants
// ═══════════════════════════════════════════════════════════════════

// Robot Actor — Autonomous ground survey unit (hardware-bound)
object "twin_survey_robot" @robot_actor @actor @twin_sync {
  position: [20, 0.5, -15]
  scale: [0.6, 0.4, 0.9]
  color: "#607d8b"
  geometry: "cube"
  material: "metal"
  twin_sync: { topic: "twin_earth/robots/survey_01" }
  actor: { mailbox_size: 200, role: "surveyor" }
  robot_actor: { kind: "robot", mode: "local", hardware_fingerprint: "sha256:abc123" }
}

// AI Agent Actor — Museum virtual guide (software-bound)
object "twin_museum_guide_ai" @ai_agent_actor @actor @ai_npc {
  position: [12, 1.4, -10]
  scale: [0.5, 1.2, 0.5]
  color: "#00bcd4"
  geometry: "capsule"
  material: "hologram"
  emissive: "#00bcd4"
  emissiveIntensity: 0.5
  actor: { mailbox_size: 500, role: "guide" }
  ai_npc: { name: "Aurelia", role: "museum_guide", awareness_radius: 8.0 }
  ai_agent_actor: { kind: "ai", mode: "BYOK", model_provider: "sovereign", model_id: "brittney-qwen-v23" }
}

// Sensor Feed — Environmental monitoring stream
object "twin_sensor_feed" @sensor_feed @actor {
  position: [-10, 2, -10]
  scale: [0.3, 0.3, 0.3]
  color: "#4caf50"
  geometry: "sphere"
  material: "neon"
  emissive: "#4caf50"
  emissiveIntensity: 0.6
  animate: "pulse"
  animSpeed: 1.0
  sensor_feed: { sensor_type: "environmental", feed_id: "env_01", unit: "celsius/ppm/dbm" }
}

// Actuator Command — Authorized actuation endpoint
object "twin_actuator_command" @actuator_command @actor {
  position: [20, 0.3, -15]
  scale: [0.4, 0.2, 0.4]
  color: "#ff5722"
  geometry: "cylinder"
  material: "neon"
  actuator_command: { actuator_id: "arm_01", actuator_type: "gripper", max_force_n: 50 }
}

// Robot Task — Assigned objective with safety envelope reference
object "twin_robot_task" @robot_task @actor {
  position: [22, 1.5, -15]
  scale: [0.5, 0.5, 0.5]
  color: "#9c27b0"
  geometry: "octahedron"
  material: "glass"
  robot_task: { task_id: "task_survey_quadrant_3", assignee: "twin_survey_robot", priority: 2, status: "active" }
}

// Safety Envelope — Runtime boundary for the survey robot
object "twin_safety_envelope" @safety_envelope @actor {
  position: [20, 0.1, -15]
  scale: [6, 0.1, 6]
  color: "#ffeb3b"
  geometry: "cube"
  material: "wireframe"
  opacity: 0.3
  safety_envelope: { envelope_id: "env_survey_01", agent_id: "twin_survey_robot", max_tick_duration_ms: 100, max_memory_bytes: 134217728, max_network_calls_per_minute: 10, substrate_enforced: true, deterministic: true, local_only: true }
}

// ═══════════════════════════════════════════════════════════════════
// Twin Earth Receipts — Cryptographically signed execution proofs
// ═══════════════════════════════════════════════════════════════════

object "receipt_robot_registration" @twin_earth_receipt @glowing {
  position: [18, 0.5, -13]
  scale: [1.2, 0.15, 0.6]
  color: "#4caf50"
  geometry: "cube"
  receipt: { id: "rcpt_reg_001", kind: "validation", actor_id: "twin_survey_robot", action: "identity:register", scope: "twin_earth", timestamp: "2026-05-13T00:00:00Z", status: "success", envelope_id: "env_survey_01", substrate_version: "1.0.0" }
}

object "receipt_ai_registration" @twin_earth_receipt @glowing {
  position: [10, 0.5, -8]
  scale: [1.2, 0.15, 0.6]
  color: "#4caf50"
  geometry: "cube"
  receipt: { id: "rcpt_reg_002", kind: "validation", actor_id: "twin_museum_guide_ai", action: "identity:register", scope: "twin_earth", timestamp: "2026-05-13T00:00:00Z", status: "success", envelope_id: "env_guide_01", substrate_version: "1.0.0" }
}

object "receipt_sensor_bind" @twin_earth_receipt @glowing {
  position: [-12, 0.5, -8]
  scale: [1.2, 0.15, 0.6]
  color: "#2196f3"
  geometry: "cube"
  receipt: { id: "rcpt_sensor_001", kind: "action", actor_id: "twin_sensor_feed", action: "shard:tick", scope: "twin_earth", timestamp: "2026-05-13T00:00:00Z", status: "success", envelope_id: "env_sensor_01", substrate_version: "1.0.0" }
}

object "receipt_task_assignment" @twin_earth_receipt @glowing {
  position: [24, 0.5, -15]
  scale: [1.2, 0.15, 0.6]
  color: "#ff9800"
  geometry: "cube"
  receipt: { id: "rcpt_task_001", kind: "action", actor_id: "twin_robot_task", action: "shard:create", scope: "twin_earth", timestamp: "2026-05-13T00:00:00Z", status: "success", envelope_id: "env_task_01", substrate_version: "1.0.0" }
}

// ═══════════════════════════════════════════════════════════════════
// Ground & Sky
// ═══════════════════════════════════════════════════════════════════

object "ground" @collidable {
  position: [0, -1, 0]
  scale: [300, 1, 300]
  color: "#2f4f4f"
  geometry: "cube"
}

// ═══════════════════════════════════════════════════════════════════
// Notes
// ═══════════════════════════════════════════════════════════════════
// - On mobile without ARKit/ARCore, @mobile_degradation falls back
//   to @degradation_map_view (2D map pins).
// - On desktop browser without WebXR, @browser_degradation falls back
//   to @degradation_static_render (pre-rendered panoramas) plus
//   @degradation_text_description (rich text POI cards).
// - Privacy consent is checked before any @location_quest triggers.
//   If consent is revoked via @privacy_opt_out, quest events are
//   suppressed and the user sees only public @earth_layer data.
// - Robot / AI actors are substrate participants with independent
//   identity, safety envelopes, and verifiable receipts.
//   Each @twin_earth_receipt references its actor by actor_id and
//   is bound to a safety envelope via envelope_id.
// - Substrate contract: packages/framework/src/board/twin-earth-substrate.ts
