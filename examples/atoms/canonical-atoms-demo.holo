composition "CanonicalAtomsDemo" {

  environment {
    skybox: "dusk"
    ambient_light: 0.35
  }

  // Global resilience + sync substrate
  world {
    @world_heartbeat { interval_ms: 1000, redundancy: 3 }
    @circuit_auto_reset { backoff_base: 2, max_attempts: 5 }
  }

  // Persistent memory substrate
  memory_hub "OpsMemory" {
    @memory_crystal {
      capacity: "semantic"
      prune_threshold: 0.4
      backend: "kv"
    }

    @forget_policy {
      after: "30d"
      when: "relevance < 0.2"
      audit: true
    }

    @versioned_state {
      strategy: "crdt"
      branches: 5
    }
  }

  // Narrative controller with convergence + bounded branching
  director "SceneDirector" {
    @plot_anchor {
      act: 2
      convergence_radius: "time 5min"
    }

    @branch_fork {
      max_depth: 3
      merge_strategy: "vote"
    }
  }

  object "GuardianAgent" {
    @llm_agent
    @recall_trigger {
      query: "similar intruder"
      min_confidence: 0.75
      max_results: 5
    }

    geometry: "capsule"
    position: [0, 1, -2]
    color: "#ff7a00"
  }

  object "StoryNode_A" {
    geometry: "cube"
    position: [-2, 1, 1]
    color: "#3aa6ff"
  }

  object "StoryNode_B" {
    geometry: "cube"
    position: [2, 1, 1]
    color: "#9c6bff"
  }

  logic {
    on_scene_load() {
      scene.emit("heartbeat:start")
      memory.store("OpsMemory", {
        topic: "intruder",
        summary: "Entity entered from east corridor",
        relevance: 0.82
      })
    }

    on_world_heartbeat(tick) {
      if (tick % 10 == 0) {
        director.evaluate("SceneDirector")
      }
    }

    on_branch_selected(choice) {
      if (choice == "A") {
        scene.focus("StoryNode_A")
      } else {
        scene.focus("StoryNode_B")
      }
    }
  }
}
