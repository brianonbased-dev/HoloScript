// Interactive button component with traits
// File type: .hsplus (Presentation Layer)

template InteractiveButton {
  geometry: "cylinder"
  rotation: [90, 0, 0]
  scale: [0.3, 0.05, 0.3]
  color: "#4ecdc4"

  @clickable
  @pointable
  @glowing
  @audio(sound: "click.wav", trigger: "on_click")
}

template GlowingOrb {
  geometry: "sphere"
  scale: 0.3
  color: "#00ffff"

  @glowing
  @pointable
  @hoverable
}
