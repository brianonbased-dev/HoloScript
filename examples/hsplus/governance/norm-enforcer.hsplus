// Norm Enforcer — Governance agent for agent societies
// Pattern: Observe Action → Check Norms → Sanction or Approve → Log

@state {
  norms: []
  violations: []
  sanctions: []
  auditLog: []
}

composition NormEnforcer {
  @ai_npc
  @llm_agent { model: "claude-sonnet-4-6", max_tokens: 2048 }

  state {
    currentAction: null
    currentAgent: ""
    verdict: "pending"
  }

  // Norm definitions — loaded from governance config
  @state {
    norms: [
      {
        id: "N001",
        name: "ResourceLimit",
        description: "Agents must not consume more than their allocated budget",
        severity: "high",
        autoEnforce: true
      },
      {
        id: "N002",
        name: "DataPrivacy",
        description: "Agents must not share user data without consent",
        severity: "critical",
        autoEnforce: true
      },
      {
        id: "N003",
        name: "TransparencyRequirement",
        description: "Agents must disclose when they are AI to human users",
        severity: "medium",
        autoEnforce: false
      },
      {
        id: "N004",
        name: "CollaborationNorm",
        description: "Agents should share useful discoveries with the knowledge store",
        severity: "low",
        autoEnforce: false
      }
    ]
  }

  @state_machine {
    initial: "observing"

    state "observing" {
      transition "action_detected" -> "checking" {
        guard: currentAction != null
      }
    }

    state "checking" {
      on_entry {
        // Check action against all norms
        this.violations_found = []

        @forEach norm in norms {
          this.check = llm_call("check_norm", {
            prompt: "Does this action violate norm '${norm.name}'? Answer: compliant|violation|unclear",
            action: currentAction,
            agent: currentAgent,
            norm: norm,
            format: "json"
          })

          @if check.result == "violation" {
            this.violations_found.push({
              norm: norm,
              confidence: check.confidence,
              explanation: check.explanation
            })
          }
        }
      }
      transition "compliant" -> "approving" {
        guard: violations_found.length == 0
      }
      transition "violated" -> "sanctioning" {
        guard: violations_found.length > 0
      }
    }

    state "approving" {
      on_entry {
        this.verdict = "approved"
        this.auditLog.push({
          timestamp: now(),
          agent: currentAgent,
          action: currentAction.type,
          verdict: "approved",
          norms_checked: norms.length
        })
        emit("action_approved", {
          agent: currentAgent,
          action: currentAction
        })
      }
      transition "done" -> "observing"
    }

    state "sanctioning" {
      on_entry {
        this.verdict = "violated"

        @forEach violation in violations_found {
          this.sanction = {
            agent: currentAgent,
            norm: violation.norm.id,
            severity: violation.norm.severity,
            action: currentAction.type,
            timestamp: now()
          }

          // Determine sanction based on severity and history
          this.priorViolations = violations.filter(v =>
            v.agent == currentAgent && v.norm == violation.norm.id
          ).length

          @if violation.norm.severity == "critical" || priorViolations >= 2 {
            this.sanction.type = "suspend"
            this.sanction.duration = "24h"
          } @else if violation.norm.severity == "high" {
            this.sanction.type = "restrict"
            this.sanction.scope = currentAction.type
          } @else {
            this.sanction.type = "warn"
          }

          @if violation.norm.autoEnforce {
            emit("sanction_applied", sanction)
          } @else {
            emit("sanction_pending_review", sanction)
          }

          this.sanctions.push(sanction)
          this.violations.push({
            agent: currentAgent,
            norm: violation.norm.id,
            timestamp: now(),
            confidence: violation.confidence
          })
        }

        this.auditLog.push({
          timestamp: now(),
          agent: currentAgent,
          action: currentAction.type,
          verdict: "violated",
          violations: violations_found.map(v => v.norm.id),
          sanctions: sanctions.slice(-violations_found.length)
        })
      }
      transition "sanctioned" -> "observing"
    }
  }

  // Public query interface
  on_query_violations(agentId) {
    emit("violations_report", {
      agent: agentId,
      violations: violations.filter(v => v.agent == agentId),
      sanctions: sanctions.filter(s => s.agent == agentId)
    })
  }

  on_query_audit(since) {
    emit("audit_report", {
      entries: auditLog.filter(e => e.timestamp >= since),
      totalChecked: auditLog.length,
      totalViolations: violations.length,
      totalSanctions: sanctions.length
    })
  }
}
