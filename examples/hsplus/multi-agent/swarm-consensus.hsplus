// Swarm Consensus — N agents vote, confidence-weighted merge
// Pattern: Broadcast → Independent Evaluation → Collect → Merge → Decide

@state {
  question: ""
  agentCount: 5
  responses: []
  consensus: null
  agreement: 0.0
  quorum: 0.7
}

composition SwarmAgent {
  @ai_npc
  @networked { sync_rate: 10 }

  state {
    agentId: ""
    response: null
    confidence: 0.0
  }

  on_evaluate(question, context) {
    this.response = llm_call("evaluate", {
      prompt: "Answer this question independently. Be specific. Rate your confidence 0-1.",
      question: question,
      context: context,
      format: "json"
    })
    this.confidence = response.confidence

    emit("vote_cast", {
      agentId: agentId,
      answer: response.answer,
      confidence: confidence,
      reasoning: response.reasoning
    })
  }
}

composition SwarmCoordinator {
  @state_machine {
    initial: "idle"

    state "idle" {
      transition "question_received" -> "broadcasting" {
        guard: question != ""
      }
    }

    state "broadcasting" {
      on_entry {
        // Spawn N independent evaluators
        @for i in range(agentCount) {
          spawn SwarmAgent {
            agentId: "swarm-${i}"
          }
        }

        // Broadcast the question to all agents
        @forEach agent in SwarmAgent.instances {
          agent.on_evaluate(question, {
            instruction: "Think independently. Do not consider what others might answer."
          })
        }
      }
      transition "all_votes_in" -> "merging" {
        guard: responses.length >= agentCount
      }
      transition "timeout" -> "merging" {
        guard: responses.length >= agentCount * quorum
        after: 30000
      }
    }

    state "merging" {
      on_entry {
        // Confidence-weighted merge
        this.totalWeight = responses.reduce((sum, r) => sum + r.confidence, 0)

        // Group answers by similarity
        this.clusters = llm_call("cluster_responses", {
          prompt: "Group these responses by answer similarity. Return clusters with member count and average confidence.",
          responses: responses,
          format: "json"
        })

        // Pick the cluster with highest weighted support
        this.winningCluster = clusters.sort(
          (a, b) => (b.memberCount * b.avgConfidence) - (a.memberCount * a.avgConfidence)
        )[0]

        this.consensus = {
          answer: winningCluster.representativeAnswer,
          support: winningCluster.memberCount / responses.length,
          avgConfidence: winningCluster.avgConfidence,
          dissenting: clusters.length > 1 ? clusters.slice(1).map(c => c.representativeAnswer) : []
        }

        this.agreement = consensus.support
      }
      transition "strong_consensus" -> "completed" {
        guard: agreement >= quorum
      }
      transition "weak_consensus" -> "deliberating" {
        guard: agreement < quorum
      }
    }

    state "deliberating" {
      on_entry {
        // Share the clusters with all agents for a second round
        @forEach agent in SwarmAgent.instances {
          agent.on_evaluate(question, {
            instruction: "Other agents gave these answers. Reconsider your position.",
            otherAnswers: consensus.dissenting,
            majorityAnswer: consensus.answer,
            round: 2
          })
        }
        this.responses = [] // Reset for round 2
      }
      transition "round2_complete" -> "merging" {
        guard: responses.length >= agentCount * quorum
      }
    }

    state "completed" {
      on_entry {
        emit("swarm_decision", {
          question: question,
          answer: consensus.answer,
          agreement: agreement,
          respondents: responses.length,
          dissenting: consensus.dissenting,
          rounds: consensus.round || 1
        })
      }
    }
  }
}
