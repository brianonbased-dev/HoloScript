  // =========================================================================
  // GALLERY LIGHTING — ambient, non-flickering (WCAG 2.3.1)
  // =========================================================================

  object "GalleryLight1" {
    position: [-5, 3.8, -4]
    scale: [0.3, 0.05, 0.3]
    geometry: "cylinder"
    color: "#fffaf0"
    emissive: "#fffaf0"
    emissiveIntensity: 1.5
  }

  object "GalleryLight2" {
    position: [-1.5, 3.8, -4]
    scale: [0.3, 0.05, 0.3]
    geometry: "cylinder"
    color: "#fffaf0"
    emissive: "#fffaf0"
    emissiveIntensity: 1.5
  }

  object "GalleryLight3" {
    position: [1.5, 3.8, -4]
    scale: [0.3, 0.05, 0.3]
    geometry: "cylinder"
    color: "#fffaf0"
    emissive: "#fffaf0"
    emissiveIntensity: 1.5
  }

  object "GalleryLight4" {
    position: [5, 3.8, -4]
    scale: [0.3, 0.05, 0.3]
    geometry: "cylinder"
    color: "#fffaf0"
    emissive: "#fffaf0"
    emissiveIntensity: 1.5
  }

  // =========================================================================
  // STATUS PANEL — live region for announcements (WCAG 4.1.3)
  // =========================================================================

  object "StatusPanel" {
    @accessible {
      role: "region"
      label: "Status Messages"
      description: "Live region displaying system announcements and navigation feedback"
      live_region: "polite"
      tab_index: 25
      focus_visible: true
    }
    @screen_reader {
      semantic_structure: true
      navigation_order: 8
      reading_mode: "linear"
      verbosity: "normal"
      announce_changes: true
    }
    @high_contrast {
      mode: "auto"
      outline_width: 2
      outline_color: "#00FFFF"
    }
    @subtitle {
      language: "en"
      position: "top"
      font_size: 18
      background: true
      background_opacity: 0.85
      max_lines: 2
      line_duration: 5000
      speaker_labels: false
    }

    position: [0, 3.6, 0]
    scale: [3, 0.3, 0.02]
    geometry: "cube"
    color: "#0a0a1a"
    opacity: 0.9

    state {
      current_message: ""
    }

    on_event("status_update", msg) {
      state.current_message = msg.text
      accessibility.announce(msg.text, msg.priority || "polite")
    }
  }

  // =========================================================================
  // HELP OVERLAY — activated by voice "help" or keyboard H
  // =========================================================================

  object "HelpOverlay" {
    @accessible {
      role: "dialog"
      label: "Help and Commands"
      description: "Lists all available voice commands and keyboard shortcuts"
      keyboard_shortcut: "h"
      tab_index: 26
      focus_visible: true
    }
    @screen_reader {
      semantic_structure: true
      navigation_order: 9
      reading_mode: "linear"
      verbosity: "verbose"
    }
    @alt_text {
      text: "Help overlay with voice commands and keyboard shortcuts"
      verbose: "A floating help panel listing all available commands: Voice commands include 'next exhibit', 'previous exhibit', 'describe this', 'read plaque', 'go to entrance', 'go to gallery', 'increase text size', 'decrease text size', and 'high contrast'. Keyboard shortcuts include 1-4 for exhibits, W for welcome, S for settings, H for help, E for entrance, C for contrast, and M for reduce motion."
      language: "en"
    }
    @high_contrast {
      mode: "auto"
      outline_width: 3
      outline_color: "#00FF00"
    }

    position: [0, 2, 0]
    scale: [2.5, 1.8, 0.02]
    geometry: "cube"
    color: "#0a0a2e"
    opacity: 0.95
    visible: false

    text: "HELP\n\nVoice Commands:\n  'next exhibit' / 'previous exhibit'\n  'describe this' / 'read plaque'\n  'go to entrance' / 'go to gallery'\n  'increase text size' / 'decrease text size'\n  'high contrast' / 'help'\n\nKeyboard Shortcuts:\n  1-4  Jump to exhibit\n  W    Welcome kiosk\n  S    Settings\n  H    Toggle help\n  E    Return to entrance\n  C    Cycle contrast mode\n  M    Toggle reduced motion\n  Esc  Skip to gallery\n  Tab  Next focusable element"
    fontSize: 0.035
    fontColor: "#e0e0e0"

    state {
      is_visible: false
    }

    on_event("show_help") {
      state.is_visible = !state.is_visible
      visible = state.is_visible
      if (state.is_visible) {
        accessibility.announce("Help overlay opened. Listing voice commands and keyboard shortcuts.", "assertive")
      } else {
        accessibility.announce("Help overlay closed.", "polite")
      }
    }

    on_activate() {
      state.is_visible = !state.is_visible
      visible = state.is_visible
    }
  }

  // =========================================================================
  // BENCH — rest area with accessibility
  // =========================================================================

  object "GalleryBench" {
    @collidable
    @sittable
    @accessible {
      role: "region"
      label: "Seating Area"
      description: "A bench in the center of the gallery for resting"
      tab_index: 27
      focus_visible: true
    }
    @alt_text {
      text: "Wooden bench in the center of the gallery"
      verbose: "A long wooden bench positioned in the center of the gallery hall, providing a place to rest while viewing the exhibits. The bench faces the four exhibit pedestals."
      language: "en"
      include_spatial: true
    }
    @haptic {
      intensity: 0.3
      proximity_enabled: false
      collision_pattern: "soft"
      hands: "both"
      duration: 60
    }

    position: [0, 0.35, -7]
    scale: [3, 0.4, 0.6]
    geometry: "cube"
    color: "#8b6f4e"
    material: "wood"
  }
}
