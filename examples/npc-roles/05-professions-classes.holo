    }

    on_patient_treated(event) {
      console.log(`[RoyalPhysician] Patient treated:
        - Patient: ${event.patient_name}
        - Ailment: ${event.ailment}
        - Treatment: ${event.treatment}
        - Prognosis: ${event.prognosis}
        - Fee: ${event.fee} gold
      `);
    }

    on_surgery_performed(event) {
      console.log(`[RoyalPhysician] Surgery performed:
        - Patient: ${event.patient}
        - Surgery Type: ${event.surgery_type}
        - Duration: ${event.duration}
        - Success: ${event.success}
        - Recovery Prognosis: ${event.recovery}
