/**
 * Professions & Social Classes
 *
 * Demonstrates farmer, miner_npc, fisher_npc, pilot, engineer, scientist,
 * doctor, royalty, noble, peasant, and prisoner traits for professional
 * occupations and social hierarchies.
 *
 * Key Features:
 * - Primary Professions: Farmers, miners, fishers
 * - Advanced Professions: Pilots, engineers, scientists, doctors
 * - Social Hierarchy: Royalty, nobles, peasants, prisoners
 * - Economic systems, class dynamics, and societal roles
 *
 * @version 1.0.0
 * @sprint 15
 */

composition ProfessionsSocialClassesScene {
  /**
   * Village Farmer - Farmer
   *
   * A hardworking farmer who tends crops and livestock.
   */
  entity VillageFarmer {
    farmer: {
      // Farming profile
      farm_name: "Greenfield Farm",
      farm_size: 50, // hectares
      farming_experience_years: 25,
      farming_type: "mixed_farming", // crops_and_livestock

      // Crops
      crops: {
        current_crops: [
          {
            crop: "wheat",
            area: 20, // hectares
            growth_stage: "mature",
            days_until_harvest: 7,
            expected_yield: 4000, // kg
            market_value: 2 // gold per kg
          },
          {
            crop: "corn",
            area: 15,
            growth_stage: "growing",
            days_until_harvest: 45,
            expected_yield: 6000,
            market_value: 1.5
          },
          {
            crop: "vegetables",
            area: 10,
            growth_stage: "various",
            days_until_harvest: 14,
            expected_yield: 2000,
            market_value: 3
          }
        ],

        crop_rotation: {
          practices_rotation: true,
          rotation_cycle: ["wheat", "legumes", "corn", "fallow"],
          current_year: 2 // In 4-year cycle
        }
      },

      // Livestock
      livestock: {
        animals: [
          { type: "cow", count: 12, produces: "milk_and_meat", daily_milk: 120 },
          { type: "chicken", count: 50, produces: "eggs_and_meat", daily_eggs: 40 },
          { type: "pig", count: 8, produces: "meat", ready_for_market: 3 },
          { type: "sheep", count: 20, produces: "wool_and_meat", shearing_due: "spring" }
        ],

        pasture_area: 5, // hectares
        barn_capacity: "adequate",
        animal_health: "good"
      },

      // Farming skills
      skills: {
        crop_cultivation: 9, // 1-10
        animal_husbandry: 8,
        soil_management: 8,
        weather_prediction: 7,
        equipment_maintenance: 7,
        market_trading: 6
      },

      // Equipment
      equipment: {
        plow: "ox_drawn",
        tools: ["scythe", "hoe", "rake", "pitchfork", "buckets"],
        storage: ["barn", "silo", "root_cellar"],
        transport: "ox_cart"
      },

      // Farming calendar
      calendar: {
        current_season: "late_summer",
        seasonal_tasks: {
          spring: ["plowing", "planting", "lambing"],
          summer: ["weeding", "irrigating", "early_harvest"],
          autumn: ["main_harvest", "preserving", "preparing_for_winter"],
          winter: ["maintenance", "planning", "animal_care"]
        }
      },

      // Economics
      economics: {
        annual_income: 800, // gold
        annual_expenses: 400,
        profit_margin: 0.50, // 50%
        sells_at: "village_market",
        main_customers: ["village_baker", "tavern", "traveling_merchants"],

        challenges: ["weather_dependent", "market_prices_fluctuate", "hard_labor"],
        benefits: ["self_sufficient", "steady_income", "community_respect"]
      },

      // Family farm
      family: {
        family_size: 5,
        family_helps: true,
        succession_plan: "pass_to_eldest_son",
        farm_generations: 3 // Family farm for 3 generations
      }
    }

    on_harvest_time(event) {
      console.log(`[VillageFarmer] Harvest time:
        - Crop: ${event.crop}
        - Yield: ${event.actual_yield}kg
        - Quality: ${event.quality}
        - Market Value: ${event.total_value} gold
      `);
    }

    on_weather_event(event) {
      console.log(`[VillageFarmer] Weather event:
        - Event: ${event.weather_type}
        - Severity: ${event.severity}
        - Crop Impact: ${event.crop_impact}
        - Action: ${event.farmer_action}
      `);
    }

    on_animal_birth(event) {
      console.log(`[VillageFarmer] Animal birth:
        - Animal: ${event.animal_type}
        - Count: ${event.birth_count}
        - Health: ${event.health}
        - Herd Size: ${event.new_total}
      `);
    }
  }

  /**
   * Mountain Miner - Miner NPC
   *
   * A skilled miner extracting valuable ores from the mountains.
   */
  entity MountainMiner {
    miner_npc: {
      // Mining profile
      mine_name: "Ironpeak Mine",
      mining_experience_years: 15,
      specialization: "ore_mining",
      miner_guild_member: true,

      // Mine
      mine: {
        mine_type: "underground_shaft",
        depth: 200, // meters
        shaft_count: 3,
        safety_level: "good",
        ventilation: "adequate",
        lighting: "torch_and_lantern"
      },

      // Mining operations
      operations: {
        ore_types_extracted: [
          {
            ore: "iron_ore",
            vein_richness: "moderate",
            daily_extraction: 500, // kg
            purity: 0.65, // 65% pure iron
            market_value: 2 // gold per kg
          },
          {
            ore: "copper_ore",
            vein_richness: "rich",
            daily_extraction: 200,
            purity: 0.70,
            market_value: 3
          },
          {
            ore: "coal",
            vein_richness: "abundant",
            daily_extraction: 800,
            purity: 0.90,
            market_value: 0.5
          }
        ],

        rare_finds: [
          {
            gem: "ruby",
            found_this_year: 2,
            value_each: 500
          }
        ]
      },

      // Mining skills
      skills: {
        pickaxe_proficiency: 9, // 1-10
        ore_identification: 8,
        tunnel_safety: 9,
        explosive_handling: 7,
        gem_appraisal: 6,
        cart_operation: 8
      },

      // Equipment
      equipment: {
        tools: ["pickaxe", "shovel", "chisel", "hammer"],
        safety_gear: ["helmet", "lamp", "rope", "breathing_cloth"],
        extraction_tools: ["wheelbarrow", "ore_cart", "pulley_system"]
      },

      // Hazards
      hazards: {
        knows_dangers: true,
        dangers: ["cave_in", "toxic_gas", "flooding", "exhaustion", "cave_creatures"],
        safety_protocols: {
          shore_up_tunnels: true,
          test_for_gas: true,
          buddy_system: true,
          emergency_exits: 2
        }
      },

      // Mining crew
      crew: {
        crew_size: 12,
        roles: {
          miners: 8,
          cart_operators: 2,
          foreman: 1,
          engineer: 1
        },
        crew_morale: 75, // 0-100
        safety_record: "good"
      },

      // Economics
      economics: {
        daily_wage: 10, // gold
        bonus_for_rare_finds: 0.1, // 10% of value
        mine_owner: "Mining Company",
        profit_sharing: 0.05, // 5% of profits
        annual_income: 3650 // gold (365 days * 10)
      },

      // Guild
      guild: {
        guild_name: "Miners Guild",
        guild_rank: "journeyman",
        guild_benefits: ["fair_wages", "safety_standards", "injury_compensation"],
        pays_dues: true
      }
    }

    on_ore_vein_discovered(event) {
      console.log(`[MountainMiner] Ore vein discovered:
        - Ore Type: ${event.ore_type}
        - Richness: ${event.richness}
        - Estimated Yield: ${event.estimated_yield}
        - Excitement: ${event.crew_excitement}
      `);
    }

    on_rare_gem_found(event) {
      console.log(`[MountainMiner] Rare gem found:
        - Gem: ${event.gem_type}
        - Size: ${event.size}
        - Quality: ${event.quality}
        - Estimated Value: ${event.value} gold
        - Finder's Bonus: ${event.bonus} gold
      `);
    }

    on_safety_incident(event) {
      console.log(`[MountainMiner] Safety incident:
        - Incident: ${event.incident_type}
        - Severity: ${event.severity}
        - Injured: ${event.injured_count}
        - Response: ${event.emergency_response}
        - Work Stopped: ${event.work_stopped}
      `);
    }
  }

  /**
   * Coastal Fisher - Fisher NPC
   *
   * A seasoned fisher who harvests the bounty of the sea.
   */
  entity CoastalFisher {
    fisher_npc: {
      // Fisher profile
      fishing_experience_years: 20,
      fishing_type: "coastal_fishing",
      owns_boat: true,
      boat_name: "Sea Dancer",

      // Boat
      boat: {
        boat_type: "fishing_trawler",
        length: 12, // meters
        crew_capacity: 4,
        cargo_capacity: 2000, // kg
        condition: "good",
        equipment: ["nets", "fishing_lines", "crab_pots", "anchor"]
      },

      // Fishing operations
      operations: {
        fishing_grounds: ["coastal_waters", "reef_area", "deep_channel"],
        fishing_methods: ["net_fishing", "line_fishing", "pot_fishing"],
        preferred_method: "net_fishing",

        daily_catch: {
          good_day: 500, // kg
          average_day: 200,
          bad_day: 50,
          recent_average: 180
        },

        fish_types: [
          { fish: "cod", abundance: "common", market_value: 3 },
          { fish: "tuna", abundance: "uncommon", market_value: 8 },
          { fish: "mackerel", abundance: "common", market_value: 2 },
          { fish: "lobster", abundance: "rare", market_value: 20 },
          { fish: "crab", abundance: "moderate", market_value: 10 }
        ]
      },

      // Fishing skills
      skills: {
        fishing_technique: 9, // 1-10
        navigation: 8,
        weather_reading: 9,
        net_repair: 8,
        fish_identification: 9,
        boat_maintenance: 7,
        swimming: 8
      },

      // Knowledge
      knowledge: {
        knows_best_fishing_spots: true,
        knows_seasonal_patterns: true,
        knows_tides: true,
        knows_fish_behavior: true,
        knows_weather_signs: true,
        secret_spots: 3 // Known only to this fisher
      },

      // Fishing schedule
      schedule: {
        typical_day: {
          departure: "04:00", // Early morning
          return: "14:00", // Early afternoon
          daily_trips: 1,
          rest_days: ["sunday"] // Observes sabbath
        },

        seasonal_variations: {
          spring: "abundant_catch",
          summer: "tourist_fishing_charters",
          autumn: "storm_season_reduced_fishing",
          winter: "harsh_weather_minimal_fishing"
        }
      },

      // Economics
      economics: {
        sells_to: ["fish_market", "restaurants", "local_buyers"],
        daily_income_average: 25, // gold
        annual_income: 7500, // 300 fishing days
        expenses: {
          boat_maintenance: 1000,
          fuel_and_bait: 2000,
          equipment: 500,
          dock_fees: 300
        },
        net_profit: 3700
      },

      // Fishing community
      community: {
        belongs_to_fishing_village: true,
        shares_knowledge: true,
        helps_other_fishers: true,
        competitive_but_fair: true,
        respects_sea: true
      },

      // Sustainability
      sustainability: {
        practices_sustainable_fishing: true,
        releases_undersized_fish: true,
        avoids_overfishing: true,
        respects_breeding_seasons: true
      }
    }

    on_big_catch(event) {
      console.log(`[CoastalFisher] Big catch:
        - Total Weight: ${event.total_weight}kg
        - Best Fish: ${event.best_fish}
        - Market Value: ${event.value} gold
        - Celebration: ${event.celebration}
      `);
    }

    on_storm_warning(event) {
      console.log(`[CoastalFisher] Storm warning:
        - Storm Severity: ${event.severity}
        - Time Until Storm: ${event.time_until}
        - Decision: ${event.decision}
        - Will Fish: ${event.will_fish}
      `);
    }

    on_rare_catch(event) {
      console.log(`[CoastalFisher] Rare catch:
        - Creature: ${event.creature}
        - Size: ${event.size}
        - Rarity: ${event.rarity}
        - Value: ${event.value} gold
        - Trophy: ${event.is_trophy}
      `);
    }
  }

  /**
   * Airship Captain - Pilot
   *
   * Commands an airship for transportation and exploration.
   */
  entity AirshipCaptain {
    pilot: {
      // Pilot profile
      pilot_license: "Airship_Master_License",
      flying_experience_years: 12,
      flight_hours: 8400,
      specialization: "cargo_and_passenger_transport",

      // Airship
      airship: {
        name: "Sky Merchant",
        type: "cargo_transport",
        length: 80, // meters
        capacity: {
          passengers: 20,
          cargo: 5000 // kg
        },
        crew: {
          captain: 1,
          first_mate: 1,
          engineers: 2,
          deck_hands: 3
        },
        condition: "excellent",
        age_years: 5
      },

      // Flight operations
      operations: {
        routes_flown: [
          {
            route: "Capital_City to Port_Town",
            distance: 500, // km
            flight_time: 10800000, // 3 hours
            frequency: "daily",
            passengers_average: 15,
            cargo_average: 3000
          },
          {
            route: "Port_Town to Mountain_City",
            distance: 300,
            flight_time: 7200000, // 2 hours
            frequency: "twice_weekly",
            passengers_average: 8,
            cargo_average: 4000
          }
        ],

        current_status: "in_flight",
        current_route: "Capital_City to Port_Town",
        altitude: 1500, // meters
        speed: 100, // km/h
        estimated_arrival: 1638356800000
      },

      // Piloting skills
      skills: {
        navigation: 9, // 1-10
        weather_reading: 9,
        emergency_procedures: 9,
        mechanical_knowledge: 7,
        passenger_management: 8,
        cargo_handling: 7
      },

      // Safety
      safety: {
        safety_record: "impeccable",
        accidents: 0,
        emergency_landings: 2, // Both successful
        safety_drills: "monthly",
        insurance_rating: "AAA",

        emergency_equipment: [
          "parachutes",
          "fire_extinguishers",
          "emergency_beacon",
          "life_rafts",
          "first_aid_kit"
        ]
      },

      // Navigation
      navigation: {
        uses_compass: true,
        uses_star_charts: true,
        uses_landmarks: true,
        uses_magical_navigation: true,
        instruments: ["altimeter", "barometer", "compass", "speed_indicator"]
      },

      // Economics
      economics: {
        ticket_price_per_passenger: 50,
        cargo_rate_per_kg: 1,
        daily_revenue_average: 1250,
        operating_costs_daily: 600,
        profit_margin: 0.52 // 52%
      }
    }

    on_flight_departure(event) {
      console.log(`[AirshipCaptain] Flight departure:
        - From: ${event.origin}
        - To: ${event.destination}
        - Passengers: ${event.passenger_count}
        - Cargo: ${event.cargo_weight}kg
        - Estimated Arrival: ${event.eta}
      `);
    }

    on_turbulence_encountered(event) {
      console.log(`[AirshipCaptain] Turbulence encountered:
        - Severity: ${event.severity}
        - Altitude Change: ${event.altitude_change}m
        - Action: ${event.pilot_action}
        - Passenger Safety: ${event.passenger_status}
      `);
    }

    on_emergency_situation(event) {
      console.log(`[AirshipCaptain] Emergency situation:
        - Emergency: ${event.emergency_type}
        - Severity: ${event.severity}
        - Response: ${event.emergency_response}
        - Outcome: ${event.outcome}
      `);
    }
  }

  /**
   * Master Engineer - Engineer
   *
   * Designs and builds mechanical and magical contraptions.
   */
  entity MasterEngineer {
    engineer: {
      // Engineering profile
      engineering_discipline: "mechanical_and_magical_engineering",
