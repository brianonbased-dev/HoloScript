      console.log(`[RoyalPhysician] Medical emergency:
        - Patient: ${event.patient}
        - Emergency: ${event.emergency_type}
        - Severity: ${event.severity}
        - Response Time: ${event.response_time}
        - Outcome: ${event.outcome}
      `);
    }
  }

  /**
   * King Edmund - Royalty
   *
   * The reigning monarch who rules the kingdom.
   */
  entity KingEdmund {
    royalty: {
      // Royal identity
      title: "King Edmund III",
      kingdom: "Kingdom of Valoria",
      dynasty: "House of Valorian",
      reign_started: 1546300800000, // 10 years ago
      age: 45,

      // Royal authority
      authority: {
        absolute_power: false, // Constitutional monarchy
        can_make_laws: true,
        can_declare_war: true,
        can_pardon_crimes: true,
        can_knight: true,
        can_grant_titles: true,
        commands_military: true
      },

      // Royal duties
      duties: {
        govern_kingdom: true,
        hold_court: true,
        attend_ceremonies: true,
        meet_ambassadors: true,
        oversee_justice: true,
        manage_treasury: true,
        protect_subjects: true
      },

      // Court
      court: {
        royal_palace: "Valorian Palace",
        court_size: 200, // courtiers, advisors, servants
        advisors: [
          { title: "Chancellor", name: "Lord Blackwood" },
          { title: "High General", name: "Sir Ironheart" },
          { title: "Court Wizard", name: "Archmage Starweaver" },
          { title: "Treasurer", name: "Count Goldsworth" }
        ],
        holds_audience: "daily",
        accessibility: "through_court_protocol"
      },

      // Kingdom stats
      kingdom: {
        population: 500000,
        territory_size: "medium_kingdom",
        prosperity: "prosperous",
        stability: "stable",
        military_strength: "strong",
        diplomatic_relations: "mostly_positive"
      },

      // Royal personality
      personality: {
        leadership_style: "just_and_wise",
        temperament: "measured",
        values: ["justice", "prosperity", "peace", "honor"],
        loved_by_people: true,
        public_approval: 78 // %
      },

      // Succession
      succession: {
        heir: "Prince William",
        heir_age: 22,
        succession_type: "primogeniture",
        line_of_succession_secure: true
      }
    }

    noble: {
      // Noble status (also a noble)
      noble_rank: "highest_nobility",
      family_lineage: "ancient_and_prestigious",
      coat_of_arms: "golden_lion_on_blue_field",

      // Noble privileges
      privileges: {
        land_ownership: "vast_estates",
        tax_exemption: false, // Sets example
        legal_privileges: "some",
        social_standing: "highest"
      }
    }

    on_royal_decree(event) {
      console.log(`[KingEdmund] Royal decree:
        - Decree: ${event.decree}
        - Scope: ${event.scope}
        - Reason: ${event.reason}
        - Public Response: ${event.public_response}
      `);
    }

    on_throne_room_audience(event) {
      console.log(`[KingEdmund] Throne room audience:
        - Petitioner: ${event.petitioner}
        - Petition: ${event.petition}
        - Royal Decision: ${event.decision}
        - Justice Served: ${event.justice}
      `);
    }

    on_diplomatic_meeting(event) {
      console.log(`[KingEdmund] Diplomatic meeting:
        - Diplomat: ${event.diplomat}
        - Kingdom: ${event.kingdom}
        - Purpose: ${event.purpose}
        - Outcome: ${event.outcome}
      `);
    }
  }

  /**
   * Duke of Westmarch - Noble
   *
   * A high-ranking noble who governs a duchy.
   */
  entity DukeOfWestmarch {
    noble: {
      // Noble identity
      title: "Duke",
      full_title: "Duke Richard of Westmarch",
      noble_rank: "duke", // duke | marquess | earl | viscount | baron
      territory: "Duchy of Westmarch",

      // Noble status
      lineage: {
        family_name: "House Westmarch",
        family_history: "300_years",
        coat_of_arms: "white_stag_on_green_field",
        family_motto: "Steadfast and True"
      },

      // Lands and estates
      lands: {
        primary_estate: "Westmarch Castle",
        manor_houses: 3,
        villages_owned: 12,
        total_land_area: 5000, // hectares
        annual_income_from_lands: 50000 // gold
      },

      // Governance
      governance: {
        governs_duchy: true,
        subjects: 50000,
        responsibilities: [
          "collect_taxes",
          "administer_justice",
          "maintain_order",
          "provide_military_levy",
          "infrastructure_maintenance"
        ],

        court: {
          holds_court: "weekly",
          court_officials: 15,
          administers_justice: true
        }
      },

      // Feudal obligations
      feudal_duties: {
        liege_lord: "King Edmund III",
        military_obligation: "provide_500_soldiers_when_called",
        tax_obligation: "10000_gold_annually",
        attendance_obligation: "attend_royal_court_quarterly",
        loyalty_oath: true
      },

      // Noble lifestyle
      lifestyle: {
        wealth_level: "very_wealthy",
        residence: "castle",
        staff_count: 100, // servants, guards, administrators
        horses: 20,
        luxury_goods: true,
        hunting_rights: "exclusive_in_duchy"
      },

      // Social standing
      social: {
        social_circle: "high_nobility",
        marriages: "strategic_alliances",
        hosts_events: true,
        event_types: ["balls", "hunts", "tournaments", "banquets"],
        etiquette: "impeccable"
      },

      // Political power
      political: {
        member_of_royal_council: true,
        influences_policy: true,
        diplomatic_connections: "extensive",
        political_faction: "royalist"
      }
    }

    on_tax_collection(event) {
      console.log(`[DukeOfWestmarch] Tax collection:
        - Period: ${event.period}
        - Amount Collected: ${event.amount} gold
        - Collection Rate: ${event.collection_rate}%
        - Sent to King: ${event.amount_to_king} gold
      `);
    }

    on_feudal_summons(event) {
      console.log(`[DukeOfWestmarch] Feudal summons:
        - Summons From: ${event.from}
        - Purpose: ${event.purpose}
        - Troops Required: ${event.troops_required}
        - Will Comply: ${event.will_comply}
      `);
    }

    on_noble_event_hosted(event) {
      console.log(`[DukeOfWestmarch] Noble event hosted:
        - Event: ${event.event_type}
        - Guests: ${event.guest_count}
        - Cost: ${event.cost} gold
        - Social Impact: ${event.social_impact}
      `);
    }
  }

  /**
   * Village Commoner - Peasant
   *
   * A common villager who works the land and pays taxes.
   */
  entity VillageCommoner {
    peasant: {
      // Peasant identity
      name: "Thomas the Miller",
      occupation: "miller",
      age: 38,
      village: "Oakshire Village",

      // Economic status
      economic_status: "poor_but_stable",
      owns_land: false, // Rents from lord
      rents_from: "Duke of Westmarch",
      annual_income: 50, // gold
      annual_expenses: 45,
      savings: 20,

      // Living conditions
      living_conditions: {
        home: "small_cottage",
        home_condition: "modest",
        rooms: 2,
        family_size: 5,
        diet: "simple", // Bread, vegetables, occasional meat
        health: "fair",
        literacy: false // Cannot read or write
      },

      // Work
      work: {
        occupation: "miller",
        works_for_self: true,
        grinds_grain_for_village: true,
        mill_fee: 0.1, // 10% of grain milled
        work_hours_per_day: 12,
        rest_days: ["sunday"]
      },

      // Feudal obligations
      obligations: {
        lord: "Duke of Westmarch",
        rent: 20, // gold per year
        labor_service: 30, // days per year working lord's land
        military_service: "if_called", // Militia duty
        tithes_to_church: 5 // gold per year
      },

      // Family
      family: {
        wife: "Mary",
        children: 3,
        children_ages: [12, 8, 4],
        children_work: true, // Help in mill
        family_survival_depends_on: "father's_work"
      },

      // Social
      social: {
        social_class: "commoner",
        social_mobility: "very_limited",
        village_standing: "respected", // Good miller
        community_ties: "strong",
        participates_in: ["village_gatherings", "harvest_festivals", "church"]
      },

      // Hardships
      hardships: {
        vulnerable_to: ["poor_harvests", "illness", "lord's_demands", "bandits"],
        no_safety_net: true,
        one_bad_year_from_ruin: true,
        hopes_and_dreams: "children_have_better_life"
      }
    }

    on_rent_due(event) {
      console.log(`[VillageCommoner] Rent due:
        - Amount: ${event.rent} gold
        - Can Afford: ${event.can_afford}
        - Payment Status: ${event.status}
        - Consequence If Unpaid: ${event.consequence}
      `);
    }

    on_harvest_result(event) {
      console.log(`[VillageCommoner] Harvest result:
        - Quality: ${event.harvest_quality}
        - Impact on Income: ${event.income_impact}
        - Food Security: ${event.food_security}
        - Winter Outlook: ${event.winter_outlook}
      `);
    }

    on_labor_service_called(event) {
      console.log(`[VillageCommoner] Labor service called:
        - Days Required: ${event.days}
        - Task: ${event.task}
        - Impact on Own Work: ${event.impact}
        - Will Comply: ${event.will_comply}
      `);
    }
  }

  /**
   * Dungeon Captive - Prisoner
   *
   * A prisoner held in the castle dungeon.
   */
  entity DungeonCaptive {
    prisoner: {
      // Prisoner identity
      prisoner_name: "Marcus Thorne",
      prisoner_number: 347,
      incarcerated_since: 1609459200000, // 3 years ago

      // Crime and sentence
      crime: {
        accused_of: "theft",
        proven_guilty: true,
        trial: "yes",
        sentence: "5_years_imprisonment",
        time_served: 3, // years
        time_remaining: 2
      },

      // Imprisonment
      imprisonment: {
        facility: "Westmarch Castle Dungeon",
        cell_type: "standard_cell",
        cell_condition: "poor",
        cell_mates: 1,
        freedom_of_movement: "none",
        allowed_outside: "1_hour_per_day"
      },

      // Daily routine
      routine: {
        wake_time: "06:00",
        meals: {
          breakfast: "gruel",
          lunch: "bread_and_water",
          dinner: "stew"
        },
        labor: {
          required_work: true,
          work_type: "stone_breaking",
          hours_per_day: 8
        },
        free_time: 2, // hours per day
        sleep_time: "20:00"
      },

      // Treatment
      treatment: {
        treatment_quality: "harsh_but_not_cruel",
        guards: "strict",
        violence_from_guards: "rare",
        medical_care: "basic",
        visitors_allowed: false,
        mail_allowed: false
      },

      // Physical and mental state
      state: {
        health: "poor",
        weight_loss: 15, // kg
        mental_state: "depressed",
        hope_level: 30, // 0-100
        thoughts_of: ["freedom", "family", "revenge", "regret"]
      },

      // Behavior
      behavior: {
        behavior_rating: "cooperative",
        disciplinary_infractions: 2,
        good_behavior_time_reduction: "possible",
        escape_attempts: 0
      },

      // Future
      future: {
        parole_eligible: true,
        parole_eligibility_date: 1667347200000, // 1 year
        post_release_plans: "unknown",
        fears: ["unable_to_reintegrate", "poverty", "ostracism"]
      }
    }

    on_visitor_arrived(event) {
      console.log(`[DungeonCaptive] Visitor arrived:
        - Visitor: ${event.visitor}
        - Relationship: ${event.relationship}
        - Allowed: ${event.allowed}
        - Duration: ${event.duration}
        - Emotional Impact: ${event.impact}
      `);
    }

    on_parole_hearing(event) {
      console.log(`[DungeonCaptive] Parole hearing:
        - Hearing Date: ${event.date}
        - Behavior Review: ${event.behavior}
        - Decision: ${event.decision}
        - Next Steps: ${event.next_steps}
      `);
    }

    on_prison_incident(event) {
      console.log(`[DungeonCaptive] Prison incident:
        - Incident: ${event.incident_type}
        - Involved: ${event.was_involved}
        - Punishment: ${event.punishment}
        - Impact on Release: ${event.release_impact}
      `);
    }
  }

  /**
   * Professions UI Panel
   */
  entity UIPanel {
    // Farmer Controls
    on_buy_produce_click() {
      emit farmer_sell to VillageFarmer {
        buyer: "player_hero",
        crop: "wheat",
        quantity: 100,
        price_per_kg: 2
      }
    }

    // Miner Controls
    on_buy_ore_click() {
      emit miner_sell to MountainMiner {
        buyer: "player_hero",
        ore: "iron_ore",
        quantity: 50,
        price_per_kg: 2
      }
    }

    // Fisher Controls
    on_buy_fish_click() {
      emit fisher_sell to CoastalFisher {
        buyer: "player_hero",
        fish: "tuna",
        quantity: 5,
        price_per_kg: 8
      }
    }

    // Pilot Controls
    on_book_flight_click() {
      emit pilot_book_flight to AirshipCaptain {
        passenger: "player_hero",
        route: "Capital_City to Port_Town",
        departure_time: "tomorrow_morning"
      }
    }

    // Engineer Controls
    on_commission_project_click() {
      emit engineer_commission to MasterEngineer {
        client: "player_hero",
        project: "Automated Defense System",
        budget: 10000
      }
    }

    // Doctor Controls
    on_request_treatment_click() {
      emit doctor_treat to RoyalPhysician {
        patient: "player_hero",
        ailment: "poison",
        urgency: "high"
      }
    }

    // Royalty Controls (audience)
    on_request_audience_click() {
      emit royalty_audience to KingEdmund {
        petitioner: "player_hero",
        petition: "Request for knighthood",
        urgency: "normal"
      }
    }

    // Noble Controls
    on_attend_ball_click() {
      emit noble_event_invite to DukeOfWestmarch {
        guest: "player_hero",
        event_type: "ball",
        date: "next_saturday"
      }
    }

    // Peasant Controls
    on_help_villager_click() {
      emit peasant_help to VillageCommoner {
        helper: "player_hero",
        help_type: "repair_mill",
        compensation: "gratitude_and_bread"
      }
    }

    // Prisoner Controls (if visiting)
    on_visit_prisoner_click() {
      emit prisoner_visit to DungeonCaptive {
        visitor: "player_hero",
        purpose: "gather_information",
        bribe_guard: true
      }
    }
  }

  /**
   * VR Camera
   */
  entity MainCamera {
    camera: {
      position: [0.0, 1.7, 5.0],
      rotation: [0.0, 0.0, 0.0],
      fov: 90.0
    }
  }
}
