    on_project_milestone(event) {
      console.log(`[MasterEngineer] Project milestone:
        - Project: ${event.project}
        - Milestone: ${event.milestone}
        - Progress: ${event.progress}%
        - On Schedule: ${event.on_schedule}
      `);
    }

