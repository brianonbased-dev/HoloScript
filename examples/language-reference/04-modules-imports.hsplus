// Language Reference: Modules & Imports (.hsplus format)
// Comprehensive reference for code organization and reusability
// For AI agent grounding and developer learning

// === IMPORTING MODULES ===

// Import entire module
import GameUtils from "./utils/game.hsplus";

// Import specific exports
import { calculateScore, formatTime } from "./utils/helpers.hsplus";

// Import with alias
import { PlayerController as PC } from "./controllers/player.hsplus";

// Import types (for TypeScript-like typing)
import type { GameConfig, PlayerState } from "./types.hsplus";

// Import composition
import MainMenu from "./scenes/menu.hsplus";

// === EXPORTING FROM MODULES ===

// Export function
export function calculateDamage(baseDamage, armor) {
  const reduction = armor / (armor + 100);
  return baseDamage * (1 - reduction);
}

// Export constant
export const MAX_PLAYERS = 8;
export const GAME_VERSION = "1.0.0";

// Export object
export const GameSettings = {
  difficulty: "normal",
  enableSound: true,
  enableParticles: true
};

// Export template
export template "Weapon" {
  state {
    damage: 10
    durability: 100
    equipped: false
  }

  actions {
    use() {
      console.log("Using weapon");
      this.state.durability -= 1;

      if (this.state.durability <= 0) {
        this.break();
      }
    }

    break() {
      console.log("Weapon broke!");
      this.destroy();
    }
  }

  geometry: "box"
}

// Export composition
export composition "WeaponShop" {
  object "Counter" {
    geometry: "box"
    position: { x: 0, y: 1, z: -3 }
  }
}

// Default export
export default composition "MainGame" {
  // Composition contents...
}

// === MODULE ORGANIZATION PATTERNS ===

// === Pattern 1: Utility Module ===
// File: utils/math.hsplus

export function clamp(value, min, max) {
  return Math.max(min, Math.min(max, value));
}

export function lerp(a, b, t) {
  return a + (b - a) * clamp(t, 0, 1);
}

export function randomRange(min, max) {
  return Math.random() * (max - min) + min;
}

export const MathConstants = {
  PI: Math.PI,
  TAU: Math.PI * 2,
  DEG_TO_RAD: Math.PI / 180,
  RAD_TO_DEG: 180 / Math.PI
};

// === Pattern 2: Component Library ===
// File: components/ui.hsplus

export template "Button" {
  type: "ui"
  uiType: "button"

  state {
    isHovered: false
    isPressed: false
  }

  on_pointer_enter() {
    this.state.isHovered = true;
  }

  on_pointer_exit() {
    this.state.isHovered = false;
  }

  on_pointer_down() {
    this.state.isPressed = true;
  }

  on_pointer_up() {
    this.state.isPressed = false;
  }
}

export template "ProgressBar" {
  type: "ui"
  uiType: "progressBar"

  state {
    value: 0
    max: 100
  }

  computed {
    percent: () => {
      return (this.state.value / this.state.max) * 100;
    }
  }
}

// === Pattern 3: Game Systems Module ===
// File: systems/inventory.hsplus

export class InventorySystem {
  constructor() {
    this.items = [];
    this.maxSlots = 20;
  }

  addItem(item) {
    if (this.items.length >= this.maxSlots) {
      console.log("Inventory full!");
      return false;
    }

    this.items.push(item);
    return true;
  }

  removeItem(itemId) {
    const index = this.items.findIndex(item => item.id === itemId);
    if (index !== -1) {
      return this.items.splice(index, 1)[0];
    }
    return null;
  }

  getItem(itemId) {
    return this.items.find(item => item.id === itemId);
  }

  clear() {
    this.items = [];
  }
}

export const inventoryManager = new InventorySystem();

// === Pattern 4: Configuration Module ===
// File: config/game.hsplus

