};

// === USING MODULES IN COMPOSITION ===

composition "GameExample" {
  // Modules are imported at top of file
  // import { Button, ProgressBar } from "./components/ui.hsplus";
  // import { GameConfig } from "./config/game.hsplus";
  // import { calculateDamage } from "./utils/combat.hsplus";

  state {
    playerHealth: 100  // Could use GameConfig.player.startHealth
  }

  actions {
    takeDamage(damage, armor) {
      // Use imported function
      const actualDamage = calculateDamage(damage, armor);
      state.playerHealth -= actualDamage;
    }
  }

  // Use imported template
  object "HealthBar" using "ProgressBar" {
    position: { x: 10, y: 10 }

    bind: {
      value: "state.playerHealth",
      max: 100
    }
  }

  object "StartButton" using "Button" {
    text: "Start Game"
    position: { x: 10, y: 60 }

    onClick: () => {
      console.log("Game started!");
    }
  }
}

// === DYNAMIC IMPORTS ===

composition "DynamicLoadExample" {
  state {
    currentLevel: null
  }

  actions {
    async loadLevel(levelName) {
      // Dynamic import
      const level = await import(`./levels/${levelName}.hsplus`);

      // Use imported level
      state.currentLevel = level.default;

      // Instantiate level
      this.addComposition(level.default);
    }

    async loadPlugin(pluginName) {
      try {
        const plugin = await import(`./plugins/${pluginName}.hsplus`);

        // Initialize plugin
        if (plugin.initialize) {
          plugin.initialize(this);
        }

        console.log("Plugin loaded:", pluginName);
      } catch (error) {
        console.error("Failed to load plugin:", error);
      }
    }
  }

  on_create() {
    // Load initial level
    this.loadLevel("level1");
  }
}

// === RE-EXPORTING ===
// File: index.hsplus (barrel export)

// Re-export everything from multiple modules
export * from "./components/ui.hsplus";
export * from "./systems/inventory.hsplus";
export * from "./utils/math.hsplus";

// Re-export specific items
export { GameConfig } from "./config/game.hsplus";
export { PlayerController } from "./controllers/player.hsplus";

// Re-export with rename
export { MainGame as Game } from "./game.hsplus";

// === CIRCULAR DEPENDENCY HANDLING ===
// File: player.hsplus

import type { Enemy } from "./enemy.hsplus";  // Use type import to avoid circular dependency

export class Player {
  constructor() {
    this.health = 100;
  }

  attackEnemy(enemy) {
    enemy.takeDamage(10);
  }
}

// File: enemy.hsplus
import type { Player } from "./player.hsplus";

export class Enemy {
  constructor() {
    this.health = 50;
  }

  takeDamage(amount) {
    this.health -= amount;
  }

  attackPlayer(player) {
    player.takeDamage(5);
  }
}

// === MODULE NAMESPACING ===

composition "NamespaceExample" {
  // Import entire module as namespace
  // import * as MathUtils from "./utils/math.hsplus";

  actions {
    calculatePosition() {
      // Use namespaced functions
      const angle = MathUtils.randomRange(0, MathUtils.MathConstants.TAU);
      const distance = MathUtils.lerp(1, 5, Math.random());

      return {
        x: Math.cos(angle) * distance,
        z: Math.sin(angle) * distance
      };
    }
  }
}

// === CONDITIONAL IMPORTS ===

composition "ConditionalImportExample" {
  state {
    useAdvancedGraphics: true
  }

  actions {
    async setupGraphics() {
      if (state.useAdvancedGraphics) {
        // Load advanced graphics module
        const graphics = await import("./graphics/advanced.hsplus");
        graphics.initialize();
      } else {
        // Load basic graphics module
        const graphics = await import("./graphics/basic.hsplus");
        graphics.initialize();
      }
    }
  }

  on_create() {
    this.setupGraphics();
  }
}

// === KEY MODULE CONCEPTS ===
// 1. IMPORT: Bring code from other files
// 2. EXPORT: Make code available to other files
// 3. DEFAULT EXPORT: One main export per module
// 4. NAMED EXPORTS: Multiple exports from one module
// 5. DYNAMIC IMPORT: Load modules at runtime (async)
// 6. RE-EXPORT: Pass through exports from another module
// 7. TYPE IMPORT: Import only type information
// 8. NAMESPACE IMPORT: Import all as single object
// 9. ALIAS: Rename imports to avoid conflicts

// === BEST PRACTICES ===
// - One composition per file (like React components)
// - Group related utilities in modules
// - Use barrel exports (index.hsplus) for libraries
// - Prefer named exports for clarity
// - Use default export only for main composition
// - Avoid circular dependencies
// - Keep modules focused and cohesive
// - Use dynamic imports for code splitting
// - Type imports for TypeScript-like safety
