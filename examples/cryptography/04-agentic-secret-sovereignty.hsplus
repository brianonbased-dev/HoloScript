/**
 * Agentic Secret Sovereignty - .hsplus Behavior Example
 *
 * Demonstrates a HoloScript-native authority layer where agents handle
 * secrets without ever turning them into prompt-visible strings.
 *
 * WHY .hsplus: Agentic secret custody is a multi-actor state machine:
 * request -> policy score -> consent -> leased capability -> brokered
 * execution -> receipt -> expiry or revocation. The invariants are not
 * just storage rules; they are semantic behavior rules that must compile to
 * MCP policy, vault policy, GitHub automation, Absorb redaction, local IDE
 * sessions, and user-facing receipts.
 *
 * Novel thesis: HoloScript is the authority IR. A secret is not a value.
 * A secret is a non-extractable object with traits, policies, game-theoretic
 * incentives, delegation limits, provenance, expiry, and evidence.
 *
 * @version 6.1.0
 * @format .hsplus (behavior)
 */

composition "AgenticSecretSovereignty" {
  environment {
    skybox: "cyber"
    ambient_light: 0.25
    physics: false
  }

  module ReceiptLedger {
    state {
      receipts: []
      receipt_count: 0
    }

    action record(event_type, actor_id, target_id, details) {
      this.state.receipt_count += 1;

      const receipt = {
        id: "rct_" + this.state.receipt_count,
        event_type: event_type,
        actor_id: actor_id,
        target_id: target_id,
        details: details || {},
        timestamp: current_time(),
        secret_exposure: "none",
        hash: "hash_" + generate_id()
      };

      this.state.receipts.push(receipt);

      emit("receipt:recorded", {
        id: receipt.id,
        event_type: event_type,
        actor_id: actor_id,
        target_id: target_id
      });

      return receipt;
    }

    action query_for_workspace(workspace_id, limit) {
      const max = limit || 25;
      return this.state.receipts
        .filter(r => r.details.workspace_id === workspace_id)
        .slice(-max);
    }

    exports {
      record
      query_for_workspace
      state
    }
  }

  module AuthorityGraph {
    state {
      grants: {}
      policies: {
        github_contents_write: {
          max_ttl_ms: 600000,
          max_uses: 1,
          consent: "per_action",
          allowed_paths: ["ecosystem/**", ".github/workflows/**", ".env.example"],
          denied_paths: [".env", ".env.*", "**/secrets/**", "**/*.pem", "**/*.key"]
        },
        holoscript_absorb_scan: {
          max_ttl_ms: 900000,
          max_uses: 1,
          consent: "repo_approval",
          redact_before_graph: true
        },
        orchestrator_knowledge_sync: {
          max_ttl_ms: 300000,
          max_uses: 1,
          consent: "workspace_default",
          publish_external: false
        }
      },
      incentive_weights: {
        narrow_scope_bonus: 30,
        short_ttl_bonus: 20,
        single_use_bonus: 20,
        broad_scope_penalty: 60,
        raw_secret_request_penalty: 100
      }
    }

    action score_request(action_id, resource, ttl_ms, max_uses, asks_for_raw_secret) {
      const policy = this.state.policies[action_id];
      if (!policy) return { allowed: false, score: 0, reason: "Unknown action" };

      let score = 50;

      if (ttl_ms <= policy.max_ttl_ms) {
        score += this.state.incentive_weights.short_ttl_bonus;
      } else {
        score -= this.state.incentive_weights.broad_scope_penalty;
      }

      if (max_uses === 1) {
        score += this.state.incentive_weights.single_use_bonus;
      }

      if (resource.indexOf("*") === -1) {
        score += this.state.incentive_weights.narrow_scope_bonus;
      } else {
        score -= this.state.incentive_weights.broad_scope_penalty;
      }

      if (asks_for_raw_secret) {
        score -= this.state.incentive_weights.raw_secret_request_penalty;
      }

      return {
        allowed: score >= 70 && !asks_for_raw_secret,
        score: score,
        consent: policy.consent,
        reason: score >= 70 ? "Least privilege request" : "Too broad or secret-extractive"
      };
    }

    action request_capability(agent_id, action_id, resource, ttl_ms, max_uses, reason) {
      const decision = this.score_request(action_id, resource, ttl_ms, max_uses, false);

      if (!decision.allowed) {
        ReceiptLedger.record("capability_denied", agent_id, resource, {
          action_id: action_id,
          reason: decision.reason,
          score: decision.score
        });
        emit("capability:denied", decision);
        return null;
      }

      const grant_id = "cap_" + generate_id();
      const grant = {
        id: grant_id,
        agent_id: agent_id,
        action_id: action_id,
        resource: resource,
        reason: reason,
        ttl_ms: ttl_ms,
        max_uses: max_uses,
        uses_remaining: max_uses,
        created_at: current_time(),
        expires_at: current_time() + ttl_ms,
        status: decision.consent === "per_action" ? "pending_consent" : "active",
        secret_visible_to_agent: false
      };

      this.state.grants[grant_id] = grant;

      ReceiptLedger.record("capability_requested", agent_id, grant_id, {
        action_id: action_id,
        resource: resource,
        reason: reason,
        consent: decision.consent,
        score: decision.score
      });

      emit("capability:requested", grant);
      return grant;
    }

    action approve(grant_id, approver_id) {
      const grant = this.state.grants[grant_id];
      if (!grant) return false;

      grant.status = "active";
      grant.approved_by = approver_id;
      grant.approved_at = current_time();

      ReceiptLedger.record("capability_approved", approver_id, grant_id, {
        agent_id: grant.agent_id,
        action_id: grant.action_id,
        resource: grant.resource
      });

      emit("capability:approved", grant);
      return true;
    }

    action consume(grant_id, execution_id) {
      const grant = this.state.grants[grant_id];
      if (!grant) return { ok: false, reason: "Unknown grant" };
      if (grant.status !== "active") return { ok: false, reason: "Grant not active" };
      if (current_time() > grant.expires_at) return { ok: false, reason: "Grant expired" };
      if (grant.uses_remaining <= 0) return { ok: false, reason: "Grant exhausted" };

      grant.uses_remaining -= 1;
      if (grant.uses_remaining === 0) {
        grant.status = "spent";
      }

      ReceiptLedger.record("capability_consumed", grant.agent_id, grant_id, {
        execution_id: execution_id,
        action_id: grant.action_id,
        resource: grant.resource,
        uses_remaining: grant.uses_remaining
      });

      return { ok: true, grant: grant };
    }

    exports {
      request_capability
      approve
      consume
      score_request
      state
    }
  }

  module SecretCustodian {
    state {
      secret_refs: {}
      custody_agents: ["vault_guardian", "rotation_agent", "receipt_auditor"]
      raw_secret_material: "[non-exportable]"
    }

    action import_secret(workspace_id, provider, name, source_attestation) {
      const ref = "secret://workspace/" + workspace_id + "/" + provider + "/" + name;

      this.state.secret_refs[ref] = {
        workspace_id: workspace_id,
        provider: provider,
        name: name,
        source_attestation: source_attestation,
        custody_mode: "agent_only",
        exportable_to_prompt: false,
        exportable_to_repo: false,
        rotation_required: true,
        created_at: current_time()
      };

      ReceiptLedger.record("secret_imported", "secret_custodian", ref, {
        workspace_id: workspace_id,
        provider: provider,
        name: name,
        custody_mode: "agent_only",
        raw_value_returned: false
      });

      emit("secret:imported", {
        ref: ref,
        workspace_id: workspace_id,
        provider: provider,
        raw_value: null
      });

      return {
        secret_ref: ref,
        raw_value: null
      };
    }

    action materialize_for_execution(secret_ref, grant_id, execution_id) {
      const secret = this.state.secret_refs[secret_ref];
      if (!secret) return { ok: false, reason: "Unknown secret" };

      const grant_check = AuthorityGraph.consume(grant_id, execution_id);
      if (!grant_check.ok) return grant_check;

      const handle = {
        execution_handle: "exec://" + execution_id + "/" + generate_id(),
        secret_ref: secret_ref,
        ttl_ms: 60000,
        raw_value: "[withheld]",
        visible_to_agent: false
      };

      ReceiptLedger.record("secret_materialized_for_execution", "broker", secret_ref, {
        execution_id: execution_id,
        grant_id: grant_id,
        raw_value_returned: false
      });

      emit("secret:materialized", handle);
      return { ok: true, handle: handle };
    }

    action rotate(secret_ref, agent_id) {
      const secret = this.state.secret_refs[secret_ref];
      if (!secret) return false;

      secret.rotated_at = current_time();
      secret.rotation_agent = agent_id;

      ReceiptLedger.record("secret_rotated", agent_id, secret_ref, {
        provider: secret.provider,
        raw_value_returned: false
      });

      emit("secret:rotated", {
        secret_ref: secret_ref,
        agent_id: agent_id
      });

      return true;
    }

    exports {
      import_secret
      materialize_for_execution
      rotate
      state
    }
  }

  module PolicyCompiler {
    action compile_authority_targets(workspace_id) {
      const targets = {
        mcp_gateway: {
          auth: "oauth_2_1_resource_server",
          token_binding: "agent_session_tool",
          raw_secret_tools: "deny"
        },
        github: {
          preferred: "github_app_installation_token",
          ttl: "1h",
          repo_scoped: true,
          commit_env_files: "deny"
        },
        absorb: {
          secret_files: "deny",
          secret_shaped_values: "redact",
          graph_storage: "handles_only"
        },
        studio_ui: {
          surface: "capability_board",
          consent: "receipt_preview",
          show_raw_secret: "never"
        },
        local_agent: {
          storage: "os_credential_store",
          session: "ephemeral",
          log_redaction: true
        }
      };

      ReceiptLedger.record("policy_compiled", "policy_compiler", workspace_id, {
        target_count: 5,
        output: targets
      });

      emit("policy:compiled", targets);
      return targets;
    }

    exports {
      compile_authority_targets
    }
  }

  entity FounderDogfoodRun {
    @llm_agent {
      model: "gpt-5.5",
      bounded_autonomy: true,
      max_actions_per_turn: 4,
      tools: [
        { name: "request_capability", authority: "handle_only" },
        { name: "materialize_for_execution", authority: "broker_only" },
        { name: "record_receipt", authority: "append_only" }
      ]
    }

    @state_machine {
      initial: "provisioning_workspace"

      state "provisioning_workspace" {
        on_entry {
          this.workspace_id = "ws_founder_dogfood";
          this.holoscript_ref = SecretCustodian.import_secret(
            this.workspace_id,
            "holoscript",
            "orchestrator_api_key",
            "existing_founder_env"
          );
        }

        transition "secret_imported" -> "compiling_policy" {
          guard: this.holoscript_ref.secret_ref != null
        }
      }

      state "compiling_policy" {
        on_entry {
          this.targets = PolicyCompiler.compile_authority_targets(this.workspace_id);
        }

        transition "compiled" -> "requesting_git_bootstrap"
      }

      state "requesting_git_bootstrap" {
        on_entry {
          this.grant = AuthorityGraph.request_capability(
            "brittney",
            "github_contents_write",
            "repo:founder/ai-workspace-template:path:ecosystem/secrets.manifest.yml",
            600000,
            1,
            "Replace committed credentials with non-extractable secret references"
          );
        }

        transition "needs_consent" -> "awaiting_consent" {
          guard: this.grant.status == "pending_consent"
        }

        transition "already_active" -> "brokered_execution" {
          guard: this.grant.status == "active"
        }
      }

      state "awaiting_consent" {
        on_entry {
          AuthorityGraph.approve(this.grant.id, "joseph");
        }

        transition "approved" -> "brokered_execution" {
          guard: this.grant.status == "active"
        }
      }

      state "brokered_execution" {
        on_entry {
          this.execution = SecretCustodian.materialize_for_execution(
            this.holoscript_ref.secret_ref,
            this.grant.id,
            "exec_workspace_bootstrap"
          );
        }

        transition "executed" -> "receipt_review" {
          guard: this.execution.ok == true
        }
      }

      state "receipt_review" {
        on_entry {
          this.receipts = ReceiptLedger.query_for_workspace(this.workspace_id, 20);
          emit("dogfood:secretless_run_complete", {
            workspace_id: this.workspace_id,
            receipt_count: this.receipts.length,
            raw_secret_exposure: "none"
          });
        }
      }
    }
  }
}
