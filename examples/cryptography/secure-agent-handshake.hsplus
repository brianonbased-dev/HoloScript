/**
 * Secure Agent Handshake — .hsplus Behavior Example
 *
 * Demonstrates post-quantum cryptographic authentication using ML-DSA-65,
 * Ed25519 hybrid signing, ML-KEM-768 key exchange, and token-based
 * session management.
 * WHY .hsplus: Cryptographic handshakes are textbook state machines.
 * The authentication lifecycle (idle -> key_exchange -> challenge ->
 * verified -> session_active -> rotating -> expired) has strict ordering
 * (cannot verify before key exchange), timeout guards (challenge must
 * complete within window), and periodic key rotation timers that require
 * @on_update. Token expiry is event-driven. Neither .holo (no state)
 * nor .hs (no timers or concurrent sessions) can express this.
 *
 * Features:
 * - KeyManager module for ML-DSA-65 + Ed25519 hybrid key generation
 * - SessionManager module for token creation, validation, and expiry
 * - SecureAgent template with authentication state machine
 * - @on_event handlers for auth lifecycle events
 * - Token types: agent_auth, session, capability
 * - Key rotation timer with @on_update
 * - Two agents demonstrating mutual authentication
 *
 * @version 5.0.0
 * @format .hsplus (behavior)
 */

composition "SecureAgentHandshake" {
  environment {
    skybox: "cyber"
    ambient_light: 0.3
    physics: false
  }

  // ========================================================================
  // KEY MANAGER MODULE
  // ========================================================================
  // Manages cryptographic key pairs using post-quantum algorithms.
  // Supports ML-DSA-65 (lattice-based signatures), ML-KEM-768
  // (lattice-based key encapsulation), and Ed25519 (classical fallback).
  // Hybrid signing combines both for quantum + classical security.

  module KeyManager {
    state {
      key_pairs: {}
      key_rotation_interval: 3600000  // 1 hour in ms
      last_rotation: null
      total_keys_generated: 0
      algorithms_available: ["ML-DSA-65", "ML-KEM-768", "Ed25519", "ECDSA-P256"]
    }

    // Generate a hybrid key pair (ML-DSA-65 + Ed25519)
    action generate_hybrid_keypair(agent_id) {
      const ml_dsa = {
        algorithm: "ML-DSA-65",
        public_key: generate_id() + "_ml_dsa_pub",
        private_key: generate_id() + "_ml_dsa_priv",
        key_size: 1952,
        generated_at: current_time()
      };

      const ed25519 = {
        algorithm: "Ed25519",
        public_key: generate_id() + "_ed25519_pub",
        private_key: generate_id() + "_ed25519_priv",
        key_size: 256,
        generated_at: current_time()
      };

      const keypair = {
        agent_id: agent_id,
        primary: ml_dsa,
        fallback: ed25519,
        hybrid: true,
        version: (this.state.key_pairs[agent_id]
          ? this.state.key_pairs[agent_id].version + 1
          : 1),
        created_at: current_time(),
        expires_at: current_time() + this.state.key_rotation_interval
      };

      this.state.key_pairs[agent_id] = keypair;
      this.state.total_keys_generated += 2;  // two algorithms
      this.state.last_rotation = current_time();

      emit("crypto:keypair_generated", {
        agent_id: agent_id,
        algorithms: ["ML-DSA-65", "Ed25519"],
        version: keypair.version
      });

      return {
        public_keys: {
          ml_dsa: ml_dsa.public_key,
          ed25519: ed25519.public_key
        },
        version: keypair.version
      };
    }

    // Generate an ML-KEM-768 key encapsulation pair for key exchange
    action generate_kem_pair(agent_id) {
      const kem = {
        algorithm: "ML-KEM-768",
        encapsulation_key: generate_id() + "_kem_encap",
        decapsulation_key: generate_id() + "_kem_decap",
        key_size: 1184,
        generated_at: current_time()
      };

      emit("crypto:kem_generated", {
        agent_id: agent_id,
        algorithm: "ML-KEM-768"
      });

      return kem;
    }

    // Sign data with hybrid signature (both ML-DSA-65 and Ed25519)
    action hybrid_sign(agent_id, data) {
      const keypair = this.state.key_pairs[agent_id];
      if (!keypair) {
        emit("crypto:sign_failed", {
          agent_id: agent_id,
          reason: "No keypair found"
        });
        return null;
      }

      // Check key expiry
      if (current_time() > keypair.expires_at) {
        emit("crypto:key_expired", {
          agent_id: agent_id,
          version: keypair.version
        });
        return null;
      }

      const signature = {
        data_hash: hash(data),
        ml_dsa_signature: generate_id() + "_sig_ml_dsa",
        ed25519_signature: generate_id() + "_sig_ed25519",
        key_version: keypair.version,
        signed_at: current_time(),
        algorithm: "ML-DSA-65+Ed25519"
      };

      emit("crypto:signed", {
        agent_id: agent_id,
        algorithm: signature.algorithm
      });

      return signature;
    }

    // Verify a hybrid signature
    action hybrid_verify(agent_id, data, signature) {
      const keypair = this.state.key_pairs[agent_id];
      if (!keypair) return false;

      // In production: verify both signatures against public keys
      // Simulated: check key version matches and data hash is consistent
      const valid = (
        signature.key_version === keypair.version &&
        signature.ml_dsa_signature != null &&
        signature.ed25519_signature != null
      );

      emit("crypto:verified", {
        agent_id: agent_id,
        valid: valid,
        algorithm: signature.algorithm
      });

      return valid;
    }

    // Check if a key pair needs rotation
    action needs_rotation(agent_id) {
      const keypair = this.state.key_pairs[agent_id];
      if (!keypair) return true;
      return current_time() > keypair.expires_at;
    }

    // Rotate keys for an agent
    action rotate_keys(agent_id) {
      const old_version = this.state.key_pairs[agent_id]
        ? this.state.key_pairs[agent_id].version
        : 0;

      const new_keys = this.generate_hybrid_keypair(agent_id);

      emit("crypto:keys_rotated", {
        agent_id: agent_id,
        old_version: old_version,
        new_version: new_keys.version
      });

      return new_keys;
    }

    // Utility: simple hash simulation
    action hash(data) {
      // In production: SHA-3 or SHAKE-256
      return "hash_" + generate_id();
    }

    exports {
      generate_hybrid_keypair
      generate_kem_pair
      hybrid_sign
      hybrid_verify
      needs_rotation
      rotate_keys
      state
    }
  }

  // ========================================================================
  // SESSION MANAGER MODULE
  // ========================================================================
  // Creates and validates authentication tokens. Supports three token
  // types: agent_auth (long-lived identity), session (request scope),
  // and capability (fine-grained permission delegation).

  module SessionManager {
    state {
      sessions: {}
      tokens: {}
      token_count: 0
      active_sessions: 0
      expired_sessions: 0
      token_types: ["agent_auth", "session", "capability"]
      default_ttl: {
        agent_auth: 86400000,   // 24 hours
        session: 3600000,       // 1 hour
        capability: 600000      // 10 minutes
      }
    }

    // Create a new session for an authenticated agent
    action create_session(agent_id, auth_method) {
      const session_id = "sess_" + generate_id();

      const session = {
        id: session_id,
        agent_id: agent_id,
        auth_method: auth_method,
        created_at: current_time(),
        last_activity: current_time(),
        status: "active",
        tokens: []
      };

      this.state.sessions[session_id] = session;
      this.state.active_sessions += 1;

      // Auto-generate an agent_auth token
      const auth_token = this.create_token(session_id, "agent_auth", {
        agent_id: agent_id,
        auth_method: auth_method
      });

      emit("session:created", {
        session_id: session_id,
        agent_id: agent_id,
        auth_token_id: auth_token.id
      });

      return { session_id: session_id, auth_token: auth_token };
    }

    // Create a token within a session
    action create_token(session_id, token_type, claims) {
      const session = this.state.sessions[session_id];
      if (!session || session.status !== "active") {
        emit("session:token_failed", { reason: "Invalid or inactive session" });
        return null;
      }

      if (!this.state.token_types.includes(token_type)) {
        emit("session:token_failed", { reason: "Invalid token type: " + token_type });
        return null;
      }

      this.state.token_count += 1;
      const ttl = this.state.default_ttl[token_type];

      const token = {
        id: "tok_" + this.state.token_count + "_" + generate_id(),
        session_id: session_id,
        type: token_type,
        claims: claims || {},
        issued_at: current_time(),
        expires_at: current_time() + ttl,
        revoked: false
      };

      this.state.tokens[token.id] = token;
      session.tokens.push(token.id);

      emit("session:token_issued", {
        token_id: token.id,
        type: token_type,
        expires_in: ttl
      });

      return token;
    }

    // Validate a token
    action validate_token(token_id) {
      const token = this.state.tokens[token_id];
      if (!token) {
        return { valid: false, reason: "Token not found" };
      }

      if (token.revoked) {
        return { valid: false, reason: "Token revoked" };
      }

      if (current_time() > token.expires_at) {
        token.revoked = true;
        emit("session:token_expired", { token_id: token_id, type: token.type });
        return { valid: false, reason: "Token expired" };
      }

      const session = this.state.sessions[token.session_id];
      if (!session || session.status !== "active") {
        return { valid: false, reason: "Session inactive" };
      }

      session.last_activity = current_time();
      return { valid: true, claims: token.claims, type: token.type };
    }

    // Revoke a specific token
    action revoke_token(token_id) {
      const token = this.state.tokens[token_id];
      if (!token) return false;

      token.revoked = true;
      emit("session:token_revoked", { token_id: token_id, type: token.type });
      return true;
    }

    // End a session (revokes all tokens)
    action end_session(session_id) {
      const session = this.state.sessions[session_id];
      if (!session) return false;

      session.status = "ended";
      this.state.active_sessions -= 1;
      this.state.expired_sessions += 1;

      // Revoke all session tokens
      for (const token_id of session.tokens) {
        this.revoke_token(token_id);
      }

      emit("session:ended", {
        session_id: session_id,
        agent_id: session.agent_id,
        duration: current_time() - session.created_at
      });
      return true;
    }

    // Create a capability token (delegated permission)
    action delegate_capability(session_id, capability, target_agent_id, ttl_override) {
      const cap_token = this.create_token(session_id, "capability", {
        capability: capability,
        delegated_to: target_agent_id,
        delegated_at: current_time()
      });

      if (cap_token && ttl_override) {
        cap_token.expires_at = current_time() + ttl_override;
      }

      emit("session:capability_delegated", {
        token_id: cap_token ? cap_token.id : null,
        capability: capability,
        target: target_agent_id
      });

      return cap_token;
    }

    exports {
      create_session
      create_token
      validate_token
      revoke_token
      end_session
      delegate_capability
      state
    }
  }

  // ========================================================================
  // SECURE AGENT TEMPLATE
  // ========================================================================
  // Each agent has a cryptographic authentication state machine that
  // governs the handshake lifecycle. Guards prevent protocol violations.

  template "SecureAgent" {
    @collidable
    geometry: "capsule"

    @state_machine {
      initial: "idle"

      states: {
        idle: {
          enter: {
            this.emissiveIntensity = 0.1;
          }
          on_initiate_handshake: -> "key_exchange" action(begin_key_exchange)
        }

        key_exchange: {
          enter: {
            this.emissiveIntensity = 0.3;
            emit("auth:key_exchange_started", { agent_id: state.agent_id });
          }
          on_keys_exchanged: -> "challenge" guard(state.peer_public_keys != null) action(issue_challenge)
          on_exchange_failed: -> "idle" action(handle_exchange_failure)
          on_timeout: -> "idle" guard(state.handshake_timer > state.handshake_timeout)
        }

        challenge: {
          enter: {
            this.emissiveIntensity = 0.5;
            emit("auth:challenge_issued", { agent_id: state.agent_id });
          }
          on_challenge_response: -> "verified" guard(state.challenge_valid) action(verify_peer)
          on_challenge_failed: -> "idle" action(handle_challenge_failure)
          on_timeout: -> "idle" guard(state.handshake_timer > state.handshake_timeout)
        }

        verified: {
          enter: {
            this.emissiveIntensity = 0.7;
            emit("auth:verified", { agent_id: state.agent_id });
          }
          on_session_created: -> "session_active" action(activate_session)
        }

        session_active: {
          enter: {
            this.emissiveIntensity = 1.0;
            emit("auth:session_active", {
              agent_id: state.agent_id,
              session_id: state.session_id
            });
          }
          on_rotation_needed: -> "rotating" guard(state.session_id != null)
          on_session_expired: -> "expired" action(handle_expiry)
          on_disconnect: -> "idle" action(cleanup_session)
          on_capability_request: -> "session_active" action(process_capability)
        }

        rotating: {
          enter: {
            this.emissiveIntensity = 0.6;
            emit("auth:rotating_keys", { agent_id: state.agent_id });
          }
          on_rotation_complete: -> "session_active" action(finalize_rotation)
          on_rotation_failed: -> "session_active" action(handle_rotation_failure)
        }

        expired: {
          enter: {
            this.emissiveIntensity = 0.05;
            emit("auth:expired", { agent_id: state.agent_id });
          }
          on_re_authenticate: -> "key_exchange" action(begin_key_exchange)
          on_dismiss: -> "idle"
        }
      }

      actions: {
        begin_key_exchange: () => {
          // Generate fresh keypair
          const keys = KeyManager.generate_hybrid_keypair(state.agent_id);
          state.own_public_keys = keys.public_keys;
          state.key_version = keys.version;
          state.handshake_timer = 0;

          // Also generate KEM pair for key exchange
          state.kem_pair = KeyManager.generate_kem_pair(state.agent_id);

          // Broadcast public keys to peer
          emit("auth:public_keys_offered", {
            agent_id: state.agent_id,
            public_keys: keys.public_keys,
            kem_encap_key: state.kem_pair.encapsulation_key,
            key_version: keys.version
          });
        }

        issue_challenge: () => {
          // Generate a random challenge nonce
          state.challenge_nonce = generate_id() + "_nonce_" + current_time();
          state.challenge_issued_at = current_time();

          // Sign the challenge with our keys
          state.challenge_signature = KeyManager.hybrid_sign(
            state.agent_id,
            state.challenge_nonce
          );

          emit("auth:challenge_sent", {
            from: state.agent_id,
            to: state.peer_id,
            nonce: state.challenge_nonce,
            signature: state.challenge_signature
          });
        }

        verify_peer: () => {
          emit("auth:peer_verified", {
            agent_id: state.agent_id,
            peer_id: state.peer_id,
            algorithm: "ML-DSA-65+Ed25519"
          });

          // Create session
          const session = SessionManager.create_session(
            state.agent_id,
            "hybrid_pq_auth"
          );
          state.session_id = session.session_id;
          state.auth_token = session.auth_token;

          emit("on_session_created");
        }

        activate_session: () => {
          state.session_start = current_time();
          state.rotation_timer = 0;

          // Generate a session token
          state.session_token = SessionManager.create_token(
            state.session_id,
            "session",
            {
              agent_id: state.agent_id,
              peer_id: state.peer_id,
              auth_level: "pq_hybrid"
            }
          );
        }

        handle_expiry: () => {
          if (state.session_id) {
            SessionManager.end_session(state.session_id);
          }
          state.session_id = null;
          state.auth_token = null;
          state.session_token = null;
        }

        cleanup_session: () => {
          if (state.session_id) {
            SessionManager.end_session(state.session_id);
          }
          state.session_id = null;
          state.auth_token = null;
          state.session_token = null;
          state.peer_id = null;
          state.peer_public_keys = null;
        }

        process_capability: () => {
          if (state.pending_capability) {
            const cap_token = SessionManager.delegate_capability(
              state.session_id,
              state.pending_capability.capability,
              state.pending_capability.target,
              state.pending_capability.ttl
            );
            state.pending_capability = null;
            emit("auth:capability_granted", {
              token_id: cap_token ? cap_token.id : null
            });
          }
        }

        finalize_rotation: () => {
          state.rotation_timer = 0;
          state.last_rotation = current_time();

          // Re-sign session with new keys
          state.session_token = SessionManager.create_token(
            state.session_id,
            "session",
            {
              agent_id: state.agent_id,
              peer_id: state.peer_id,
              auth_level: "pq_hybrid",
              key_version: state.key_version
            }
          );

          emit("auth:rotation_complete", {
            agent_id: state.agent_id,
            key_version: state.key_version
          });
        }

        handle_rotation_failure: () => {
          state.rotation_error = "Key rotation failed, continuing with current keys";
          emit("auth:rotation_failed", { agent_id: state.agent_id });
        }

        handle_exchange_failure: () => {
          state.last_error = "Key exchange failed";
          state.peer_public_keys = null;
          emit("auth:exchange_failed", { agent_id: state.agent_id });
        }

        handle_challenge_failure: () => {
          state.last_error = "Challenge verification failed";
          emit("auth:challenge_failed", { agent_id: state.agent_id });
        }
      }
    }

    state {
      agent_id: null
      peer_id: null
      own_public_keys: null
      peer_public_keys: null
      kem_pair: null
      key_version: 0
      challenge_nonce: null
      challenge_signature: null
      challenge_valid: false
      challenge_issued_at: null
      session_id: null
      session_start: null
      auth_token: null
      session_token: null
      handshake_timer: 0
      handshake_timeout: 10000
      rotation_timer: 0
      rotation_interval: 300000   // 5 minutes for demo (production: 1 hour)
      last_rotation: null
      rotation_error: null
      last_error: null
      pending_capability: null
    }

    // ------------------------------------------------------------------
    // Handshake timer and key rotation monitoring
    // ------------------------------------------------------------------
    @on_update: (delta) => {
      // Track handshake timeout during exchange/challenge phases
      if (this.current_state === "key_exchange" || this.current_state === "challenge") {
        state.handshake_timer += delta * 1000;
        if (state.handshake_timer > state.handshake_timeout) {
          emit("on_timeout");
        }
      }

      // Monitor key rotation schedule during active session
      if (this.current_state === "session_active") {
        state.rotation_timer += delta * 1000;

        if (state.rotation_timer > state.rotation_interval) {
          // Check if keys need rotation
          if (KeyManager.needs_rotation(state.agent_id)) {
            KeyManager.rotate_keys(state.agent_id);
            state.key_version = KeyManager.state.key_pairs[state.agent_id].version;
            emit("on_rotation_needed");
          } else {
            state.rotation_timer = 0;  // reset, keys are still fresh
          }
        }

        // Validate session token periodically
        if (state.session_token) {
          const validation = SessionManager.validate_token(state.session_token.id);
          if (!validation.valid) {
            emit("on_session_expired");
          }
        }
      }
    }

    // ------------------------------------------------------------------
    // Event handlers for peer communication
    // ------------------------------------------------------------------

    // Receive peer's public keys
    @on_event("auth:public_keys_offered"): (data) => {
      // Only accept if we are in key_exchange and this is from our peer
      if (data.agent_id === state.peer_id) {
        state.peer_public_keys = data.public_keys;
        emit("on_keys_exchanged");
      }
    }

    // Receive challenge from peer
    @on_event("auth:challenge_sent"): (data) => {
      if (data.to === state.agent_id && data.from === state.peer_id) {
        // Verify the challenge signature
        const valid = KeyManager.hybrid_verify(
          state.peer_id,
          data.nonce,
          data.signature
        );

        state.challenge_valid = valid;

        if (valid) {
          // Sign the nonce ourselves and respond
          const our_sig = KeyManager.hybrid_sign(state.agent_id, data.nonce);
          emit("auth:challenge_response", {
            from: state.agent_id,
            to: state.peer_id,
            nonce: data.nonce,
            signature: our_sig,
            valid: true
          });
        } else {
          emit("on_challenge_failed");
        }
      }
    }

    // Receive challenge response from peer
    @on_event("auth:challenge_response"): (data) => {
      if (data.to === state.agent_id && data.from === state.peer_id) {
        state.challenge_valid = data.valid && KeyManager.hybrid_verify(
          state.peer_id,
          data.nonce,
          data.signature
        );

        if (state.challenge_valid) {
          emit("on_challenge_response");
        } else {
          emit("on_challenge_failed");
        }
      }
    }

    // Handle key rotation completion broadcast
    @on_event("crypto:keys_rotated"): (data) => {
      if (data.agent_id === state.agent_id && this.current_state === "rotating") {
        emit("on_rotation_complete");
      }
    }
  }

  // ========================================================================
  // SCENE OBJECTS -- Two Agents Performing Mutual Authentication
  // ========================================================================

  // Agent Alpha: initiates the handshake
  object "AgentAlpha" using "SecureAgent" {
    position: [-3, 1, 0]
    color: "#00aaff"
    emissive: "#00aaff"

    state {
      agent_id: "alpha-secure-001"
      peer_id: "beta-secure-002"
    }

    // Auto-initiate handshake on scene load
    @on_event("scene:loaded"): () => {
      emit("on_initiate_handshake");
    }
  }

  // Agent Beta: responds to the handshake
  object "AgentBeta" using "SecureAgent" {
    position: [3, 1, 0]
    color: "#ff6600"
    emissive: "#ff6600"

    state {
      agent_id: "beta-secure-002"
      peer_id: "alpha-secure-001"
    }

    // Beta also initiates (mutual authentication)
    @on_event("auth:public_keys_offered"): (data) => {
      if (data.agent_id === state.peer_id && this.current_state === "idle") {
        emit("on_initiate_handshake");
      }
    }
  }

  // ------------------------------------------------------------------
  // Visual connection indicators
  // ------------------------------------------------------------------

  // Encrypted channel beam between agents
  object "EncryptedChannel" {
    @glowing
    geometry: "cube"
    position: [0, 1, 0]
    scale: [5.5, 0.03, 0.03]
    color: "#1a1a1a"
    emissive: "#1a1a1a"
    emissiveIntensity: 0.1

    @on_event("auth:key_exchange_started"): () => {
      this.color = "#ffaa00";
      this.emissive = "#ffaa00";
      this.emissiveIntensity = 0.3;
    }

    @on_event("auth:challenge_issued"): () => {
      this.color = "#ff6600";
      this.emissive = "#ff6600";
      this.emissiveIntensity = 0.5;
    }

    @on_event("auth:verified"): () => {
      this.color = "#00ff88";
      this.emissive = "#00ff88";
      this.emissiveIntensity = 0.8;
    }

    @on_event("auth:session_active"): () => {
      this.color = "#00ffcc";
      this.emissive = "#00ffcc";
      this.emissiveIntensity = 1.0;
    }

    @on_event("auth:rotating_keys"): () => {
      this.emissiveIntensity = 0.4;
      // Flicker during rotation
      setTimeout(() => {
        this.emissiveIntensity = 1.0;
      }, 500);
    }

    @on_event("auth:expired"): () => {
      this.color = "#e74c3c";
      this.emissive = "#e74c3c";
      this.emissiveIntensity = 0.2;
    }
  }

  // Key exchange visualization particles
  object "KeyExchangeParticles" {
    @animated
    @glowing
    geometry: "sphere"
    position: [0, 1, 0]
    scale: [0.1, 0.1, 0.1]
    color: "#ffaa00"
    emissive: "#ffaa00"
    emissiveIntensity: 0.5
    visible: false

    @on_event("auth:key_exchange_started"): () => {
      this.visible = true;
      this.animate = "ping_pong";
    }

    @on_event("auth:session_active"): () => {
      this.visible = false;
    }
  }

  // Agent platforms
  object "PlatformAlpha" {
    @glowing
    geometry: "cylinder"
    position: [-3, 0.1, 0]
    scale: [1.5, 0.08, 1.5]
    color: "#001a33"
    emissive: "#00aaff"
    emissiveIntensity: 0.15
  }

  object "PlatformBeta" {
    @glowing
    geometry: "cylinder"
    position: [3, 0.1, 0]
    scale: [1.5, 0.08, 1.5]
    color: "#331a00"
    emissive: "#ff6600"
    emissiveIntensity: 0.15
  }

  object "Floor" {
    @collidable
    geometry: "cube"
    position: [0, 0, 0]
    scale: [14, 0.1, 10]
    color: "#0a0a14"
  }

  // ========================================================================
  // HUD -- Security and session monitoring panels
  // ========================================================================

  panel "AuthStatusHUD" {
    position: "top-left"

    text "AlphaAuth" {
      bind: "Alpha: " + AgentAlpha.current_state + " (v" + AgentAlpha.state.key_version + ")"
      style: "info"
    }
    text "BetaAuth" {
      bind: "Beta:  " + AgentBeta.current_state + " (v" + AgentBeta.state.key_version + ")"
      style: "info"
    }
    text "Algorithm" {
      bind: "Algorithms: ML-DSA-65 + Ed25519 (hybrid)"
      style: "info"
    }
  }

  panel "SessionHUD" {
    position: "top-right"

    text "ActiveSessions" {
      bind: "Sessions: " + SessionManager.state.active_sessions + " active, " + SessionManager.state.expired_sessions + " expired"
      style: "info"
    }
    text "Tokens" {
      bind: "Tokens issued: " + SessionManager.state.token_count
      style: "info"
    }
    text "KeysGenerated" {
      bind: "Keys generated: " + KeyManager.state.total_keys_generated
      style: "info"
    }
  }

  panel "CryptoHUD" {
    position: "bottom-left"

    text "AlphaRotation" {
      bind: "Alpha rotation in: " + Math.max(0, Math.floor((AgentAlpha.state.rotation_interval - AgentAlpha.state.rotation_timer) / 1000)) + "s"
      style: "info"
    }
    text "BetaRotation" {
      bind: "Beta rotation in: " + Math.max(0, Math.floor((AgentBeta.state.rotation_interval - AgentBeta.state.rotation_timer) / 1000)) + "s"
      style: "info"
    }
    text "KEMAlgorithm" {
      bind: "Key Exchange: ML-KEM-768"
      style: "info"
    }
  }
}
