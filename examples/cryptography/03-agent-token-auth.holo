/**
 * Agent Token Auth — HoloScript v5.0 Distributed Authentication Example
 *
 * Demonstrates secure agent authentication across distributed scenes.
 * This example shows:
 *  - Agent authentication flow with ML-DSA-65 signatures
 *  - Cross-scene token propagation
 *  - Session management with refresh tokens
 *  - Multi-scene single sign-on (SSO)
 *  - Proof-of-Possession (PoP) challenge-response
 *  - Token revocation and session invalidation
 *
 * Use Case: Distributed Agent Identity
 *   - Agents authenticate once, access multiple scenes
 *   - Quantum-resistant authentication tokens
 *   - Zero-knowledge proof of identity
 *   - Federated agent sessions
 *
 * Run this example:
 *   holoc examples/cryptography/03-agent-token-auth.holo --target r3f
 *
 * @version 5.0.0
 */

scene DistributedAuth {
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // AUTHENTICATION SERVICE CONFIGURATION
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity AuthService {
    traits: [auth_provider];

    auth_provider: {
      // Authentication methods
      supportedMethods: ["signature", "pop_challenge", "capability_token"],

      // Signature algorithm
      signatureAlgorithm: "hybrid-ed25519-ml-dsa-65",

      // Token configuration
      accessTokenTTL: 900000,      // 15 minutes
      refreshTokenTTL: 2592000000, // 30 days
      sessionTTL: 86400000,        // 24 hours

      // PoP challenge configuration
      popChallengeEnabled: true,
      challengeExpiration: 60000,  // 1 minute
      nonceSize: 32,               // 32 bytes (256 bits)

      // Multi-scene SSO
      federatedScenesEnabled: true,
      sceneRegistry: "https://registry.holoscript.io/scenes",

      // Session management
      maxConcurrentSessions: 5,
      sessionRefreshEnabled: true,
      slidingExpiration: true,     // Extend session on activity

      // Revocation
      revocationCheckInterval: 300000,  // 5 minutes
      revocationListUrl: "https://revocation.holoscript.io/list",
    };
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Authentication Flow
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(AuthService, "auth_initiated") {
    log("🔐 Authentication initiated");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Method: ${event.method}`);
    log(`  Scene: ${event.sceneId}`);
    log(`  Timestamp: ${event.timestamp}`);
  }

  on(AuthService, "challenge_issued") {
    log("⚡ PoP challenge issued");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Nonce: ${event.nonce.substring(0, 16)}... (32 bytes)`);
    log(`  Challenge: Sign this nonce with your private key`);
    log(`  Expires in: ${event.expirationMs}ms`);
    log(`  Algorithm required: ${event.requiredAlgorithm}`);
  }

  on(AuthService, "challenge_responded") {
    log("✅ PoP challenge response received");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Signature: ${event.signature.substring(0, 32)}...`);
    log(`  Algorithm: ${event.algorithm}`);
    log(`  Verifying signature...`);
  }

  on(AuthService, "auth_success") {
    log("✅ Authentication SUCCESS");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Session ID: ${event.sessionId}`);
    log(`  Access token: ${event.accessToken.substring(0, 50)}...`);
    log(`  Refresh token: ${event.refreshToken.substring(0, 50)}...`);
    log(`  Expires at: ${event.expiresAt}`);
    log(`  Capabilities: ${event.capabilities.length} granted`);
  }

  on(AuthService, "auth_failed") {
    log("❌ Authentication FAILED");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Reason: ${event.reason}`);
    log(`  Details: ${event.details}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Session Management
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(AuthService, "session_created") {
    log("🎟️  Session created");
    log(`  Session ID: ${event.sessionId}`);
    log(`  Agent ID: ${event.agentId}`);
    log(`  Scene: ${event.sceneId}`);
    log(`  Expires at: ${event.expiresAt}`);
    log(`  Sliding expiration: ${event.slidingExpiration ? "✅" : "❌"}`);
  }

  on(AuthService, "session_validated") {
    log("✅ Session validated");
    log(`  Session ID: ${event.sessionId}`);
    log(`  Agent ID: ${event.agentId}`);
    log(`  Valid until: ${event.expiresAt}`);
    log(`  Activity extended: ${event.extended ? "✅ Yes" : "❌ No"}`);
  }

  on(AuthService, "session_expired") {
    log("⏰ Session expired");
    log(`  Session ID: ${event.sessionId}`);
    log(`  Agent ID: ${event.agentId}`);
    log(`  Expired at: ${event.expiredAt}`);
    log(`  Reason: ${event.reason}`);
  }

  on(AuthService, "session_refreshed") {
    log("🔄 Session refreshed");
    log(`  Session ID: ${event.sessionId}`);
    log(`  Old expiration: ${event.oldExpiresAt}`);
    log(`  New expiration: ${event.newExpiresAt}`);
    log(`  Extended by: ${event.extensionMs}ms`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Cross-Scene SSO
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(AuthService, "scene_access_requested") {
    log("🌐 Cross-scene access requested");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Source scene: ${event.sourceSceneId}`);
    log(`  Target scene: ${event.targetSceneId}`);
    log(`  Session ID: ${event.sessionId}`);
  }

  on(AuthService, "scene_access_granted") {
    log("✅ Cross-scene access GRANTED");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Target scene: ${event.targetSceneId}`);
    log(`  Scene token: ${event.sceneToken.substring(0, 50)}...`);
    log(`  Capabilities: ${event.capabilities.length}`);
    log(`  Federated SSO active`);
  }

  on(AuthService, "scene_access_denied") {
    log("🚫 Cross-scene access DENIED");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Target scene: ${event.targetSceneId}`);
    log(`  Reason: ${event.reason}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Token Refresh
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(AuthService, "token_refresh_requested") {
    log("🔄 Token refresh requested");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Refresh token: ${event.refreshToken.substring(0, 50)}...`);
  }

  on(AuthService, "token_refreshed") {
    log("✅ Token refreshed");
    log(`  Agent ID: ${event.agentId}`);
    log(`  New access token: ${event.newAccessToken.substring(0, 50)}...`);
    log(`  New refresh token: ${event.newRefreshToken.substring(0, 50)}...`);
    log(`  Expires at: ${event.expiresAt}`);
  }

  on(AuthService, "token_refresh_failed") {
    log("❌ Token refresh FAILED");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Reason: ${event.reason}`);
    log(`  Re-authentication required`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // EVENT HANDLERS — Revocation & Logout
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  on(AuthService, "logout_initiated") {
    log("👋 Logout initiated");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Session ID: ${event.sessionId}`);
    log(`  Logout type: ${event.logoutType}`);  // single | all_sessions
  }

  on(AuthService, "logout_success") {
    log("✅ Logout successful");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Sessions terminated: ${event.sessionCount}`);
    log(`  Tokens revoked: ${event.tokenCount}`);
  }

  on(AuthService, "token_revoked") {
    log("🚫 Token revoked");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Token ID: ${event.tokenId}`);
    log(`  Reason: ${event.reason}`);
    log(`  Revoked by: ${event.revokedBy}`);
    log(`  Revoked at: ${event.revokedAt}`);
  }

  on(AuthService, "session_invalidated") {
    log("🚫 Session invalidated");
    log(`  Session ID: ${event.sessionId}`);
    log(`  Agent ID: ${event.agentId}`);
    log(`  Reason: ${event.reason}`);
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // DEMO CONTROLS
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity DemoControls {
    traits: [interactive];
  }

  // Demo 1: Initiate authentication
  on(DemoControls, "click") {
    if (event.target === "initiate_auth_button") {
      emit(AuthService, "initiate_auth", {
        agentId: "agent_alice",
        method: "pop_challenge",
        sceneId: "scene_main_hub",
        publicKey: "alice_ed25519_ml_dsa_65_public_key...",
      });
      log("🔐 Initiating authentication for Alice...");
    }
  }

  // Demo 2: Respond to PoP challenge
  on(DemoControls, "click") {
    if (event.target === "respond_challenge_button") {
      emit(AuthService, "respond_challenge", {
        agentId: "agent_alice",
        nonce: "challenge_nonce_abc123...",
        signature: "alice_hybrid_signature_of_nonce...",
        algorithm: "hybrid-ed25519-ml-dsa-65",
      });
      log("✅ Responding to PoP challenge...");
    }
  }

  // Demo 3: Validate existing session
  on(DemoControls, "click") {
    if (event.target === "validate_session_button") {
      emit(AuthService, "validate_session", {
        sessionId: "session_alice_12345",
        agentId: "agent_alice",
        sceneId: "scene_main_hub",
      });
      log("🔍 Validating session...");
    }
  }

  // Demo 4: Request cross-scene access
  on(DemoControls, "click") {
    if (event.target === "cross_scene_access_button") {
      emit(AuthService, "request_scene_access", {
        agentId: "agent_alice",
        sessionId: "session_alice_12345",
        sourceSceneId: "scene_main_hub",
        targetSceneId: "scene_training_room",
        requestedCapabilities: [
          { action: "read", resource: "scenes/training_room" },
          { action: "execute", resource: "traits/navigation" },
        ],
      });
      log("🌐 Requesting cross-scene access...");
    }
  }

  // Demo 5: Refresh access token
  on(DemoControls, "click") {
    if (event.target === "refresh_token_button") {
      emit(AuthService, "refresh_token", {
        agentId: "agent_alice",
        refreshToken: "alice_refresh_token_xyz...",
      });
      log("🔄 Refreshing access token...");
    }
  }

  // Demo 6: Extend session (sliding expiration)
  on(DemoControls, "click") {
    if (event.target === "extend_session_button") {
      emit(AuthService, "extend_session", {
        sessionId: "session_alice_12345",
        agentId: "agent_alice",
        activityType: "interaction",
      });
      log("🔄 Extending session due to activity...");
    }
  }

  // Demo 7: Logout from current session
  on(DemoControls, "click") {
    if (event.target === "logout_single_button") {
      emit(AuthService, "logout", {
        agentId: "agent_alice",
        sessionId: "session_alice_12345",
        logoutType: "single",
      });
      log("👋 Logging out from current session...");
    }
  }

  // Demo 8: Logout from all sessions
  on(DemoControls, "click") {
    if (event.target === "logout_all_button") {
      emit(AuthService, "logout", {
        agentId: "agent_alice",
        logoutType: "all_sessions",
      });
      log("👋 Logging out from ALL sessions...");
    }
  }

  // Demo 9: Revoke specific token
  on(DemoControls, "click") {
    if (event.target === "revoke_token_button") {
      emit(AuthService, "revoke_token", {
        agentId: "agent_alice",
        tokenId: "token_alice_abc123",
        reason: "Security policy violation",
        revokedBy: "system_admin",
      });
      log("🚫 Revoking token...");
    }
  }

  // Demo 10: Check session list
  on(DemoControls, "click") {
    if (event.target === "list_sessions_button") {
      emit(AuthService, "list_sessions", {
        agentId: "agent_alice",
      });
      log("📋 Fetching active sessions...");
    }
  }

  on(AuthService, "session_list") {
    log("📋 ACTIVE SESSIONS");
    log(`  Agent ID: ${event.agentId}`);
    log(`  Total sessions: ${event.sessions.length}`);
    log("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    for (const session of event.sessions) {
      log(`  Session: ${session.sessionId}`);
      log(`    Scene: ${session.sceneId}`);
      log(`    Created: ${session.createdAt}`);
      log(`    Expires: ${session.expiresAt}`);
      log(`    Last activity: ${session.lastActivityAt}`);
      log("  ─────────────────────────────────────────");
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // VISUALIZATION
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  entity AuthDashboard {
    geometry: plane;
    position: [0, 2.5, -4];
    scale: [6, 3.5, 1];
    traits: [text_display];

    text_display: {
      content: "DISTRIBUTED AGENT AUTHENTICATION\n\n🔐 Authentication Flow:\n  1. Agent initiates auth\n  2. Service issues PoP challenge (nonce)\n  3. Agent signs nonce with private key\n  4. Service verifies signature\n  5. Issues access + refresh tokens\n  6. Creates session\n\n🎫 Token Types:\n  • Access token - Short-lived (15 min)\n  • Refresh token - Long-lived (30 days)\n  • Scene token - Per-scene capabilities\n\n🌐 Multi-Scene SSO:\n  • Authenticate once, access all scenes\n  • Federated session management\n  • Per-scene capability tokens\n  • Seamless scene transitions\n\n🔄 Session Management:\n  • Sliding expiration (extend on activity)\n  • Max 5 concurrent sessions\n  • Session refresh without re-auth\n  • Global logout (all sessions)\n\n🛡️  Security Features:\n  • Hybrid signatures (Ed25519 + ML-DSA-65)\n  • PoP binding (prevent token theft)\n  • Token revocation lists\n  • Session invalidation\n  • Quantum-resistant tokens\n\n⚡ PoP Challenge:\n  • 32-byte random nonce\n  • 1-minute expiration\n  • Zero-knowledge proof",
      fontSize: 0.08,
      color: "#34d399",
    };
  }
}
