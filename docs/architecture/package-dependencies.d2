direction: down

title: |md
  # HoloScript Package Dependency Graph
  37 dependency edges across 71 packages
|

# ============================================================
# FOUNDATION LAYER
# ============================================================
foundation: "Foundation" {
  style.fill: "#1a1a2e"
  style.font-color: "#e0e0e0"

  core: "@holoscript/core" {
    style.fill: "#c0392b"
    style.font-color: "#fff"
    style.font-size: 16
    style.bold: true
    style.border-radius: 12
  }
  crdt: "@holoscript/crdt" {
    style.fill: "#2c3e50"
    style.font-color: "#ecf0f1"
    style.border-radius: 8
  }
  std: "@holoscript/std" {
    style.fill: "#2c3e50"
    style.font-color: "#ecf0f1"
    style.border-radius: 8
  }
  auth: "@holoscript/auth" {
    style.fill: "#2c3e50"
    style.font-color: "#ecf0f1"
    style.border-radius: 8
  }
}

# ============================================================
# LANGUAGE LAYER
# ============================================================
language: "Language & Tooling" {
  style.fill: "#0f3460"
  style.font-color: "#e0e0e0"

  parser: "parser" { style.fill: "#1a5276"; style.font-color: "#aed6f1"; style.border-radius: 8 }
  traits: "traits" { style.fill: "#1a5276"; style.font-color: "#aed6f1"; style.border-radius: 8 }
  compiler: "compiler" { style.fill: "#1a5276"; style.font-color: "#aed6f1"; style.border-radius: 8 }
  linter: "linter" { style.fill: "#1a5276"; style.font-color: "#aed6f1"; style.border-radius: 8 }
  lsp: "lsp" { style.fill: "#1a5276"; style.font-color: "#aed6f1"; style.border-radius: 8 }
  formatter: "formatter" { style.fill: "#1a5276"; style.font-color: "#aed6f1"; style.border-radius: 8 }
}

# ============================================================
# RUNTIME LAYER
# ============================================================
runtime_layer: "Runtime & Engine" {
  style.fill: "#1b4332"
  style.font-color: "#e0e0e0"

  engine: "engine" { style.fill: "#2d6a4f"; style.font-color: "#b7e4c7"; style.border-radius: 8 }
  runtime: "runtime" { style.fill: "#2d6a4f"; style.font-color: "#b7e4c7"; style.border-radius: 8 }
  holo-vm: "holo-vm" { style.fill: "#2d6a4f"; style.font-color: "#b7e4c7"; style.border-radius: 8 }
  uaal: "uaal" { style.fill: "#2d6a4f"; style.font-color: "#95d5b2"; style.border-radius: 8 }
  vm-bridge: "vm-bridge" { style.fill: "#2d6a4f"; style.font-color: "#95d5b2"; style.border-radius: 8 }
}

# ============================================================
# AI & INTELLIGENCE
# ============================================================
ai_layer: "AI & Intelligence" {
  style.fill: "#2d2d44"
  style.font-color: "#e0e0e0"

  intelligence: "intelligence" { style.fill: "#3d3d5c"; style.font-color: "#c4b5fd"; style.border-radius: 8 }
  llm-provider: "llm-provider" { style.fill: "#3d3d5c"; style.font-color: "#c4b5fd"; style.border-radius: 8 }
  ai-validator: "ai-validator" { style.fill: "#3d3d5c"; style.font-color: "#c4b5fd"; style.border-radius: 8 }
}

# ============================================================
# DEVELOPER TOOLS
# ============================================================
devtools: "Developer Tools" {
  style.fill: "#4a1942"
  style.font-color: "#e0e0e0"

  cli: "cli" { style.fill: "#6b2d5b"; style.font-color: "#f0a6ca"; style.border-radius: 8 }
  mcp-server: "mcp-server" { style.fill: "#6b2d5b"; style.font-color: "#f0a6ca"; style.border-radius: 8 }
  vscode-extension: "vscode-ext" { style.fill: "#6b2d5b"; style.font-color: "#f0a6ca"; style.border-radius: 8 }
  benchmark: "benchmark" { style.fill: "#6b2d5b"; style.font-color: "#d48ec7"; style.border-radius: 8 }
  sdk: "sdk" { style.fill: "#6b2d5b"; style.font-color: "#d48ec7"; style.border-radius: 8 }
}

# ============================================================
# CONNECTORS HUB
# ============================================================
connectors: "Studio Integration Hub" {
  style.fill: "#1a3a1a"
  style.font-color: "#e0e0e0"

  connector-core: "connector-core" { style.fill: "#2a5a2a"; style.font-color: "#90ee90"; style.border-radius: 8 }
  connector-github: "github" { style.fill: "#2a5a2a"; style.font-color: "#70cc70"; style.border-radius: 8 }
  connector-railway: "railway" { style.fill: "#2a5a2a"; style.font-color: "#70cc70"; style.border-radius: 8 }
  connector-upstash: "upstash" { style.fill: "#2a5a2a"; style.font-color: "#70cc70"; style.border-radius: 8 }
  connector-appstore: "appstore" { style.fill: "#2a5a2a"; style.font-color: "#70cc70"; style.border-radius: 8 }
}

# ============================================================
# STUDIO & WEB
# ============================================================
studio_layer: "Studio & Web" {
  style.fill: "#3c1518"
  style.font-color: "#e0e0e0"

  studio: "studio" { style.fill: "#69140e"; style.font-color: "#f8d7da"; style.border-radius: 8 }
  r3f-renderer: "r3f-renderer" { style.fill: "#69140e"; style.font-color: "#f8d7da"; style.border-radius: 8 }
  studio-plugin-sdk: "studio-plugin-sdk" { style.fill: "#69140e"; style.font-color: "#e6b0aa"; style.border-radius: 8 }
  playground: "playground" { style.fill: "#69140e"; style.font-color: "#e6b0aa"; style.border-radius: 8 }
}

# ============================================================
# MARKETPLACE
# ============================================================
marketplace: "Marketplace" {
  style.fill: "#2c2c3e"
  style.font-color: "#e0e0e0"

  graphql-api: "graphql-api" { style.fill: "#3d3d5c"; style.font-color: "#c4b5fd"; style.border-radius: 8 }
  marketplace-api: "marketplace-api" { style.fill: "#3d3d5c"; style.font-color: "#c4b5fd"; style.border-radius: 8 }
  marketplace-web: "marketplace-web" { style.fill: "#3d3d5c"; style.font-color: "#c4b5fd"; style.border-radius: 8 }
  registry: "registry" { style.fill: "#3d3d5c"; style.font-color: "#a29bfe"; style.border-radius: 8 }
}

# ============================================================
# DEPENDENCY EDGES
# ============================================================

# core depends on crdt
foundation.core -> foundation.crdt: { style.stroke: "#e74c3c" }

# Language layer → core
language.parser -> foundation.core: { style.stroke: "#5dade2" }
language.traits -> foundation.core: { style.stroke: "#5dade2" }
language.linter -> foundation.core: { style.stroke: "#5dade2" }
language.compiler -> foundation.core: { style.stroke: "#5dade2" }
language.compiler -> language.traits: { style.stroke: "#27ae60" }
language.compiler -> language.parser: { style.stroke: "#27ae60" }
language.lsp -> foundation.core: { style.stroke: "#5dade2" }
language.lsp -> language.linter: { style.stroke: "#27ae60" }

# Runtime → core
runtime_layer.engine -> foundation.core: { style.stroke: "#5dade2" }
runtime_layer.runtime -> foundation.core: { style.stroke: "#5dade2" }
runtime_layer.holo-vm -> foundation.core: { style.stroke: "#5dade2" }
runtime_layer.vm-bridge -> runtime_layer.holo-vm: { style.stroke: "#27ae60" }
runtime_layer.vm-bridge -> runtime_layer.uaal: { style.stroke: "#27ae60" }

# AI → core
ai_layer.intelligence -> foundation.core: { style.stroke: "#5dade2" }
ai_layer.ai-validator -> foundation.core: { style.stroke: "#5dade2" }

# DevTools
devtools.cli -> foundation.core: { style.stroke: "#5dade2" }
devtools.cli -> ai_layer.llm-provider: { style.stroke: "#9b59b6" }
devtools.cli -> devtools.sdk: { style.stroke: "#27ae60" }
devtools.mcp-server -> foundation.core: { style.stroke: "#5dade2" }
devtools.mcp-server -> ai_layer.llm-provider: { style.stroke: "#9b59b6" }
devtools.vscode-extension -> devtools.sdk: { style.stroke: "#27ae60" }
devtools.vscode-extension -> language.lsp: { style.stroke: "#27ae60" }
devtools.vscode-extension -> language.formatter: { style.stroke: "#27ae60" }
devtools.benchmark -> foundation.core: { style.stroke: "#5dade2" }
devtools.benchmark -> language.formatter: { style.stroke: "#27ae60" }
devtools.benchmark -> language.lsp: { style.stroke: "#27ae60" }

# Connectors → connector-core
connectors.connector-github -> connectors.connector-core: { style.stroke: "#27ae60" }
connectors.connector-railway -> connectors.connector-core: { style.stroke: "#27ae60" }
connectors.connector-upstash -> connectors.connector-core: { style.stroke: "#27ae60" }
connectors.connector-appstore -> connectors.connector-core: { style.stroke: "#27ae60" }

# Studio
studio_layer.studio -> foundation.core: { style.stroke: "#5dade2" }
studio_layer.studio -> studio_layer.r3f-renderer: { style.stroke: "#27ae60" }
studio_layer.studio -> foundation.std: { style.stroke: "#27ae60" }
studio_layer.studio -> studio_layer.studio-plugin-sdk: { style.stroke: "#27ae60" }
studio_layer.r3f-renderer -> foundation.core: { style.stroke: "#5dade2" }
studio_layer.playground -> foundation.core: { style.stroke: "#5dade2" }
studio_layer.playground -> foundation.std: { style.stroke: "#27ae60" }

# Marketplace
marketplace.graphql-api -> foundation.auth: { style.stroke: "#f39c12" }
marketplace.graphql-api -> foundation.core: { style.stroke: "#5dade2" }
marketplace.marketplace-api -> foundation.auth: { style.stroke: "#f39c12" }
marketplace.marketplace-api -> foundation.core: { style.stroke: "#5dade2" }
marketplace.marketplace-api -> marketplace.registry: { style.stroke: "#27ae60" }
marketplace.marketplace-web -> marketplace.marketplace-api: { style.stroke: "#27ae60" }
