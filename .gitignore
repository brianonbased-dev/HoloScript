# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.js

# testing
coverage/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript incremental compilation output
*.tsbuildinfo

# local holoscript compiler output
*.js.map

# Local benchmark outputs — regenerated on every `pnpm bench` run.
# `git status` was showing 5 churning JSON files in this dir.
/.bench-logs/

# PersistentTrait file-backend test artifacts — written by trait-starters-p3.test.ts
.holo-persist/

# Local wallet broadcaster pages — regenerated by scripts/anchor-*.mjs.
/.broadcaster/

# Mesh harvest destination — populated by scripts/mesh-deploy/harvest-deliverables.sh
/.mesh-harvest/

# Local holoscript graph cache — written by holo_absorb_repo, expires in 24h
.holoscript/

# Agent workspace artifacts — written by AI agents, not source
.agents/
.canary/
.holomesh/
.performance-reports/
.tmp/
.ai-context-stream.jsonl
.ai-workspace/
.cursor-queue-temp.json
.git_commit_msg.txt
.lint-main.txt
.local-worker-key
.preflight-result.json
audit-results/

# Root-only agent run-debris: test/tsc/lint dumps + board/audit JSON scratch.
# Leading / anchors to repo root so tracked board.json, packages/**/test-output.js,
# packages/framework/ALL-test-results.json, research/**/audit-*.json are NOT caught.
/core-fail*.txt
/core-errors.txt
/core-test-results.txt
/clean-check.txt
/test-output*.txt
/test-results.txt
/test-full-run*.txt
/test-run-*.txt
/test_output.txt
/test_results.json
/ts-test-output*.txt
/ts-test-verify.txt
/tsc_errors_*.txt
