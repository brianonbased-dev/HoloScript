# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.js

# testing
coverage/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript incremental compilation output
*.tsbuildinfo

# local holoscript compiler output
*.js.map

# Local benchmark outputs — regenerated on every `pnpm bench` run.
# `git status` was showing 5 churning JSON files in this dir.
/.bench-logs/

# PersistentTrait file-backend test artifacts — written by trait-starters-p3.test.ts
.holo-persist/

# Local wallet broadcaster pages — regenerated by scripts/anchor-*.mjs.
/.broadcaster/

# Mesh harvest destination — populated by scripts/mesh-deploy/harvest-deliverables.sh
/.mesh-harvest/

# Local holoscript graph cache — written by holo_absorb_repo, expires in 24h
.holoscript/

# Agent workspace artifacts — written by AI agents, not source
.agents/
.canary/
.holomesh/
.performance-reports/
.tmp/
.ai-context-stream.jsonl
.ai-workspace/
.cursor-queue-temp.json
.git_commit_msg.txt
.lint-main.txt
.local-worker-key
.preflight-result.json
audit-results/

# Root-only agent run-debris: test/tsc/lint dumps + board/audit JSON scratch.
# Leading / anchors to repo root so tracked board.json, packages/**/test-output.js,
# packages/framework/ALL-test-results.json, research/**/audit-*.json are NOT caught.
/core-fail*.txt
/core-errors.txt
/core-test-results.txt
/clean-check.txt
/test-output*.txt
/test-results.txt
/test-full-run*.txt
/test-run-*.txt
/test_output.txt
/test_results.json
/ts-test-output*.txt
/ts-test-verify.txt
/tsc_errors_*.txt
/studio_tsc*.txt
/shortlog*.txt
/stat.txt
/wavee-*.txt
/vitest-engine.json
/vitest-result.json
/board-utf8.json
/board2.json
/board_utf8.json
/board_output.json
/board_close_*.json
/clean_board.json
/temp_board.json
/claim_*.json
/audit-current.json
/audit-after-overrides.json
/dep-audit*.json
/todos.txt

# Training datasets — large binary/JSONL files, never commit
datasets/

# Rust build output
target/

# Next.js build caches in services
services/studio-api/.next/
services/studio-api/next-env.d.ts

# Service error logs and scratch dumps
services/absorb-service/*.txt
services/holoscript-net/archive/
services/llm-service/*.err
services/render-service/*.txt

# Compiled JS/TS declaration outputs from TypeScript source scripts
# (the .ts sources are tracked; the compiled outputs are not)
examples/**/*.js
examples/**/*.d.ts
scripts/training/*.js
scripts/training/*.d.ts
docs/tour/*.js
docs/tour/*.d.ts

# Agent IDE workspace (Claude/Cursor skill drafts, heap monitors)
.claude/

# Scratch test files at repo root
/test-wasm.ts
/test_ast.mjs
/test_db.ts
/test_tools.mjs
/send_api.mjs
/sync_wpg.js

# Temp and test-result directories
temp_ts_morph/
test-results/
tmp/

