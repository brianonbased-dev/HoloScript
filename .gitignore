# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.js

# testing
coverage/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript incremental compilation output
*.tsbuildinfo

# local holoscript compiler output
*.js.map

# Local benchmark outputs — regenerated on every `pnpm bench` run.
# `git status` was showing 5 churning JSON files in this dir.
/.bench-logs/

# PersistentTrait file-backend test artifacts — written by trait-starters-p3.test.ts
.holo-persist/

# Local wallet broadcaster pages — regenerated by scripts/anchor-*.mjs.
/.broadcaster/

# Mesh harvest destination — populated by scripts/mesh-deploy/harvest-deliverables.sh
/.mesh-harvest/

# Local holoscript graph cache — written by holo_absorb_repo, expires in 24h
.holoscript/

# Agent workspace artifacts — written by AI agents, not source
.agents/
.canary/
.holomesh/
.performance-reports/
.tmp/
.ai-context-stream.jsonl
.ai-workspace/
.cursor-queue-temp.json
.git_commit_msg.txt
.lint-main.txt
.local-worker-key
.preflight-result.json
audit-results/
/.scratch/

# Training datasets — large binary/JSONL files, never commit
datasets/

# Rust build output
target/

# Next.js build caches in services
services/studio-api/.next/
services/studio-api/next-env.d.ts

# Service error logs and scratch dumps
services/absorb-service/*.txt
services/holoscript-net/archive/
services/llm-service/*.err
services/render-service/*.txt

# Compiled JS/TS declaration outputs from TypeScript source scripts
# (the .ts sources are tracked; the compiled outputs are not)
examples/**/*.js
examples/**/*.d.ts
scripts/training/*.js
scripts/training/*.d.ts
docs/tour/*.js
docs/tour/*.d.ts

# Agent IDE workspace (Claude/Cursor skill drafts, heap monitors)
.claude/

# Scratch test files at repo root
/test-wasm.ts
/test_ast.mjs
/test_db.ts
/test_tools.mjs
/send_api.mjs
/sync_wpg.js

# Temp and test-result directories
temp_ts_morph/
test-results/
tmp/

# bio-demo compiled output
bio-demo/*.js

# benchmarks compiled outputs
benchmarks/tools/*.js
benchmarks/tools/*.d.ts

# samples compiled outputs
samples/**/*.js
samples/**/*.d.ts

# Deployment scratch directories
scripts/mesh-deploy/mesh-deploy-logs/

# Compiled declaration files in script subdirectories
scripts/analysis/**/*.d.ts
scripts/debug/**/*.d.ts
scripts/archive/**/*.d.ts

# Generated validation/tm report (run-time output)
scripts/tm-traits-validation-report.json

# TypeScript declaration files and source maps generated next to source files.
# (Real declarations are emitted to dist/ or hand-crafted via generate-types.mjs;
#  these .d.ts/.d.ts.map files scattered inside src/ are compiler debris.)
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
# A few packages emit declarations at the package root level
packages/*/src/*.d.ts
packages/*/src/*.d.ts.map

# tsup bundler temp files (generated on every build, hash in name)
packages/*/tsup.config.bundled_*.mjs
packages/*/tsup.config.d.ts

# Generated package declaration files
packages/cli/src/holoscript-subpaths.d.ts
packages/cli/src/sdk-schema.d.ts
packages/ai-validator/tsup.config.d.ts

# Package-level error/build dumps
packages/absorb-service/*.txt
packages/absorb-service/err.txt
packages/core/nul
packages/core/scripts/archive/*.js
packages/core/scripts/merge-enhanced-datasets.d.ts
packages/core/scripts/merge-enhanced-datasets.js
packages/core/scripts/regenerate-mcp-jsonl.d.ts
packages/core/scripts/regenerate-mcp-jsonl.js
packages/core/scripts/validate-dataset.d.ts
packages/core/scripts/validate-dataset.js
packages/adapter-postgres/tsup.config.bundled_*.mjs

# Per-package Next.js builds and generated env files
packages/*/.next/
packages/*/next-env.d.ts

# Per-package error/test dumps (txt/json scratch files at package root)
packages/engine/*.txt
packages/engine/*.js
packages/mcp-server/*.txt
packages/mcp-server/*.js
packages/studio/*.txt
packages/studio/*.json
packages/studio/e2e/*.d.ts
packages/studio/e2e/*.js
packages/studio/scripts/archive/*.js
packages/studio/scripts/patch-core-dts.js
packages/studio/scripts/replace_loggers.js
packages/studio/scripts/testGen.js
packages/studio/.holo_audits/
packages/studio/playwright-report/
packages/studio/playwright-results.xml
packages/formatter/*.txt
packages/lsp/*.txt
packages/lsp/*.js
packages/marketplace-api/*.txt
packages/crdt/*.txt
packages/vscode-extension/*.txt

# VSCode extension build + packaged extension binaries
packages/vscode-extension/out/
packages/vscode-extension/*.vsix

# Video tutorial render outputs and narration audio (large binaries)
packages/video-tutorials/out/
packages/video-tutorials/public/narration/
packages/video-tutorials/scripts/*.d.ts
packages/video-tutorials/scripts/*.js
packages/video-tutorials/remotion.config.d.ts

# Tree-sitter generated Web bindings
packages/tree-sitter-holoscript/bindings/web/

# Playwright + smoke build artifacts
packages/studio/playwright.config.d.ts
packages/platform/dist-smoke/

# Temp type stubs and LLM provider scratch
packages/llm-provider/temp-dts/

# Windows nul device artifacts at any package depth
packages/*/nul
packages/*/src/nul
packages/*/src/traits/nul

# Miscellaneous package-level debris not caught by patterns above
/packages/core_tsc_errors.txt
/patch.mjs
/scripts/fix-source-files.d.ts
packages/core/scripts/archive/*.d.ts
packages/core/test/*.d.ts
packages/create-holoscript/templates/**/*.js
packages/holoscript/tests/*.d.ts
packages/holoscript/tests/*.js
packages/linter/verify-linter.d.ts
packages/linter/verify-linter.js
packages/plugins/web-preview/src/*.d.ts
packages/studio-plugin-sdk/bin/create-plugin.js
packages/studio/public/browser-benchmark.js
packages/studio/public/browser-benchmark.test.js
packages/tree-sitter-holoscript/test_error.txt
packages/video-tutorials/tsc_video_errors.txt
packages/visual/vite.config.d.ts
packages/visualizer-client/vite.config.d.ts

