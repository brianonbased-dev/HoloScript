#!/bin/bash
# AI Ecosystem: Pre-Commit Quality Gates (TypeScript)
# Fast linting only — no test gating (CI validates all tests)
#
# Gates: ESLint + workspace dependency check
# Tests: DISABLED (CI catches failures; avoids daemon interference)

echo "🔍 Running quality gates (TypeScript)..."

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any gate failed
FAILED=0

# Timeout wrapper — kills long-running gates after N seconds
run_with_timeout() {
    local timeout_secs=$1
    shift
    if command -v timeout &> /dev/null; then
        timeout "$timeout_secs" "$@" 2>&1
    else
        # Windows/Git Bash fallback: run with background job + wait
        "$@" 2>&1 &
        local pid=$!
        ( sleep "$timeout_secs" && kill -9 $pid 2>/dev/null ) &
        local killer=$!
        wait $pid 2>/dev/null
        local exit_code=$?
        kill $killer 2>/dev/null
        wait $killer 2>/dev/null
        return $exit_code
    fi
}

# Skip all gates for explicitly automated workflows.
# --no-verify bypasses hooks already, but these guards prevent accidental
# bleed-through when daemon/IDE agents run git operations without that flag.
if [ "$SKIP_HOOKS" = "1" ] || [ "$HOLODAEMON_SKIP_HOOKS" = "1" ] || [ "$HOLODAEMON_ACTIVE" = "1" ] || [ "$COPILOT_AGENT" = "1" ] || [ "$GITHUB_COPILOT_AGENT" = "1" ] || [ "$IDE_AGENT" = "1" ]; then
    echo -e "  ${YELLOW}⚠${NC}  Automated run detected — skipping all gates"
    exit 0
fi

# Multi-agent safety: warn when staged + unstaged changes coexist
STAGED_COUNT=$(git diff --cached --name-only | wc -l)
UNSTAGED_COUNT=$(git diff --name-only | wc -l)
if [ "$STAGED_COUNT" -gt 0 ] && [ "$UNSTAGED_COUNT" -gt 0 ]; then
    echo -e "  ${YELLOW}⚠${NC}  Multi-agent: $STAGED_COUNT staged, $UNSTAGED_COUNT unstaged files coexist"
    echo "     Only staged files will be committed. Unstaged changes are from other contexts."
fi

# Gate 1: Linting (30s timeout)
echo "  ├─ ESLint..."
if command -v npm &> /dev/null && [ -f "package.json" ]; then
    LINT_OUT=$(run_with_timeout 30 npm run lint --if-present 2>&1) || true
    if echo "$LINT_OUT" | grep -q "npm ERR!"; then
        echo -e "  ${RED}❌ Linting failed${NC}"
        echo "     Run 'npm run lint:fix' to auto-fix issues"
        FAILED=1
    else
        echo -e "  ${GREEN}✓${NC} Linting passed"
    fi
fi

# Gate 2: Type checking — DISABLED for pre-commit
# Reason: tsc --noEmit on any package takes 20-60s and frequently OOMs
# at 4GB. CI handles full type-check.
echo -e "  ├─ TypeScript type checking... ${YELLOW}⚠ skipped (CI handles this)${NC}"

# Gate 3: Tests — DISABLED for local development
# Reason: Vitest startup takes ~5s, full run 6s. CI runs full validation anyway.
echo -e "  ├─ Tests (core validators)... ${YELLOW}⚠ skipped (CI validates all tests)${NC}"

# Gate 4: Workspace dependency check (30s — slow FS on Windows/agent sandboxes)
echo "  ├─ Workspace dependency check..."
if [ -f "scripts/check-workspace-deps.js" ]; then
    DEPS_OUTPUT=$(run_with_timeout 30 node scripts/check-workspace-deps.js 2>&1)
    DEPS_STATUS=$?
    if [ "$DEPS_STATUS" -ne 0 ]; then
        echo -e "  ${RED}❌ Hardcoded @holoscript/* versions found${NC}"
        echo "$DEPS_OUTPUT"
        echo "     Run 'node scripts/check-workspace-deps.js --fix' to auto-correct"
        FAILED=1
    else
        echo -e "  ${GREEN}✓${NC} Workspace deps OK"
    fi
fi

# Gate 5: Stale build-artifact shadow check (fast, fails loud).
# Background: ai-ecosystem 2026-04-20 SECURITY-mode audit found 224
# stale .js/.d.ts/.map shadows in packages/engine/src/simulation/ that
# silently shadowed .ts source in Node module resolution, masking
# Wave-2 item 5a edits during test runs. Src/ is effectively .ts-only
# at runtime (compiled output lives in dist/); any UNTRACKED .js/.d.ts
# under packages/*/src/ is stale tsc output and should be deleted.
# Note: some .d.ts files are tracked in src/ (hand-crafted type
# declarations, e.g. packages/cli/src/HoloScriptCLI.d.ts). Those are
# intentional and not flagged by this gate — we check UNTRACKED-
# non-ignored files only (git ls-files --others --exclude-standard).
# Knowledge store entry: grad-stale-js-shadow-debugging (confidence 0.9).
echo "  ├─ Stale build-artifact check..."
# Node's module resolution prefers .js and .d.ts over co-located .ts
# when both exist, and does NOT respect .gitignore. Untracked/gitignored
# .js or .d.ts files in src/ silently shadow the .ts source — the
# Wave-2 item 5a debugging incident (2026-04-20) was 224 such files in
# packages/engine/src/simulation/ masking source edits from vitest.
#
# Gate scope: .js, .js.map, .d.ts under packages/*/src/. Drops
# .d.ts.map since those don't participate in Node module resolution
# (822 of them are tracked as tsc sourcemap output — separate hygiene
# issue, not a security gate concern).
# Uses find (sees gitignored too) minus tracked (the ~13 intentional
# hand-crafted declarations that stay as-is).
# Knowledge store: grad-stale-js-shadow-debugging (confidence 0.9).
ALL_SHADOWS=$(find packages/*/src -type f \( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' \) 2>/dev/null | sort)
TRACKED_SHADOWS=$(git ls-files 2>/dev/null | grep -E '^packages/[^/]+/src/.*\.(js|js\.map|d\.ts)$' | sort || true)
if [ -z "$ALL_SHADOWS" ]; then
    UNTRACKED_SHADOWS=""
else
    UNTRACKED_SHADOWS=$(comm -23 <(printf '%s\n' "$ALL_SHADOWS") <(printf '%s\n' "$TRACKED_SHADOWS") 2>/dev/null)
fi
if [ -n "$UNTRACKED_SHADOWS" ]; then
    SHADOW_COUNT=$(echo "$UNTRACKED_SHADOWS" | wc -l | tr -d ' ')
    echo -e "  ${RED}❌ $SHADOW_COUNT stale (untracked) build artifact(s) in packages/*/src/${NC}"
    echo "     First few:"
    echo "$UNTRACKED_SHADOWS" | head -5 | sed 's/^/       /'
    echo "     These can silently shadow .ts source in Node module"
    echo "     resolution (vitest/tsx reads stale compiled .js over"
    echo "     current .ts edits — tests pass/fail unpredictably)."
    echo "     Fix: delete them (they regenerate on build):"
    echo "       find packages/*/src \\( -name '*.js' -o -name '*.js.map' \\"
    echo "         -o -name '*.d.ts' \\) -type f -delete"
    FAILED=1
else
    echo -e "  ${GREEN}✓${NC} No stale build artifacts"
fi

# Gate 5b: Tracked emit artifacts must match scripts/allowlists/package-src-emit-legacy.txt
# (CI runs the same script; keeps allowlist honest when removing legacy shadows).
echo "  ├─ Tracked src emit allowlist (packages/*/src/)..."
VERIFY_SRC_OUT=$(run_with_timeout 20 node scripts/verify-no-js-in-package-src.mjs 2>&1)
VERIFY_SRC_STATUS=$?
if [ "$VERIFY_SRC_STATUS" -ne 0 ]; then
    echo -e "  ${RED}❌ verify-no-js-in-package-src failed${NC}"
    echo "$VERIFY_SRC_OUT"
    FAILED=1
else
    echo -e "  ${GREEN}✓${NC} Emit allowlist OK"
fi

# Gate 5c: Untracked-sibling imports (root-cause fix for SEC-T-Zero)
# Blocks the "32 files imported but not git-added" class of bug. Local tests
# pass (files on disk); Railway/CI fail MODULE_NOT_FOUND on a clean checkout.
# Opt-out: HOLOMESH_SKIP_UNTRACKED_SIBLING_CHECK=1 for rare emergency cases.
echo "  ├─ Untracked-sibling import check..."
if [ -f "scripts/check-untracked-sibling-imports.js" ]; then
    UNTSIB_OUT=$(run_with_timeout 15 node scripts/check-untracked-sibling-imports.js 2>&1)
    UNTSIB_STATUS=$?
    if [ "$UNTSIB_STATUS" -ne 0 ]; then
        echo -e "  ${RED}❌ Staged file imports an untracked sibling${NC}"
        echo "$UNTSIB_OUT"
        FAILED=1
    else
        echo -e "  ${GREEN}✓${NC} No untracked-sibling imports"
    fi
else
    echo -e "  ${YELLOW}⚠${NC}  scripts/check-untracked-sibling-imports.js not present (skipped)"
fi

# Gate 6: Complexity — skipped (not configured)
echo -e "  ├─ Complexity analysis... ${YELLOW}⚠ skipped${NC}"

# Gate 7: Security audit — DISABLED for pre-commit
echo -e "  ├─ Security audit... ${YELLOW}⚠ skipped (CI handles this)${NC}"

# Final result
if [ $FAILED -eq 1 ]; then
    echo ""
    echo -e "${RED}❌ Quality gates failed. Commit blocked.${NC}"
    echo "   Fix the issues above and try again."
    exit 1
else
    echo ""
    echo -e "${GREEN}✅ All quality gates passed!${NC}"
    exit 0
fi
