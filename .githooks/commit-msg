#!/bin/bash
# Wave-D D.021 — vault-aware commit message reminder (WARN only, never blocks).
# Install: git config core.hooksPath .githooks  (from repo root)
# Or copy to .git/hooks/commit-msg and chmod +x

if [ "$SKIP_HOOKS" = "1" ] || [ "$HOLODAEMON_SKIP_HOOKS" = "1" ]; then
  exit 0
fi

MSG_FILE=$1
YELLOW='\033[1;33m'
NC='\033[0m'

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

MSG=$(cat "$MSG_FILE")
if echo "$MSG" | grep -qiE '^merge '; then
  exit 0
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

TOUCH=
if echo "$STAGED" | grep -qE '^(memory/|research/)'; then
  TOUCH=1
fi
if [ -z "$TOUCH" ]; then
  if echo "$STAGED" | grep -E '^docs/.*\.md$' | grep -qvE '^docs/(archive|_archive|marketing|strategy)/'; then
    TOUCH=1
  fi
fi
if [ -z "$TOUCH" ]; then
  exit 0
fi

# Expect a tier keyword plus a digit reference (e.g. W.GOLD-12, P.GOLD 3).
if echo "$MSG" | grep -qE '(W\.GOLD|P\.GOLD|G\.GOLD)[-_[:space:]]*[0-9]'; then
  exit 0
fi

echo -e "${YELLOW}[commit-msg] D.021: Staged paths include memory/, research/, or active docs/. Consider a vault tier digit ref (e.g. W.GOLD-12).${NC}" >&2
exit 0
