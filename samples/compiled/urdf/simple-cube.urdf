<?xml version="1.0"?>
<!-- HoloScript URDF Export -->
<!-- Generated from: simple-cube.holo -->
<!-- Compiler: HoloScript v3.4.0 -->
<!-- Target: URDF (Unified Robot Description Format) -->
<!-- Timestamp: 2026-02-16T18:00:00Z -->

<robot name="simple_cube_holoscript">
  <!-- Base link (cube body) -->
  <link name="cube_body">
    <visual>
      <origin xyz="0 1 0" rpy="0 0 0"/> <!-- @position(0, 1, 0) -->
      <geometry>
        <box size="1.0 1.0 1.0"/>
      </geometry>
      <material name="red_material">
        <!-- @color(red) -->
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 1 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.0 1.0 1.0"/>
      </geometry>
    </collision>

    <inertial>
      <!-- Default cube inertial properties (1kg, 1m sides) -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.1667" ixy="0.0" ixz="0.0"
        iyy="0.1667" iyz="0.0"
        izz="0.1667"/>
    </inertial>
  </link>

  <!-- HoloScript Metadata (custom tags for traits) -->
  <holoscript xmlns="https://holoscript.net/urdf/v1">
    <object type="cube" name="cube_body">
      <traits>
        <trait name="@color">
          <param name="value">red</param>
          <mapping target="material">red_material</mapping>
        </trait>
        <trait name="@position">
          <param name="x">0</param>
          <param name="y">1</param>
          <param name="z">0</param>
          <mapping target="visual/origin">xyz="0 1 0"</mapping>
          <mapping target="collision/origin">xyz="0 1 0"</mapping>
        </trait>
        <trait name="@grabbable">
          <note>
            URDF doesn't have native grabbable concept.
            Implement in ROS node with MoveIt or custom grasping.
            Suggested approach: Add grasp pose frames for manipulation.
          </note>
          <implementation>
            <suggestion>Use MoveIt's grasp generation</suggestion>
            <suggestion>Add end-effector frames</suggestion>
            <suggestion>Configure collision checking</suggestion>
          </implementation>
        </trait>
      </traits>
    </object>
  </holoscript>

  <!-- ROS/Gazebo Plugin Hints -->
  <gazebo reference="cube_body">
    <material>Gazebo/Red</material>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>

    <!-- Plugin for grabbable interaction (optional) -->
    <!-- Uncomment if using Gazebo with grasping plugin -->
    <!--
    <plugin name="gazebo_grasp_fix" filename="libgazebo_grasp_fix.so">
      <arm>
        <arm_name>robot_arm</arm_name>
        <palm_link>palm_link</palm_link>
        <gripper_link>left_finger</gripper_link>
        <gripper_link>right_finger</gripper_link>
      </arm>
      <forces_angle_tolerance>100</forces_angle_tolerance>
      <update_rate>4</update_rate>
      <grip_count_threshold>4</grip_count_threshold>
      <max_grip_count>8</max_grip_count>
      <release_tolerance>0.005</release_tolerance>
      <disable_collisions_on_attach>false</disable_collisions_on_attach>
      <contact_topic>__default_topic__</contact_topic>
    </plugin>
    -->
  </gazebo>

</robot>
