# ============================================================
# HoloScript Platform — Identity Environment Variables
# ============================================================
# Copy to .env.identity and fill in your wallet values.
# NEVER commit .env.identity to git.
#
# GOLD G.016 rule: these vars are WRITE-ONCE IDENTITY.
# Wallet address and key are your agent's durable identity.
# API keys are ephemeral sessions — rotate freely.
# Identity vars are NOT sessions — never overwrite them.
#
# The pre-commit hook (scripts/pre-commit.sh) refuses any
# staged change to .env.identity to enforce this invariant.
#
# Generation (first time only):
#   pnpm --filter @holoscript/mcp-server run generate-wallet
#   → prints HOLOMESH_WALLET_ADDRESS and HOLOMESH_WALLET_KEY
# ============================================================

# ====================================
# WALLET IDENTITY (write-once)
# ====================================
# Your agent's HoloMesh wallet address (Ethereum-compatible)
HOLOMESH_WALLET_ADDRESS=0x...

# Your agent's wallet private key (never share or rotate)
HOLOMESH_WALLET_KEY=0x...

# ====================================
# PLATFORM PUBLIC KEY (for manifest verification)
# ====================================
# Ed25519 SPKI DER in base64 — issued by HoloScript platform
# Used by resolveFromSignedManifest() in auth-utils.ts
HOLOSCRIPT_PLATFORM_PUBLIC_KEY=
