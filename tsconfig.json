{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": [
    "packages/core/src/**/*",
    "packages/cli/src/**/*",
    "packages/mcp-server/src/**/*",
    "packages/crdt/src/**/*",
    "packages/lsp/src/**/*",
    "packages/vscode-extension/src/**/*",
    "packages/graphql-api/src/**/*",
    "packages/marketplace-web/src/**/*",
    "packages/marketplace-api/src/**/*",
    "packages/auth/src/**/*",
    "packages/llm-provider/src/**/*",
    // packages/studio has its own tsconfig with @/ path aliases — exclude from root
    // "packages/studio/src/**/*",
    "packages/formatter/src/**/*",
    "packages/linter/src/**/*",
    "packages/partner-sdk/src/**/*",
    "packages/adapter-postgres/src/**/*",
    "packages/collab-server/src/**/*",
    "packages/registry/src/**/*",
    "packages/runtime/src/**/*",
    "packages/fs/src/**/*",
    "packages/security-sandbox/src/**/*",
    "packages/ai-validator/src/**/*",
    "packages/holoscript-cdn/src/**/*",
    "packages/std/src/**/*",
    "packages/animation-presets/src/**/*",
    "packages/benchmark/src/**/*",
    "packages/holoscript/src/**/*",
    "packages/visual/src/**/*",
    "packages/test/src/**/*",
    "packages/agent-sdk/src/**/*",
    "packages/agent-protocol/src/**/*",
    "packages/uaal/src/**/*",
    "packages/holo-vm/src/**/*",
    "packages/vm-bridge/src/**/*",
    "packages/studio-plugin-sdk/src/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "examples",
    "temp",
    "benchmarks",
    "samples",
    "scripts/training",
    "scripts/archive",
    "scripts/debug",
    "scripts/analysis"
  ]
}
