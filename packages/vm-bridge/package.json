{
  "name": "@holoscript/vm-bridge",
  "version": "5.1.0",
  "description": "Bridge between HoloVM (spatial scenes) and uAAL VM (cognitive agent cycles). Enables agents that perceive, reason about, and mutate 3D scenes.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@holoscript/holo-vm": "workspace:^",
    "@holoscript/uaal": "workspace:^"
  },
  "dependencies": {
    "@holoscript/holo-vm": "workspace:*",
    "@holoscript/uaal": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "@types/node": "^24.10.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "holoscript",
    "uaal",
    "vm",
    "bridge",
    "spatial",
    "cognitive",
    "agent"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/vm-bridge"
  }
}
