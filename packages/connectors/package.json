{
  "name": "@holoscript/connectors",
  "version": "6.0.0",
  "description": "Unified connector package for GitHub, Railway, Upstash, VS Code, App Store integrations",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./github": {
      "types": "./dist/github.d.ts",
      "import": "./dist/github.js"
    },
    "./railway": {
      "types": "./dist/railway.d.ts",
      "import": "./dist/railway.js"
    },
    "./upstash": {
      "types": "./dist/upstash.d.ts",
      "import": "./dist/upstash.js"
    },
    "./vscode": {
      "types": "./dist/vscode.d.ts",
      "import": "./dist/vscode.js"
    },
    "./appstore": {
      "types": "./dist/appstore.d.ts",
      "import": "./dist/appstore.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "connector",
    "github",
    "railway",
    "upstash",
    "vscode",
    "app-store",
    "mcp"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/connectors"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@octokit/auth-token": "^5.1.1",
    "@octokit/rest": "^21.0.0",
    "@upstash/qstash": "^2.7.0",
    "@upstash/redis": "^1.34.0",
    "@upstash/vector": "^1.1.5",
    "form-data": "^4.0.0",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^24.10.1",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}