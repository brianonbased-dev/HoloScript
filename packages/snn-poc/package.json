{
  "name": "@holoscript/snn-poc",
  "version": "1.0.0",
  "description": "@deprecated — Superseded by @holoscript/snn-webgpu. CPU reference utilities preserved in snn-webgpu/src/poc/.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate": "tsx src/validate.ts"
  },
  "keywords": [
    "holoscript",
    "webgpu",
    "snn",
    "spiking-neural-network",
    "lif-neuron",
    "wgsl",
    "compute-shader",
    "neuromorphic",
    "proof-of-concept"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/snn-poc"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "@webgpu/types": "^0.1.40",
    "tsup": "^8.0.1",
    "tsx": "^4.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@webgpu/types": ">=0.1.40"
  },
  "peerDependenciesMeta": {
    "@webgpu/types": {
      "optional": true
    }
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
