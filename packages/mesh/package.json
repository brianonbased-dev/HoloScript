{
  "name": "@holoscript/mesh",
  "version": "7.0.0",
  "description": "HoloScript Mesh and Network Layer",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./src/traits/visual/index.ts",
    "./dist/traits/index.js"
  ],
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --max-old-space-size=16384 run-vitest.mjs",
    "test:coverage": "node --max-old-space-size=16384 run-vitest.mjs --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "vr",
    "ar",
    "xr",
    "webxr",
    "virtual-reality",
    "spatial-computing",
    "parser",
    "ast",
    "compiler",
    "runtime",
    "3d",
    "threejs",
    "digital-twin",
    "iot",
    "declarative"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/mesh"
  },
  "dependencies": {
    "@holoscript/agent-protocol": "workspace:*",
    "@holoscript/alphafold-plugin": "workspace:*",
    "@holoscript/core-types": "workspace:*",
    "@holoscript/domain-plugin-template": "workspace:*",
    "@holoscript/medical-plugin": "workspace:*",
    "@holoscript/narupa-plugin": "workspace:*",
    "@holoscript/plugin-banking-finance": "workspace:*",
