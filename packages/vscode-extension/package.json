    "esbuild": "^0.27.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@holoscript/formatter": "workspace:*",
    "@holoscript/lsp": "workspace:*",
    "@holoscript/sdk": "workspace:^",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "vscode-languageclient": "^9.0.1",
    "y-websocket": "^2.0.3",
    "yjs": "^13.6.15"
  }
}
