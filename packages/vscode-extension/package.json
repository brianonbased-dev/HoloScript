        "category": "Hololand",
        "icon": "$(dashboard)"
      },
      {
        "command": "holoscript.hololand.openVRRPreview",
        "title": "Open VRR Twin Preview",
        "category": "Hololand",
        "icon": "$(globe)"
      },
      {
        "command": "holoscript.hololand.openQuestBuilder",
        "title": "Open Quest Builder UI",
        "category": "Hololand",
        "icon": "$(tools)"
      },
      {
        "command": "holoscript.hololand.openARSimulator",
        "title": "Open AR Simulator",
        "category": "Hololand",
        "icon": "$(device-camera)"
      },
      {
        "command": "holoscript.hololand.openWalletDashboard",
        "title": "Open Agent Wallet Dashboard",
        "category": "Hololand",
        "icon": "$(account)"
      }
    ],
    "customEditors": [
      {
        "viewType": "holoscript.smartAssetViewer",
        "displayName": "Smart Asset Viewer",
        "selector": [
          {
            "filenamePattern": "*.hsa"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "holoscript.openPreviewToSide",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "holoscript.openPreview",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus",
          "group": "holoscript"
        },
        {
          "command": "holoscript.showSemanticDiff",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus",
          "group": "holoscript-git@1"
        },
        {
          "command": "holoscript.blameLine",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus",
          "group": "holoscript-git@2"
        },
        {
          "command": "holoscript.show3DDiff",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus",
          "group": "holoscript-git@3"
        }
      ],
      "explorer/context": [
        {
          "command": "holoscript.showSemanticDiff",
          "when": "resourceExtname == .holo || resourceExtname == .hs",
          "group": "holoscript-git"
        },
        {
          "command": "holoscript.showFileHistory",
          "when": "resourceExtname == .holo || resourceExtname == .hs",
          "group": "holoscript-git"
        }
      ],
      "view/title": [
        {
          "command": "holoscript.traitTree.refresh",
          "when": "view == holoscript.traitCompositionTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "holoscript.traitTree.revealInEditor",
          "when": "view == holoscript.traitCompositionTree && viewItem =~ /traitDefinition|traitProperty/",
          "group": "navigation@1"
        },
        {
          "command": "holoscript.traitTree.copyTraitName",
          "when": "view == holoscript.traitCompositionTree && viewItem =~ /traitDefinition|traitComposition/",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "holoscript.openPreview",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus"
        },
        {
          "command": "holoscript.openPreviewToSide",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "holoscript.openPreviewToSide",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == holoscript || editorLangId == holoscriptplus"
      },
      {
        "command": "holoscript.openPreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == holoscript || editorLangId == holoscriptplus"
      }
    ],
    "walkthroughs": [
      {
        "id": "holoscript-getting-started",
        "title": "Getting Started with HoloScript",
        "description": "Learn to build VR/AR experiences with HoloScript in 5 minutes",
        "steps": [
          {
            "id": "welcome",
            "title": "Welcome to HoloScript",
            "description": "The first spatial programming language for VR/AR development.\n\n[Open Welcome Guide](command:markdown.showPreview?%5B%22walkthroughs/getting-started/01-welcome.md%22%5D)",
            "media": {
              "markdown": "walkthroughs/getting-started/01-welcome.md"
            }
          },
          {
            "id": "createFile",
            "title": "Create Your First Scene",
            "description": "Create a `.holo` file and write your first VR scene.\n\n[Create Your First Scene](command:holoscript.createFirstScene)",
            "media": {
              "markdown": "walkthroughs/getting-started/02-first-scene.md"
            },
            "completionEvents": [
              "onFileCreated:*.holo"
            ]
          },
          {
            "id": "learnTraits",
            "title": "Add VR Traits",
            "description": "Use `@grabbable`, `@physics`, `@glowing` to add VR interactivity.",
            "media": {
              "markdown": "walkthroughs/getting-started/03-traits.md"
            }
          },
          {
            "id": "preview",
            "title": "Preview Your Scene",
            "description": "See your scene in 3D with live preview.\n\n[Open Preview](command:holoscript.openPreviewToSide)",
            "media": {
              "markdown": "walkthroughs/getting-started/04-preview.md"
            },
            "completionEvents": [
              "onCommand:holoscript.openPreviewToSide",
              "onCommand:holoscript.openPreview"
            ]
          },
          {
            "id": "aiIntegration",
            "title": "AI Integration",
            "description": "Use Claude, GPT, or Copilot to generate HoloScript code.",
            "media": {
              "markdown": "walkthroughs/getting-started/05-ai-integration.md"
            }
          },
          {
            "id": "nextSteps",
            "title": "Next Steps",
            "description": "Explore examples, documentation, and the community.",
            "media": {
              "markdown": "walkthroughs/getting-started/06-next-steps.md"
            }
          }
        ]
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "holoscriptMcp",
        "label": "HoloScript MCP Server"
      }
    ],
    "breakpoints": [
      {
        "language": "holoscript"
      },
      {
        "language": "holoscriptplus"
      }
    ],
    "debuggers": [
      {
        "type": "holoscript-debug",
        "languages": [
          "holoscript",
          "holoscriptplus"
        ],
        "label": "HoloScript Debug",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the .holo, .hsplus, or .hs file to debug.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop on the first executable line after launch.",
                "default": true
              },
              "trace": {
                "type": "boolean",
                "description": "Enable diagnostic logging from the debug adapter.",
                "default": false
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debugged program.",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "description": "Environment variables to set for the debugged program.",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {}
              }
            }
          },
          "attach": {
            "properties": {
              "port": {
                "type": "number",
                "description": "Port to attach to a running HoloScript process.",
                "default": 9229
              },
              "host": {
                "type": "string",
                "description": "Host address of the running HoloScript process.",
                "default": "localhost"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "holoscript-debug",
            "request": "launch",
            "name": "Debug HoloScript",
            "program": "${file}",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "HoloScript: Debug File",
            "description": "Debug the currently open HoloScript file.",
            "body": {
              "type": "holoscript-debug",
              "request": "launch",
              "name": "Debug ${1:HoloScript File}",
              "program": "^\"\\${file}\"",
              "stopOnEntry": true
            }
          },
          {
            "label": "HoloScript: Debug Composition",
            "description": "Debug a specific HoloScript composition file.",
            "body": {
              "type": "holoscript-debug",
              "request": "launch",
              "name": "Debug ${1:Composition}",
              "program": "^\"\\${workspaceFolder}/${2:main.holo}\"",
              "stopOnEntry": false,
              "cwd": "^\"\\${workspaceFolder}\""
            }
          },
          {
            "label": "HoloScript: Attach to Process",
            "description": "Attach to an already running HoloScript process.",
            "body": {
              "type": "holoscript-debug",
              "request": "attach",
              "name": "Attach to HoloScript",
              "port": 9229,
              "host": "localhost"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "esbuild-base": "node esbuild.js",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "build": "npm run esbuild",
    "watch": "npm run esbuild-watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
