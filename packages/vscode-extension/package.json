{
  "name": "holoscript-vscode",
  "displayName": "HoloScript Enhanced",
  "description": "Language support for HoloScript+ with AI integration, Spatial Profiling, and Live Preview",
  "version": "3.1.0",
  "publisher": "holoscript",
  "icon": "icons/holoscript-logo.png",
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "holoscript",
    "vr",
    "ar",
    "spatial computing",
    "3d",
    "webxr"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:holoscript",
    "onLanguage:holoscriptplus",
    "onDebugResolve:holoscript-debug",
    "onDebugDynamicConfigurations:holoscript-debug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "HoloScript MCP",
      "properties": {
        "holoscript.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP orchestrator integration for IDE agents."
        },
        "holoscript.mcp.holoscriptMcpEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable HoloScript MCP server (mcp.holoscript.net) for GitHub Copilot and AI agents."
        },
        "holoscript.mcp.orchestratorUrl": {
          "type": "string",
          "default": "http://localhost:5567",
          "description": "MCP orchestrator base URL."
        },
        "holoscript.mcp.apiKey": {
          "type": "string",
          "default": "",
          "description": "MCP API key for registration and heartbeats."
        },
        "holoscript.mcp.heartbeatSeconds": {
          "type": "number",
          "default": 20,
          "minimum": 10,
          "description": "Heartbeat interval in seconds."
        },
        "holoscript.mcp.visibility": {
          "type": "string",
          "enum": [
            "public",
            "private"
          ],
          "default": "public",
          "description": "Visibility of this IDE agent in the orchestrator registry."
        },
        "holoscript.mcp.workspaceId": {
          "type": "string",
          "default": "holoscript",
          "description": "Workspace ID to register under."
        },
        "holoscript.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Enable auto-formatting on save."
        },
        "holoscript.formatOnSaveTimeout": {
          "type": "number",
          "default": 1000,
          "description": "Timeout for formatting on save in milliseconds."
        },
        "holoscript.ai.enableAutoSuggest": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI auto-suggestions while typing."
        },
        "holoscript.collaboration.serverUrl": {
          "type": "string",
          "default": "wss://collab.holoscript.net",
          "description": "WebSocket URL for collaboration server."
        },
        "holoscript.collaboration.autoJoin": {
          "type": "boolean",
          "default": false,
          "description": "Automatically join collaboration sessions from shared links."
        },
        "holoscript.collaboration.showCursors": {
          "type": "boolean",
          "default": true,
          "description": "Show other participants' cursors."
        },
        "holoscript.collaboration.showSelections": {
          "type": "boolean",
          "default": true,
          "description": "Show other participants' selections."
        },
        "holoscript.collaboration.showNames": {
          "type": "boolean",
          "default": true,
          "description": "Show participant names above cursors."
        },
        "holoscript.git.enableSemanticDiff": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic diff for HoloScript files."
        },
        "holoscript.git.enable3DPreview": {
          "type": "boolean",
          "default": true,
          "description": "Enable 3D diff preview."
        },
        "holoscript.git.formatOnCommit": {
          "type": "boolean",
          "default": true,
          "description": "Auto-format HoloScript files on commit."
        },
        "holoscript.git.validateOnCommit": {
          "type": "boolean",
          "default": true,
          "description": "Validate HoloScript syntax on commit."
        },
        "holoscript.git.showInlineDiff": {
          "type": "boolean",
          "default": true,
          "description": "Show inline diff decorations in editor."
        },
        "holoscript.hololand.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Hololand Platform integration (VRR, AR, AgentKit, Zora, StoryWeaver, Quest Builder, x402)."
        },
        "holoscript.hololand.vrr.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start VRR synchronization on extension activation."
        },
        "holoscript.hololand.vrr.updateInterval": {
          "type": "number",
          "default": 300000,
          "minimum": 60000,
          "description": "VRR sync update interval in milliseconds (minimum 1 minute)."
        },
        "holoscript.hololand.vrr.weatherApiKey": {
          "type": "string",
          "default": "",
          "description": "Weather.gov API key for real-time weather sync."
        },
        "holoscript.hololand.vrr.eventbriteApiKey": {
          "type": "string",
          "default": "",
          "description": "Eventbrite API key for real-time event sync."
        },
        "holoscript.hololand.vrr.squareApiKey": {
          "type": "string",
          "default": "",
          "description": "Square API key for real-time inventory sync."
        },
        "holoscript.hololand.x402.simulationMode": {
          "type": "boolean",
          "default": true,
          "description": "Use simulation mode for x402 payments (no real blockchain transactions)."
        },
        "holoscript.hololand.x402.defaultCurrency": {
          "type": "string",
          "enum": [
            "ETH",
            "USDC",
            "DAI"
          ],
          "default": "ETH",
          "description": "Default cryptocurrency for x402 payments."
        },
        "holoscript.hololand.agentkit.network": {
          "type": "string",
          "enum": [
            "base",
            "ethereum",
            "base-sepolia"
          ],
          "default": "base-sepolia",
          "description": "Blockchain network for AgentKit wallets."
        },
        "holoscript.hololand.agentkit.simulationMode": {
          "type": "boolean",
          "default": true,
          "description": "Use simulation mode for AgentKit operations (no real blockchain transactions)."
        },
        "holoscript.hololand.agentkit.defaultGasLimit": {
          "type": "number",
          "default": 21000,
          "description": "Default gas limit for AgentKit transactions."
        },
        "holoscript.hololand.zora.network": {
          "type": "string",
          "enum": [
            "base",
            "ethereum",
            "zora",
            "base-sepolia"
          ],
          "default": "base",
          "description": "Network for Zora NFT minting."
        },
        "holoscript.hololand.zora.defaultRoyalty": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "maximum": 100,
          "description": "Default royalty percentage for Zora NFTs (10-15% typical)."
        },
        "holoscript.hololand.zora.ipfsGateway": {
          "type": "string",
          "default": "https://ipfs.io/ipfs",
          "description": "IPFS gateway URL for NFT metadata."
        },
        "holoscript.hololand.zora.simulationMode": {
          "type": "boolean",
          "default": true,
          "description": "Use simulation mode for Zora operations (no real blockchain transactions)."
        },
        "holoscript.hololand.storyweaver.provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "gemini"
          ],
          "default": "openai",
          "description": "AI provider for StoryWeaver narrative generation."
        },
        "holoscript.hololand.storyweaver.model": {
          "type": "string",
          "default": "",
          "description": "Specific model to use (e.g., 'gpt-4', 'claude-3-opus', 'gemini-pro')."
        },
        "holoscript.hololand.storyweaver.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for StoryWeaver AI provider."
        },
        "holoscript.hololand.storyweaver.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "AI temperature for narrative generation (0-2)."
        },
        "holoscript.hololand.storyweaver.maxTokens": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 8000,
          "description": "Maximum tokens for AI-generated narratives."
        },
        "holoscript.hololand.ar.simulationMode": {
          "type": "boolean",
          "default": true,
          "description": "Use simulation mode for AR preview (no real camera/QR scanning)."
        },
        "holoscript.hololand.ar.defaultTrigger": {
          "type": "string",
          "enum": [
            "qr",
            "nfc",
            "image",
            "location"
          ],
          "default": "qr",
          "description": "Default AR portal trigger type."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "holohub",
          "title": "HoloHub",
          "icon": "icons/holoscript.svg"
        }
      ]
    },
    "views": {
      "holohub": [
        {
          "id": "holohub.assets",
          "name": "Marketplace",
          "icon": "media/icon.png"
        },
        {
          "id": "holoscript.serviceHub",
          "name": "Service Connectors",
          "icon": "media/icon.png"
        },
        {
          "id": "holoscript.diffVisualization",
          "name": "Diff Preview",
          "type": "webview",
          "icon": "media/icon.png"
        }
      ],
      "explorer": [
        {
          "id": "holoscript.traitCompositionTree",
          "name": "Trait Composition",
          "when": "editorLangId == holoscript || editorLangId == holoscriptplus",
          "icon": "$(symbol-interface)",
          "contextualTitle": "HoloScript Traits"
        }
      ]
    },
    "languages": [
      {
        "id": "holoscript",
        "aliases": [
          "HoloScript",
          "hosl"
        ],
        "extensions": [
          ".holo"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/holoscript.svg",
          "dark": "./icons/holoscript.svg"
        }
      },
      {
        "id": "holoscriptplus",
        "aliases": [
          "HoloScript+",
          "hsplus"
        ],
        "extensions": [
          ".hsplus",
          ".hs"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/holoscript-plus.svg",
          "dark": "./icons/holoscript-plus.svg"
        }
      }
    ],
    "iconThemes": [
      {
        "id": "holoscript-icons",
        "label": "HoloScript Icons",
        "path": "./icons/icon-theme.json"
      }
    ],
    "grammars": [
      {
        "language": "holoscript",
        "scopeName": "source.holoscript",
        "path": "./syntaxes/holoscript.tmLanguage.json"
      },
      {
        "language": "holoscriptplus",
        "scopeName": "source.holoscript",
        "path": "./syntaxes/holoscript.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "holoscript",
        "scopes": {
          "decorator": [
            "entity.name.tag.trait.holoscript"
          ],
          "decorator.defaultLibrary": [
            "entity.name.tag.trait.builtin.holoscript"
          ],
          "keyword": [
            "keyword.control.holoscript"
          ],
          "keyword.defaultLibrary": [
            "keyword.other.holoscript"
          ],
          "class": [
            "entity.name.type.class.holoscript"
          ],
          "class.declaration": [
            "entity.name.type.class.declaration.holoscript"
          ],
          "namespace": [
            "entity.name.namespace.holoscript"
          ],
          "property": [
            "variable.other.property.holoscript"
          ],
          "variable": [
            "variable.other.holoscript"
          ],
          "function": [
            "entity.name.function.holoscript"
          ],
          "function.defaultLibrary": [
            "support.function.builtin.holoscript"
          ],
          "string": [
            "string.quoted.double.holoscript"
          ],
          "number": [
            "constant.numeric.holoscript"
          ],
          "operator": [
            "keyword.operator.holoscript"
          ],
          "comment": [
            "comment.line.holoscript"
          ]
        }
      },
      {
        "language": "holoscriptplus",
        "scopes": {
          "decorator": [
            "entity.name.tag.trait.holoscript"
          ],
          "decorator.defaultLibrary": [
            "entity.name.tag.trait.builtin.holoscript"
          ],
          "keyword": [
            "keyword.control.holoscript"
          ],
          "keyword.defaultLibrary": [
            "keyword.other.holoscript"
          ],
          "class": [
            "entity.name.type.class.holoscript"
          ],
          "class.declaration": [
            "entity.name.type.class.declaration.holoscript"
          ],
          "namespace": [
            "entity.name.namespace.holoscript"
          ],
          "property": [
            "variable.other.property.holoscript"
          ],
          "variable": [
            "variable.other.holoscript"
          ],
          "function": [
            "entity.name.function.holoscript"
          ],
          "function.defaultLibrary": [
            "support.function.builtin.holoscript"
          ],
          "string": [
            "string.quoted.double.holoscript"
          ],
          "number": [
            "constant.numeric.holoscript"
          ],
          "operator": [
            "keyword.operator.holoscript"
          ],
          "comment": [
            "comment.line.holoscript"
          ]
        }
      }
    ],
    "snippets": [
      {
        "language": "holoscript",
        "path": "./snippets/holoscript.json"
      },
      {
        "language": "holoscriptplus",
        "path": "./snippets/holoscript.json"
      }
    ],
    "commands": [
      {
        "command": "holoscript.openPreview",
        "title": "Open Preview",
        "category": "HoloScript",
        "icon": "$(preview)"
