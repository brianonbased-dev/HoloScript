# Studio LLM Provider Configuration
# Copy this file to .env.local and fill in your API keys

# Option 1: Anthropic (Preferred - used by default if set)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Option 2: xAI Grok (fallback if Anthropic not set)
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-3-mini

# Option 3: OpenAI (fallback if xAI not set)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini

# Option 4: Ollama (local fallback, no key needed)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# NextAuth Secret (required for authentication)
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Database (if using persistence)
# DATABASE_URL=postgresql://...
