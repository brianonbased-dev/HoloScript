# Studio Development Environment
# Copy this file to .env.local and fill in your API keys.
# NEVER commit .env.local to git.
#
# Quick start:
#   cp .env.local.example .env.local
#   # edit .env.local with real keys
#   pnpm run dev

# ============================================
# LLM Provider (Brittney)
# ============================================

# Anthropic API key (required for Brittney AI)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Brittney model override (optional — defaults to claude-opus-4-7)
# Available models: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
# BRITTNEY_MODEL=claude-opus-4-7

# ============================================
# NextAuth (dev credentials provider)
# ============================================

# Required for cookie JWT signing. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# Must match dev server port (3101, not 3000)
NEXTAUTH_URL=http://localhost:3101

# ============================================
# Optional: OAuth Providers
# ============================================
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# ============================================
# Optional: Database for persistent sessions
# ============================================
# DATABASE_URL=postgresql://...
