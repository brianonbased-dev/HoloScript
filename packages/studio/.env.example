# HoloScript Studio - Environment Configuration Example
# Copy this file to .env.local for development or .env.production for production

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3100
NODE_ENV=development

# ============================================================================
# API ENDPOINTS
# ============================================================================

# Marketplace API (community templates)
NEXT_PUBLIC_MARKETPLACE_URL=https://marketplace.holoscript.net/api

# Cloud Deployment API (serverless deployment)
NEXT_PUBLIC_CLOUD_API_URL=https://cloud.holoscript.net/api

# Collaboration WebSocket Server (real-time editing)
NEXT_PUBLIC_COLLABORATION_WS=wss://collab.holoscript.net

# MCP Orchestrator (tool discovery)
NEXT_PUBLIC_MCP_ORCHESTRATOR_URL=https://mcp-orchestrator-production-45f9.up.railway.app
NEXT_PUBLIC_MCP_API_KEY=dev-key-12345

# ============================================================================
# AUTHENTICATION
# ============================================================================

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

# Google Analytics
NEXT_PUBLIC_GTAG_ID=

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable major features
NEXT_PUBLIC_ENABLE_COLLABORATION=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_CLOUD_DEPLOY=true
NEXT_PUBLIC_ENABLE_PLUGINS=true
NEXT_PUBLIC_ENABLE_VERSION_CONTROL=true

# Development features
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=false
NEXT_PUBLIC_ENABLE_PERFORMANCE_METRICS=false

# ============================================================================
# RATE LIMITING
# ============================================================================

# API rate limits (requests per time window)
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# WebSocket connection limits
WS_MAX_CONNECTIONS_PER_USER=5
WS_MAX_CONNECTIONS_PER_SESSION=50

# ============================================================================
# STORAGE & CACHING
# ============================================================================

# Database (for user data, if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/holoscript_studio

# Redis (for session storage, caching)
REDIS_URL=redis://localhost:6379

# S3-compatible storage (for assets, exports)
S3_BUCKET=holoscript-studio-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://s3.amazonaws.com  # or use Cloudflare R2, MinIO

# ============================================================================
# AI/LLM CONFIGURATION (for Brittney AI assistant)
# ============================================================================

# OpenAI API
OPENAI_API_KEY=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Ollama (local models)
OLLAMA_HOST=http://localhost:11434

# Default model selection
DEFAULT_AI_MODEL=claude-3-sonnet-20240229

# ============================================================================
# COLLABORATION SETTINGS
# ============================================================================

# Session timeout (milliseconds)
COLLABORATION_SESSION_TIMEOUT=3600000  # 1 hour

# Message history limit
COLLABORATION_MESSAGE_LIMIT=100

# Auto-save interval (milliseconds)
COLLABORATION_AUTOSAVE_INTERVAL=30000  # 30 seconds

# ============================================================================
# VERSION CONTROL SETTINGS
# ============================================================================

# Maximum commits to store in history
VERSION_CONTROL_MAX_COMMITS=50

# Auto-commit on save
VERSION_CONTROL_AUTO_COMMIT=false

# ============================================================================
# SECURITY
# ============================================================================

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3000

# API secret for internal services
API_SECRET_KEY=  # Generate with: openssl rand -hex 32

# Enable/disable security headers
ENABLE_SECURITY_HEADERS=true
ENABLE_CSP=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Enable hot module replacement
NEXT_PUBLIC_HMR=true

# Show dev tools
NEXT_PUBLIC_SHOW_DEV_TOOLS=true

# Mock external APIs (for offline development)
MOCK_MARKETPLACE_API=false
MOCK_CLOUD_API=false
MOCK_COLLABORATION_WS=false

# ============================================================================
# PRODUCTION OPTIMIZATION
# ============================================================================

# Enable compression
ENABLE_COMPRESSION=true

# Enable image optimization
NEXT_PUBLIC_OPTIMIZE_IMAGES=true

# CDN URL (for static assets)
CDN_URL=

# Cache-Control max-age (seconds)
STATIC_ASSET_MAX_AGE=31536000  # 1 year

# ============================================================================
# LOGGING
# ============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Log format (json, pretty)
LOG_FORMAT=pretty

# ============================================================================
# NOTES
# ============================================================================

# Development:
# 1. Copy this file to .env.local
# 2. Fill in required values (NEXTAUTH_SECRET, API keys)
# 3. Set MOCK_* flags to true for offline development
# 4. Run: npm run dev

# Production:
# 1. Copy this file to .env.production
# 2. Set all production URLs (marketplace, cloud, collab)
# 3. Configure authentication providers
# 4. Set up monitoring (Sentry, Google Analytics)
# 5. Run: npm run build && npm run start

# Security Checklist:
# - Generate unique NEXTAUTH_SECRET and API_SECRET_KEY
# - Never commit .env.local or .env.production to git
# - Use environment-specific API keys (dev, staging, prod)
# - Enable HTTPS/TLS in production
# - Set appropriate CORS origins
# - Enable rate limiting
# - Configure firewall rules

# Performance Checklist:
# - Enable CDN for static assets
# - Configure Redis caching
# - Enable image optimization
# - Set appropriate cache headers
# - Monitor API response times
# - Use database connection pooling
