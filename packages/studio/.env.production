# HoloScript Studio — Production Environment
#
# This file defines NON-SECRET production defaults.
# Secrets (GITHUB_CLIENT_SECRET, NEXTAUTH_SECRET, etc.) are injected via
# Railway environment variables or GitHub Actions secrets during deploy.
# See ENVIRONMENT_SETUP.md § Production OAuth Setup for the full checklist.
#
# NEVER commit real secrets to this file.

# ============================================================================
# CORE URLS
# ============================================================================

NEXT_PUBLIC_APP_URL=https://holoscript.studio
NEXT_PUBLIC_STUDIO_URL=https://holoscript.studio
NODE_ENV=production

# ============================================================================
# API ENDPOINTS
# ============================================================================

NEXT_PUBLIC_MARKETPLACE_URL=https://marketplace.holoscript.net/api
NEXT_PUBLIC_CLOUD_API_URL=https://cloud.holoscript.net/api
NEXT_PUBLIC_COLLABORATION_WS=wss://collab.holoscript.net
NEXT_PUBLIC_MCP_ORCHESTRATOR_URL=https://mcp-orchestrator-production-45f9.up.railway.app

# ============================================================================
# AUTHENTICATION
# ============================================================================

# NextAuth.js — must match the public production URL
NEXTAUTH_URL=https://holoscript.studio

# NEXTAUTH_SECRET is injected via Railway / GitHub Actions secret.
# Generate with: openssl rand -base64 32

# GitHub OAuth — injected via Railway / GitHub Actions secret.
# The GitHub OAuth App must have:
#   Homepage URL: https://holoscript.studio
#   Authorization callback URL: https://holoscript.studio/api/auth/callback/github
#   Enable Device Flow: checked (for server-side repo operations)
# GITHUB_CLIENT_ID=<set-via-secret>
# GITHUB_CLIENT_SECRET=<set-via-secret>

# GitHub REST API (server-side routes)
GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=<set-via-secret>
# GOOGLE_CLIENT_SECRET=<set-via-secret>

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

# Google Analytics (optional)
# NEXT_PUBLIC_GTAG_ID=

# Sentry Error Tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ============================================================================
# FEATURE FLAGS (production tuning)
# ============================================================================

NEXT_PUBLIC_ENABLE_COLLABORATION=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_CLOUD_DEPLOY=true
NEXT_PUBLIC_ENABLE_PLUGINS=true
NEXT_PUBLIC_ENABLE_VERSION_CONTROL=true

# Disable dev/debug features in production
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=false
NEXT_PUBLIC_ENABLE_PERFORMANCE_METRICS=false

# ============================================================================
# RATE LIMITING
# ============================================================================

RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000
WS_MAX_CONNECTIONS_PER_USER=5
WS_MAX_CONNECTIONS_PER_SESSION=50

# ============================================================================
# STORAGE & CACHING
# ============================================================================

# DATABASE_URL is injected via Railway (Postgres) for persistent sessions.
# REDIS_URL is injected via Railway (Redis) for session storage / caching.

# S3-compatible storage (for assets, exports)
S3_BUCKET=holoscript-studio-assets
S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=<set-via-secret>
# S3_SECRET_ACCESS_KEY=<set-via-secret>
# S3_ENDPOINT=https://s3.amazonaws.com

# ============================================================================
# AI/LLM CONFIGURATION (Brittney AI assistant)
# ============================================================================

# LLM keys are injected via Railway / GitHub Actions secret.
# ANTHROPIC_API_KEY=<set-via-secret>
# OPENAI_API_KEY=<set-via-secret>
# XAI_API_KEY=<set-via-secret>

# Default model selection
DEFAULT_AI_MODEL=claude-sonnet-4-20250514

# ============================================================================
# COLLABORATION SETTINGS
# ============================================================================

COLLABORATION_SESSION_TIMEOUT=3600000
COLLABORATION_MESSAGE_LIMIT=100
COLLABORATION_AUTOSAVE_INTERVAL=30000

# ============================================================================
# VERSION CONTROL SETTINGS
# ============================================================================

VERSION_CONTROL_MAX_COMMITS=50
VERSION_CONTROL_AUTO_COMMIT=false

# ============================================================================
# SECURITY
# ============================================================================

ALLOWED_ORIGINS=https://holoscript.studio,https://marketplace.holoscript.net,https://collab.holoscript.net
ENABLE_SECURITY_HEADERS=true
ENABLE_CSP=true

# ============================================================================
# PRODUCTION OPTIMIZATION
# ============================================================================

ENABLE_COMPRESSION=true
NEXT_PUBLIC_OPTIMIZE_IMAGES=true
STATIC_ASSET_MAX_AGE=31536000

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=warn
ENABLE_REQUEST_LOGGING=true
LOG_FORMAT=json
