composition "AI Agent Scene" {
  environment {
    skybox: "cyber_city"
    ambient: 0.5
  }

  object "Testing Arena" @collidable {
    geometry: "box"
    position: [0, -0.5, 0]
    scale: [30, 1, 30]
    color: "#223344"
    material: "grid_floor"
  }

  // NPC Agent with autonomous traits
  object "Helper Bot" @physics @behavior_tree(type: "assistant", root: "wander_and_greet") @memory @dialogue {
    geometry: "cylinder"
    position: [2, 1, 3]
    scale: [0.6, 1.8, 0.6]
    color: "#00ffcc"
    material: "chrome"

    // Set emotional baseline and context
    emotion: "helpful"
    context_prompt: "You are a friendly guide inside the HoloScript AI Agent Scene."
  }

  object "Data Terminal" @networked @collidable {
    geometry: "cube"
    position: [-4, 1.5, -4]
    scale: [1, 3, 1]
    color: "#333333"

    object "Screen" @glowing {
      geometry: "box"
      position: [0, 0.5, 0.55]
      scale: [0.8, 0.6, 0.1]
      color: "#00ddff"
      material: "emissive"
    }
  }

  directional_light "Sun" {
    color: "#ffffea"
    intensity: 1.2
    position: [10, 15, 10]
  }
}
