{
  "name": "@holoscript/studio",
  "version": "7.0.0",
  "description": "HoloScript Studio - AI-powered 3D scene builder for everyone",
  "private": true,
  "exports": {
    ".": "./src/app/layout.tsx",
    "./embed": "./src/embed/index.ts",
    "./mock-generator": "./src/lib/mock-generator.ts"
  },
  "scripts": {
    "predev": "pnpm run holo:build",
    "dev": "next dev --webpack --port 3101",
    "holo:build": "tsx scripts/compile-holo-pages.ts",
    "holo:watch": "tsx scripts/compile-holo-pages.ts --watch",
    "prebuild": "pnpm run holo:build",
    "build": "next build --webpack",
    "start": "next start --port 3100",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "wasm:deploy": "cp ../holoscript-component/dist/holoscript.core.wasm ../holoscript-component/dist/holoscript.core2.wasm ../holoscript-component/dist/holoscript.js ../holoscript-component/dist/holoscript.d.ts public/wasm/ && cp -r ../holoscript-component/dist/interfaces public/wasm/",
    "wasm:build": "pnpm --filter @holoscript/component run build && pnpm run wasm:deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@holoscript/absorb-service": "workspace:*",
    "@holoscript/config": "workspace:*",
    "@holoscript/connector-appstore": "workspace:*",
    "@holoscript/connector-core": "workspace:*",
    "@holoscript/connector-github": "workspace:*",
    "@holoscript/connector-railway": "workspace:*",
    "@holoscript/connector-upstash": "workspace:*",
    "@holoscript/connector-vscode": "workspace:*",
    "@holoscript/core": "workspace:*",
    "@holoscript/engine": "workspace:*",
    "@holoscript/framework": "workspace:*",
    "@holoscript/marketplace-agentkit": "workspace:*",
    "@holoscript/mesh": "workspace:*",
    "@holoscript/platform": "workspace:*",
    "@holoscript/r3f-renderer": "workspace:*",
    "@holoscript/std": "workspace:*",
    "@holoscript/studio-plugin-sdk": "workspace:*",
    "@holoscript/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/xr": "^6.6.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/redis": "^1.34.0",
    "chart.js": "^4.4.0",
    "clsx": "^2.1.0",
    "drizzle-orm": ">=0.45.2",
    "idb": "^8.0.0",
    "idb-keyval": "^6.2.1",
    "isomorphic-git": "^1.37.2",
    "lucide-react": "^0.314.0",
    "memfs": "^4.56.11",
    "next": ">=15.5.15",
    "next-auth": "4",
    "pg": "^8.13.1",
    "picomatch": ">=4.0.4",
    "posthog-js": "^1.363.1",
    "prismjs": "^1.29.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "reactflow": "^11.11.4",
    "sharp": "^0.34.5",
    "three": "^0.182.0",
    "viem": "^2.47.1",
    "y-websocket": "^2.0.3",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zundo": "^2.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^24.10.1",
    "@types/picomatch": "^4.0.0",
    "@types/prismjs": "^1.26.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "agentation": "^3.0.2",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8.4.33",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
