  page u_username { @route("/u/[username]") @file("packages/studio/src/app/u/[username]/page.tsx") @calls_apis(["/api/users/[id]"])
  }

  page vibe { @route("/vibe") @file("packages/studio/src/app/vibe/page.tsx") @uses_stores(["SceneStore"])
