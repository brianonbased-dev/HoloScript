  }

  page view_id { @route("/view/[id]") @file("packages/studio/src/app/view/[id]/page.tsx") @calls_apis(["/api/publish"])
  }

  page workspace_agents_new { @route("/workspace/agents/new") @file("packages/studio/src/app/workspace/agents/new/page.tsx") @uses_stores(["SceneStore"]) @calls_apis(["/api/agents/fleet"])
