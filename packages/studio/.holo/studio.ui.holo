  }

  page workspace_knowledge { @route("/workspace/knowledge") @file("packages/studio/src/app/workspace/knowledge/page.tsx") @calls_apis(["/api/knowledge/query", "/api/knowledge/sync"])
    WPGEntryForm { @file("packages/studio/src/components/knowledge/WPGEntryForm.tsx") @calls_apis(["/api/knowledge/query", "/api/knowledge/sync"]) }
