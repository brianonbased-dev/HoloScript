    AIGeneratorWizard { @file("packages/studio/src/components/generative/AIGeneratorWizard.tsx") @reused_in([workspace_agents_new, workspace_templates_new, workspace_traits_new]) @uses_stores(["SceneStore"]) @calls_apis(["/api/agents/fleet"]) }
