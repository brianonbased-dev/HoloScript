{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holoscript.dev/schemas/mvc/evidence-trail.json",
  "title": "EvidenceTrail",
  "description": "VCP v1.1 hash chain for tamper-proof evidence tracking",
  "type": "object",
  "required": ["crdtType", "crdtId", "vcpMetadata", "entries", "headHash", "lastUpdated"],
  "properties": {
    "crdtType": {
      "type": "string",
      "const": "hash-chain"
    },
    "crdtId": {
      "type": "string",
      "format": "uuid"
    },
    "vcpMetadata": {
      "$ref": "#/$defs/VCPMetadata"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EvidenceEntry"
      },
      "maxItems": 100
    },
    "headHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64,128}$"
    },
    "lastVerification": {
      "$ref": "#/$defs/ChainVerificationResult"
    },
    "lastUpdated": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "VCPMetadata": {
      "type": "object",
      "required": ["version", "hashAlgorithm", "createdAt", "creatorDid"],
      "properties": {
        "version": {
          "type": "string",
          "const": "1.1"
        },
        "hashAlgorithm": {
          "type": "string",
          "enum": ["sha256", "sha512", "blake3"]
        },
        "createdAt": {
          "type": "integer",
          "minimum": 0
        },
        "creatorDid": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$"
        },
        "purpose": {
          "type": "string",
          "maxLength": 200
        },
        "expiresAt": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "EvidenceEntry": {
      "type": "object",
      "required": ["sequence", "type", "timestamp", "content", "hash", "previousHash", "agentDid"],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "type": {
          "type": "string",
          "enum": ["observation", "action", "reasoning", "external_data", "credential", "attestation", "measurement"]
        },
        "timestamp": {
          "type": "integer",
          "minimum": 0
        },
        "content": {
          "type": "string",
          "maxLength": 300
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64,128}$"
        },
        "previousHash": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[a-f0-9]{64,128}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "agentDid": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$"
        },
        "signature": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "maxLength": 100
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "relatedTo": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ChainVerificationResult": {
      "type": "object",
      "required": ["valid", "entriesVerified", "brokenLinks", "invalidSignatures", "verifiedAt"],
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "entriesVerified": {
          "type": "integer",
          "minimum": 0
        },
        "brokenLinks": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "invalidSignatures": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "verifiedAt": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
