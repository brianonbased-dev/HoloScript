{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holoscript.dev/schemas/mvc/decision-history.json",
  "title": "DecisionHistory",
  "description": "G-Set CRDT for append-only decision log",
  "type": "object",
  "required": ["crdtType", "crdtId", "decisions", "vectorClock", "lastUpdated"],
  "properties": {
    "crdtType": {
      "type": "string",
      "const": "g-set",
      "description": "CRDT type identifier"
    },
    "crdtId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique CRDT instance ID"
    },
    "decisions": {
      "type": "array",
      "description": "Set of all decision entries",
      "items": {
        "$ref": "#/$defs/DecisionEntry"
      },
      "maxItems": 100
    },
    "vectorClock": {
      "type": "object",
      "description": "Vector clock for causality tracking",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "lastUpdated": {
      "type": "integer",
      "description": "Last update timestamp (Unix milliseconds)",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "DecisionEntry": {
      "type": "object",
      "required": ["id", "timestamp", "type", "description", "choice"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique decision ID"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds",
          "minimum": 0
        },
        "type": {
          "type": "string",
          "enum": ["task", "preference", "strategy", "resource", "social"],
          "description": "Decision type category"
        },
        "description": {
          "type": "string",
          "maxLength": 200,
          "description": "Brief decision description"
        },
        "choice": {
          "type": "string",
          "maxLength": 100,
          "description": "Chosen option/action"
        },
        "parentId": {
          "type": "string",
          "format": "uuid",
          "description": "Parent decision ID for causal chains"
        },
        "agentDid": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$",
          "description": "Agent DID that made this decision"
        },
        "outcome": {
          "type": "string",
          "enum": ["success", "failure", "pending"],
          "description": "Outcome result"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score"
        }
      },
      "additionalProperties": false
    }
  }
}
