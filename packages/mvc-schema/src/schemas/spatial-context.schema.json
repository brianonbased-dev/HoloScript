{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holoscript.dev/schemas/mvc/spatial-context.json",
  "title": "SpatialContextSummary",
  "description": "WGS84 geospatial anchors for cross-reality positioning",
  "type": "object",
  "required": ["crdtType", "crdtId", "agentDid", "recentAnchors", "lastUpdated"],
  "properties": {
    "crdtType": {
      "type": "string",
      "const": "lww+gset"
    },
    "crdtId": {
      "type": "string",
      "format": "uuid"
    },
    "agentDid": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$"
    },
    "primaryAnchor": {
      "$ref": "#/$defs/SpatialAnchor"
    },
    "currentPose": {
      "$ref": "#/$defs/AgentPose"
    },
    "recentAnchors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SpatialAnchor"
      },
      "maxItems": 20
    },
    "environment": {
      "$ref": "#/$defs/EnvironmentalContext"
    },
    "poseMetadata": {
      "$ref": "#/$defs/LWWMetadata"
    },
    "anchorMetadata": {
      "$ref": "#/$defs/LWWMetadata"
    },
    "lastUpdated": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "WGS84Coordinate": {
      "type": "object",
      "required": ["latitude", "longitude", "altitude"],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "altitude": {
          "type": "number"
        },
        "horizontalAccuracy": {
          "type": "number",
          "minimum": 0
        },
        "verticalAccuracy": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "SpatialAnchor": {
      "type": "object",
      "required": ["id", "coordinate", "label", "createdAt", "lastVerified"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "coordinate": {
          "$ref": "#/$defs/WGS84Coordinate"
        },
        "label": {
          "type": "string",
          "maxLength": 100
        },
        "createdAt": {
          "type": "integer",
          "minimum": 0
        },
        "lastVerified": {
          "type": "integer",
          "minimum": 0
        },
        "creatorDid": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$"
        },
        "type": {
          "type": "string",
          "enum": ["waypoint", "poi", "workspace", "meeting", "reference"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "AgentPose": {
      "type": "object",
      "required": ["position", "orientation", "timestamp"],
      "properties": {
        "position": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 3,
          "maxItems": 3
        },
        "orientation": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "timestamp": {
          "type": "integer",
          "minimum": 0
        },
        "velocity": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 3,
          "maxItems": 3
        },
        "angularVelocity": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "additionalProperties": false
    },
    "EnvironmentalContext": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["indoor", "outdoor", "mixed", "virtual", "unknown"]
        },
        "lightingLevel": {
          "type": "number",
          "minimum": 0
        },
        "noiseLevel": {
          "type": "number",
          "minimum": 0
        },
        "temperature": {
          "type": "number"
        },
        "weather": {
          "type": "string",
          "enum": ["clear", "cloudy", "rainy", "snowy", "foggy"]
        }
      },
      "additionalProperties": false
    },
    "LWWMetadata": {
      "type": "object",
      "required": ["timestamp", "actorDid", "operationId"],
      "properties": {
        "timestamp": {
          "type": "integer",
          "minimum": 0
        },
        "actorDid": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$"
        },
        "operationId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
