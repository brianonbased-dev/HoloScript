{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holoscript.dev/schemas/mvc/preferences.json",
  "title": "UserPreferences",
  "description": "LWW-Register per field for user preferences",
  "type": "object",
  "required": ["crdtType", "crdtId", "agentDid", "lwwMetadata", "lastUpdated"],
  "properties": {
    "crdtType": {
      "type": "string",
      "const": "lww-map"
    },
    "crdtId": {
      "type": "string",
      "format": "uuid"
    },
    "agentDid": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$"
    },
    "spatial": {
      "$ref": "#/$defs/SpatialPreferences"
    },
    "communication": {
      "$ref": "#/$defs/CommunicationPreferences"
    },
    "visual": {
      "$ref": "#/$defs/VisualPreferences"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyPreferences"
    },
    "lwwMetadata": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/LWWMetadata"
      }
    },
    "lastUpdated": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "SpatialPreferences": {
      "type": "object",
      "properties": {
        "movementSpeed": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "personalSpaceRadius": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "interactionDistance": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "handDominance": {
          "type": "string",
          "enum": ["left", "right", "ambidextrous"]
        }
      },
      "additionalProperties": false
    },
    "CommunicationPreferences": {
      "type": "object",
      "properties": {
        "style": {
          "type": "string",
          "enum": ["formal", "casual", "technical", "concise"]
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}$"
        },
        "voiceInput": {
          "type": "boolean"
        },
        "textToSpeech": {
          "type": "boolean"
        },
        "notifications": {
          "type": "string",
          "enum": ["all", "important", "critical", "none"]
        }
      },
      "additionalProperties": false
    },
    "VisualPreferences": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "auto", "high-contrast"]
        },
        "uiScale": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2.0
        },
        "colorVisionMode": {
          "type": "string",
          "enum": ["normal", "protanopia", "deuteranopia", "tritanopia"]
        },
        "reducedMotion": {
          "type": "boolean"
        },
        "showAnchors": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "PrivacyPreferences": {
      "type": "object",
      "properties": {
        "shareLocation": {
          "type": "boolean"
        },
        "shareTaskState": {
          "type": "boolean"
        },
        "allowCollaboration": {
          "type": "boolean"
        },
        "visibilityMode": {
          "type": "string",
          "enum": ["public", "friends", "team", "private"]
        }
      },
      "additionalProperties": false
    },
    "LWWMetadata": {
      "type": "object",
      "required": ["timestamp", "actorDid", "operationId"],
      "properties": {
        "timestamp": {
          "type": "integer",
          "minimum": 0
        },
        "actorDid": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._%-]+$"
        },
        "operationId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
