{
  "name": "@holoscript/mvc-schema",
  "version": "1.0.0",
  "description": "Minimal Viable Context (MVC) schema for cross-reality agent state synchronization with authenticated CRDTs",
  "_architectureNote": "A.011.06f: Canonical home decision — mvc-schema belongs with the networking/crdt layer. It depends on @holoscript/crdt, defines CRDT-compatible schemas (G-Set, OR-Set, LWW-Map), and has zero external consumers outside its own package. If consolidated, merge into @holoscript/crdt as a 'schemas' sub-export rather than moving to marketplace-api.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.cjs"
    },
    "./compression": {
      "types": "./dist/compression/index.d.ts",
      "import": "./dist/compression/index.js",
      "require": "./dist/compression/index.cjs"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "require": "./dist/validation/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "size-check": "node scripts/check-size.mjs"
  },
  "keywords": [
    "mvc",
    "minimal-viable-context",
    "cross-reality",
    "agent-state",
    "crdt",
    "compression",
    "json-schema",
    "cbor",
    "spatial-computing",
    "geospatial"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/mvc-schema"
  },
  "dependencies": {
    "@holoscript/crdt": "workspace:*",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cbor-x": "^1.6.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
