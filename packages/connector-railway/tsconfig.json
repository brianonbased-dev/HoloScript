{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@holoscript/connector-core": [
        "../connector-core/src/index.ts"
      ]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../connector-core" }
  ]
}
