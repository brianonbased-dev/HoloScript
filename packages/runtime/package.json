{
  "name": "@holoscript/runtime",
  "version": "6.0.3",
  "description": "HoloScript browser runtime — React Three Fiber integration, physics, event system, and device APIs for spatial applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js",
      "require": "./dist/events.cjs"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js",
      "require": "./dist/storage.cjs"
    },
    "./device": {
      "types": "./dist/device.d.ts",
      "import": "./dist/device.js",
      "require": "./dist/device.cjs"
    },
    "./timing": {
      "types": "./dist/timing.d.ts",
      "import": "./dist/timing.js",
      "require": "./dist/timing.cjs"
    },
    "./math": {
      "types": "./dist/math.d.ts",
      "import": "./dist/math.js",
      "require": "./dist/math.cjs"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js",
      "require": "./dist/navigation.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@holoscript/core": "workspace:*",
    "cannon-es": "^0.20.0"
  },
  "peerDependencies": {
    "@react-three/fiber": "^9.5.0",
    "monaco-editor": "^0.45.0",
    "react": "^19.2.0",
    "three": "^0.182.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "monaco-editor": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/three": "^0.170.0",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "holoscript",
    "runtime",
    "react-three-fiber",
    "3d",
    "vr",
    "ar",
    "xr",
    "webxr",
    "spatial-computing",
    "threejs",
    "physics",
    "declarative"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/runtime"
  }
}
