{
  "name": "@holoscript/linter",
  "version": "7.0.0",
  "description": "Static analysis tool for HoloScript (.holo) and HoloScript+ (.hsplus) files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "holoscript-lint": "./bin/holoscript-lint.cjs"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "dev": "tsc --watch",
    "test": "vitest run --pool=forks",
    "lint": "eslint src/",
    "clean": "rimraf dist",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "holoscript",
    "hsplus",
    "linter",
    "static-analysis",
    "vr",
    "ar",
    "hololand"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/linter"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@holoscript/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "rimraf": "^5.0.5",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
