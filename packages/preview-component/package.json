{
  "name": "@holoscript/preview-component",
  "version": "0.1.0",
  "description": "Standalone React component for embedding interactive HoloScript 3D scene previews in GitHub PRs, docs, and playgrounds",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.170.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.170.0",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "holoscript",
    "react",
    "3d-preview",
    "three.js",
    "vr",
    "xr",
    "embed",
    "scene-viewer",
    "webgl"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/preview-component"
  },
  "author": "Brian X Base Team",
  "engines": {
    "node": ">=18.0.0"
  }
}
