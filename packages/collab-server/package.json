{
  "name": "@holoscript/collab-server",
  "version": "1.0.0",
  "description": "Lightweight WebSocket relay server for HoloScript Studio multi-user collaboration",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "npx tsx --watch src/server.ts",
    "start": "npx tsx src/server.ts",
    "build": "npx esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js --format=esm",
    "test": "npx vitest run --reporter verbose"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.4",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
