{
  "name": "@holoscript/connector-github",
  "version": "1.0.0",
  "description": "GitHub MCP Connector for HoloScript Studio Integration Hub - repo, issue, PR, and CI/CD operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "github",
    "mcp",
    "connector",
    "ci-cd",
    "actions"
  ],
  "dependencies": {
    "@holoscript/connector-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@octokit/auth-token": "^5.1.1",
    "@octokit/rest": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  },
  "author": "Brian X Base Team",
  "license": "MIT"
}
