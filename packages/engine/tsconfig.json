{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "types": ["node", "@webgpu/types"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "baseUrl": ".",
    "paths": {
      "@holoscript/core": ["../core/dist"],
      "@holoscript/core/*": ["../core/dist/*"],
      "@holoscript/framework": ["../framework/dist"],
      "@holoscript/framework/*": ["../framework/dist/*"],
      "@holoscript/crdt-spatial": ["../crdt-spatial/dist"],
      "@holoscript/snn-webgpu": ["../snn-webgpu/dist"],
      "@holoscript/uaal": ["../uaal/dist"]
    },
    "noImplicitAny": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
