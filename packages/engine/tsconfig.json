{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "types": ["@webgpu/types", "node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "baseUrl": ".",
    "paths": {
      "@holoscript/core": ["../core/src/index.ts"],
      "@holoscript/core/*": ["../core/src/*"],
      "@holoscript/uaal": ["../uaal/src/index.ts"],
      "@holoscript/framework": ["../framework/src/index.ts"]
    },
    "noImplicitAny": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
