{
  "name": "@holoscript/engine",
  "version": "6.0.0",
  "description": "Engine runtime extracted from @holoscript/core — rendering, physics, animation, ECS, and 20+ subsystems for spatial computing.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./rendering": {
      "types": "./dist/rendering/index.d.ts",
      "import": "./dist/rendering/index.js",
      "require": "./dist/rendering/index.cjs"
    },
    "./physics": {
      "types": "./dist/physics/index.d.ts",
      "import": "./dist/physics/index.js",
      "require": "./dist/physics/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/rendering/index.ts src/physics/index.ts src/runtime/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/rendering/index.ts src/physics/index.ts src/runtime/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "engine",
    "spatial",
    "physics",
    "rendering",
    "ecs",
    "animation",
    "vr",
    "xr",
    "runtime"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/engine"
  },
  "peerDependencies": {
    "@holoscript/core": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@holoscript/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.18.3",
    "@webgpu/types": "^0.1.40",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}