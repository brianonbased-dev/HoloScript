{
  "name": "@holoscript/spatial-index",
  "version": "1.0.0",
  "description": "High-performance R-Tree spatial index for geospatial anchors with IndexedDB persistence",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "bench": "vitest bench"
  },
  "keywords": [
    "rtree",
    "r-tree",
    "spatial-index",
    "geospatial",
    "indexeddb",
    "bulk-loading",
    "OMT",
    "spatial-query"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/spatial-index"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
