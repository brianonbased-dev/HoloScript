{
  "name": "@holoscript/playground",
  "version": "1.0.2",
  "description": "Interactive web-based playground for trying HoloScript in the browser",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && gh-pages -d dist"
  },
  "keywords": [
    "holoscript",
    "playground",
    "editor",
    "interactive",
    "demo"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "gh-pages": "^6.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@holoscript/core": "workspace:*",
    "@holoscript/std": "workspace:*",
    "monaco-editor": "^0.45.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
