{
  "name": "@holoscript/graphql-api",
  "version": "0.1.0",
  "description": "GraphQL API layer for HoloScript compiler with TypeGraphQL and Apollo Server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "graphql",
    "apollo",
    "type-graphql",
    "compiler-api"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/graphql-api"
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@envelop/core": "^5.5.1",
    "@envelop/response-cache": "^9.1.1",
    "@holoscript/auth": "workspace:*",
    "@holoscript/core": "workspace:*",
    "body-parser": "^2.2.2",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "graphql": "^16.13.1",
    "graphql-query-complexity": "^1.1.0",
    "graphql-rate-limit": "^3.3.0",
    "graphql-shield": "^7.6.5",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.7",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0-rc.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.10.0",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
