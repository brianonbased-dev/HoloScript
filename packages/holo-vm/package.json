{
  "name": "@holoscript/holo-vm",
  "version": "5.1.0",
  "description": "HOLO VM — HoloScript native bytecode execution engine for spatial computing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./opcodes": {
      "types": "./dist/opcodes.d.ts",
      "import": "./dist/opcodes.js",
      "require": "./dist/opcodes.cjs"
    },
    "./bytecode": {
      "types": "./dist/bytecode.d.ts",
      "import": "./dist/bytecode.js",
      "require": "./dist/bytecode.cjs"
    },
    "./executor": {
      "types": "./dist/executor.d.ts",
      "import": "./dist/executor.js",
      "require": "./dist/executor.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@holoscript/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "holoscript",
    "vm",
    "bytecode",
    "spatial-computing",
    "ecs",
    "wasm"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/holo-vm"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
