{
  "name": "@holoscript/studio-bridge",
  "version": "1.0.0",
  "description": "Bidirectional Visual-to-AST translation bridge between HoloScript Studio visual editor and the HoloScript AST/compiler pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./visual-to-ast": {
      "types": "./dist/VisualToAST.d.ts",
      "import": "./dist/VisualToAST.js"
    },
    "./ast-to-visual": {
      "types": "./dist/ASTToVisual.d.ts",
      "import": "./dist/ASTToVisual.js"
    },
    "./sync": {
      "types": "./dist/SyncEngine.d.ts",
      "import": "./dist/SyncEngine.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "holoscript",
    "studio",
    "bridge",
    "visual-programming",
    "ast",
    "bidirectional",
    "node-editor",
    "code-generation"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/studio-bridge"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
