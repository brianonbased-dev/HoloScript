    blend_weight: 1.0
    speed: 0.9
    clip: "Swimming"
    pack: "Aquatic"
    alternatives: ["Treading Water", "Breaststroke", "Backstroke", "Float Idle"]
    tags: ["locomotion", "movement", "aquatic", "cycle"]
  }
}

// ---------------------------------------------------------------------------
// Fly
// ---------------------------------------------------------------------------

template "FlyPreset" {
  @animated {
    name: "fly"
    description: "Aerial flight pose with arms spread. Smooth looping glide suitable for superhero or winged characters."
    category: "locomotion"
    duration: 2.0
    delay: 0
    easing: "ease-in-out"
    loop: true
    blend_weight: 1.0
    speed: 0.8
    clip: "Flying"
    pack: "Aerial"
    alternatives: ["Hovering", "Fly Forward", "Fly Idle", "Glide"]
    tags: ["locomotion", "movement", "aerial", "cycle", "superhero"]
  }
}

// ---------------------------------------------------------------------------
// Climb
// ---------------------------------------------------------------------------

template "ClimbPreset" {
  @animated {
    name: "climb"
    description: "Vertical climbing cycle with alternating hand-over-hand grip and leg push."
    category: "locomotion"
