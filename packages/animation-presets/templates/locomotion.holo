/**
 * Locomotion Animation Presets — .holo templates
 *
 * Movement-based character behaviors mapped to canonical Mixamo clips.
 * Each template declares an @animated trait with timing, loop, blend,
 * speed, and clip metadata ready for composition use.
 *
 * Usage:
 *   object "player" using "WalkPreset" { position: [0, 0, 0] }
 */

// ---------------------------------------------------------------------------
// Walk
// ---------------------------------------------------------------------------

template "WalkPreset" {
  @animated {
    name: "walk"
    description: "Standard bipedal walking cycle. Loops continuously with natural stride cadence."
    category: "locomotion"
    duration: 1.0
    delay: 0
    easing: "linear"
    loop: true
    blend_weight: 1.0
    speed: 1.0
    clip: "Walking"
    pack: "Locomotion"
    alternatives: ["Slow Walk", "Walk With Briefcase", "Sneaking Walk", "Confident Walk"]
    tags: ["locomotion", "movement", "bipedal", "cycle"]
  }
}

// ---------------------------------------------------------------------------
// Run
// ---------------------------------------------------------------------------

template "RunPreset" {
  @animated {
    name: "run"
    description: "Fast bipedal running cycle. Higher speed multiplier, tighter timing than walk."
    category: "locomotion"
    duration: 0.7
    delay: 0
    easing: "linear"
    loop: true
    blend_weight: 1.0
    speed: 1.4
    clip: "Running"
    pack: "Locomotion"
    alternatives: ["Fast Run", "Sprint", "Jog", "Run Forward"]
    tags: ["locomotion", "movement", "fast", "bipedal", "cycle"]
  }
}

// ---------------------------------------------------------------------------
// Jump
// ---------------------------------------------------------------------------

template "JumpPreset" {
  @animated {
    name: "jump"
    description: "Vertical jump with anticipation crouch, airborne phase, and landing recovery. Plays once."
    category: "locomotion"
    duration: 1.2
    delay: 0
    easing: "ease-out"
    loop: false
    blend_weight: 1.0
    speed: 1.0
    clip: "Jump"
    pack: "Locomotion"
    alternatives: ["Standing Jump", "Running Jump", "Jump Up", "Jump Forward"]
    tags: ["locomotion", "movement", "aerial", "one-shot"]
  }
}

// ---------------------------------------------------------------------------
// Crouch
// ---------------------------------------------------------------------------

template "CrouchPreset" {
  @animated {
    name: "crouch"
    description: "Lowered crouch stance with knees bent. Blends smoothly from standing to crouched position."
    category: "locomotion"
    duration: 0.6
    delay: 0
    easing: "ease-in-out"
    loop: false
    blend_weight: 1.0
    speed: 1.0
    clip: "Crouching Idle"
    pack: "Locomotion"
    alternatives: ["Crouch Walk", "Crouch To Stand", "Stand To Crouch", "Sneaking Idle"]
    tags: ["locomotion", "stance", "stealth", "low"]
  }
}

// ---------------------------------------------------------------------------
// Swim
// ---------------------------------------------------------------------------

template "SwimPreset" {
  @animated {
    name: "swim"
