{
  "productName": "HoloScript Studio",
  "version": "0.1.0",
  "identifier": "com.holoscript.studio",
  "build": {
    "beforeDevCommand": "cd ../studio && pnpm dev",
    "devUrl": "http://localhost:3100",
    "beforeBuildCommand": "cd ../studio && pnpm build",
    "frontendDist": "../../studio/out"
  },
  "app": {
    "windows": [
      {
        "title": "HoloScript Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
