{
  "$schema": "https://raw.githubusercontent.com/nicepkg/tauri-v2/HEAD/tooling/cli/schema.json",
  "identifier": "default",
  "description": "Default capability for HoloScript Studio desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-set-size",
    "core:window:allow-set-min-size",
    "core:window:allow-center",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "updater:default"
  ]
}