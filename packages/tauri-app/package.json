{
  "name": "@holoscript/tauri-app",
  "version": "0.1.0",
  "private": true,
  "description": "Tauri 2.0 desktop shell for HoloScript Studio — native GPU, file system, and offline capabilities",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:debug": "tauri build --debug",
    "tauri": "tauri",
    "lint": "eslint src/",
