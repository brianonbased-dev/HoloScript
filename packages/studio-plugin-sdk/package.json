{
  "name": "@holoscript/studio-plugin-sdk",
  "version": "1.0.0",
  "description": "Plugin SDK for extending HoloScript Studio with custom nodes, panels, and tools",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-holoscript-plugin": "./bin/create-plugin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox/index.d.ts",
      "import": "./dist/sandbox/index.js"
    },
    "./sandbox/guest": {
      "types": "./dist/sandbox/PluginGuestSDK.d.ts",
      "import": "./dist/sandbox/PluginGuestSDK.js"
    },
    "./sandbox/types": {
      "types": "./dist/sandbox/types.d.ts",
      "import": "./dist/sandbox/types.js"
    },
    "./responsive": {
      "types": "./dist/responsive/index.d.ts",
      "import": "./dist/responsive/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "holoscript",
    "studio",
    "plugin",
    "sdk",
    "extensibility",
    "sandbox",
    "iframe",
    "isolation",
    "security",
    "postmessage"
  ],
  "author": "HoloScript Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/prompts": "^2.4.9",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
