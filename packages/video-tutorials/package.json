{
  "name": "@holoscript/video-tutorials",
  "version": "0.1.0",
  "private": true,
  "description": "Programmatic instructional video generation for HoloScript and HoloLand",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "render": "tsx scripts/render-all.ts",
    "render:unity": "tsx scripts/render-all.ts --filter unity",
    "render:godot": "tsx scripts/render-all.ts --filter godot",
    "render:babylon": "tsx scripts/render-all.ts --filter babylon",
    "render:all": "tsx scripts/render-all.ts",
    "narration": "tsx scripts/generate-narration.ts",
    "record:cli": "python scripts/record-cli-demo.py"
  },
  "dependencies": {
    "@holoscript/core": "workspace:*",
    "@remotion/bundler": "^4.0.0",
