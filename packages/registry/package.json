{
  "name": "@holoscript/registry",
  "version": "7.0.0",
  "description": "HoloScript package registry and team workspace API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "holoscript",
    "registry",
    "packages",
    "workspaces"
  ],
  "author": "HoloScript Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
