{
  "name": "@holoscript/connector-upstash",
  "version": "1.0.0",
  "description": "Upstash MCP Connector for HoloScript Studio Integration Hub - Redis caching, Vector search, QStash scheduling",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "upstash",
    "redis",
    "vector",
    "qstash",
    "mcp",
    "connector",
    "caching",
    "scheduling"
  ],
  "dependencies": {
    "@holoscript/connector-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@upstash/qstash": "^2.7.0",
    "@upstash/redis": "^1.34.0",
    "@upstash/vector": "^1.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  },
