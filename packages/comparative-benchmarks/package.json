{
  "name": "@holoscript/comparative-benchmarks",
  "version": "1.2.1",
  "description": "Performance benchmarks comparing HoloScript against Unity and glTF runtimes",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "holoscript-bench": "./dist/cli.js",
    "holoscript-bench-paper12": "./dist/paper12-cli.js"
  },
  "files": [
    "dist",
    "results"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "bench": "node dist/cli.js",
    "bench:unity": "node dist/cli.js --target=unity",
    "bench:gltf": "node dist/cli.js --target=gltf",
    "bench:all": "node dist/cli.js --target=all",
    "bench:paper12": "node dist/paper12-cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@holoscript/core": "workspace:^",
    "tinybench": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "holoscript",
    "benchmarks",
    "performance",
    "unity",
    "gltf",
    "comparison"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/comparative-benchmarks"
  },
  "author": "Brian X Base Team",
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
