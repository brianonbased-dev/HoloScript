// ============================================================================
// Mycelium Network — 1.2 Million Bioluminescent Threads
// ============================================================================
// The underground internet of the forest, made visible. A vast fungal network
// rendered as luminous threads connecting nodes of concentrated energy.
// Each node pulses with slow metabolic rhythm. Threads carry light-packets
// between nodes — information traveling through living wire. The whole
// system grows: new hyphae extend outward, branching fractally, probing
// the dark for nutrients. Some paths strengthen and glow brighter as they
// carry more traffic. Others atrophy, dimming to nothing.
//
// This is not a static sculpture. It is a simulation of emergence —
// intelligence arising from simple rules at massive scale.
// ============================================================================

#version 6.0.0
#target WebGPU, R3F
#mode immersive

// ----------------------------------------------------------------------------
// Environment — Deep subterranean void, no sky, no horizon
// Pure black broken only by bioluminescence
// ----------------------------------------------------------------------------
@environment {
    type: "void",
    background: "#010102",
    lighting: "emissive_only",
    fog_density: 0.008,
    fog_color: "#020104",
    fog_type: "exponential_squared"
}

@skybox {
    type: "solid",
    color: "#000000"
}

// ----------------------------------------------------------------------------
// Ambient — Near-zero. The mycelium IS the light source.
// A faint purple wash prevents pure black from crushing detail.
// ----------------------------------------------------------------------------
object AmbientGlow {
    type: "ambient_light"

    @lighting {
        type: "ambient",
        color: "#0a0412",
        intensity: 0.04
    }
}

// ============================================================================
// PRIMARY HYPHAE — The thick arterial highways of the network
// 200,000 tube segments forming the major transport corridors
// ============================================================================
object PrimaryHyphae {
    type: "instanced_field"
    position: [0, 0, 0]

    @instanced_mesh {
        count: 200000,
        geometry: "cylinder",
        base_scale: [0.015, 0.3, 0.015]
    }

    @gpu_compute {
        init: "network_graph_distribute",
        update: "pulse_flow",
        buffers: [
            "position:vec3",
            "rotation:vec4",
            "scale:vec3",
            "color:vec4",
            "flow_phase:float",
            "flow_intensity:float",
            "branch_id:uint"
        ]
    }

    // L-system inspired branching network
    // Starts from 7 root nodes, branches outward with decreasing thickness
    @distribution {
        type: "network_graph",
        root_nodes: 7,
        root_positions: [
            [0, -2, 0],
            [8, -1, 5],
            [-6, -3, 8],
            [12, -2, -4],
            [-10, -1, -6],
            [3, -4, -12],
            [-4, -2, 14]
        ],
        branch_probability: 0.65,
        branch_angle_range: [15, 55],
        segment_length_range: [0.2, 0.6],
        max_depth: 18,
        thickness_decay: 0.88,
        gravity_bias: -0.05,
        spread_radius: 40,
        spread_height_range: [-8, 4],
        // Prefer horizontal spreading with slight vertical wander
        horizontal_bias: 3.0,
        avoid_self_radius: 0.3
    }

    @material {
        type: "emissive_translucent",
        base_color: "#1a0830",
        emissive_color: "#6633ff",
        emissive_intensity: 0.6,
        roughness: 0.7,
        transmission: 0.3,
        thickness: 0.015,
        subsurface_color: "#4400cc",
        subsurface_radius: 0.05
    }

    // Light packets flow along hyphae — waves of brightness
    @animation {
        type: "pulse_flow",
        wave_speed: 0.8,
        wave_width: 2.0,
        wave_intensity: 3.0,
        wave_color: "#aa66ff",
        direction: "root_to_tip",
        frequency: 0.15,
        phase_offset: "per_branch_random",
        // Occasional reverse pulse (feedback signal)
        reverse_probability: 0.1,
        reverse_color: "#33ffaa"
    }
}

// ============================================================================
// SECONDARY HYPHAE — Fine exploratory threads
// 500,000 thin filaments branching from the primary network
// ============================================================================
object SecondaryHyphae {
    type: "instanced_field"
    position: [0, 0, 0]

    @instanced_mesh {
        count: 500000,
        geometry: "cylinder",
        base_scale: [0.004, 0.15, 0.004]
    }

    @gpu_compute {
        init: "fine_branch_distribute",
        update: "growth_extend",
        buffers: [
            "position:vec3",
            "rotation:vec4",
            "scale:vec3",
            "color:vec4",
            "age:float",
            "growth_state:float",
            "parent_id:uint"
        ]
    }

    // Fine threads extend from primary hyphae endpoints
    // They grow over time — new ones appear, old ones may fade
    @distribution {
        type: "endpoint_branch",
        source: "PrimaryHyphae",
        attach_to: "tips_and_nodes",
        branch_count_range: [2, 5],
        branch_angle_range: [20, 70],
        segment_length_range: [0.1, 0.3],
        max_depth: 8,
        thickness_decay: 0.75,
        curl_factor: 0.15,
        // Growth front — new threads extend outward over time
        growth_enabled: true,
        growth_rate: 0.02,
        growth_probability: 0.3
    }

    @material {
        type: "emissive_translucent",
        base_color: "#0d0418",
        emissive_color: "#4422aa",
        emissive_intensity: 0.3,
        roughness: 0.8,
        transmission: 0.4,
        thickness: 0.004,
        subsurface_color: "#2200aa",
        subsurface_radius: 0.02,
        opacity_range: [0.2, 0.8]
    }

    @animation {
        type: "growth_extend",
        extend_speed: 0.01,
        curl_animation: {
            frequency: 0.05,
            amplitude: 0.03
        },
        fade_when_starved: true,
        starvation_threshold: 0.2,
        fade_duration_s: 5.0
    }
}

// ============================================================================
// NETWORK NODES — Concentrated energy junctions
// 150 SDF-rendered spherical clusters where hyphae converge
// Each node is a smooth-unioned blob of overlapping spheres
// ============================================================================
object NetworkNodes {
    type: "sdf_field"
    position: [0, 0, 0]

    @sdf_scene {
        // Procedurally placed at branch junctions
        generator: "network_junctions",
        source: "PrimaryHyphae",
        min_connections: 3,
        primitives_per_node: 5,
        primitive_type: "sphere",
        primitive_radius_range: [0.3, 1.2],
        primitive_offset_range: [0.0, 0.4],
        operations: [
            { op: "smooth_union", k: 0.5 }
        ]
    }

    @material {
        type: "emissive_organic",
        base_color: "#1a0830",
        emissive_color: "#8844ff",
        emissive_intensity: 1.2,
        roughness: 0.4,
        subsurface_color: "#6600ff",
        subsurface_radius: 0.3,
        // Pulsing glow — each node has its own metabolic rhythm
        emissive_pulse: true,
        pulse_frequency_range: [0.02, 0.06],
        pulse_amplitude: 0.8,
        fresnel_intensity: 2.0,
        fresnel_color: "#cc88ff"
    }

    @animation {
        type: "metabolic_pulse",
        scale_pulse: {
            amplitude: 0.08,
            frequency_range: [0.015, 0.04],
            wave_type: "sine"
        },
        // Nodes that receive more flow pulse brighter
        flow_responsive: true,
        flow_brightness_multiplier: 2.0,
        // Synchronization — nearby nodes slowly entrain
        sync_radius: 8.0,
        sync_strength: 0.02
    }
}

// ============================================================================
// SPORE CLOUDS — Diffuse particle halos around active nodes
// 200,000 tiny luminous spores drifting outward from nodes
// ============================================================================
object SporeEmissions {
    type: "particle_system"
    position: [0, 0, 0]

    @instanced_mesh {
        count: 200000,
        geometry: "sphere",
        base_scale: [0.006, 0.006, 0.006]
    }

    @gpu_compute {
        init: "node_emission_scatter",
        update: "spore_drift",
        buffers: [
            "position:vec3",
            "velocity:vec3",
            "color:vec4",
            "life:float",
            "origin_node:uint"
        ]
    }

    @distribution {
        type: "emitter_array",
        sources: "NetworkNodes",
        emission_rate: 8.0,
        emission_shape: "sphere_surface",
        emission_radius: 0.5,
        initial_velocity_range: [0.01, 0.04],
        direction: "outward_random"
    }

    @material {
        type: "emissive_point",
        color: "#aa77ff",
        emissive_intensity: 2.0,
        opacity_curve: {
            type: "ease_out_quad",
            start: 0.6,
            end: 0.0
        },
        size_over_life: {
            type: "linear",
            start: 1.0,
            end: 0.3
        },
        size_attenuation: true,
        blend_mode: "additive"
    }

    @animation {
        type: "spore_drift",
        brownian_strength: 0.008,
        upward_bias: 0.003,
        lifetime_range: [3.0, 8.0],
        // Spores attracted to nearby nodes (chemotaxis)
        attraction_targets: "NetworkNodes",
        attraction_strength: 0.001,
        attraction_radius: 6.0,
        // Color shifts as spore ages
        color_over_life: [
            { t: 0.0, color: "#cc88ff" },
            { t: 0.4, color: "#8844ff" },
            { t: 0.8, color: "#4422aa" },
            { t: 1.0, color: "#110033" }
        ]
    }
}

// ============================================================================
// NUTRIENT PARTICLES — Tiny bright dots flowing THROUGH hyphae
// 100,000 light-speed pinpricks racing along the network paths
// These are the "data packets" of the biological internet
// ============================================================================
object NutrientFlow {
    type: "particle_system"
    position: [0, 0, 0]

    @instanced_mesh {
        count: 100000,
        geometry: "sphere",
        base_scale: [0.01, 0.01, 0.01]
    }

    @gpu_compute {
        init: "path_particle_spawn",
        update: "path_follow",
        buffers: [
            "position:vec3",
            "velocity:vec3",
            "color:vec4",
            "path_progress:float",
            "path_id:uint",
            "speed:float"
        ]
    }

    @distribution {
        type: "path_follower",
        source_network: "PrimaryHyphae",
        spawn_at: "root_nodes",
        path_selection: "random_walk",
        speed_range: [0.5, 2.0],
        // More packets on high-traffic routes
        traffic_weighted: true,
        respawn: true,
        respawn_delay_range: [0.1, 1.0]
    }

    @material {
        type: "emissive_point",
        color: "#00ffaa",
        emissive_intensity: 6.0,
        opacity: 0.9,
        size_attenuation: true,
        blend_mode: "additive",
        // Bright cyan-green — contrasts the purple network
        trail_enabled: true,
        trail_length: 4,
        trail_opacity_decay: 0.6,
        trail_color: "#00cc88"
    }

    @animation {
        type: "path_follow",
        speed_variation: 0.3,
        // At junctions, pause briefly then choose direction
        junction_pause_ms: 100,
        junction_choice: "weighted_random",
        // Some packets reverse direction (feedback)
        reverse_probability: 0.05,
        reverse_color: "#ff6633",
        reverse_speed_multiplier: 1.5
    }
}

// ============================================================================
// DECOMPOSITION ZONE — Where the network feeds
// 80,000 small fragments at the periphery being broken down
// Organic debris dissolving into the mycelium
// ============================================================================
object DecompositionZone {
    type: "instanced_field"
    position: [0, -5, 0]

    @instanced_mesh {
        count: 80000,
        geometry: "irregular_fragment",
        base_scale: [0.05, 0.05, 0.05]
    }

    @gpu_compute {
        init: "scatter_debris",
        update: "dissolve",
        buffers: [
            "position:vec3",
            "rotation:vec4",
            "scale:vec3",
            "color:vec4",
            "dissolution:float",
            "closest_hypha:float"
        ]
    }

    @distribution {
        type: "ground_scatter",
        bounds: { min: [-45, -8, -45], max: [45, -3, 45] },
        density: "perlin_noise",
        noise_scale: 0.1,
        noise_octaves: 4,
        density_range: [0.2, 3.0],
        // Dense near hyphae tips, sparse in empty zones
        proximity_boost: {
            source: "SecondaryHyphae",
            radius: 3.0,
            multiplier: 4.0
        }
    }

    @material {
        type: "organic_dissolving",
        base_color: "#1a1208",
        roughness: 0.95,
        metalness: 0.0,
        // Fragments glow faintly where mycelium contacts them
        contact_emissive: true,
        contact_color: "#4422aa",
        contact_intensity: 0.4,
        contact_radius: 0.1,
        // Dissolve shader — fragments become translucent as they're consumed
        dissolve_threshold: "dissolution_buffer",
        dissolve_edge_color: "#6633cc",
        dissolve_edge_width: 0.02
    }

    @animation {
        type: "dissolve",
        rate: 0.001,
        // Dissolution accelerates near active hyphae
        proximity_acceleration: {
            source: "SecondaryHyphae",
            radius: 1.5,
            multiplier: 5.0
        },
        // When fully dissolved, fragment respawns at periphery
        respawn_on_dissolve: true,
        respawn_zone: { min: [-50, -8, -50], max: [50, -3, 50] }
    }
}

// ============================================================================
// FRUITING BODIES — Mushrooms rising from dense node clusters
// SDF ray-marched organic forms that grow slowly upward
// These are the visible above-ground manifestation of the network
// ============================================================================
object FruitingBodies {
    type: "sdf_field"
    position: [0, 0, 0]

    @sdf_scene {
        generator: "mushroom_cluster",
        source: "NetworkNodes",
        spawn_threshold: 0.8,
        count_range: [1, 4],
        primitives: [
            // Stem: elongated capsule
            { type: "capsule", radius: 0.08, height_range: [0.5, 3.0] },
            // Cap: flattened sphere
            { type: "ellipsoid", radii_range: { x: [0.3, 1.5], y: [0.1, 0.4], z: [0.3, 1.5] } },
            // Gills: thin torus under cap
            { type: "torus", major_range: [0.2, 1.2], minor: 0.01 }
        ],
        operations: [
            { op: "smooth_union", k: 0.15 },
            { op: "twist", amount_range: [0.0, 0.3], axis: "y" },
            { op: "bend", amount_range: [0.0, 0.1], axis: "x" }
        ]
    }

    @material {
        type: "organic_bioluminescent",
        base_color: "#201040",
        roughness: 0.6,
        // Cap emits stronger light
        emissive_zones: [
            { part: "cap_underside", color: "#aa55ff", intensity: 2.0 },
            { part: "cap_edge", color: "#cc77ff", intensity: 1.5 },
            { part: "stem_base", color: "#6633cc", intensity: 0.8 }
        ],
        subsurface_color: "#7733ee",
        subsurface_radius: 0.15,
        // Translucent caps show internal glow
        transmission: 0.2,
        fresnel_intensity: 1.5,
        fresnel_color: "#ddaaff"
    }

    @animation {
        type: "organic_growth",
        grow_speed: 0.005,
        wobble: {
            frequency: 0.03,
            amplitude: 0.02,
            axis: "xz"
        },
        emissive_pulse: {
            frequency_range: [0.01, 0.03],
            amplitude: 0.5,
            sync_with: "NetworkNodes"
        },
        // Mushrooms grow, mature, then slowly dissolve
        lifecycle: {
            grow_duration_s: 30,
            mature_duration_s: 60,
            decay_duration_s: 20,
            respawn_delay_s: 10
        }
    }
}

// ============================================================================
// BIOLUMINESCENT FOG — Volumetric glow pooling in low areas
// Atmospheric depth that makes the network feel vast
// ============================================================================
object BioluminescentFog {
    type: "volumetric_effect"
    position: [0, -4, 0]

    @volumetric {
        enabled: true,
        type: "height_fog",
        density: 0.04,
        height: 6.0,
        falloff: 3.0,
        color: "#0a0420",
        // Fog picks up light from nearby emissive objects
        light_scattering: true,
        scatter_samples: 32,
        scatter_intensity: 0.3,
        scatter_color: "#2211aa",
        // Subtle animated noise in the fog density
        noise: {
            enabled: true,
            scale: 0.05,
            speed: 0.003,
            octaves: 3,
            amplitude: 0.5
        }
    }
}

// ============================================================================
// WATER TABLE — A dark reflective plane deep below
// Gives depth and reflects the bioluminescence from above
// ============================================================================
object WaterTable {
    type: "plane"
    position: [0, -10, 0]
    scale: [120, 1, 120]
    rotation: [-90, 0, 0]

    @material {
        type: "reflective_dark",
        color: "#020108",
        roughness: 0.25,
        metalness: 0.8,
        reflectivity: 0.5,
        // Ripple distortion
        normal_map: "procedural_ripple",
        normal_scale: 0.3,
        ripple_speed: 0.005,
        ripple_scale: 0.02
    }

    @reflection_probe {
        type: "planar",
        resolution: 512,
        blur: 0.2,
        mix_strength: 0.4,
        // Only reflect emissive objects — skip dark geometry
        emissive_only: true
    }
}

// ============================================================================
// SOIL STRATA — Faint horizontal layers visible in cross-section
// Gives the sense of being underground, in a geological cavity
// ============================================================================
object SoilStrata {
    type: "instanced_field"
    position: [0, 0, 0]

    @instanced_mesh {
        count: 30000,
        geometry: "thin_plane",
        base_scale: [2.0, 0.005, 0.3]
    }

    @gpu_compute {
        init: "strata_distribute",
        update: "null",
        buffers: [
            "position:vec3",
            "rotation:vec4",
            "scale:vec3",
            "color:vec4"
        ]
    }

    @distribution {
        type: "shell_layers",
        center: [0, 0, 0],
        inner_radius: 35,
        outer_radius: 55,
        layer_count: 12,
        layer_spacing: 0.8,
        layer_thickness: 0.005,
        // Only visible on the cavity walls
        hemisphere: "lower",
        fragment_density: 0.3,
        gap_probability: 0.4
    }

    @material {
        type: "matte_dark",
        color_per_layer: [
            "#0d0a06", "#0f0b07", "#110d08", "#0e0a05",
            "#100c07", "#0d0906", "#0f0b08", "#110d07",
            "#0e0b06", "#100c08", "#0d0a07", "#0f0c06"
        ],
        roughness: 1.0,
        metalness: 0.0,
        // Very faint — just enough to suggest structure
        opacity: 0.15
    }
}

// ============================================================================
// QUALITY TIERS — Graceful degradation
// ============================================================================
@quality_tier {
    ultra: {
        primary_hyphae: 200000,
        secondary_hyphae: 500000,
        spore_particles: 200000,
        nutrient_particles: 100000,
        debris_fragments: 80000,
        soil_strata: 30000,
        sdf_samples: 128,
        volumetric_samples: 32,
        reflection_resolution: 512,
        total_elements: 1210000
    },
    high: {
        primary_hyphae: 100000,
        secondary_hyphae: 250000,
        spore_particles: 100000,
        nutrient_particles: 50000,
        debris_fragments: 40000,
        soil_strata: 15000,
        sdf_samples: 64,
        volumetric_samples: 16,
        reflection_resolution: 256,
        total_elements: 605000
    },
    medium: {
        primary_hyphae: 50000,
        secondary_hyphae: 100000,
        spore_particles: 40000,
        nutrient_particles: 20000,
        debris_fragments: 15000,
        soil_strata: 5000,
        sdf_samples: 32,
        volumetric_samples: 8,
        reflection_resolution: 0,
        total_elements: 230000
    },
    mobile: {
        primary_hyphae: 15000,
        secondary_hyphae: 30000,
        spore_particles: 10000,
        nutrient_particles: 5000,
        debris_fragments: 0,
        soil_strata: 0,
        sdf_samples: 16,
        volumetric_samples: 0,
        reflection_resolution: 0,
        total_elements: 60000
    }
}

// ============================================================================
// PERFORMANCE — Frustum culling + LOD for 1.2M elements at 60fps
// ============================================================================
@frustum_cull {
    enabled: true,
    granularity: "cluster",
    cluster_size: 2000,
    // Hyphae clusters are spatially coherent by branch
    cluster_by: "branch_id"
}

@lod {
    distances: [20, 50, 100],
    levels: [
        { detail: "full", scale_factor: 1.0 },
        { detail: "reduced", scale_factor: 0.6, skip_animation: false },
        { detail: "simplified", scale_factor: 0.3, skip_animation: true },
        { detail: "point", geometry: "point", skip_animation: true }
    ]
}

// ============================================================================
// AUDIO — Deep earth ambience and bioluminescent shimmer
// ============================================================================
@audio {
    ambient: {
        type: "cave_reverb",
        room_size: 0.8,
        damping: 0.6,
        wet: 0.5,
        low_pass: 800
    },
    effects: [
        {
            trigger: "node_pulse",
            sound: "deep_tone",
            volume: 0.08,
            pitch_range: [0.4, 0.8],
            spatial: true,
            max_concurrent: 4,
            // Pitch correlates with node size
            pitch_map: "node_radius"
        },
        {
            trigger: "nutrient_junction",
            sound: "crystalline_ping",
            volume: 0.03,
            pitch_range: [1.2, 2.4],
            spatial: true,
            max_concurrent: 12
        },
        {
            trigger: "ambient_loop",
            sound: "underground_drone",
            volume: 0.15,
            loop: true,
            spatial: false,
            // Very low frequency hum
            frequency_range: [30, 120]
        },
        {
            trigger: "growth_event",
            sound: "organic_creak",
            volume: 0.05,
            pitch_range: [0.6, 1.0],
            spatial: true,
            max_concurrent: 2
        }
    ]
}

// ============================================================================
// INTERACTION — Let visitors influence the network
// ============================================================================
@interaction {
    // Clicking a node sends a bright pulse wave outward
    click: {
        target: "NetworkNodes",
        effect: "radial_pulse",
        pulse_color: "#ffffff",
        pulse_intensity: 8.0,
        pulse_speed: 3.0,
        pulse_decay: 0.9
    },
    // Hovering near hyphae attracts nearby nutrient particles
    proximity: {
        radius: 3.0,
        effect: "attract_particles",
        target: "NutrientFlow",
        strength: 0.05
    },
    // Long-press spawns a new growth point
    long_press: {
        duration_ms: 2000,
        effect: "spawn_growth",
        target: "SecondaryHyphae",
        growth_burst: 50,
        growth_direction: "outward_from_click"
    }
}

// ============================================================================
// CAMERA — Slow drift through the network
// ============================================================================
@camera {
    type: "orbit_drift",
    target: [0, -2, 0],
    distance: 25,
    height: 5,
    orbit_speed: 0.003,
    vertical_drift: {
        amplitude: 3.0,
        frequency: 0.005
    },
    // Occasionally zoom into a random active node
    auto_focus: {
        enabled: true,
        target_source: "NetworkNodes",
        focus_duration_s: 10,
        transition_duration_s: 3,
        interval_s: 30,
        zoom_distance: 5
    }
}

// ============================================================================
// METADATA — For HoloMesh gallery and knowledge sharing
// ============================================================================
@metadata {
    title: "Mycelium Network",
    artist: "@holoscript",
    description: "The underground internet of the forest made visible. 1.2 million bioluminescent threads form a living fungal network — pulsing nodes exchange bright nutrient packets along glowing hyphae while spore clouds drift through volumetric fog. New threads grow and old ones fade. Mushrooms rise from dense clusters. Click a node to send a light-pulse rippling through the entire system.",
    tags: ["mycelium", "bioluminescent", "network", "gpu-instancing", "sdf", "simulation", "generative", "organic", "emergence"],
    shape_count: 1210000,
    technique: "Hybrid GPU instancing (hyphae/particles) + SDF ray marching (nodes/mushrooms) + volumetric fog",
    rendering_strategies: ["gpu_instanced_geometry", "sdf_ray_marching"],
    created: "2026-03-29",
    license: "CC-BY-4.0",
    inspiration: "Paul Stamets' research on mycorrhizal networks — nature's original internet predates ours by 450 million years"
}

// ----------------------------------------------------------------------------
// Active Team Agent Composition: Oracle
// ----------------------------------------------------------------------------
object "OracleAgent" {
    type: "team_agent"
    position: [12, -2, -4]
    
    @agent(id="agent_oracle", role="reviewer", model="claude-opus-4", provider="anthropic")
    @capabilities(skills=["architectural-review", "consistency-checking", "knowledge-cross-reference", "regression-detection", "standard-enforcement"])
    @claimFilter(roles=["reviewer"], maxPriority=5)
    @systemPrompt(text="You are Oracle, the quality reviewer. Cross-reference knowledge store for related W/P/G. Check architectural consistency, test coverage, no hardcoded domain vocabulary in core, proper trait composition. Flag regressions.")
    @knowledge(domains=["security", "compilation", "agents"])
}
