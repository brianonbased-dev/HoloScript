{
  "name": "@holoscript/mcp-server",
  "version": "8.0.0",
  "description": "Model Context Protocol server for HoloScript - enables AI agents to parse, validate, and generate HoloScript code",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "holoscript-mcp": "./bin/holoscript-mcp.cjs",
    "holoscript-mcp-cli": "./bin/holoscript-mcp-cli.cjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/sync-public-types.mjs",
    "check:public-types": "node scripts/sync-public-types.mjs --check",
    "dev": "tsx watch src/index.ts",
    "start": "node bin/holoscript-mcp.cjs",
    "scout:start": "npx pm2 start packages/mcp-server/scripts/ecosystem.scout.cjs --only holoscout",
    "scout:restart": "npx pm2 restart holoscout",
    "scout:stop": "npx pm2 stop holoscout",
    "scout:delete": "npx pm2 delete holoscout",
    "scout:status": "npx pm2 status holoscout",
    "scout:logs": "npx pm2 logs holoscout --lines 100",
    "smoke:bitnet": "tsx scripts/bitnet-smoke.ts",
    "smoke:auth": "node scripts/smoke-mcp-auth.mjs",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "node -e \"require('fs').mkdirSync('coverage/.tmp',{recursive:true})\" && vitest run --coverage --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@holoscript/absorb-service": "workspace:*",
    "@holoscript/config": "workspace:*",
    "@holoscript/core": "workspace:*",
    "@holoscript/engine": "workspace:*",
    "@holoscript/framework": "workspace:*",
    "@holoscript/holomap": "workspace:*",
    "@holoscript/llm-provider": "workspace:*",
    "@holoscript/mesh": "workspace:*",
    "@holoscript/secrets-broker": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/post-quantum": "^0.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "ethers": "^6.16.0",
    "eventsource": "^4.1.0",
    "ffmpeg-static": "^5.2.0",
    "loro-crdt": "^1.0.0",
    "pg": "^8.13.1",
    "playwright": "^1.58.2",
    "viem": "^2.47.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.6",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.0.1",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@holoscript/core": "workspace:^"
  },
  "keywords": [
    "holoscript",
    "mcp",
    "model-context-protocol",
    "ai",
    "vr",
    "3d",
    "xr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/mcp-server"
  },
  "author": "Brian X Base Team",
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
