{
  "name": "@holoscript/mcp-server",
  "version": "3.6.1",
  "description": "Model Context Protocol server for HoloScript - enables AI agents to parse, validate, and generate HoloScript code",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "holoscript-mcp": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@holoscript/core": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright": "^1.58.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@holoscript/core": "3.42.0"
  },
  "keywords": [
    "holoscript",
    "mcp",
    "model-context-protocol",
    "ai",
    "vr",
    "3d",
    "xr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianonbased-dev/Holoscript.git",
    "directory": "packages/mcp-server"
  },
  "author": "Brian X Base Team"
}
