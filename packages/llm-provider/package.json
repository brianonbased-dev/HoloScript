{
  "name": "@holoscript/llm-provider",
  "version": "1.2.0",
  "description": "Unified LLM provider SDK for HoloScript - OpenAI, Anthropic, Gemini, OpenRouter, xAI, and local LLM adapters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/bitnet": {
      "types": "./dist/adapters/bitnet.d.ts",
      "import": "./dist/adapters/bitnet.js",
      "require": "./dist/adapters/bitnet.cjs"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.js",
      "require": "./dist/adapters/openai.cjs"
    },
    "./adapters/anthropic": {
      "types": "./dist/adapters/anthropic.d.ts",
      "import": "./dist/adapters/anthropic.js",
      "require": "./dist/adapters/anthropic.cjs"
    },
    "./adapters/gemini": {
      "types": "./dist/adapters/gemini.d.ts",
      "import": "./dist/adapters/gemini.js",
      "require": "./dist/adapters/gemini.cjs"
    },
    "./adapters/openrouter": {
      "types": "./dist/adapters/openrouter.d.ts",
      "import": "./dist/adapters/openrouter.js",
      "require": "./dist/adapters/openrouter.cjs"
    },
    "./adapters/xai": {
      "types": "./dist/adapters/xai.d.ts",
      "import": "./dist/adapters/xai.js",
      "require": "./dist/adapters/xai.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --declaration --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "openai": "^6.32.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "keywords": [
    "holoscript",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "openrouter",
    "xai",
    "grok",
    "vr",
    "ar",
    "ai",
    "spatial-computing"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/llm-provider"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
