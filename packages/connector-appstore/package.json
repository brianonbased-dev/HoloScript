{
  "name": "@holoscript/connector-appstore",
  "version": "1.0.0",
  "description": "Dual-platform App Store connector for HoloScript - Apple App Store Connect and Google Play Developer API integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "app-store",
    "google-play",
    "apple",
    "testflight",
    "mcp",
    "connector",
    "ci-cd",
    "deployment"
  ],
  "dependencies": {
    "@holoscript/connector-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "form-data": "^4.0.0",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.10.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  },
  "author": "Brian X Base Team",
  "license": "MIT"
}
