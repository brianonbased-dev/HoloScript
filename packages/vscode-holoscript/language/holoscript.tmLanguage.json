{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HoloScript",
  "scopeName": "source.holoscript",
  "fileTypes": ["holo", "holoscript", "hs+"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#traits" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#vectors" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.holoscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.holoscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.holoscript",
          "match": "\\b(scene|object|let|const|if|else|for|while|return|import|export|from|extends|implements|interface|type|enum|class|new|this|super)\\b"
        },
        {
          "name": "keyword.other.holoscript",
          "match": "\\b(true|false|null|undefined|async|await|yield)\\b"
        },
        {
          "name": "storage.type.holoscript",
          "match": "\\b(string|number|boolean|vec2|vec3|vec4|color|asset|fn|void)\\b"
        }
      ]
    },
    "traits": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.holoscript",
          "match": "@(\\w+)(?=\\(|\\s)",
          "captures": {
            "1": { "name": "support.function.trait.holoscript" }
          }
        },
        {
          "name": "meta.trait.holoscript",
          "begin": "@(\\w+)\\(",
          "beginCaptures": {
            "1": { "name": "support.function.trait.holoscript" }
          },
          "end": "\\)",
          "patterns": [
            {
              "name": "entity.other.attribute-name.holoscript",
              "match": "(\\w+)\\s*:"
            },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#vectors" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.holoscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.holoscript", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.holoscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.holoscript", "match": "\\\\." }
          ]
        },
        {
          "name": "string.template.holoscript",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.embedded.holoscript",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.holoscript",
          "match": "\\b-?\\d+\\.?\\d*([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.other.color.holoscript",
          "match": "#[0-9a-fA-F]{3,8}\\b"
        }
      ]
    },
    "vectors": {
      "patterns": [
        {
          "name": "meta.vector.holoscript",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [{ "include": "#numbers" }]
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.holoscript",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
