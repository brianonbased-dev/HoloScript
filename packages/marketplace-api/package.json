{
  "name": "@holoscript/marketplace-api",
  "version": "1.2.3",
  "description": "HoloScript Trait Marketplace API - publishing, discovery, and dependency resolution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@holoscript/auth": "workspace:*",
    "@holoscript/core": "workspace:*",
    "@holoscript/framework": "workspace:*",
    "@holoscript/registry": "workspace:*",
    "@holoscript/marketplace-agentkit": "workspace:*",
    "@zoralabs/protocol-deployments": "^0.7.5",
    "@zoralabs/protocol-sdk": "^0.13.18",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.13.1",
    "rate-limiter-flexible": "^9.1.1",
    "redis": "^4.6.12",
    "semver": "^7.7.4",
    "viem": "^2.47.1",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.6",
    "@types/semver": "^7.5.6",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "holoscript",
    "marketplace",
    "traits",
    "registry",
    "api"
  ],
  "author": "HoloScript Team",
  "license": "MIT",
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
