{
  "name": "@holoscript/marketplace-api",
  "version": "1.2.1",
  "description": "HoloScript Trait Marketplace API - publishing, discovery, and dependency resolution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@holoscript/auth": "workspace:*",
    "@holoscript/core": "workspace:*",
    "@holoscript/registry": "workspace:*",
    "@coinbase/agentkit": "^0.10.4",
    "@zoralabs/protocol-deployments": "^0.7.2",
    "@zoralabs/protocol-sdk": "^0.13.18",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "rate-limiter-flexible": "^9.1.1",
    "redis": "^4.6.12",
    "semver": "^7.7.4",
    "viem": "^2.21.0",
    "winston": "^3.11.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.0",
    "@types/semver": "^7.5.6",
    "tsx": "^4.7.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "holoscript",
    "marketplace",
    "traits",
    "registry",
    "api"
  ],
  "author": "HoloScript Team",
  "license": "MIT",
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
