{
  "id": "winery",
  "name": "Winery & Viticulture",
  "industry": "wine",
  "description": "Full vertical for wine operations: tasting room storefront, vineyard management, fermentation tracking, TTB compliance, soil science, and varietal genetics.",
  "tags": ["wine", "winery", "vineyard", "viticulture", "tasting"],
  "theme": {
    "primary": "#722f37",
    "secondary": "#faf0e6",
    "accent": "#c9a96e",
    "shelf_material": "wood_oak",
    "card_style": "elegant"
  },
  "modules": [
    {
      "id": "wine-retail",
      "type": "retail",
      "keywords": [
        { "term": "varietal", "traits": ["@label", "@filterable", "@tag"], "spatialRole": "category" },
        { "term": "vintage", "traits": ["@label", "@tag"], "spatialRole": "category" },
        { "term": "appellation", "traits": ["@tag", "@filterable"], "spatialRole": "category" },
        { "term": "tasting_notes", "traits": ["@info_popup", "@readable"], "spatialRole": "description" },
        { "term": "abv", "traits": ["@gauge", "@label"], "spatialRole": "metric" },
        { "term": "score", "traits": ["@gauge", "@label", "@badge"], "spatialRole": "metric" },
        { "term": "pairing", "traits": ["@info_popup", "@tag"], "spatialRole": "description" },
        { "term": "bottle", "traits": ["@texture", "@billboard"], "spatialRole": "media" },
        { "term": "reserve", "traits": ["@tag", "@badge"], "spatialRole": "boolean_state" },
        { "term": "estate", "traits": ["@tag", "@filterable"], "spatialRole": "category" }
      ],
      "properties": [
        { "fieldName": "varietal", "label": "Varietal", "type": "enum", "enumValues": ["cabernet_sauvignon", "pinot_noir", "chardonnay", "merlot", "sauvignon_blanc", "zinfandel", "syrah", "riesling"], "displayAs": "tag" },
        { "fieldName": "vintage", "label": "Vintage", "type": "number", "range": [1990, 2026], "displayAs": "label" },
        { "fieldName": "abv", "label": "ABV %", "type": "number", "range": [8, 18], "unit": "%", "displayAs": "gauge" },
        { "fieldName": "price", "label": "Price", "type": "number", "unit": "$", "displayAs": "label" },
        { "fieldName": "critic_score", "label": "Score", "type": "number", "range": [70, 100], "displayAs": "gauge" }
      ]
    },
    {
      "id": "wine-agriculture",
      "type": "agriculture",
      "keywords": [
        { "term": "terroir", "traits": ["@tag", "@info_popup", "@spatial_anchor"], "spatialRole": "geospatial" },
        { "term": "rootstock", "traits": ["@lineage", "@tag"], "spatialRole": "relationship" },
        { "term": "canopy", "traits": ["@gauge", "@heatmap_3d"], "spatialRole": "metric" },
        { "term": "veraison", "traits": ["@lifecycle", "@alert"], "spatialRole": "timestamp" },
        { "term": "pruning", "traits": ["@lifecycle"], "spatialRole": "timestamp" },
        { "term": "block", "traits": ["@spatial_anchor", "@tag"], "spatialRole": "geospatial", "description": "Vineyard block/section" }
      ],
      "stages": [
        {
          "id": "dormancy", "name": "Dormancy", "durationDays": 120,
          "thresholds": [
            { "sensor": "temperature", "name": "Dormancy Temp", "target": 40, "range": [25, 55], "unit": "°F", "severity": "info" }
          ]
        },
        {
          "id": "budbreak", "name": "Bud Break", "durationDays": 21,
          "thresholds": [
            { "sensor": "temperature", "name": "Budbreak Temp", "target": 55, "range": [45, 65], "unit": "°F", "severity": "warning" },
            { "sensor": "humidity", "name": "Budbreak RH", "target": 60, "range": [50, 75], "unit": "%", "severity": "info" }
          ]
        },
        {
          "id": "flowering", "name": "Flowering", "durationDays": 14,
          "thresholds": [
            { "sensor": "temperature", "name": "Flowering Temp", "target": 68, "range": [60, 78], "unit": "°F", "severity": "critical" }
          ]
        },
        {
          "id": "veraison", "name": "Veraison", "durationDays": 28,
          "thresholds": [
            { "sensor": "temperature", "name": "Veraison Temp", "target": 75, "range": [65, 90], "unit": "°F", "severity": "warning" }
          ]
        },
        {
          "id": "harvest", "name": "Harvest", "durationDays": 21,
          "thresholds": [
            { "sensor": "temperature", "name": "Harvest Temp", "target": 70, "range": [55, 85], "unit": "°F", "severity": "critical" }
          ]
        }
      ],
      "recommendedBehaviorTrees": ["sensor-threshold-monitor", "scheduled-process"]
    },
    {
      "id": "wine-manufacturing",
      "type": "manufacturing",
      "keywords": [
        { "term": "fermentation", "traits": ["@lifecycle", "@gauge", "@telemetry"], "spatialRole": "metric" },
        { "term": "brix", "traits": ["@gauge", "@alert"], "spatialRole": "metric" },
        { "term": "ph", "traits": ["@gauge", "@alert"], "spatialRole": "metric" },
        { "term": "sulfites", "traits": ["@gauge", "@label"], "spatialRole": "metric" },
        { "term": "barrel", "traits": ["@tag", "@spatial_anchor", "@digital_twin"], "spatialRole": "identity" },
        { "term": "bottling", "traits": ["@lifecycle", "@tag"], "spatialRole": "timestamp" },
        { "term": "aging", "traits": ["@lifecycle", "@gauge"], "spatialRole": "metric" },
        { "term": "racking", "traits": ["@lifecycle"], "spatialRole": "timestamp" }
      ],
      "stages": [
        { "id": "crush", "name": "Crush", "durationDays": 3, "thresholds": [
          { "sensor": "temperature", "name": "Crush Temp", "target": 60, "range": [50, 70], "unit": "°F", "severity": "warning" }
        ]},
        { "id": "primary_fermentation", "name": "Primary Fermentation", "durationDays": 14, "thresholds": [
          { "sensor": "temperature", "name": "Ferm Temp", "target": 72, "range": [60, 85], "unit": "°F", "severity": "critical" }
        ]},
        { "id": "aging", "name": "Barrel Aging", "durationDays": 365, "thresholds": [
          { "sensor": "temperature", "name": "Cellar Temp", "target": 55, "range": [50, 60], "unit": "°F", "severity": "warning" },
          { "sensor": "humidity", "name": "Cellar RH", "target": 70, "range": [60, 80], "unit": "%", "severity": "warning" }
        ]}
      ]
    },
    {
      "id": "wine-compliance",
      "type": "compliance",
      "keywords": [
        { "term": "ttb", "traits": ["@tag", "@audit_trail"], "description": "Alcohol and Tobacco Tax and Trade Bureau" },
        { "term": "ava", "traits": ["@tag", "@label"], "spatialRole": "category", "description": "American Viticultural Area" },
        { "term": "lot_number", "traits": ["@tag", "@label"], "spatialRole": "identity" }
      ],
      "rules": [
        { "id": "ttb-reporting", "name": "TTB Reporting", "requires": ["production_volume", "tax_class", "appellation"], "authority": "TTB", "mandatory": true },
        { "id": "label-approval", "name": "Label Approval (COLA)", "requires": ["brand_name", "class_type", "appellation", "abv", "net_contents"], "authority": "TTB", "mandatory": true },
        { "id": "sulfite-declaration", "name": "Sulfite Declaration", "requires": ["sulfite_level"], "authority": "FDA", "mandatory": true }
      ]
    },
    {
      "id": "wine-genetics",
      "type": "genetics",
      "keywords": [
        { "term": "clone", "traits": ["@tag", "@lineage"], "spatialRole": "category", "description": "Clonal selection of a grape varietal" },
        { "term": "rootstock", "traits": ["@lineage", "@tag"], "spatialRole": "relationship" },
        { "term": "cross", "traits": ["@lineage"], "spatialRole": "relationship" }
      ],
      "compositionRules": [
        { "property": "acidity", "mergeStrategy": "blend", "canConflict": false },
        { "property": "tannin", "mergeStrategy": "blend", "canConflict": false },
        { "property": "sugar_content", "mergeStrategy": "average", "canConflict": false },
        { "property": "disease_resistance", "mergeStrategy": "max", "canConflict": false },
        { "property": "growth_habit", "mergeStrategy": "dominant", "canConflict": true },
        { "property": "ripening_period", "mergeStrategy": "average", "canConflict": false }
      ]
    }
  ]
}
