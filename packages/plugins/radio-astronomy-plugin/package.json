{
  "name": "@holoscript/radio-astronomy-plugin",
  "version": "2.0.0",
  "description": "Radio Astrophysics plugin for HoloScript spatial environments. Adds primitives for interferometers, pulsar analysis, and synchrotron emissions.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "holoscript",
    "plugin",
    "astrophysics",
    "radio-astronomy",
    "science"
  ],
  "author": "brianonbased-dev",
  "license": "MIT",
  "dependencies": {
    "@holoscript/engine": "workspace:*"
  },
  "peerDependencies": {
    "@holoscript/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
