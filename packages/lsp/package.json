{
  "name": "@holoscript/lsp",
  "version": "6.0.3",
  "description": "Language Server Protocol implementation for HoloScript",
  "main": "dist/server.js",
  "bin": {
    "holoscript-lsp": "./dist/server.js"
  },
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationDir dist --skipLibCheck",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "holoscript",
    "lsp",
    "language-server",
    "hololand"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/lsp"
  },
  "dependencies": {
    "@holoscript/core": "workspace:*",
    "@holoscript/linter": "workspace:*",
    "tree-sitter": "^0.22.4",
    "tree-sitter-holoscript": "workspace:*",
    "vscode-debugadapter": "^1.51.0",
    "vscode-debugprotocol": "^1.51.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/brianonbased-dev/HoloScript#readme",
  "bugs": {
    "url": "https://github.com/brianonbased-dev/HoloScript/issues"
  }
}
