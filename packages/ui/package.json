    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.2",
    "typescript": "~5.9.3",
    "tailwindcss": "^3.4.1",
