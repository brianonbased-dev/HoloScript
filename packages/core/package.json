{
  "name": "@holoscript/core",
  "version": "6.1.0",
  "description": "Core parser, AST, compiler infrastructure, trait system, and runtime for HoloScript â€” the open AI-spatial reality protocol for 3D/XR/IoT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./src/traits/visual/index.ts",
    "./dist/traits/index.js"
  ],
  "files": [
    "bin",
    "dist",
    "!dist/**/*.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./math/vec3": {
      "import": "./dist/math/vec3.js",
      "require": "./dist/math/vec3.cjs"
    },
    "./math/vec3.js": {
      "import": "./dist/math/vec3.js",
      "require": "./dist/math/vec3.cjs"
    },
    "./math/tropical-spmv": {
      "types": "./dist/math/tropical-spmv.d.ts",
      "import": "./dist/math/tropical-spmv.js",
      "require": "./dist/math/tropical-spmv.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
