      "types": "./dist/self-improvement/index.d.ts",
      "import": "./dist/self-improvement/index.js",
      "require": "./dist/self-improvement/index.cjs"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js",
      "require": "./dist/compiler/index.cjs"
    },
    "./compiler/index": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js",
      "require": "./dist/compiler/index.cjs"
    },
    "./compiler/*": {
      "types": "./dist/compiler/*.d.ts",
      "import": "./dist/compiler/*.js",
      "require": "./dist/compiler/*.cjs"
    },
    "./trait-docs": {
      "types": "./dist/traitDocs/traitDocs.d.ts",
      "import": "./dist/traitDocs/traitDocs.js",
      "require": "./dist/traitDocs/traitDocs.cjs"
    },
    "./traits": {
      "types": "./dist/traits/index.d.ts",
      "import": "./dist/traits/index.js"
    },
    "./traits/webcam-gaze": {
      "types": "./dist/traits/webcam-gaze.d.ts",
      "import": "./dist/traits/webcam-gaze.js",
      "require": "./dist/traits/webcam-gaze.cjs"
    },
    "./traits/botanical-lotus": {
      "types": "./dist/traits/botanical-lotus.d.ts",
      "import": "./dist/traits/botanical-lotus.js"
    },
    "./traits/simulation-solver-factory": {
      "types": "./dist/traits/simulation-solver-factory.d.ts",
      "import": "./dist/traits/simulation-solver-factory.js"
    },
    "./traits/engines": {
      "types": "./dist/traits/engines/index.d.ts",
      "import": "./dist/traits/engines/index.js"
    },
    "./coordinators": {
      "types": "./dist/coordinators/index.d.ts",
      "import": "./dist/coordinators/index.js"
