{
  "name": "@holoscript/core",
  "version": "5.1.0",
  "description": "HoloScript+: VR language with declarative syntax, state management, reactive traits, and VR interactions. Full backward compatible with original HoloScript.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./type-checker": {
      "types": "./dist/type-checker.d.ts",
      "import": "./dist/type-checker.js",
      "require": "./dist/type-checker.cjs"
    },
    "./debugger": {
      "types": "./dist/debugger.d.ts",
      "import": "./dist/debugger.js",
      "require": "./dist/debugger.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./wot": {
      "types": "./dist/wot/index.d.ts",
      "import": "./dist/wot/index.js",
      "require": "./dist/wot/index.cjs"
    },
    "./codebase": {
      "types": "./dist/codebase/index.d.ts",
      "import": "./dist/codebase/index.js",
      "require": "./dist/codebase/index.cjs"
    },
    "./self-improvement": {
      "types": "./dist/self-improvement/index.d.ts",
      "import": "./dist/self-improvement/index.js",
      "require": "./dist/self-improvement/index.cjs"
    },
    "./compiler/*": {
      "types": "./dist/compiler/*.d.ts",
      "import": "./dist/compiler/*.js",
      "require": "./dist/compiler/*.cjs"
    },
    "./traits": {
      "types": "./dist/traits/index.d.ts",
      "import": "./dist/traits/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./scripting": {
      "types": "./dist/entries/scripting.d.ts",
      "import": "./dist/entries/scripting.js",
      "require": "./dist/entries/scripting.cjs"
    },
    "./interop": {
      "types": "./dist/entries/interop.d.ts",
      "import": "./dist/entries/interop.js",
      "require": "./dist/entries/interop.cjs"
    }
  },
  "bin": {
    "holoscript": "./dist/cli/holoscript-runner.js"
  },
  "scripts": {
    "build": "tsup && node scripts/generate-types.mjs",
    "dev": "tsup --watch",
    "test": "node --max-old-space-size=16384 run-vitest.mjs",
    "test:coverage": "node --max-old-space-size=16384 run-vitest.mjs --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "vr",
    "virtual-reality",
    "parser",
    "ast",
    "runtime",
    "spatial-programming",
    "voice-commands",
    "gesture-control"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/core"
  },
  "dependencies": {
    "@gltf-transform/core": "^3.7.0",
    "@gltf-transform/extensions": "^3.7.0",
    "@gltf-transform/functions": "^3.7.0",
    "@holoscript/crdt": "workspace:*",
    "@zoralabs/protocol-deployments": "^0.7.2",
    "basis_universal": "^1.0.0",
    "draco3d": "^1.5.6",
    "ipfs-http-client": "^60.0.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "three": "^0.182.0",
    "viem": "^2.47.1",
    "ws": "^8.16.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@noble/post-quantum": "^0.5.4",
    "tree-sitter": "0.21.1",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.24.0"
  },
  "peerDependencies": {
    "@pixiv/three-vrm": "^2.0.0",
    "ioredis": "^5.3.0",
    "puppeteer": "^23.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@pixiv/three-vrm": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.170.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.18",
    "@webgpu/types": "^0.1.40",
    "tsup": "^8.0.1",
    "typedoc": "^0.28.16",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
