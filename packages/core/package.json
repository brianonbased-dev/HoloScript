{
  "name": "@holoscript/core",
  "version": "3.42.0",
  "description": "HoloScript+: VR language with declarative syntax, state management, reactive traits, and VR interactions. Full backward compatible with original HoloScript.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js",
      "require": "./dist/parser.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.js"
    },
    "./type-checker": {
      "types": "./dist/type-checker.d.ts",
      "import": "./dist/type-checker.js",
      "require": "./dist/type-checker.js"
    },
    "./debugger": {
      "types": "./dist/debugger.d.ts",
      "import": "./dist/debugger.js",
      "require": "./dist/debugger.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.js"
    },
    "./wot": {
      "types": "./dist/wot/index.d.ts",
      "import": "./dist/wot/index.js",
      "require": "./dist/wot/index.js"
    },
    "./compiler/*": {
      "types": "./dist/compiler/*.d.ts",
      "import": "./dist/compiler/*.js",
      "require": "./dist/compiler/*.js"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/generate-types.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "holoscript",
    "vr",
    "virtual-reality",
    "parser",
    "ast",
    "runtime",
    "spatial-programming",
    "voice-commands",
    "gesture-control"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/Holoscript.git",
    "directory": "packages/core"
  },
  "dependencies": {
    "@gltf-transform/core": "^3.7.0",
    "@gltf-transform/extensions": "^3.7.0",
    "@gltf-transform/functions": "^3.7.0",
    "@zoralabs/protocol-deployments": "^0.7.2",
    "basis_universal": "^1.0.0",
    "draco3d": "^1.5.6",
    "ipfs-http-client": "^60.0.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "three": "^0.182.0",
    "viem": "^2.45.3",
    "ws": "^8.16.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@pixiv/three-vrm": "^2.0.0",
    "ioredis": "^5.3.0",
    "puppeteer": "^23.0.0"
  },
  "peerDependenciesMeta": {
    "@pixiv/three-vrm": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.170.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.18",
    "@webgpu/types": "^0.1.40",
    "tsup": "^8.0.1",
    "typedoc": "^0.28.16",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
