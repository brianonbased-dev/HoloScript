      "require": "./dist/type-checker.cjs"
    },
    "./debugger": {
      "types": "./dist/debugger.d.ts",
      "import": "./dist/debugger.js",
      "require": "./dist/debugger.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./codebase": {
      "types": "./dist/codebase/index.d.ts",
      "import": "./dist/codebase/index.js",
      "require": "./dist/codebase/index.cjs"
    },
    "./world": {
      "types": "./dist/world/index.d.ts",
      "import": "./dist/world/index.js",
      "require": "./dist/world/index.cjs"
    },
    "./world-model": {
      "types": "./dist/world-model/index.d.ts",
      "import": "./dist/world-model/index.js",
      "require": "./dist/world-model/index.cjs"
    },
