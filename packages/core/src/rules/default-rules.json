{
  "version": "1.0.0",
  "description": "Default trait composition rules for the top 200 most-used traits",
  "rules": [
    {
      "id": "conflict-static-physics",
      "type": "conflict",
      "traits": ["static", "physics"],
      "description": "Static objects cannot have dynamic physics simulation",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "error",
      "replacement": "Use @kinematic for controlled physics"
    },
    {
      "id": "conflict-invisible-glowing",
      "type": "conflict",
      "traits": ["invisible", "glowing"],
      "description": "Invisible objects should not emit light via @glowing",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "warning"
    },
    {
      "id": "conflict-static-grabbable",
      "type": "conflict",
      "traits": ["static", "grabbable"],
      "description": "Static objects cannot be grabbed (they have no physics body)",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "error",
      "replacement": "Use @kinematic + @grabbable instead"
    },
    {
      "id": "conflict-vr-only-ar-only",
      "type": "conflict",
      "traits": ["vr_only", "ar_only"],
      "description": "Object cannot be both VR-only and AR-only",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "error"
    },
    {
      "id": "conflict-vr-only-desktop-only",
      "type": "conflict",
      "traits": ["vr_only", "desktop_only"],
      "description": "Object cannot be both VR-only and desktop-only",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "error"
    },
    {
      "id": "conflict-frozen-boiling",
      "type": "conflict",
      "traits": ["frozen_liquid", "boiling"],
      "description": "A fluid cannot be both frozen and boiling simultaneously",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "error"
    },
    {
      "id": "conflict-predator-prey-self",
      "type": "conflict",
      "traits": ["predator", "prey"],
      "description": "An entity should not be both predator and prey",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "warning"
    },
    {
      "id": "conflict-hostile-friendly",
      "type": "conflict",
      "traits": ["hostile", "friendly"],
      "description": "An NPC cannot be both hostile and friendly simultaneously",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "warning",
      "replacement": "Use @neutral or faction-based behavior"
    },
    {
      "id": "conflict-cloaking-glowing",
      "type": "conflict",
      "traits": ["cloaking", "glowing"],
      "description": "A cloaked object should not emit visible glow",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "warning"
    },
    {
      "id": "conflict-zero-gravity-buoyancy",
      "type": "conflict",
      "traits": ["zero_gravity", "buoyancy"],
      "description": "Buoyancy requires gravity to function",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "warning"
    },
    {
      "id": "expansion-networked-serializable",
      "type": "expansion",
      "traits": ["networked"],
      "description": "Networked objects must be serializable for state sync",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "info",
      "implies": ["synced"]
    },
    {
      "id": "expansion-grabbable-physics",
      "type": "expansion",
      "traits": ["grabbable"],
      "description": "Grabbable objects need a physics body for hand interaction",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "info",
      "implies": ["physics"]
    },
    {
      "id": "expansion-throwable-physics",
      "type": "expansion",
      "traits": ["throwable"],
      "description": "Throwable objects need a physics body for trajectory simulation",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "info",
      "implies": ["physics"]
    },
    {
      "id": "expansion-lip-sync-voice",
      "type": "expansion",
      "traits": ["lip_sync"],
      "description": "Lip sync requires voice/TTS to drive mouth animation",
      "commutative": true,
      "ruleVersion": "1.0.0",
      "severity": "info",
      "implies": ["voice"]
    },
    {
      "id": "expansion-voice-proximity-networked",
