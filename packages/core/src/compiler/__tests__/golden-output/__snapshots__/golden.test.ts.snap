"// Auto-generated by HoloScript BabylonCompiler
// Source: composition "GoldenScene"

import * as BABYLON from "@babylonjs/core";
import HavokPhysics from "@babylonjs/havok";

export class GeneratedScene {
  private engine: BABYLON.Engine;
  private scene: BABYLON.Scene;
  private canvas: HTMLCanvasElement;
  
  constructor(canvas: HTMLCanvasElement) {
    this.canvas = canvas;
    this.engine = new BABYLON.Engine(canvas, true, { preserveDrawingBuffer: true, stencil: true });
    this.scene = new BABYLON.Scene(this.engine);
  }
  
  async build(): Promise<void> {
    this.scene.clearColor = new BABYLON.Color4(0.05, 0.05, 0.1, 1);
    const havokInstance = await HavokPhysics();
    const havokPlugin = new BABYLON.HavokPlugin(true, havokInstance);
    this.scene.enablePhysics(new BABYLON.Vector3(0, -9.81, 0), havokPlugin);
    
    const defaultLight = new BABYLON.HemisphericLight("defaultLight", new BABYLON.Vector3(0, 1, 0), this.scene);
    defaultLight.intensity = 0.7;
    
    const camera = new BABYLON.ArcRotateCamera("defaultCamera", -Math.PI / 2, Math.PI / 3, 10, BABYLON.Vector3.Zero(), this.scene);
    camera.attachControl(this.canvas, true);
    
    // Object: hero
    const hero = BABYLON.MeshBuilder.CreateBox("hero", { size: 1 }, this.scene);
    const heroMat = new BABYLON.PBRMaterial("heroMat", this.scene);
    heroMat.albedoColor = new BABYLON.Color3(0.000, 1.000, 0.800);
    hero.material = heroMat;
    hero.position = new BABYLON.Vector3(0, 1.6, 0);
    // @@grabbable: {}
    // @@collidable: {}
    // @@networked: {}
    
    // Object: platform
    const platform = BABYLON.MeshBuilder.CreateBox("platform", { size: 1 }, this.scene);
    platform.position = new BABYLON.Vector3(0, 0, 0);
    platform.scaling = new BABYLON.Vector3(5, 0.1, 5);
    // @@collidable: {}
    // @@physics: {}
    
    // Object: collectible
    const collectible = BABYLON.MeshBuilder.CreateSphere("collectible", { diameter: 1, segments: 32 }, this.scene);
    const collectibleMat = new BABYLON.PBRMaterial("collectibleMat", this.scene);
    collectibleMat.albedoColor = new BABYLON.Color3(1.000, 0.800, 0.000);
    collectible.material = collectibleMat;
    collectible.position = new BABYLON.Vector3(2, 1, -3);
    // @@grabbable: {}
    // @@glowing: {}
    
    this.engine.runRenderLoop(() => { this.scene.render(); });
    window.addEventListener("resize", () => { this.engine.resize(); });
  }
  
  dispose(): void { this.scene.dispose(); this.engine.dispose(); }
}"
`;

