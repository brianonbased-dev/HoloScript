"(module
  ;; Imports from host
  (import "env" "log_i32" (func $log_i32 (param i32)))
  (import "env" "log_f32" (func $log_f32 (param f32)))
  (import "env" "log_str" (func $log_str (param i32 i32)))
  (import "env" "emit_event" (func $emit_event (param i32 i32)))
  (import "env" "get_time" (func $get_time (result f64)))
  
  ;; Memory: 16 pages (1024KB)
  (memory (export "memory") 16)
  
  ;; Globals
  (global $frame_count (mut i32) (i32.const 0))
  (global $delta_time (mut f32) (f32.const 0.0))
  (global $last_time (mut f64) (f64.const 0.0))
  (global $object_count i32 (i32.const 3))
  
  ;; Function types
  (type $void_void (func))
  (type $i32_void (func (param i32)))
  (type $f32_void (func (param f32)))
  (type $void_i32 (func (result i32)))
  (type $void_f32 (func (result f32)))
  (type $i32_i32 (func (param i32) (result i32)))
  (type $i32_f32 (func (param i32) (result f32)))
  (type $i32_i32_void (func (param i32 i32)))
  (type $update_fn (func (param f32)))
  
  ;; Initialize module
  (func $init (export "init")
      ;; score
      (i32.store (i32.const 0) (i32.const 0))
      ;; lives
      (i32.store (i32.const 4) (i32.const 3))
      ;; active
      (i32.store (i32.const 8) (i32.const 1))
      ;; playerName
      (i32.store (i32.const 12) (i32.const 0))
      ;; Object: hero
      (i32.store (i32.const 16) (i32.const 0)) ;; type
      (i32.store (i32.const 20) (i32.const 1)) ;; active
      (i32.store (i32.const 24) (i32.const -1)) ;; parent
      ;; Object: platform
      (i32.store (i32.const 40) (i32.const 1)) ;; type
      (i32.store (i32.const 44) (i32.const 1)) ;; active
      (i32.store (i32.const 48) (i32.const -1)) ;; parent
      ;; Object: collectible
      (i32.store (i32.const 64) (i32.const 2)) ;; type
      (i32.store (i32.const 68) (i32.const 1)) ;; active
      (i32.store (i32.const 72) (i32.const -1)) ;; parent
  )
  
  ;; State accessors
  (func $get_score (export "get_score") (result i32)
    (i32.load (i32.const 0))
  )
  (func $set_score (export "set_score") (param $value i32)
    (i32.store (i32.const 0) (local.get $value))
  )
  (func $get_lives (export "get_lives") (result i32)
    (i32.load (i32.const 4))
  )
  (func $set_lives (export "set_lives") (param $value i32)
    (i32.store (i32.const 4) (local.get $value))
  )
  (func $get_active (export "get_active") (result i32)
    (i32.load (i32.const 8))
  )
  (func $set_active (export "set_active") (param $value i32)
    (i32.store (i32.const 8) (local.get $value))
  )
  (func $get_playerName (export "get_playerName") (result i32)
    (i32.load (i32.const 12))
  )
  (func $set_playerName (export "set_playerName") (param $value i32)
    (i32.store (i32.const 12) (local.get $value))
  )
  
  ;; Object functions
  (func $get_object_count (export "get_object_count") (result i32)
    (global.get $object_count)
  )
  (func $is_object_active (export "is_object_active") (param $idx i32) (result i32)
    (i32.load
      (i32.add
        (i32.const 16)
        (i32.add
          (i32.mul (local.get $idx) (i32.const 64)) ;; obj size
          (i32.const 4) ;; active offset
        )
      )
    )
  )
  (func $set_object_active (export "set_object_active") (param $idx i32) (param $active i32)
    (i32.store
      (i32.add
        (i32.const 16)
        (i32.add
          (i32.mul (local.get $idx) (i32.const 64))
          (i32.const 4)
        )
      )
      (local.get $active)
    )
  )
  
  ;; Event functions
  (func $dispatch_event (param $event_id i32) (param $payload i32)
    (call $emit_event (local.get $event_id) (local.get $payload))
  )
  
  ;; Main update function
  (func $update (export "update") (param $dt f32)
    (global.set $delta_time (local.get $dt))
    (global.set $frame_count
      (i32.add (global.get $frame_count) (i32.const 1))
    )
      ;; Update hero
      (if (call $is_object_active (i32.const 0))
        (then
          (call $update_object_0 (local.get $dt))
        )
      )
      ;; Update platform
      (if (call $is_object_active (i32.const 1))
        (then
          (call $update_object_1 (local.get $dt))
        )
      )
      ;; Update collectible
      (if (call $is_object_active (i32.const 2))
        (then
          (call $update_object_2 (local.get $dt))
        )
      )
  )
  
  (func $update_object_0 (param $dt f32)
    ;; Update logic for hero
    ;; (custom logic would be generated here based on traits/lifecycle)
  )
  (func $update_object_1 (param $dt f32)
    ;; Update logic for platform
    ;; (custom logic would be generated here based on traits/lifecycle)
  )
  (func $update_object_2 (param $dt f32)
    ;; Update logic for collectible
    ;; (custom logic would be generated here based on traits/lifecycle)
  )
  
  ;; Data sections
  (data (i32.const 1112) "Hero")
  
)"
`;

