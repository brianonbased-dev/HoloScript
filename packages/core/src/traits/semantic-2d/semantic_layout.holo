@trait {
  name: "@semantic_layout",
  category: "ui",
  description: "Meaning-aware, non-grid layout (extends SpatialTextLayoutTrait).",
  props: {
    flow: enum("semantic" | "priority" | "radial" | "cluster"),
    alignment: "meaning-aware" | "gravity",
    wrap: boolean = true,
    spacing: number = 12,
    adaptive_scale: boolean = true
  }
}
