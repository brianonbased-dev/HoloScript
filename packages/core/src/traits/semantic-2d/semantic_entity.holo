@trait {
  name: "@semantic_entity",
  category: "ui",
  description: "Every UI element is a meaningful entity with state, intent, and agency.",
  props: {
    id: uuid,
    type: string,
    meaning: string,
    priority: number = 1.0,
    children: array<@semantic_entity>
  },
  behaviors: ["@dynamic_visual", "@agent_attention"]
}
