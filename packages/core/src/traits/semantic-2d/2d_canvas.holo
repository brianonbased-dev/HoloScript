@trait {
  name: "@2d_canvas",
  category: "ui",
  description: "Root semantic canvas for 2D interfaces. Projects any scene as flat but alive.",
  props: {
    title: string,
    projection: enum("flat-semantic" | "hybrid" | "immersive") = "flat-semantic",
    background: @procedural_field | color | gradient,
    responsive: boolean = true,
    economy_enabled: boolean = true
  },
  compiler_targets: ["web", "r3f", "node-service", "unity"]
}
