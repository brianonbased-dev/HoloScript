{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HoloScript Project Configuration",
  "description": "Configuration for HoloScript workspaces, packages, and build targets",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semantic version"
    },
    "entry": {
      "type": "string",
      "default": "src/main.holo",
      "description": "Main entry file"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "r3f", "unity", "unreal", "godot", "visionos", "vrchat",
          "babylon", "playcanvas", "wasm", "webgpu", "urdf", "dtdl",
          "sdf", "usd", "gltf", "android", "ios", "androidxr"
        ]
      },
      "description": "Compile targets"
    },
    "workspace": {
      "type": "object",
      "properties": {
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for workspace packages (e.g. 'packages/*')"
        },
        "sharedDependencies": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Shared dependency versions across packages"
        }
      },
      "description": "Monorepo workspace configuration"
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Package dependencies (e.g. '@holoscript/std': '^0.2.0')"
    },
    "compiler": {
      "type": "object",
      "properties": {
        "strict": {
          "type": "boolean",
          "default": true,
          "description": "Enable strict type checking"
        },
        "domainBlocks": {
          "type": "boolean",
          "default": true,
          "description": "Enable v4.2 domain block compilation"
        },
        "sourceMap": {
          "type": "boolean",
          "default": true,
          "description": "Generate source maps"
        },
        "treeshake": {
          "type": "boolean",
          "default": false,
          "description": "Enable tree-shaking for unused exports"
        }
      },
      "description": "Compiler options"
    },
    "lsp": {
      "type": "object",
      "properties": {
        "diagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time diagnostics"
        },
        "completions": {
          "type": "boolean",
          "default": true,
          "description": "Enable autocompletion"
        },
        "importResolver": {
          "type": "object",
          "properties": {
            "rootDir": { "type": "string" },
            "packageMap": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "description": "Import resolution configuration"
        }
      },
      "description": "Language server options"
    },
    "assets": {
      "type": "object",
      "properties": {
        "textures": { "type": "string", "default": "assets/textures" },
        "models": { "type": "string", "default": "assets/models" },
        "audio": { "type": "string", "default": "assets/audio" },
        "shaders": { "type": "string", "default": "assets/shaders" }
      },
      "description": "Asset directory paths"
    }
  },
  "required": ["name", "version"]
}
