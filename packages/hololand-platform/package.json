{
  "name": "@holoscript/hololand-platform",
  "version": "6.1.0",
  "description": "Hololand VR Platform Services (Affective Memory, State, etc)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "hololand-device-lab": "dist/device-lab.js",
    "hololand-evidence-envelope": "dist/evidence-envelope.js",
    "hololand-adversarial-trajectory": "dist/adversarial-trajectory.js",
    "hololand-headset-share": "dist/headset-share.js",
    "holo-tunnel": "dist/holo-tunnel.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "adversarial-trajectory": "pnpm run build && node dist/adversarial-trajectory.js",
    "device-lab": "pnpm run build && node dist/device-lab.js",
    "evidence-envelope": "pnpm run build && node dist/evidence-envelope.js",
    "headset-share": "pnpm run build && node dist/headset-share.js",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --passWithNoTests"
  },
  "dependencies": {
    "@holoscript/crdt-spatial": "workspace:*",
    "@holoscript/framework": "workspace:*",
    "@holoscript/runtime": "workspace:*",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  }
}
