{
  "name": "@holoscript/crdt",
  "version": "1.0.0",
  "description": "Authenticated Conflict-free Replicated Data Types with DID-based signing for distributed agent state synchronization",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "crdt",
    "conflict-free-replicated-data-types",
    "distributed",
    "decentralized-identity",
    "did",
    "peer-to-peer",
    "agent-state",
    "synchronization"
  ],
  "author": "Brian X Base Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git",
    "directory": "packages/crdt"
  },
  "dependencies": {
    "did-jwt": "^8.0.4",
    "did-resolver": "^4.1.0",
    "simple-peer": "^9.11.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/simple-peer": "^9.11.8",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
