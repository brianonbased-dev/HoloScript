# Dockerfile for testbed seed-legit orchestrator.
# Builds the adversarial package and runs seed-legit.ts on container start.

FROM node:22-slim

WORKDIR /app

# Copy package files and install deps (workspace root + this package).
COPY package.json tsconfig.json ./
RUN npm install

# Copy source.
COPY src ./src

# Build.
RUN npx tsc -p tsconfig.json

# Default: emit the server manifest.
CMD ["node", "dist/testbed/seed-legit.js"]
