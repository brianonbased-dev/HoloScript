{
  "name": "@holoscript/absorb-service-host",
  "version": "7.0.0",
  "description": "HTTP/MCP host service for @holoscript/absorb-service (engine logic lives in package)",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "npx drizzle-kit push && node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@holoscript/absorb-service": "workspace:*",
    "@holoscript/config": "workspace:*",
    "@holoscript/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "drizzle-orm": ">=0.45.2",
    "express": "^5.2.1",
    "pg": "^8.13.1",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
