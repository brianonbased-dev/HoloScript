{
  "name": "brittney-service",
  "version": "1.0.0",
  "description": "Brittney Cloud Service — AI-powered HoloScript spatial intelligence gateway",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
