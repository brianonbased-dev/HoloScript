    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.3.3",
    "tsx": "^4.19.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
