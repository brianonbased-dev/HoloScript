{
  "name": "@holoscript/net-service",
  "version": "1.0.4",
  "description": "Railway-based hosting for holoscript.net docs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "vite",
    "build:client": "node build-client.mjs",
    "build:server": "tsup server.ts --out-dir dist/server --external @holoscript/mcp-server --external @holoscript/core",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/server.js"
  },
  "dependencies": {
    "@holoscript/core": "workspace:*",
    "@holoscript/mcp-server": "workspace:*",
    "@holoscript/r3f-renderer": "workspace:*",
    "@holoscript/runtime": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/rapier": "^2.2.0",
    "compression": "^1.7.4",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.314.0",
    "morgan": "^1.10.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.4",
    "three": "^0.182.0",
    "ws": "^8.20.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite-plugin-node-polyfills": "^0.25.0"
  }
}
