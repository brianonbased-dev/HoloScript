{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "services/holoscript-net/Dockerfile",
    "watchPatterns": ["services/holoscript-net/**", "docs/.vitepress/dist/**"]
  },
  "deploy": {
    "numReplicas": 1,
    "sleep": false,
    "restartPolicyType": "ON_FAILURE",
    "healthCheckPath": "/health",
    "healthCheckTimeout": 30
  }
}
