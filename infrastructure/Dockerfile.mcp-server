# HoloScript MCP Server - Monorepo Build
#
# Builds from the pnpm workspace root to resolve workspace dependencies
# Dependency chain: mcp-server → core + engine + llm-provider + absorb-service + cli, core → crdt + engine

ARG PNPM_VERSION=8.12.0

FROM node:20-alpine AS base
ARG PNPM_VERSION
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate

# Collect all package.json for full workspace lockfile resolution
FROM base AS manifests
WORKDIR /app
COPY . .
RUN find packages services benchmarks -name "package.json" -not -path "*/node_modules/*" -exec sh -c 'mkdir -p /manifests/$(dirname {}) && cp {} /manifests/{}' \; 2>/dev/null; true

FROM base AS builder
WORKDIR /app

# Copy workspace config + all package.json manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY --from=manifests /manifests/ ./
COPY scripts/docker/build-engine-no-dts.sh scripts/docker/build-engine-no-dts.sh
COPY scripts/docker/build-core-stack-no-dts.sh scripts/docker/build-core-stack-no-dts.sh

# Install dependencies (--ignore-scripts prevents tsup from running before source is copied)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Copy source code
COPY packages/crdt/ packages/crdt/
COPY packages/agent-protocol/ packages/agent-protocol/
COPY packages/core/ packages/core/
COPY packages/engine/ packages/engine/
COPY packages/framework/ packages/framework/
COPY packages/cli/ packages/cli/
COPY packages/llm-provider/ packages/llm-provider/
COPY packages/config/ packages/config/
COPY packages/absorb-service/ packages/absorb-service/
COPY packages/mcp-server/ packages/mcp-server/
COPY packages/platform/ packages/platform/
COPY packages/mesh/ packages/mesh/


# Build in dependency order
# Skip DTS for shared runtime stack — server image only needs JS runtime.
RUN chmod +x scripts/docker/build-engine-no-dts.sh scripts/docker/build-core-stack-no-dts.sh && ./scripts/docker/build-core-stack-no-dts.sh
RUN cd packages/config && npx tsup --no-dts
RUN cd packages/llm-provider && npx tsup --no-dts
RUN cd packages/platform && npx tsup --no-dts
RUN cd packages/mesh && npx tsup --no-dts
RUN cd packages/absorb-service && npx tsup
RUN cd packages/mcp-server && npx tsup


# --- Production stage ---
FROM node:20-alpine

ARG PNPM_VERSION
ARG INSTALL_CHROMIUM=0

# Install su-exec for dropping privileges in entrypoint.
# Chromium is optional and only needed for browser-render endpoints.
RUN apk add --no-cache su-exec ca-certificates && \
    if [ "${INSTALL_CHROMIUM}" = "1" ]; then \
      apk add --no-cache chromium nss freetype harfbuzz ttf-freefont; \
    fi

# Configure Playwright to use system Chromium instead of downloading its own
# Alpine's chromium package installs the binary at /usr/bin/chromium.
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Install pnpm
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate

WORKDIR /app

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nodejs

# Copy workspace config + ALL package manifests for correct pnpm workspace resolution
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY --from=manifests /manifests/ ./

# Install all dependencies (full workspace resolution for correct symlinks)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Copy built artifacts
COPY --from=builder /app/packages/crdt/dist packages/crdt/dist
COPY --from=builder /app/packages/agent-protocol/dist packages/agent-protocol/dist
COPY --from=builder /app/packages/core/dist packages/core/dist
COPY --from=builder /app/packages/engine/dist packages/engine/dist
COPY --from=builder /app/packages/framework/dist packages/framework/dist
COPY --from=builder /app/packages/config/dist packages/config/dist
COPY --from=builder /app/packages/llm-provider/dist packages/llm-provider/dist
COPY --from=builder /app/packages/absorb-service/dist packages/absorb-service/dist
COPY --from=builder /app/packages/mcp-server/dist packages/mcp-server/dist
COPY --from=builder /app/packages/platform/dist packages/platform/dist
COPY --from=builder /app/packages/mesh/dist packages/mesh/dist
COPY packages/mcp-server/migrations/ packages/mcp-server/migrations/
COPY packages/mcp-server/scripts/docker-entrypoint.sh packages/mcp-server/scripts/docker-entrypoint.sh


# Fail fast if framework build artifacts are missing (prevents runtime breakage
# when mcp-server resolves @holoscript/framework in production).
RUN test -f /app/packages/framework/dist/index.js

# Create persistent directories (Railway volume mount points)
RUN mkdir -p /app/.holoscript /app/.holoscript/holomesh

# Set ownership
RUN chown -R nodejs:nodejs /app

# Ensure entrypoint is executable
RUN chmod +x /app/packages/mcp-server/scripts/docker-entrypoint.sh

# Environment
ENV NODE_ENV=production
ENV HOLOSCRIPT_CACHE_DIR=/app/.holoscript
ENV HOLOMESH_DATA_DIR=/app/.holoscript/holomesh
ENV EMBEDDING_PROVIDER=openai

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:${PORT:-3000}/health',(r)=>process.exit(r.statusCode===200?0:1))"

# Start HTTP server
CMD ["/app/packages/mcp-server/scripts/docker-entrypoint.sh"]
