# Moltbook Daemon — Autonomous agent on Moltbook social network
#
# Reuses the MCP server build chain (core → absorb-service → mcp-server)
# but runs the holoscript moltbook-daemon CLI instead of the HTTP server.
# No Chromium/Playwright needed — this is a headless BT runner.

FROM node:20-alpine AS builder

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace config
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# Copy the packages we need (full dependency chain)
COPY packages/crdt/package.json packages/crdt/
COPY packages/agent-protocol/package.json packages/agent-protocol/
COPY packages/core/package.json packages/core/
COPY packages/cli/package.json packages/cli/
COPY packages/llm-provider/package.json packages/llm-provider/
COPY packages/absorb-service/package.json packages/absorb-service/
COPY packages/mcp-server/package.json packages/mcp-server/

# Install dependencies
RUN pnpm install --frozen-lockfile --ignore-scripts

# Copy source code
COPY packages/crdt/ packages/crdt/
COPY packages/agent-protocol/ packages/agent-protocol/
COPY packages/core/ packages/core/
COPY packages/cli/ packages/cli/
COPY packages/llm-provider/ packages/llm-provider/
COPY packages/absorb-service/ packages/absorb-service/
COPY packages/mcp-server/ packages/mcp-server/

# Build in dependency order
RUN cd packages/crdt && npx tsup --no-dts
RUN cd packages/agent-protocol && npx tsup --no-dts
RUN cd packages/core && npx tsup --no-dts && node scripts/generate-types.mjs
RUN cd packages/llm-provider && npx tsup --no-dts
RUN cd packages/absorb-service && npx tsup
RUN cd packages/mcp-server && npx tsup

# --- Production stage ---
FROM node:20-alpine

# Install pnpm (no Chromium needed — this is headless)
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nodejs

# Copy workspace config
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/crdt/package.json packages/crdt/
COPY packages/agent-protocol/package.json packages/agent-protocol/
COPY packages/core/package.json packages/core/
COPY packages/cli/package.json packages/cli/
COPY packages/llm-provider/package.json packages/llm-provider/
COPY packages/absorb-service/package.json packages/absorb-service/
COPY packages/mcp-server/package.json packages/mcp-server/

# Install all dependencies with flat hoisting so core's dynamic
# import('@holoscript/mcp-server/...') resolves at runtime
RUN pnpm install --frozen-lockfile --ignore-scripts --shamefully-hoist

# Copy built artifacts
COPY --from=builder /app/packages/crdt/dist packages/crdt/dist
COPY --from=builder /app/packages/agent-protocol/dist packages/agent-protocol/dist
COPY --from=builder /app/packages/core/dist packages/core/dist
COPY --from=builder /app/packages/llm-provider/dist packages/llm-provider/dist
COPY --from=builder /app/packages/absorb-service/dist packages/absorb-service/dist
COPY --from=builder /app/packages/mcp-server/dist packages/mcp-server/dist

# Copy composition file (the daemon's brain)
COPY compositions/moltbook-agent.hsplus compositions/moltbook-agent.hsplus

# Create persistent state directory
RUN mkdir -p /app/compositions/.holoscript && \
    chown -R nodejs:nodejs /app

# Environment
ENV NODE_ENV=production

# Run as non-root
USER nodejs

# The daemon is a long-running CLI process, not an HTTP server.
# Railway start command is set in railway.moltbook-daemon.toml.
CMD ["node", "packages/core/dist/cli/holoscript-runner.js", "moltbook-daemon", "compositions/moltbook-agent.hsplus", "--always-on", "--provider", "anthropic", "--debug"]
