# BitNet Inference Server
#
# Builds and runs the real bitnet.cpp server with microsoft/BitNet-b1.58-2B-4T.
# This is an OpenAI-compatible inference server running 1-bit quantized models
# that require ~500 MB and no GPU — deployable on Railway, Fly.io, or any VPS.
#
# Railway deployment:
#   1. Create a new Railway service pointing at this Dockerfile
#   2. Set env var PORT (Railway injects this automatically)
#   3. Attach a persistent volume at /data (for model cache between deploys)
#   4. Set HOLOSCRIPT_BITNET_URL=https://<your-railway-domain> in the MCP server service
#
# Resource requirements:
#   RAM:  2 GB minimum (model is ~500 MB, inference uses ~1 GB peak)
#   CPU:  2 vCPU recommended (1-bit arithmetic scales well with cores)
#   Disk: 2 GB for model weights + build artifacts

FROM python:3.11-slim AS builder

# Build dependencies for bitnet.cpp (cmake + C/C++ compiler + clang)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    cmake \
    build-essential \
    ninja-build \
    clang \
    wget \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /bitnet

# Clone bitnet.cpp
RUN git clone --recursive https://github.com/microsoft/BitNet .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Download the model, generate optimized kernels, compile the binary.
# --hf-repo: HuggingFace model identifier (must match SUPPORTED_HF_MODELS)
# --model-dir: where to save downloaded model weights
# --quant-type: i2_s (2-bit signed) is recommended for 2B-4T
# --use-pretuned: use pre-optimized kernel parameters if available
RUN python setup_env.py \
    --hf-repo microsoft/BitNet-b1.58-2B-4T \
    --model-dir /data/models \
    --quant-type i2_s \
    --use-pretuned

# --- Production stage ---
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /bitnet

# Copy built binary, model, and runtime scripts
COPY --from=builder /bitnet/build /bitnet/build
COPY --from=builder /bitnet/run_inference_server.py /bitnet/run_inference_server.py
COPY --from=builder /bitnet/run_inference.py /bitnet/run_inference.py
COPY --from=builder /data/models /data/models

# Runtime env
ENV PORT=8080
ENV HOST=0.0.0.0

EXPOSE ${PORT}

# Health check — llama-server responds at /health after warmup
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=5 \
  CMD wget -qO- http://localhost:${PORT}/health > /dev/null 2>&1 || exit 1

# Start the bitnet.cpp inference server (OpenAI-compatible HTTP API)
CMD python run_inference_server.py \
      --model /data/models/BitNet-b1.58-2B-4T/ggml-model-i2_s.gguf \
      --host ${HOST} \
      --port ${PORT} \
      --threads 2 \
      --ctx-size 2048
