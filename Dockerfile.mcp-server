# HoloScript MCP Server - Monorepo Build
#
# Builds from the pnpm workspace root to resolve workspace dependencies
# Dependency chain: mcp-server → core + llm-provider + cli, core → crdt

FROM node:20-alpine AS builder

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace config
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# Copy the packages we need (full dependency chain)
COPY packages/crdt/package.json packages/crdt/
COPY packages/agent-protocol/package.json packages/agent-protocol/
COPY packages/core/package.json packages/core/
COPY packages/cli/package.json packages/cli/
COPY packages/llm-provider/package.json packages/llm-provider/
COPY packages/mcp-server/package.json packages/mcp-server/

# Install dependencies (--ignore-scripts prevents tsup from running before source is copied)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Copy source code
COPY packages/crdt/ packages/crdt/
COPY packages/agent-protocol/ packages/agent-protocol/
COPY packages/core/ packages/core/
COPY packages/cli/ packages/cli/
COPY packages/llm-provider/ packages/llm-provider/
COPY packages/mcp-server/ packages/mcp-server/

# Build in dependency order
# Skip DTS for all packages — server only needs JS runtime, not type declarations
RUN cd packages/crdt && npx tsup --no-dts
RUN cd packages/agent-protocol && npx tsup --no-dts
RUN cd packages/core && npx tsup --no-dts && node scripts/generate-types.mjs
RUN cd packages/llm-provider && npx tsup --no-dts
RUN cd packages/mcp-server && npx tsup

# --- Production stage ---
FROM node:20-alpine

# Install su-exec for dropping privileges in entrypoint
# Install Chromium for Playwright browser-based screenshot rendering
RUN apk add --no-cache su-exec chromium nss freetype harfbuzz ca-certificates ttf-freefont

# Configure Playwright to use system Chromium instead of downloading its own
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nodejs

# Copy workspace config
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/crdt/package.json packages/crdt/
COPY packages/agent-protocol/package.json packages/agent-protocol/
COPY packages/core/package.json packages/core/
COPY packages/cli/package.json packages/cli/
COPY packages/llm-provider/package.json packages/llm-provider/
COPY packages/mcp-server/package.json packages/mcp-server/

# Install all dependencies (some externalized packages like jsonwebtoken aren't
# declared as prod deps but are required at runtime via core's CJS bundle)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Copy built artifacts
COPY --from=builder /app/packages/crdt/dist packages/crdt/dist
COPY --from=builder /app/packages/agent-protocol/dist packages/agent-protocol/dist
COPY --from=builder /app/packages/core/dist packages/core/dist
COPY --from=builder /app/packages/llm-provider/dist packages/llm-provider/dist
COPY --from=builder /app/packages/mcp-server/dist packages/mcp-server/dist
COPY packages/mcp-server/scripts/docker-entrypoint.sh packages/mcp-server/scripts/docker-entrypoint.sh

# Create persistent cache directory (Railway volume mount point)
RUN mkdir -p /app/.holoscript

# Set ownership
RUN chown -R nodejs:nodejs /app

# Ensure entrypoint is executable
RUN chmod +x /app/packages/mcp-server/scripts/docker-entrypoint.sh

# Environment
ENV NODE_ENV=production
ENV HOLOSCRIPT_CACHE_DIR=/app/.holoscript

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:${PORT:-3000}/health',(r)=>process.exit(r.statusCode===200?0:1))"

# Start HTTP server
CMD ["/app/packages/mcp-server/scripts/docker-entrypoint.sh"]
