/**
 * Bridge Load Test — Digital Twin Showcase
 *
 * Structural FEM with interactive vehicle placement.
 * Color-coded Von Mises stress visualization with safety factor warnings.
 *
 * @version 1.0.0
 * @format .hsplus
 * @see HL-RENDER-3: Simulation Showcase Worlds
 * @see W.256: FEAScript proves browser-based FEA viability
 */

composition "BridgeLoadTest" {

  state {
    version: "1.0.0"
    showStressOverlay: true
    displacementScale: 100
    vehicleWeight: 30000
    vehiclePosition: [25, 0, 0]
    safetyThreshold: 1.5
    colormap: "turbo"
    analysisMode: "static_linear"
  }

  object "Bridge" {
    @mesh { source: "assets/models/suspension_bridge.glb" }
    @material {
      name: "structural_steel"
      base_color: "#707580"
      roughness: 0.4
      metalness: 0.9
    }
  }

  simulation "structural" {
    @structural_fem {
      mesh: $Bridge
      analysis: $state.analysisMode

      material {
        type: steel_a36
        youngs_modulus: 200e9
        poisson_ratio: 0.3
        yield_strength: 250e6
        density: 7850
      }

      constraints {
        fixed "left_abutment" { nodes: "abutment_left_group" }
        fixed "right_abutment" { nodes: "abutment_right_group" }
        pinned "tower_left_base" { nodes: "tower_left_base_group" }
        pinned "tower_right_base" { nodes: "tower_right_base_group" }
      }

      loads {
        gravity "self_weight" {
          acceleration: [0, -9.81, 0]
        }
        distributed "deck_dead_load" {
          surface: "deck_surface"
          pressure: -3000
        }
        point "vehicle" {
          position: $state.vehiclePosition
          force: [0, -$state.vehicleWeight * 9.81, 0]
        }
      }
    }

    @scalar_field_overlay {
      source: $structural.von_mises_stress
      colormap: $state.colormap
      range: [0, 250e6]
      opacity: 0.7
      visible: $state.showStressOverlay
      label: "Von Mises Stress (Pa)"
    }

    @scalar_field_overlay {
      source: $structural.safety_factor
      colormap: "coolwarm"
      range: [0.5, 3.0]
      opacity: 0.5
      visible: false
      label: "Safety Factor"
    }
  }

  object "Vehicle" {
    @mesh { primitive: box, size: [4, 2, 2.5] }
    @material { base_color: "#cc3333", roughness: 0.3 }
    @draggable { axis: x, min: 0, max: 50 }
    position: $state.vehiclePosition
  }

  environment "sky" {
    @atmosphere {
      model: bruneton_precomputed
      sun_direction: [0.4, 0.7, 0.2]
      turbidity: 2.0
      exposure: 1.1
    }
  }

  environment "lighting" {
    @global_illumination {
      method: ssgi
      samples: 12
      intensity: 0.8
    }
  }

  environment "post" {
    @post_processing {
      steps: [
        { effect: ssao, radius: 0.5, intensity: 0.6 },
        { effect: bloom, threshold: 0.9, intensity: 0.2 },
        { effect: tone_mapping, exposure: 1.0 },
        { effect: fxaa }
      ]
    }
  }
}
