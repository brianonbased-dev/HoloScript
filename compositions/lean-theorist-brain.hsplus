      check_3_knowledge_present: "POST /knowledge/query {search:'lean4 OR formal-methods', limit:10} returns >= 4 entries with type in {wisdom, pattern, gotcha} and tags including 'lean4'",
      check_4_find_collaborator_rerun: "/find-collaborator type-theory output changes from 'TIER 1: NONE' to 'TIER 1: lean-theorist-brain on <surface>, X knowledge entries'",
      target_paper_gates_unblocked: ["paper-22 (Mechanized SimulationContract -> CAV/FM)", "paper-23 (Formal Semantics of HoloScript Core -> POPL/TyDe)"],
      capability_build_task: "task_1777063669122_u574"
    }
  }

