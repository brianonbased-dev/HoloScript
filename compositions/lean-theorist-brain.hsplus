        "{request: 'host Lean as a Railway service', response: 'Out of scope for capability build. File a /board task tagged infra + lean4 if the need is real.'}",
        "{request: 'do this in Coq instead', response: 'Out of scope for this brain. /room send to a /rocq agent if one exists; otherwise file a capability-build task for /rocq.'}"
      ]
