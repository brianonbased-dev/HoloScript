{
  "name": "holoscript",
  "version": "6.0.2",
  "private": true,
  "description": "HoloScript - The open platform for spatial worlds",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "pnpm --filter core build && pnpm --filter !core build",
    "build:parallel": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:core": "pnpm --filter @holoscript/core test",
    "test:holomap": "pnpm --filter @holoscript/holomap test && pnpm --filter @holoscript/core exec vitest run src/reconstruction/__tests__",
    "holomap:status": "node scripts/check-ingest-path-status.mjs",
    "preflight": "node scripts/preflight.mjs",
    "preflight:full": "node scripts/preflight.mjs --full",
    "preflight:fix": "node scripts/preflight.mjs --fix",
    "lint": "eslint packages/*/src/**/*.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bench": "pnpm --filter @holoscript/benchmark bench",
    "bench:ci": "pnpm --filter @holoscript/benchmark bench:ci",
    "bench:paper-rigorous": "node scripts/bench-paper-rigorous.mjs",
    "benchmark": "tsx benchmarks/tools/benchmark-runner.ts",
    "ops:dashboard": "tsx docs/ops/admin-cli.ts",
    "webgpu:determinism:mock": "node scripts/run-webgpu-determinism.mjs",
    "clean": "pnpm -r exec rm -rf dist",
    "build:auto": "bash scripts/auto-build-manager.sh",
    "build:archive": "bash scripts/archive-build-artifacts.sh",
    "build:restore": "bash scripts/restore-build-archive.sh",
    "build:monitor": "bash scripts/monitor-disk-usage.sh",
    "build:prune": "bash scripts/prune-old-archives.sh",
    "build:wasm": "bash scripts/build/wasm-build.sh --sizes",
    "build:wasm:debug": "bash scripts/build/wasm-build.sh --debug --sizes",
    "build:wasm:parallel": "bash scripts/build/wasm-build.sh --parallel --sizes",
    "build:wasm:check": "bash scripts/build/wasm-build.sh --check",
    "build:wasm:clean": "bash scripts/build/wasm-build.sh --clean",
    "build:wasm:win": "powershell -File scripts/build/wasm-build.ps1 -Sizes",
    "types:generate": "bash scripts/generate-types.sh",
    "types:generate:win": "powershell -File scripts/generate-types.ps1",
    "hooks:install": "node scripts/install-hooks.js",
    "health:repo": "node scripts/repo-health.js",
    "health:repo:quick": "node scripts/repo-health.js --skip-tests",
    "architecture:check": "node scripts/check-architecture-coupling.js",
    "verify:core-engine-imports": "node scripts/verify-core-engine-import-allowlist.mjs",
    "verify:claude-plugin-skills": "node scripts/verify-claude-plugin-skills.mjs",
    "verify:package-src-no-emit": "node scripts/verify-no-js-in-package-src.mjs",
    "tests:hotspots": "node scripts/check-hotspot-test-coverage.js",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "version:check": "node scripts/check-version-policy.js",
    "version:check:strict": "node scripts/check-version-policy.js --strict",
    "version:patch": "node scripts/sync-versions.js patch",
    "version:minor": "node scripts/sync-versions.js minor",
    "version:major": "node scripts/sync-versions.js major",
    "version:prerelease": "node scripts/sync-versions.js prerelease",
    "release:guard": "node scripts/release-guard.js",
    "release:version": "changeset version",
    "release:publish": "node scripts/release-guard.js && changeset publish",
    "publish": "echo 'Use pnpm release:publish instead. Raw publish is blocked.' && exit 1",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch",
    "docs:api:json": "typedoc --json docs/api/api.json",
    "docs:roadmap:drift": "node scripts/check-roadmap-drift.mjs",
    "check:tropical-mentions": "node scripts/check-tropical-mentions.mjs",
    "check:security-audit": "node scripts/security-audit-io-network.mjs",
    "check:security-audit:strict": "node scripts/security-audit-io-network.mjs --strict",
    "check:security-audit:verbose": "node scripts/security-audit-io-network.mjs --verbose",
    "test:mutate": "npx stryker run",
    "audit:security": "pnpm audit --audit-level=moderate",
    "analyze:bundle": "pnpm --filter @holoscript/core build && npx rollup-plugin-visualizer dist/stats.html",
    "self-improve": "tsx scripts/self-improve.ts --verbose",
    "self-improve:daemon": "tsx scripts/self-improve.ts --daemon --verbose",
    "self-improve:commit": "tsx scripts/self-improve.ts --daemon --commit --verbose",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "syncpack:check": "syncpack list-mismatches",
    "agents:status": "tsx scripts/build/deploy-multi-agents.ts --status",
    "agents:deploy": "tsx scripts/build/deploy-multi-agents.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@changesets/cli": "^2.29.4",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "audit-ci": "^7.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.1",
    "eslint-config-next": "15.5.14",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jscpd": "^4.0.8",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "syncpack": "^14.0.0",
    "tsup": "^8.0.1",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@8.12.0",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "axios": ">=1.15.0",
      "follow-redirects": ">=1.16.0",
      "dompurify": ">=3.4.0",
      "glob": ">=11.1.0",
      "minimatch": ">=9.0.7",
      "qs": ">=6.15.0",
      "markdown-it": ">=14.1.1",
      "@x402/svm": ">=2.9.0",
      "brace-expansion": ">=5.0.5",
      "picomatch": ">=4.0.4",
      "yaml": ">=2.8.3",
      "terser-webpack-plugin": ">=5.4.0",
      "lodash-es": ">=4.18.1",
      "lodash": ">=4.18.1",
      "defu": ">=6.1.6",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.2",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=7.0.3",
      "parse-duration": ">=2.1.3",
      "underscore": ">=1.13.8",
      "h3": ">=1.15.6",
      "socket.io-parser": ">=4.2.6",
      "@modelcontextprotocol/sdk": ">=1.25.2",
      "tree-sitter": "0.22.4",
      "path-to-regexp": "0.1.13",
      "esbuild": ">=0.25.0",
      "nanoid": ">=5.0.9",
      "bn.js": ">=4.12.3",
      "next": ">=15.5.15",
      "@apollo/server": ">=5.5.0",
      "elliptic": ">=6.6.1",
      "bigint-buffer": ">=1.1.5",
      "three": "0.182.0",
      "@react-three/fiber": "9.5.0",
      "protobufjs": ">=7.5.5",
      "vite": ">=7.3.2",
      "drizzle-orm": ">=0.45.2",
      "basic-ftp": ">=5.3.0"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Brian X Base Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianonbased-dev/HoloScript.git"
  },
  "dependencies": {
    "tree-sitter": "0.22.4",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^27.0.2"
  }
}
